\section{Introduction}

This paper is a first attempt at a denotational semantics for \versecalc{}.

\section{Background}

\begin{figure}
$
\begin{array}{l}
\text{\bf Syntax} \\
\begin{array}{rcl}
  e & ::= & |v| \vb op \vb |e_1 e_2| \\
  v & ::= & |x| \vb |k| \vb op \vb |lam x e| \\
  op & ::= & |add| \vb \ldots
\end{array}
\\[4mm]
\text{\bf Domains} \\
\begin{array}{rcll}
\Value & = & \mathbb{Z} + (\Value \rightarrow \mtype) \\
\mtype & = & \mlift{(\wrong + \Value)} \\
\Env & = & Ident \rightarrow \Value \\
\end{array}
\\[4mm]
\text{\bf Semantics of expressions} \\

  \begin{array}{rcll}
  \semapp{E}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{E}{|v|}{\rho} & = & \mlift{(\semapp{V}{|v|} \rho)} \\
  \semapp{E}{|e_1 e_2|}{\rho} & = &  \apply(\semapp{E}{|e_1|}{\rho}, \semapp{E}{|e_2|}{\rho}) \\[2mm]
  \semapp{V}{|v|}{} & : & \Env \rightarrow \Value \\
  \semapp{V}{|x|}{\rho} & = & \rho(x) \\
  \semapp{V}{|k|}{\rho} & = & |k| \\
  \semapp{V}{op}{\rho} & = & \semapp{O}{op} \\
  \semapp{V}{|lam x e|}{\rho} & = & \lambda v. \semapp{E}{e}{\rho[ x \mapsto v ]}
  \\[2mm]
  \semapp{O}{op} & : & \Value \\
  \semapp{O}{|add|} & = & \lambda x y. \text{if $(x=k_1 \wedge y=k_2)$ then $k_1 + k_2$ else $\wrong$}
  \\[2mm]
  \apply & : & (\mtype \times \mtype) \rightarrow \mtype \\
  \apply( \bot, w) & = & \bot \\
  \apply( w, \bot) & = & \bot \\
  \apply( \mlift{\wrong}, w) & = & \mlift{\wrong} \\
  \apply( \mlift{w}, \mlift{\wrong}) & = & \mlift{\wrong} \\
  \apply( \mlift{k}, \mlift{w}) & = & \mlift{\wrong} \\
  \apply( \mlift{f}, \mlift{w}) & = & f(w) & f \in \Value \rightarrow \mtype
  \end{array} \\ \\
\end{array}
$
\caption{Expression semantics}
\label{fig:lambda-sem}
\end{figure}

\Cref{fig:lambda-sem} gives the conventional denotational semantics for lambda calculus.

\section{Syntax of Core Verse}

\begin{figure}
  $$
  \begin{array}{l}
    \textbf{Syntax} \\
    \begin{array}{lr@@{\;}r@@{\;}l}
    \text{Integers} & k \\
    \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
%     \text{Programs} & p  & ::=  & |succeeds e| \quad \text{where} \; \freevars{e} = \emptyset \\
    \text{Expressions} & e  & ::=  & |v| \vb |apply1N v_1 v_2|
       \vb |e_1 == e_2| \vb |e_1 ; e_2| \vb  |def x e|
       \vb |e_1 choice e_2| \vb |fail| \vb |one e| \vb |all e| \\
%       && \vb & |succeeds e| \vb |decides e| \\
%       && \vb & |if e_1 then lam x e_2 else e_3| \vb |for e_1 do lam x e_2| \\
%       & & \vb & |hastype e_1 e_2| \\
    \text{Values} & v & ::= & x  \vb \hnf \\
    \text{Head values} & \hnf & ::= & k \vb op \vb |arr (v_1, dots, v_n)| \vb |lam x e| \\
    \text{Primops} & op  & ::= & |gt| \vb |add| \vb |int|
    \end{array} \\
    \\[-3mm]
    \text{\emph{Concrete syntax}:} \;\;
    \begin{array}[t]{l}
          \text{``|choice|'', ``;'', and ``|=|'' are right-associative.} \\
          \text{``|=|'' binds more tightly than ``;''.} \\
          \text{``$\lambda$'', ``|defKW|'' scope as far to the right as possible.} \\
          \hspace{2mm} \text{{\eg}, |(lam y (def x (x=1; x+y)))| means |(lam y ((def x (((x=1); (x+y))))))|.}
    \end{array} \\ \\[-3mm]
    \textbf{Shorthand} \\
    \begin{array}{rcl}
%%      |emptytup| & \text{means} & |arr ()|\\
%%      |tup (v_1, dots, v_n)| & \text{means} & |arr (v_1,dots, v_n)| \quad n \geq 2 \\
      v_1 + v_2 & \text{means} & |applyN add ( v_1, v_2 ) | \\
      v_1 > v_2 & \text{means} & |applyN gt ( v_1, v_2 ) | \\
      |def (x_1 ^^ x_2 dots x_n) e| & \text{means} & |def x_1 (def x_2 (dots ^ def x_n e))| \\
     \end{array} \\
  \\[-2mm]
  \text{$\freevars{e}$ means the free variable of $e$; in \versecalc{}, $\lambda$ and |defKW| are the only binders.}
  %\text{$S_1 \disjoint S_2$ means that set $S_1$ is disjoint from $S_2$.}
  \end{array}
  $$
\caption{The Verse calculus: syntax} \label{fig:syntax}
\end{figure}

As a reminder, the syntax of \versecalc{} is given in \cref{fig:syntax}.

\section{A denotational semantics}

