\begin{figure}
$
\begin{array}{l}
\text{\bf Domains} \\
\begin{array}{rcll}
\Value & = & \mathbb{Z} + \tuple{\Value} + (\Value \rightarrow \mtype) \\
\tuple{\Value} & = & \text{a finite tuple of values $\Value$} \\
\Env & = & Ident \rightarrow \Value \\
\end{array}
\\[7mm]
\text{\bf Semantics of expressions and values} \\

  \begin{array}{rcll}
  \semapp{E}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{E}{|v|}{\rho} & = & \munit(\semapp{V}{|v|}{\rho}) \\
  \semapp{E}{|fail|}{\rho} & = & \mempty \\
  \semapp{E}{|e_1 choice e_2|}{\rho} & = & \semapp{E}{|e_1|}{\rho} \; \munion     \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|e_1 = e_2|}{\rho}      & = & \semapp{E}{|e_1|}{\rho} \; \mintersect \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|e_1 ; e_2|}{\rho}      & = & \semapp{E}{|e_1|}{\rho} \; \msemi      \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|apply1N v_1 v_2|}{\rho} & = & \apply(\semapp{V}{|v_1|}{\rho}, \; \semapp{V}{|v_2|}{\rho}) \\
  \semapp{E}{|def x e|}{\rho} & = & \bigcup_{w \in \Value}\, \semapp{E}{e}{(\extendrho{\rho}{x \mapsto w})} \\
  \semapp{E}{|one e|}{\rho} & = & \mone (\semapp{E}{e}{\rho}) \\
  \semapp{E}{|all e|}{\rho} & = & \munit(\mall (\semapp{E}{e}{\rho})) \\
%   \semapp{E}{|succeeds e|}{\rho} & = & \msucceeds (\semapp{E}{e}{\rho}) \\
%   \semapp{E}{|decides e|}{\rho} & = & \mdecides (\semapp{E}{e}{\rho}) \\
%  \semapp{E}{|if e_1 then lam x e_2 else e_3|}{\rho}
%      & = & \semapp{E}{e_2}{(\extendrho{\rho}{x \mapsto w})} & \text{if } \mone(\semapp{E}{e_1}{\rho}) = \{ w \} \\
%      & = & \semapp{E}{e_3}{\rho} & \text{otherwise} \\
%   \semapp{E}{|for e_1 do lam x e_2|}{\rho} & = & \text{not yet}
%%     & = & \mcross (\semapp{E}{e_2}{(\extendrho{\rho}{x \mapsto \munits{v_i}})})
%%     &   & \hspace{0.5em}  \cdots, \semapp{E}{e_2}{(\extendrho{\rho}{x \mapsto \munits{v_n}})}) &
%%                    & \text{where } \mall(\semapp{E}{e_1}{\rho}) = |tup (v_1, dots, v_n)|

% Commenting out hastype for now
%   \semapp{E}{|hastype e_1 e_2|}{\rho} & = & \begin{array}[t]{ll}
%     r & \text{if $\semapp{E}{|def (x t) (x=e_1; t=e_2; t x|}{\rho} = r$} \\
%       \wrong & \text{otherwise} \\
%      \multicolumn{2}{l}{\text{where $r = \semapp{E}{e_1}{\rho}$}}
%         \end{array} \\
\\
  \semapp{V}{|v|}{} & : & \Env \rightarrow \Value \\
  \semapp{V}{|x|}{\rho} & = & \rho(x) \\
  \semapp{V}{|k|}{\rho} & = & k \\
  \semapp{V}{op}\rho & = & \semapp{O}{op} \\
  \semapp{V}{|lam x e|}{\rho} & = & \lambda w . \semapp{E}{e} (\extendrho{\rho}{x \mapsto w}) \\
  \semapp{V}{|tup (v_1,dots,v_n)|}{\rho} & = & \tuple{\semapp{V}{v_1}{\rho}, \cdots, \semapp{V}{v_n}{\rho}} \\
\\
  \semapp{O}{|op|}{} & : & \Value \\
  \semapp{O}{|add|} & = &  \multicolumn{2}{l}{\lambda w.
    \begin{array}[t]{l}
       \text{\bf if}\, (w = |tup(k_1,k_2)|) \\
       \text{\bf then}\, \munit(k_1+k_2) \\
       \text{\bf else}\, \wrong
  \end{array}}\\
%  \semapp{O}{|gt|}  & = &  \multicolumn{2}{l}{\lambda w.\, \text{\bf if}\, (w = |tup(k_1,k_2)|)
%      \,\text{\bf then (if}\, (k_1 > k_2)
%                       \,\text{\bf then}\, \munit(k_1)
%                       \,\text{\bf else}\, \mempty \,)
%      \,\text{\bf else}\, \wrong } \\
%  \semapp{O}{|int|}  & = &  \multicolumn{2}{l}{\lambda w.\, \text{\bf if}\, (w = k)
%      \,\text{\bf then}\, \munit(k)
%      \,\text{\bf else}\, \mempty}
  \end{array} \\ \\
  
\begin{array}{rcll}
apply & : & (\Value \times \Value) \rightarrow \mtype \\
apply( k, w) & = & \wrong & \\
apply( \tuple{v_0, \ldots, v_n}, k) & = & \munit(v_k) & 0 \leq k \leq n \\
  & = &  \mempty & \text{otherwise} \\
apply( \tuple{v_0, \ldots, v_n}, w) & = & \wrong & w \not\in \mathbb{Z} \\
apply( f, w ) & = & f(w) & f \in \Value \rightarrow \mtype \\
\end{array}
\end{array}
$
\caption{Expression semantics}
\label{fig:den-sem1}
\end{figure}

\begin{figure}
$$
