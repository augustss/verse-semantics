\section{A simpler order-sensitive denotational semantics} \label{sec:simple-order-sensitive}

The labelled semantics from the previous section can be simplified. Here, we show two isomorphic presentations. We ignore |\wrong| and |\bot| for now.

\newcommand{\sseq}{\mathit{seq}}
\newcommand{\powersett}{\powerset}

\begin{figure}
$$
\begin{array}{l}
\text{\bf Domains} \\
\begin{array}{rcll}
\mtype & = & \mlift{(\wrong + [\powerset{W}])} \\
\end{array} \\
\\
\text{\bf Operations} \\
\begin{array}{rrcll}
\text{Empty}        & \mempty & : &  \mtype \\
    & \mempty & = & [] \\[1mm]
\text{Singleton}    & \munits{.} & : & \Value \rightarrow \mtype \\
     & \munits{w} & = & [\setform{ w }] \\[1mm]
\text{Union (Exists)}        & \cup & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
 &  s_1 \cup s_2 & = & \mathit{zipWith} \, (\cup) \, s_1 \, s_2 \\[1mm]
\text{Union (Choice)}        & \munion & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
 &  s_1 \munion s_2 & = & s_1 \bowtie s_2 \\[1mm]
\text{Intersection} & \mintersect & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
 &  s_1 \mintersect s_2 & = & [ u_1 \cap u_2 \, \vert \, u_1 \in s_1, u_2 \in s_2 ] \\[1mm]
\text{Sequencing} & \msemi & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
&  s_1 \msemi s_2 & = & [ u_2 \, \vert \, u_1 \in s_1, u_2 \in s_2 ] \\[1mm]
% \text{Tagging} & \mtag & : & [L] \times \mtype \rightarrow \mtype \\
% & \mtag(t, s) & = & \setform{(\lblsemi{t}{l}, w) \mid (l, w) \in s} \\[1mm]
\text{One}  & \mone & : & \mtype \rightarrow \mtype \\
& \mone(s) & = & \shead{(\sseq{(s)})} \\[1mm]
\text{All}  & \mall & : & \mtype \rightarrow \mtype \\
& \mall(s) & = & \stuple{(\sseq{(s)})} \\[1mm]
\text{Head}  & \shead & : & [\powersett{W}] \rightarrow \mtype \\
& \shead([])  & = & [] \\
& \shead(u:s) & = & [u] & \text{if $u$ is a singleton set} \\
& \shead(u:s) & = & \wrong & \text{if $u$ has more than one element}\\[1mm]
\text{To tuple} & \stuple & : & [\powersett{W}] \rightarrow \mtype \\
     & \stuple([\{w_1\}, \cdots, \{w_n\}]) & = & [\tuple{w_1,\cdots,w_n}] \\
     & \stuple(ws) & = & \wrong & \text{if any $r \in ws$ has more than one element} \\
     & \stuple(ws) & = & \bot & \text{if |ws| is infinite} \\[1mm]
\text{Seq} & \sseq & : & \mtype \rightarrow [\powersett{W}] \\
     & \sseq(s) & = & [ r \, \vert \, r \in s, r \not= \varnothing ] \\
\end{array}
