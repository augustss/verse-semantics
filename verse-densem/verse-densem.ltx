  \sfolapp{|one e|}(|ell|) & = & |ell = [] &&| \exists |ell_1| . \;  \sfolapp{|e|}(|ell_1|) \\
  \sfolapp{|all e|}(|ell|) & = & |true| \\
  \sfolapp{|a@i|}(|ell|) & = & |ell =| label(\termapp{i}) |&&| 0 \leq \termapp{i} < size(\termapp{a}) \\
~ \\
  \folapp{|e|} & : & \Labels \times \Term \rightarrow \Forml \\
  \folapp{|v|}(|ell,t|) & = & |ell = [] && term v = t| \\
  \folapp{|fail|}(|ell,t|) & = & |false| \\
  \folapp{|e_1 choice e_2|}(|ell,t|) & = &
    |ell| \not= |[] && ((head ell = L &&| \folapp{|e_1|}(|tail ell,t|))
    \vee (|head ell = R &&| \folapp{|e_2|}(|tail ell,t|))) \\
  \folapp{|v = e|}(|ell,t|) & = &
    \folapp{|e|}(|ell,t|) |&&| \termapp{|v|} = |t| \\
  \folapp{|e_1 ; e_2|}(|ell,t|) & = &
  \exists |ell_1, ell_2| . \; |ell = ell_1 ++ ell_2 &&| 
    \sfolapp{|e_1|}(|ell_1|) |&&| \folapp{|e_2|}(|ell_2,t|) \\
  \folapp{|def x e|}(|ell,t|) & = &
    \exists |x| . \; \folapp{|e|}(|ell,t|) \\
  \folapp{|one e|}(|ell,t|) & = & |ell = [] &&|
  \exists |ell_1| . \; (\folapp{|e|}(|ell_1,t|) |&&| \forall |ell_2 < ell_1| . \; \neg{}\sfolapp{|e|}(|ell_2|) ) \\
  \folapp{|all e|}(|ell,t|) & = & ... \\
  \folapp{|a@i|}(|ell,t|) & = & |ell =| label(\termapp{i}) |&&| 0 \leq \termapp{i} < size(\termapp{a}) |&&| index(\termapp{a},\termapp{i}) = t\\
  \end{array}
$$
\caption{First-order logic semantics of expressions based on labelled semantics}
\end{figure}

