\subsection{Denotational semantics of TimLambda}

\Cref{fig:tim-den-sem1} and \ref{fig:tim-den-sem2} describe the denotational semantics of TimLambda.

\begin{figure}
$
\begin{array}{l}
\text{\bf Domains} \\
\begin{array}{rcll}
\Value & = & \bot + \mathbb{Z} + \tuple{\Value} + (\Value \rightarrow \mtyped) + \wrong \\
\tuple{\Value} & = & \text{a finite tuple of values $\Value$} \\
\Env & = & Ident \rightarrow \Value \\
\end{array}
\\ \\
\text{\bf Semantics of expressions and values} \\

  \begin{array}{rcll}
  \semapp{E}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{E}{|v|}{\rho} & = & \munits{\semapp{V}{v}{\rho}} \\
  \semapp{E}{|fail|}{\rho} & = & \mempty \\
  \semapp{E}{|e_1 choice e_2|}{\rho} & = & \semapp{E}{|e_1|}{\rho} \; \munion     \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|e_1 = e_2|}{\rho}      & = & \semapp{E}{|e_1|}{\rho} \; \mintersect \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|e_1 ; e_2|}{\rho}      & = & \semapp{E}{|e_1|}{\rho} \; \msemi      \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|apply1N v_1 v_2|}{\rho} & = & \apply(\semapp{V}{|v_1|}{\rho}, \; \semapp{V}{|v_2|}{\rho}) \\
  \semapp{E}{|def x e|}{\rho} & = & \bigcup_{w \in \Value}\, \semapp{E}{e}{(\extendrho{\rho}{x \mapsto w})} \\
  \semapp{E}{|one e|}{\rho} & = & \mone (\semapp{E}{e}{\rho}) \\
  \semapp{E}{|all e|}{\rho} & = & \munits{\mall (\semapp{E}{e}{\rho})} \\
  \semapp{E}{|lam x (def (y_1 dots y_n) (where e_1 dot e_2))|}{\rho} & = & \{
    \begin{array}[t]{ll}
      f
        \mid f \in (\Value \rightarrow \mtyped) , \\
        \forall |w w_1 dots w_n| \in |W| . \\
          \begin{array}[t]{l}
            \semapp{E}{|e_1|}{\extendrho{\rho}{|x| \mapsto w, |y_1| \mapsto w_1 |dots|}} \neq \varnothing \implies \\
            \exists z \in f(w) . \, \\
            z \in \semapp{E}{|e_2|}{\extendrho{\rho}{|x| \mapsto w, |y_1| \mapsto w_1 |dots|}} \\
          \end{array} \\
    \end{array}
  \end{array}          \\
\\
  \begin{array}{rcll}
  \semapp{V}{|v|}{} & : & \Env \rightarrow \Value \\
  \semapp{V}{|x|}{\rho} & = & \rho(x) \\
  \semapp{V}{|k|}{\rho} & = & k \\
  \semapp{V}{op}\rho & = & \semapp{O}{op} \\
%%%  \semapp{V}{|lam x e|}{\rho} & = & \lambda w . \semapp{E}{e} (\extendrho{\rho}{x \mapsto w}) \\
  \semapp{V}{|tup (v_1,dots,v_n)|}{\rho} & = & \tuple{\semapp{V}{v_1}{\rho}, \cdots, \semapp{V}{v_n}{\rho}} \\
  \end{array}
  \\ \\
\begin{array}{rcll}
apply & : & (\Value \times \Value) \rightarrow \mtype \\
apply( \bot, w) & = & \bot \\
apply( \wrong, w) & = & \wrong \\
apply( k, w) & = & \wrong & k \in \mathbb{Z} \\
apply( \tuple{v_0, \ldots, v_n}, w) & = &
%     \multicolumn{2}{l}{
%     ((\munits{w} \mintersect \munits{0}) \msemi \munits{v_0}) \; \munion |dots| \; \munion
%     ((\munits{w} \mintersect \munits{n}) \msemi \munits{v_n})
%     }
  \{ v_0 \mid w=0 \} \; \munion \; |dots| \; \munion \; \{ v_n \mid w=n \}
  \\
apply( f, w ) & = & f\, w & f \in \Value \rightarrow \mtyped \\
\end{array}
\\ \\
\begin{array}{lrcll}
\text{Empty}        & \mempty & : &  \mtyped \\
\text{Singleton}    & \munits{.} & : & \Value \rightarrow \mtyped \\
\text{Union}        & \munion & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
\text{Intersection} & \mintersect & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
\text{Product}      & \msemi & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
\end{array}

\end{array}
$
