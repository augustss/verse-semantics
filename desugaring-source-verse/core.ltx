%% Complicated subscript tweak so that a subscript is the same height whether or not a superscript is present.
%% See Knuth, "The TeXBook", page 179, second "double-dangerous-turn" paragraph.
%% The implementation here affects only subscripts in the \mathcal font.
\newif\ifalignsubscripts

\global\alignsubscriptstrue

\newcommand{\setsubscriptalignparameters}{
\ifalignsubscripts
{\setbox0=\hbox{$\mathcal{A
\global\fontdimen16\textfont2=\fontdimen17\textfont2
}$}}
\fi
}

\setsubscriptalignparameters

\newcommand{\alignsubscript}[1]{\ifalignsubscripts\smash{#1}\else#1\fi}
%\newcommand{\alignsubscript}[1]{\ifalignsubscripts\vbox to 0pt{\vss$#1$}\else#1\fi}




%  -------------------------- Syntax -----------------------
\newcommand{\figureSyntax}{
\begin{figure}[t]
  $$
\begin{array}{l}
\mbox{\em Syntax} \\
  \begin{array}{lrcl@@{}}
      \text{Integers} & k \\
      \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
      \text{Skolems} & \multicolumn{3}{l}{r,s,t} \\
          & |rs| & ::= & |{r_1, xdots, r_n}|  \hspace{1cm} (n \geq 0)\\
      \text{Programs} & p  & ::=  & |one e| \quad \text{where} \; \freevars{e} = \{ \} \\
      \text{Expressions} & |e| & ::= & |v| \vb |lv == e_1 ; e_2| \vb |e_1 choice e_2| \vb |fail| \vb |def x e| \vb |apply1N v_1 v_2| \vb |one e| \vb |all e| \\
      && \vb & |some v| \vb |e_1 guard e_2| \vb |check fx e|
      \vb |verify2 rs as e| \\
      \text{Lvalues} & |lv| & ::= & |_| \vb |v| \\
      \text{Values} & |v| & ::= & x  \vb \hnf \\
      \text{Ground values} & |gv| & ::= & |k| \vb |r| \vb |arr (gv_1, xdots, gv_n)| \\
      \text{Head values} & \hnf & ::= & |k| \vb |r|  \vb |op| \vb |arr (v_1, xdots, v_n)| \vb |lam x e|
             \vb |olam v (lam x_1 e_1) (lam x_2 e_2)|\\
      \text{Prim operators} & |op|  & ::= & |add| \vb |sub| \vb |gt| \vb |isInt| \vb \ldots \\
      \text{Effects} & |fx| & ::= & |succeeds| \vb |decides| \vb |fails|  \\
      \text{Assumptions} & |a| & ::= & |r = gv| \vb |noteq r gv| \vb |r = apply1N op gv| \vb |not (apply1N op gv)| \\
      & |as| & ::= & |{a_1, xdots, a_n}|   \hspace{1cm} (n \geq 0)
\end{array}
\\ \\
\mbox{\em Contexts} \\
\begin{array}{lrcl}
\text{Value contexts}  & |V| & ::= & \hole \vb |tup (v_1, xdots, V, xdots, v_n)|\\
% \text{Eval. contexts}  & |E| & ::= & |hole| \vb |lv == E; e| \vb |lv == e; E| \vb |E guard e| \vb |def x E| \\
% \text{Pure contexts}  & |C| & ::= & |hole| \vb |lv == C; e| \vb |lv == cf; C| \vb |def x C| \vb |C guard e| \\
\text{Evaluation contexts} & |EX xs| & ::= & |hole| \vb |lv == EX xs; e| \vb |lv == suspx xs; EX xs| \vb |def x (EX (xs,x))| \vb |EX xs guard e| \\
\text{Proof contexts}  & |PX xs| & ::= & |hole| \vb |lv == PX xs; e| \vb |lv == suspx xs; PX xs| \vb |def x (PX (xs,x))| \vb |PX xs guard e| \\
   && \vb &  |one (FC^[PX xs])| \vb |all (VC^[PX xs])| \vb |check fx (PX xs)| \\
%   & |PV| & ::= & |P| \vb |v `choice` PV| \\
\text{First choice} & |FC| & ::= & |hole| \vb |hole `choice` e| \\
\text{Value choice} & |VC| & ::= & |FC| \vb |v `choice` VC| \\
% \text{Choice-free exprs} & |cf| & ::= & |v | \vb |l==cf; cf| \vb op[v] \vb |one e| \vb |all e| \vb |cf guard cf| \\

\text{Suspended exp}  & |suspx xs| & ::= &
|l==suspx1 xs; suspx2 xs| \vb |suspx xs guard e| \vb |one (FC^[suspx xs])| \\
  & & \vb & |all (VC^[suspx xs])| \vb  |verify2 rs as e| \vb |check fx (suspx xs)| \\
  & & \vb & |apply1N op v|  \hspace{4mm}
    \text{where |v = V^[x]| for some $|x| \in |xs|$ and context |V|} \\
  & & \vb & |apply1N x v|  \hspace{5mm}
    \text{where $|x| \in |xs|$} \\

%    \text{Suspended exprs}  & |susp| & ::= &|lv == susp; susp| \vb |one susp| \vb |all susp| \\
%    && \vb & |apply1N pp x| \vb  |susp guard e| \vb |check fx susp| \vb |some susp| \\
\end{array} \\
% \begin{array}{ll}
% \text{Effect-free} & \text{|ef| is an |eq| that can have choice and fail, but not I/O effects or divergence} \\
% \text{Choice-free:} & \text{|cf| is an |eq| that has no choice, I/O effects or divergence; but it can fail} \\
% \text{Note:} & \text{The productions |def x C| in |C|, and |def x S| in |S| are optional.}
% \end{array}

\\
\mbox{\em Substitution} \\
\begin{array}{ll}
  |subst S x v| & \text{Substitute |v| for |x| everywhere in |S|} \\
%  |substw S x v| & \text{Substitute |v| for |x| everywhere outside |assumeKW| in |S|} \\
\end{array}
\\ \\
\mbox{\em Blocked expressions and contexts} \\
\begin{array}{rcl}
  |blockedc xs hole| & = & \mathit{true} \\
  |blockedc xs (def x C)| & = & |blockedc (xs,x) C| \\
  |blockedc xs (l==e; C)| & = & |blockede xs e `and` blockedc xs C| \\
\end{array}
\\ \\
\begin{array}{rcl}
  |blockede xs (l==e_1; e_2)| & = & |blockede xs e_1 `and` blockede xs e_2|\\
  |blockede xs (e_1 guard e_2)| & = & |blockede xs e_1|\\
  |blockede xs (verify2 rs as e)| & = & true \\
  |blockede xs (check fx e)| & = & |blockede xs e| \\
  |blockede xs (def x e)| & = & |blockede ((xs,x)) e| \\
  |blockede xs (apply1N op v)| & = & \text{|v = V^[x]| for some $|x| \in |xs|$ and context |V|} \\
  |blockede xs (apply1N x v)| & = & |x| \in |xs| \\

\end{array}
%  |substw S x v| & \text{Substitute |v| for |x| everywhere outside |assumeKW| in |S|} \\
\\ \\
\mbox{\em Free variables and bound variables (give definitions)} \\
%  \begin{array}{rcl}
%       |fvs(hole)| & = & \{ \} \\
%       |fvs(v==E; e)| & = & |fvs(v) `cup` fvs(E) `cup` fvs(e)| \\
%       |fvs(v==ef; E)| & = & |fvs(v) `cup` fvs(ef) `cup` fvs(E)| \\
%       |fvs(def x E)| & = & |{x} `cup` fvs(E)| |-- this is correct| \\
%    \end{array}
\end{array}
     $$
  \caption{Core Verse Syntax} \label{fig:vc-syntax}
\end{figure}
}

\newcommand{\alphamark}{use $\alpha$}

% ------------------ Rewrite rules -------------------

\newcommand{\figureRewriteRules}{
  \begin{figure}
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Application}
\rulename{app-add}          & |applyN add (k_1 ,k_2)| & \movesto & |k_3| & \text{where $k_3 = k_1 + k_2$}\\
\rulename{app-gt}           & |applyN gt (k_1,k_2)|   & \movesto & |k_1| &  \text{if $k_1 > k_2$} \\
\rulename{app-gt-fail}      & |applyN gt (k_1,k_2)|   & \movesto & |fail| &  \text{if $k_1 \leq k_2$} \\
\rulename{app-lam}^{\alpha} & |apply1 (lam x e) v| & \movesto & |def x (x==v; e)|
                                                  & \text{if $x \not\in \freevars{|v|}$} \\
\rulename{app-tup}          & |apply1 (tup (v_1,xdots, v_n)) v| & \movesto &
                            |(v == 1^^^ v_1) choice xdots choice (v == n^^^ v_n)| & n \geq 1 \\
\rulename{app-tup-0}        & |apply1 emptytup v| & \movesto & |fail|
\end{array}
\\ \\[-0.8em]
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Unification}
  \rulename{u-lit}   & |k == k; e| & \movesto & |e| & \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e|
       & \movesto & |v_1==v1' `eqsemi` xdots `eqsemi` v_n==v_n' `eqsemi` e| & n \geq 0\\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & |fail| & \text{if \rulename{u-lit}, \rulename{u-tup}, \rulename{u-olam} do not match} \\
  \rulename{u-occurs} & |x==V^[x]; e| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
\\[-0.8em]

\rulegroupname{Existentials}

%\rulename{subst-exi} & |S^[x==v]| & \movesto & |subst S x v ^[x==v]|
%  & \text{$|v|\ne|V^[x]|$} \\
\rulename{exi-subst} & |def x (EX x^[x==v; e])| & \movesto & |subst (EXX^[e]) x v|
  & \text{$|x|\not\in\freevars{|v|};\, |x|,\freevars{|v|} \not\in \boundvars{|S|}$} \\
\rulename{exi-elim} & |def x e| & \movesto & |e| & \text{if $|x| \notin \freevars{|e|}$}\\
\rulename{exi-float}^{* \alpha} & |C^[def x e]| & \movesto & |def x C^[e]| & \text{if $x \notin \freevars{|C|} \cup \boundvars{|C|}$} \\
\rulename{exi-choice}^{\alpha} & |def x (C^[e_1 choice e_2])| & \movesto & |C^[(def x e_1) choice (def x e_2)]| & \text{if $x \notin \freevars{|C|} \cup \boundvars{|C|}$} \\
\end{array}
\\ \\[-0.8em]
\begin{array}{@@{\hskip0.5em} l  r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Normalization}
%\rulename{def-elim} & |def x (E^[x==v])| & \movesto & |E^[ok]| & \text{if $|x| \notin \freevars{|E|}\cup \freevars{|v|}$}\\
%\rulename{exi-move}^{\alpha} & |E^[def x e]| & \leftrightarrow & |def x E^[e]| & \text{if $x \notin \freevars{|E|} \cup \boundvars{|E|}$} \\
\rulename{seq-assoc} & |lv_2 == (lv_1 == e_1; e_2); e_3| & \movesto & |lv_1 == e_1; lv_2 == e_2; e_3| \\
% \rulename{seq-float} & |v == (eq_1 ; e_2)| & \movesto & |eq_1 `eqsemi` v == e_2| \\
% \rulename{eq-float} & |v_1 == (v_2 == e)| & \movesto & |v_2 == e; v_1 = ok| \\
\rulename{eq-swap}^{*} & |v == x; e| & \movesto & |x == v; e|  \\
% \rulename{eq-result} & |v == e; ok| & \movesto & |v = e| \\
\rulename{seq-elim} & |_ == v ; e| & \movesto & |e| \\
\rulename{rec} & |z = V^[lam x e_1]; e_2| & \movesto & \multicolumn{2}{l}{|z = V^[lam x (def z (z = V^[lam x e_1]; e_1))]; e_2|
  \hspace{4mm} \text{$|z| \in \freevars{|e_1|}$}} \\

    \\[-0.8em]

\rulegroupname{Choice}
\rulename{choice-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
\rulename{choice-fail-l} & |fail choice e| & \movesto & |e| \\
\rulename{choice-fail-r} & |e choice fail| & \movesto & |e| \\
\rulename{choice} & |C^[e_1 choice e_2]| & \movesto & |C^[e_1] choice C^[e_2]| \\
\rulename{fail} & |C^[fail]| & \movesto & |fail| \\

    \\[-0.8em]

\rulegroupname{One and All}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice}  & |one (v choice e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)|  & n \geq 1 \\

\end{array} \\
\\[-0.8em]
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Open Lambdas}
  \rulename{u-olam}          & \multicolumn{3}{l}{|olam v_1 dom_1 rng_1 == olam v_2 dom_2 rng_2|} \\
  & \multicolumn{4}{l}{\hspace{5mm} \movesto |defKW z|.
  \begin{array}[t]{l}
        |v_1 == olam z ((lam x (check fails (apply1N dom_1 x); apply1N dom_2 x))) rng_2;| \\
        |v_2 == olam z ((lam x (check fails (apply1N dom_2 x); apply1N dom_1 x))) rng_1| \\
   \end{array}} \\[5mm]
  \rulename{app-olam} & |apply1N (olam g dom rng) v| & \movesto &
  \multicolumn{2}{l}{|if (x := apply1N dom v) then apply1N rng x else apply1N g v|} \\[1mm]
\end{array}
\\
\text{\textit{Note}: In rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.} \\
\text{\textit{Note}: Rules marked with a superscript $*$ may apply infinitely.}
\end{array}$

\caption{\textbf{The \vcname: Rewrite rules for execution}} \label{fig:rules}
\Description{A table that exhibits the rewrite rules for the Verse Calculus, groupesd into five categories: Application, Unification, Normalization, Garbage Collection, and Choice}
\end{figure}
}




