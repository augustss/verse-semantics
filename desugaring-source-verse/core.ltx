% ------------------ Rewrite rules -------------------

\newcommand{\figureRewriteRules}{
  \begin{figure}
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Application}
\rulename{app-add}          & |applyN add (k_1 ,k_2)| & \movesto & |k_3| & \text{where $k_3 = k_1 + k_2$}\\
\rulename{app-gt}           & |applyN gt (k_1,k_2)|   & \movesto & |k_1| &  \text{if $k_1 > k_2$} \\
\rulename{app-gt-fail}      & |applyN gt (k_1,k_2)|   & \movesto & |fail| &  \text{if $k_1 \leq k_2$} \\
\rulename{app-lam}^{\alpha} & |apply1 (lam x e) v| & \movesto & |def x (x==v; e)|
                                                  & \text{if $x \not\in \freevars{|v|}$} \\
\rulename{app-tup}          & |apply1 (tup (v_1,xdots, v_n)) v| & \movesto &
                            |(v == 1^^^ v_1) choice xdots choice (v == n^^^ v_n)| & n \geq 1 \\
\rulename{app-tup-0}        & |apply1 emptytup v| & \movesto & |fail|
\end{array}
\\ \\[-0.8em]
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Unification}
  \rulename{u-lit}   & |k == k; e| & \movesto & |e| & \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e|
       & \movesto & |v_1==v1' `eqsemi` xdots `eqsemi` v_n==v_n' `eqsemi` e| & n \geq 0\\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & |fail| & \text{if \rulename{u-lit}, \rulename{u-tup}, \rulename{u-olam} do not match} \\
  \rulename{u-occurs} & |x==V^[x]; e| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
\\[-0.8em]

\rulegroupname{Existentials}

%\rulename{subst-exi} & |S^[x==v]| & \movesto & |subst S x v ^[x==v]|
%  & \text{$|v|\ne|V^[x]|$} \\
\rulename{exi-subst} & |def x (C^[x==v; e])| & \movesto & |subst (C^[e]) x v|
  & \text{if |validc x emptyset C|, $x \not\in \freevars{v}$}  \\
\rulename{exi-elim} & |def x e| & \movesto & |e| & \text{if $|x| \notin \freevars{|e|}$}\\
\rulename{exi-float}^{* \alpha} & |C^[def x e]| & \movesto & |def x C^[e]| & \text{if $x \notin \freevars{|C|} \cup \boundvars{|C|}$} \\
\rulename{exi-choice}^{\alpha} & |def x (C^[e_1 choice e_2])| & \movesto & |C^[(def x e_1) choice (def x e_2)]| & \text{if $x \notin \freevars{|C|} \cup \boundvars{|C|}$} \\
\end{array}
\\ \\[-0.8em]
\begin{array}{@@{\hskip0.5em} l  r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Normalization}
%\rulename{def-elim} & |def x (E^[x==v])| & \movesto & |E^[ok]| & \text{if $|x| \notin \freevars{|E|}\cup \freevars{|v|}$}\\
%\rulename{exi-move}^{\alpha} & |E^[def x e]| & \leftrightarrow & |def x E^[e]| & \text{if $x \notin \freevars{|E|} \cup \boundvars{|E|}$} \\
\rulename{seq-assoc} & |lv_2 == (lv_1 == e_1; e_2); e_3| & \movesto & |lv_1 == e_1; lv_2 == e_2; e_3| \\
% \rulename{seq-float} & |v == (eq_1 ; e_2)| & \movesto & |eq_1 `eqsemi` v == e_2| \\
% \rulename{eq-float} & |v_1 == (v_2 == e)| & \movesto & |v_2 == e; v_1 = ok| \\
\rulename{eq-swap}^{*} & |v == x; e| & \movesto & |x == v; e|  \\
% \rulename{eq-result} & |v == e; ok| & \movesto & |v = e| \\
\rulename{seq-elim} & |_ == v ; e| & \movesto & |e| \\
\rulename{rec} & |z = V^[lam x e_1]; e_2| & \movesto & \multicolumn{2}{l}{|z = V^[lam x (def z (z = V^[lam x e_1]; e_1))]; e_2|
  \hspace{4mm} \text{$|z| \in \freevars{|lam x e_1|}$}} \\

    \\[-0.8em]

\rulegroupname{Choice}
\rulename{choice-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
\rulename{choice-fail-l} & |fail choice e| & \movesto & |e| \\
\rulename{choice-fail-r} & |e choice fail| & \movesto & |e| \\
\rulename{choice} & |SX^[C^[e_1 choice e_2]]| & \movesto & |SX^[C^[e_1] choice C^[e_2]]| & \text{if |choicefreec C|}\\
\rulename{fail} & |C^[fail]| & \movesto & |fail| & \text{if |blockedc emptyset C|}\\

    \\[-0.8em]

\rulegroupname{One and All}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice}  & |one (v choice e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)|  & n \geq 1 \\

\end{array} \\
\\[-0.8em]
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Open Lambdas}
  \rulename{u-olam}          & \multicolumn{3}{l}{|olam v_1 dom_1 rng_1 == olam v_2 dom_2 rng_2|} \\
  & \multicolumn{4}{l}{\hspace{5mm} \movesto |defKW z|.
  \begin{array}[t]{l}
        |v_1 == olam z ((lam x (check fails (apply1N dom_1 x); apply1N dom_2 x))) rng_2;| \\
        |v_2 == olam z ((lam x (check fails (apply1N dom_2 x); apply1N dom_1 x))) rng_1| \\
   \end{array}} \\[5mm]
  \rulename{app-olam} & |apply1N (olam g dom rng) v| & \movesto &
  \multicolumn{2}{l}{|if (x := apply1N dom v) then apply1N rng x else apply1N g v|} \\[1mm]
\end{array}
\\
\text{\textit{Note}: In rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.} \\
\text{\textit{Note}: Rules marked with a superscript $*$ may apply infinitely.}
\end{array}$

\caption{\textbf{The \vcname: Rewrite rules for execution}} \label{fig:rules}
\Description{A table that exhibits the rewrite rules for the Verse Calculus, groupesd into five categories: Application, Unification, Normalization, Garbage Collection, and Choice}
\end{figure}
}

% ----------------------------------------
%             Verification rules
% ----------------------------------------

\newcommand{\figureVerificationRules}{
\begin{figure}[t]
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
  \multicolumn{5}{l}{\textit{Auxiliary functions}} \\
  & |skolval X v| & = & |X| \cap |freevars v| = \emptyset \\[2mm]


\multicolumn{5}{l}{\textit{Guard}} \\
\rulename{guard-elim} & |v guard e| & \movesto & |e| \\
\rulename{guard-fail} & |fail guard e| & \movesto & |fail| \\
\end{array} \\
\\[-2mm]

\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\multicolumn{5}{l}{\textit{Check}} \\
\rulename{check-fail}   & |check fx fail|  & \movesto & |fail|
   & \text{$|fx| \in \{|fails|,|decides|\}$}\\
  \rulename{check-suc}    & |check fx v|  & \movesto & |v| & \text{$\skol{|v|}, |fx| \in \{|succeeds|,|decides|\}$} \\
  \rulename{check-choice} & |check succeeds (v choice e)|  & \movesto & |v choice (check fails e)| & \text{$\skol{|v|}$} \\
\end{array} \\
\\[-0.6em]

\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\multicolumn{5}{l}{\textit{Verify} \hspace{3mm} \text{All rules require |blockedc emptyset P|}} \\
\rulename{solver} & |verify2 rs as e| & \movesto & |tup ()| \hspace{5mm} \text{if $|rs;as| \vDash \mathit{inconsistent}$} \\
  \rulename{verify-val} & |verify2 rs as v|      & \movesto & |tup ()| & \\
  \rulename{verify-choice} & |verify2 rs as (e_1 choice e_2)|      & \movesto & |verify2 rs as e_1 ; verify2 rs as e_2| & \\
  \rulename{verify-fail} & |verify2 rs as fail|    & \movesto & |tup ()| & \\[1mm]
  \rulename{skolemise}^{\alpha} & |verify2 rs as (P^[some v])| & \movesto
  & |verify2 (rs,r) as (def x (x = apply1N v r; P^[x]))| \\
  &&& \text{if $|r| \notin |rs|$ and |skolval (boundvars P) v|} \\
 \rulename{split-v} & |verify2 rs as (P^[r==gv; e])| & \movesto &
    |verify2 rs (as, r==gv) (P^[ e ]);| \\
    &&& |verify2 rs (as, noteq r gv) (P^[ fail ])|\\[1mm]
  \rulename{split-op} & |verify2 (rs) as (P^[apply1N op gv]))| & \movesto &
          |verify2 (rs,r) (as, r = apply1N op gv) (P^[ r ]);| \\
    &&& |verify2 rs (as, not (apply1N op gv)) (P^[ fail ])| \\
    &&& \text{if $r \not\in R$} \\[1mm]
 \rulename{split-tup} & \multicolumn{3}{l}{|verify2 rs as (P^[r==tup (v_1, xdots, v_n); e])|} \\
     && \movesto & |verifyKW|
           \begin{array}[t]{@@{}l}
             |(rs, r_1 xdots r_n; as, r==tup (r_1, xdots, r_n))| \\
             |{ P^[ r_1==v_1; xdots; r_n == v_n; e ] };|
           \end{array}\\
    &&& |verify2 rs (as, noteq r (tup (_, xdots,_))) (P^[ e ])| \\  \\[-2mm]
\end{array}\\

\end{array}$
\\[0.1in]
\caption{TRS Verifier Rewrite Rules}
\label{fig:spj-verifier-rewrite-rules}
\end{figure}
}

