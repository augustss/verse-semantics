%  -------------------------- Syntax -----------------------
\newcommand{\figureSyntax}{
\begin{figure}[t]
  $$
\begin{array}{l}
\mbox{\em Syntax} \\
  \begin{array}{lrcl@@{}}
      \text{Integers} & k \\
      \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
          & |X| & ::= & |{x_1, xdots, x_n}|  \hspace{1cm} (n \geq 0)\\
      \text{Skolems} & \multicolumn{3}{l}{r,s,t} \\
          & |rs| & ::= & |{r_1, xdots, r_n}|  \hspace{1cm} (n \geq 0)\\
      \text{Programs} & p  & ::=  & |one e| \quad \text{where} \; \freevars{e} = \{ \} \\
      \text{Expressions} & |e| & ::= & |v| \vb |lv == e_1 ; e_2| \vb |e_1 choice e_2| \vb |fail| \vb |def x e| \vb |apply1N v_1 v_2| \vb |one e| \vb |all e| \\
      && \vb & |some v| \vb |v guard e| \vb |check fx e|
      \vb |verify2 rs as e| \\
      \text{Lvalues} & |lv| & ::= & |_| \vb |v| \\
      \text{Values} & |v| & ::= & x  \vb \hnf \\
      \text{Ground values} & |gv| & ::= & |k| \vb |r| \vb |arr (gv_1, xdots, gv_n)| \\
      \text{Head values} & \hnf & ::= & |k| \vb |r|  \vb |op| \vb |arr (v_1, xdots, v_n)| \vb |lam x e|
             \vb |olam v (lam x_1 e_1) (lam x_2 e_2)|\\
      \text{Prim operators} & |op|  & ::= & |add| \vb |sub| \vb |gt| \vb |isInt| \vb \ldots \\
      \text{Effects} & |fx| & ::= & |succeeds| \vb |decides| \vb |fails|  \\
      \text{Assumptions} & |a| & ::= & |r = gv| \vb |noteq r gv| \vb |r = apply1N op gv| \vb |not (apply1N op gv)| \\
      & |as| & ::= & |{a_1, xdots, a_n}|   \hspace{1cm} (n \geq 0)
\end{array}
\\ \\
\begin{array}{lrcl}
\text{Value contexts}  & |V| & ::= & \hole \vb |tup (v_1, xdots, V, xdots, v_n)|\\
\text{Scope contexts}  & |SX| & ::= & |one hole| \vb |all hole| \vb |hole choice e| \vb |e choice hole| \\
\text{Evaluation contexts}  & |C| & ::= & |hole| \vb |lv == C; e| \vb |lv == e; C| \vb |def x C| \\
\text{Proof contexts}  & |P| & ::= & |hole| \vb |lv == P; e| \vb |lv == e; P| \vb |def x P|  \\
                       &     & \vb & |one (FC^[P])| \vb |all (VC^[P])| \vb |check fx P| \\
\text{First choice} & |FC| & ::= & |hole| \vb |FC `choice` e| \\
\text{Value choice} & |VC| & ::= & |FC| \vb |v `choice` VC| \\
% \text{Choice-free exprs} & |cf| & ::= & |v | \vb |l==cf; cf| \vb op[v] \vb |one e| \vb |all e| \vb |cf guard cf| \\
\end{array} \\
\\

\mbox{\em Substitution} \\
\begin{array}{ll}
  |subst e x v| & \text{Substitute |v| for |x| everywhere in |e|} \\
\end{array}
\\ \\
\mbox{\em Free variables and bound variables (give definitions)} \\
%  \begin{array}{rcl}
%       |fvs(hole)| & = & \{ \} \\
%       |fvs(v==E; e)| & = & |fvs(v) `cup` fvs(E) `cup` fvs(e)| \\
%       |fvs(v==ef; E)| & = & |fvs(v) `cup` fvs(ef) `cup` fvs(E)| \\
%       |fvs(def x E)| & = & |{x} `cup` fvs(E)| |-- this is correct| \\
%    \end{array}
\end{array}
     $$
  \caption{Core Verse Syntax} \label{fig:vc-syntax}
\end{figure}

\begin{figure}
$\begin{array}{@@{}l}
\begin{array}{rcll}
  |validc x Y hole| & = & \mathit{true} \\
  |validc x Y (def y C)| & = & |validc x (Y,y) C| \\
  |validc x Y (l==e; C)| & = & |blockedc (x,Y) (l==e; C)| & \text{if $|x| \in \freevars{e}$} \\
  |validc x Y (l==e; C)| & = & |blockede (x,Y) e `and` validc x Y C| & \text{if $|x| \not\in \freevars{e}$} \\
  & & |`or` validc x (Y `delete` freevars e) C|
\\[2mm]
  |blockedc X hole| & = & |true| \\
  |blockedc X (def x P)| & = & |blockedc (X,x) P| \\
  |blockedc X (l==P; e)| & = & |blockedc X P| \\
  |blockedc X (l==e; P)| & = & |blockede X e `and` blockedc X P| \\
  |blockedc X (check fx P)| & = & |blockedc X P| \\
  |blockedc X (one (FC^[P]))| & = & |blockedc X P| \\
  |blockedc X (all (VC^[P]))| & = & |blockedc X P| \\
\end{array}
\\ \\[-1mm] 
\begin{array}{rcl}
  |blockede X v| & = & |false|\\
  |blockede X (l==e_1; e_2)| & = & |blockede X e_1 `and` blockede X e_2|\\
  |blockede X (e_1 choice e_2)| & = & |blockede X e_1 `and` blockede X e_2|\\
  |blockede X fail| & = & |false| \\
  |blockede X (one e)| & = & |blockede X e| \\
  |blockede X (all e)| & = & |blockede X e| \\
  |blockede X (def x e)| & = & |blockede (X,x) e| \\
  |blockede X (apply1N v_1 v_2)| & = & (|v_1| = |x| \in |X|) \\
   & & |`or`| (|v_1| = |op| |`and`| |v_2 = V^[x]|) \hspace{2mm} \text{for some $|x| \in |X|$ and context |V|} \\
  |blockede X (e_1 guard e_2)| & = & |X| \cap \freevars{|v|} \not= \emptyset\\
  |blockede X (verify2 rs as e)| & = & |true| \\
  |blockede X (check fx e)| & = & |blockede X e| \\
\end{array}
\\ \\[-1mm]
\begin{array}{rcl}
  |choicefreec hole| & = & |true| \\
  |choicefreec (def x C)| & = & |choicefreec C| \\
  |choicefreec (l==C; e)| & = & |choicefreec C| \\
  |choicefreec (l==e; C)| & = & |choicefreee e `and` choicefreec C| \\
  \\[2mm]
  |choicefreee (e_1 choice e_2)| & = & |false|\\
  |choicefreee fail| & = & |true|\\
  |choicefreee (one e)| & = & |true|\\
  |choicefreee (all e)| & = & |true|\\
  |choicefreee (l==e_1; e_2)| & = & |choicefreee e_1 `and` choicefreee e_2|\\
  |choicefreee (v guard e)| & = & |choicefreee e|\\
  |choicefreee (def x e)| & = & |choicefreee e| \\
  |choicefreee (apply1N v_1 v_2)| & = & \text{|v_1| is a choice-free primop |op|} \\
  |choicefreee v|  & = & |true| \\
\end{array}
\end{array}
$
  \caption{Blocked expressions and contexts} \label{fig:vc-contexts}
\end{figure}
}

