\rulename{mbind}   & |DMe i (x:=t)|         & = & |x := DMe i t| \\
\rulename{meq}     & |DMe i (t_1=t_2)|      & = & |(DMe i t_1) = (DMe i t_2)| \\
\rulename{msemi}   & |DMe i (t_1 ; t_2)|    & = & |De t_1 ; DMe i t_2| \\
\rulename{mchoice} & |DMe i ((t_1 `choice` t_2))| & = & |(DMe i t_1) `choice` (DMe i t_2)| \\
\multicolumn{2}{l}{\rulename{mif}\hspace{1cm} |DMe i (if(t_1) then t_2 else t_3)|} & = &
    \multicolumn{2}{@@{}l}{|if ((De t_1)) then DMe i t_2 else DMe i t_3|} \\[2mm]

\multicolumn{4}{l}{\mbox{\it Misc.}} \\
\rulename{msquig} & |DMe i (y squiggt x := t)| & = & |y := i; DMe i (x := t)| \\
\rulename{marray} & |DMe i (arr(t_1, xdots, t_n))| & = &
    |def (x_1 xdots x_n) (i == arr (x_1, xdots, x_n));
     arr (Me x_1 t_1, xdots, Me x_n t_n)|
    \\[2mm]

\multicolumn{4}{l}{\mbox{\it Equality rules}} \\
\rulename{mconst}  & |DMe i k|                  & = & |i = k| \\
\rulename{mvar}    & |DMe i x|                  & = & |i = x| \\
\rulename{mapp}    & |DMe i (t_1^[t_2])|        & = & |i = ((De t_1))^[De t_2]| \\

\end{array}
\end{array}$$
