\section{Source Verse}

\Cref{fig:source-verse-expr} and \ref{fig:source-verse-misc}
give the source language that we desugar.

\begin{figurebox}
$$
\begin{array}{rcll}
  |t| & ::= & |x|               & \text{Variable} \\
      & \vb & |k|               & \text{Constant} \\
      & \vb & |t_1 ; t_2|       & \text{Sequencing} \\
      & \vb & |t_1^[t_2]|       & \text{Function application} \\
      & \vb & |t_1^(t_2)|       & \text{Non-failing function application} \\
      & \vb & |x := t|          & \text{Definition} \\
      & \vb & |def x t|         & \text{Existential} \\
      & \vb & |t_1 `choice` t_2| & \text{Choice} \\
      & \vb & |t_1 = t_2|       & \text{Unification} \\
      & \vb & |if(t) then b_1 else b_2| & \text{Conditional expression} \\
      & \vb & |for(t) in b|     & \text{Finite loop} \\
      & \vb & |check r t|     & \text{Effects check} \\
      & \vb & |array (t_1, dots, t_n)| & \text{Array}, n \geq 0 \\
      & \vb & |t_1, dots, t_n|  & \text{Array}, n \geq 2 \\
      & \vb & |()|              & \text{Empty array} \\
      & \vb & |t_1 eqgt t_2|    & \text{Lambda expression} \\
      & \vb & |p := t|          & \text{General definition} \\
      & \vb & |op_b t|          & \text{Prefix operator} \\
      & \vb & |t op_a|          & \text{Postfix operator} \\
      & \vb & |t_1 op_i t_2|    & \text{Infix operator} \\
      & \vb & |: t|             & \text{Range} \\
      & \vb & |l : t|           & \text{Type ascription} \\
      & \vb & |t_1 where t_2|   & \text{Reverse sequencing} \\
      & \vb & |function (a_1 dots a_n) t|    & \text{Function} \\
      & \vb & |if(t) then b|    & \text{Conditional expression} \\
      & \vb & |if(t) else b|    & \text{Conditional expression} \\
      & \vb & |if{t}|           & \text{Conditional expression} \\
      & \vb & |for{t}|          & \text{Finite loop} \\
      & \vb & |let(t) in b|     & \text{Local binding} \\
      & \vb & |do b|            & \text{Scope delimiter} \\
      & \vb & |case(t) of {t_1; dots t_n}|    & \text{Case expression} \\
      & \vb & |case{t_1; dots t_n}| & \text{Case expression} \\
      & \vb & |type^{t}|         & \text{Type definition} \\
      & \vb & |option^{}|        & \text{Create an option} \\
      & \vb & |option^{t}|       & \text{Create an option} \\
\end{array}
$$
\caption{Source Verse expressions} \label{fig:source-verse-expr}
\end{figurebox}

\begin{figurebox}
$$
\begin{array}{rcll}
  |x,y,f| &     & \textit{Variable} \\
  |k| &     & \textit{Integer constant} \\
      \\
\multicolumn{4}{l}{\text{\bf Blocks}} \\
  |b| & ::= & |t| \vb |{t_1; dots ; t_n}|  \\
\\
\multicolumn{4}{l}{\text{\bf Function arguments}} \\
  |a| & ::= & |(t)|  \vb |()| \vb |apeff a r| \\
\\
\multicolumn{4}{l}{\text{{\bf Patterns: left hand side of a definition |(p := t)|}. Subset of |t|.}} \\
  |p| & ::= & x \vb |p a| \vb |p^hat|  \vb |p^?|\vb  |p squiggt l| \\
     & \vb & |: t| \vb |p : t|  \vb |p_1, dots, p_n| \\
  \\

\multicolumn{4}{l}{\text{{\bf Left hand side of a type ascription |(l:t)|}. Subset of |t|.}} \\
  |l| & ::= & x \vb |l a| \vb |l^hat| \vb |l^?|  \vb  |p squiggt l| \vb |l^arrayty|  \\
  \\
\multicolumn{4}{l}{\text{\bf Operators}} \\
 |op_b| & ::= &  ! \vb - \vb + \vb |hat| \vb ? \vb |arrayty|  & \text{Prefix}\\
 |op_a| & ::= &  ? \vb |hat| \vb ..  & \text{Postfix}\\
 |op_i| & ::= &  + \vb - \vb * \vb / \vb |srcand| \vb |srcor| \vb : \vb .. & \text{Infix} \\
        & \vb & < \vb <= \vb > \vb >= \vb <> \vb |minusgt| \\
\end{array}
$$
\\
Variables can be alphanumeric, but also |prefix op|, |postfix op|, and |operator op|.
\caption{Source Verse} \label{fig:source-verse-misc}
\end{figurebox}

