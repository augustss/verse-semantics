\section{Desugaring Source Verse}

\begin{figurebox}
$$
\begin{array}{rclll}
\multicolumn{5}{l}{\textbf{Desugar a definition |p := e| into simple definitions with just |x := e|}} \\
\ifdesugarops
  |Pd x e| & = & |x := e| \\
\fi
  |Pd (f a) e| & = & |Pd f ((De (function a () {e})))| \\
  |Pd (: t) e| & = & |Pd (x:t) e| & \text{|x| fresh} \\
  |Pd (p : t) e| & = & |Pd p ((De t^[e]))| \\
  |Pd (p ?) e| & = & |Pd p (De ((option^{e}))| \\
  |Pd (e_1^hat) e| & = & |assign^(De e_1,e)| \\
  |Pd (p_0, dots, p_n) e| & = &
    \multicolumn{2}{l}{|Pd p_0 x_0; dots; Pd p_n x_n; array (x_0:any,dots,x_n:any) = e|} & \text{|x_i| fresh} \\
  |Pd (p squiggt l) e| & = & |Ld (p squiggt l) (De (type^{e}))| \\
  \\
\multicolumn{5}{l}{\textbf{Desugar a type ascription |l : t|}} \\
  |Ld x t| & = & |def y x := t^[y]; y| & |y| \not\in |t| \\
  OR: & = & |def y x := t^[y]| & |y| \not\in |t| \\
  |Ld (l a) t| & = & |Ld l (arrow (function a () {t}))| \\
  |Ld (l^hat) t| & = & |Ld l ((new^(t)))| \\
  |Ld (l?) t| & = & |Ld l ((? t))| \\
  |Ld (l^arrayty) t| & = & |Ld l ((arrayty^t))| \\
  |Ld (p squiggt l) t| & = & |Pd p ((Ld l t))| \\
\end{array}
$$
\caption{Desugaring of expressions (3)} \label{fig:desugar-expr}
\end{figurebox}

\begin{figurebox}
$$
\begin{array}{rcll}
  \multicolumn{4}{c}{ \text{Desugar Source Verse into a subset of Source Verse.} } \\[1mm]

  \multicolumn{1}{l}{\textbf{Basic forms}} \\
\ifdesugarops
  |De k| & = & |k| \\
  |De x| & = & |x| \\
  |De (e_1 ; e_2)| & = & |De e_1 ; De e_2| \\
  |De (e_1^[e_2])| & = & |(De e_1)[De e_2]| \\
  |De (e_1^(e_2))| & = & |(De e_1)(De e_2)| \\
  |De (e_1 = e_2)| & = & |De e_1 = De e_2| \\
  |De (e_1 `choice` e_2)| & = & |De e_1 `choice` De e_2| \\
\fi
  |De (e_1, dots, e_n)| & = & |array (De e_1 , dots, De e_n)| \\
  |De (())| & = & |array ()| \\
  \\
\ifdesugarops
  \multicolumn{1}{l}{\textbf{Bindings}} \\
  |De (l : t)| & = & |Ld l (De t)| \\
  |De (p := e)| & = & |Pd p (De e)| \\
  \\
\fi
  \multicolumn{4}{l}{\textbf{Functions}\quad \text{convert all functions to |functionKW(x:any){e}|}} \\
  |De (e_1 eqgt e_2)| & = & |De (function e_1 () {e_2})| \\
  |De (functionKW a_1 a_2 dots a_n b)| & = & |De (functionKW a_1 (functionKW a_2 dots a_n b))| & \\
  |De (functionKW () b)| & = & |De (functionKW (()) b)| & \\
  |De (functionKW a (eff r) b)| & = & |De (functionKW a (check r b))| & \\
  |De (function e () b)| & = & |function(x:any)()((if (De e = x) then b else :false)| & \text{|x| fresh} \\
  \\
  \multicolumn{1}{l}{\textbf{Types}} \\
  |De (:t)| & = & |De t^[x:any]| & \text{|x| fresh} \\
  %%  |De (type^{e})| & = & |type^{De e}| \\
  |De (type^{e})| & = & |De (x:any => x = e)| & \text{|x| fresh} \\  
  \\
  \multicolumn{1}{l}{\textbf{Conditionals}} \\
  |De (if{e})| & = & |De (if(e) else false)| \\
  |De (if(e_1) then e_2)| & = & |De (if(e_1) then e_2 else false)| \\
  |De (if(e_1) else e_2)| & = & |De (if (x := e_1) then x else e_2)| & \text{|x| fresh} \\
  |De (if(e_1) then e_2 else e_3)| & = & |if (De e_1) then De e_2 else De e_3| \\
  \\
  \multicolumn{1}{l}{\textbf{For}} \\
  |De (for{e})| & = & |De (for (x := e) in { x })| & \text{|x| fresh} \\
  \\
\end{array}
$$
\caption{Desugaring of expressions (1)} \label{fig:desugar-expr1}
\end{figurebox}

\begin{figurebox}
$$
\begin{array}{rcll}
  \multicolumn{1}{l}{\textbf{Operators}} \\
  |De (op_b e)| & = & |De (prefix op_b [e])| & \text{if |op_b| can fail}\\
  |De (op_b e)| & = & |De (prefix op_b (e))| \\
  |De (e op_a)| & = & |De (postfix op_a [e])| & \text{if |op_a| can fail}\\
  |De (e op_a)| & = & |De (postfix op_a (e))| \\
  |De (e_1 srcand e_2)| & = & |De (e_1; e_2)| \\
  |De (e_1 srcor e_2)| & = & |De (if(e_1) else if (e_2) else :false)| \\
  |De (!e)| & = & |De (if e then :false else false)| \\
  |De (e_1 where e_2)| & = & |De (x := e_1; e_2; x)| & \text{|x| fresh} \\
  |De (e_1 op_i e_2)| & = & |De (operator op_i [e_1, e_2])| & \text{if |op_i| can fail}\\
  |De (e_1 op_i e_2)| & = & |De (operator op_i (e_1, e_2))| \\
  \\
  \multicolumn{1}{l}{\textbf{Let, do, case}} \\
  |De (let(e) in b)| & = & |De (e); De b| & \textit{see note} \\
  |De (do b)| & = & |De b| & \textit{see note}  \\
  |De (case{e_1; dots e_n})| & = & |De ((x:any) => case(x){e_1; dots e_n})| & \text{|x| fresh} \\
  |De (case(e){e_1; dots e_n}| & = & |De (x:=e; e_1^[x] srcor dots srcor e_n^[x])| & \text{|x| fresh} \\
  \multicolumn{4}{l}{\lennart{This desugaring does not work for multivalued |e_i|.}} \\
  \\
  \multicolumn{1}{l}{\textbf{Misc}} \\
  |De ({e_1; dots e_n})| & = & |De (e_1; dots e_n)| \\
  |De (option^{})| & = & |false| \\
  |De (option^{e}| & = & |if(x:=e)then truth(x) else false| & \text{|x| fresh} \\
\end{array}
$$
{\em Note}: The desugaring assumes a scope correct Verse program.
This means that there can be no variable name clashes in |let| and |do|.
A more robust desugaring could \textalpha-convert such clashes.
\caption{Desugaring of expressions (2)} \label{fig:desugar-expr2}
\end{figurebox}


\begin{figurebox}
\begin{code}
any    = (x => x)
int    = (x => applyx isInt x; x)
nat    = (x => applyx isInt x; x > (-1); x)
false  = array()
arrow  = (ft => f => y => applyx (applyx ft y) (applyx f y))
\end{code}

\caption{Core prelude} \label{fig:core-prelude}
\end{figurebox}


\begin{figurebox}

$$
  \begin{array}{rcll}
    |Cr|   & \multicolumn{3}{l}{ \text{ converts the limited Source Verse to Core.} } \\
    |Cr k| & = & |k| \\
    |Cr x| & = & |x| \\
    |Cr (array (e_1, dots, e_n))| & = &
    \begin{array}[t]{@@{}l}
    |defTwoLines (x_1,dots,x_n) (x_1=e_1; dots; x_n=e_n; arr (v_1, dots, v_n)| \\
    \end{array}
	& \text{|x_i| fresh} \\
    |Cr (e_1 ; e_2)| & = & |Cr e_1 ; Cr e_2| \\
    |Cr (e_1 = e_2)| & = & |Cr e_1 = Cr e_2| \\
    |Cr (x := :any)| & = & |x| \\
    |Cr (x := e)| & = & |x = Cr e| \\
    |Cr (e_1^[e_2])| & = & |def (x,y) (x = e_1; y = e_2; applyx (Cr e_1) (Cr e_2)| & \text{|x,y| fresh} \\
    |Cr (e_1^(e_2))| & = & |succeeds (Cr (e_1^[e_2]))| \\
    |Cr (e_1 `choice` e_2)| & = & |Bi e_1 `choice` Bi e_2| \\
    |Cr (if e_1 then e_2 else e_3)| & = &
    \begin{array}[t]{@@{}l}
    |defTwoLines x (x = one(Bi (e_1; Th e_2) `choice` Bi (Th e_3));applyx x ())|
    \end{array}
    & \text{|x| fresh} \\
    |Cr (for e_1 in e_2)| & = & |all(Bi(e_1 ; Th e_2))| \\
    |Cr (function(x:any)()e)| & = & |x => Bi e| \\
%%    |Cr (type^{e})| & = & |x => Bi (x = e; x)| & \text{|x| fresh} \\
    \\
    |Th| & \multicolumn{3}{l}{ \text{creates a thunk, i.e., dummy function.} } \\
    |Th e| & = & |function(x:any)()e| & \text{|x| fresh} \\
    \\
    |Bi| & \multicolumn{3}{l}{ \text{inserts |defKW| for all local bindings.} } \\
    |Bi e| & = & |def (Vr e) (Cr e)| \\
    \\
    |Vr| & \multicolumn{3}{l}{ \text{finds all locally defined variables.} } \\
    |Vr k| & = & |emp| \\
    |Vr x| & = & |emp| \\
    |Vr (array (e_1, dots, e_n))| & = & |Vr e_1, dots, Vr e_n| \\
    |Vr (e_1 ; e_2)| & = & |Vr e_1 , Vr e_2| \\
    |Vr (e_1 = e_2)| & = & |Vr e_1 , Vr e_2| \\
    |Vr (x := e)| & = & |x , Vr e| \\
    |Vr (e_1^[e_2])| & = & |Vr e_1 , Vr e_2| \\
    |Vr (e_1^(e_2))| & = & |Vr e_1 , Vr e_2| \\
    |Vr (e_1 `choice` e_2)| & = & |emp| \\
    |Vr (if e_1 then e_2 else e_3)| & = & |emp| \\
    |Vr (for e_1 in e_2)| & = & |emp| \\
    |Vr (function(x:any)()e)| & = & |emp| \\
    |Vr (type^{e})| & = & |emp| \\
  \end{array}
  $$
\caption{Core conversion} \label{fig:core-conversion}
\end{figurebox}


\begin{figurebox}
$$
\begin{array}{l}
\begin{array}{rclll}
    \multicolumn{5}{l}{ \text{Reduction rules for |splitKW| } } \\
    \rulename{split-fail} & |split fail f g| & \movesto & |applyx f ()| \\
    \rulename{split-value} & |split v f g| & \movesto & |def x (x = applyx g v; applyx x (_ => fail)| & \text{|x| fresh} \\
    \rulename{split-choice} & |split (v `choice` e) f g| & \movesto & |def x (x = applyx g v; applyx x (_ => e)| & \text{|x| fresh} \\
    \rulename{split-wrong} & |split wrong f g| & \movesto & |wrong| \\
    \rulename{split-wrong} & |split (wrong `choice` e) f g| & \movesto & |wrong| \\
\end{array} \\
\\
\begin{array}{rclll}
    \multicolumn{5}{l}{ \text{Definition of |oneKW|, |allKW|, |succeedsKW|, and |decidesKW| in terms of |splitKW|. } } \\
    |one e| & = & |split e (_ => fail) (x => _ => x)| & \text{|x| fresh} \\
    |all e| & = &
    \begin{array}[t]{@@{}l}
      |defKW f,g in {| \\
      \quad |f := _ => ();| \\
      \quad |g := x => y => cons (applyx x ()) (split (applyx y ()) f g);| \\
      \quad |split e f g }|
    \end{array}  & \text{|x,y| fresh} \\
    |succeeds e| & = & |splitKW^{e, _ => wrong,| \\
    \quad        &   & \quad |x => y => split (applyx y ()) (_ => x) (_ => _ => wrong)}| & \text{|x,y| fresh}\\
    |decides e| & = & |splitKW^{e, _ => fail,| \\
    \quad        &   & \quad |x => y => split (applyx y ()) (_ => x) (_ => _ => wrong)}| & \text{|x,y| fresh}\\
\end{array}
\end{array}
$$
\lennart{Does |f| need to be a thunk?  Does second argument to |g| need to be a thunk? Yes, or it may |fail| in the wrong place.}
\caption{Alternative: Use |splitKW| instead of |oneKW|, |allKW|, |succeedsKW|, and |decidesKW|.} \label{fig:split}
\end{figurebox}



