\begin{figure}
$$
\begin{array}{@@{}l}
\begin{array}{rcll}
\multicolumn{4}{l}{\textbf{Application and unification}} \\
  |t_1 where t_2| & \rightarrow & |x := t_1 ; t_2; x| & \text{fresh |x|}\\
  |t_1 == x| & \rightarrow & |x == t_1|  & \text{|t_1| not variable}\\
  |t_1 == t_2| & \rightarrow & |x := t_1; x = t_2|  & \text{|t_1|,|t_2| not variable, fresh |x|}\\
  |t_1^[t_2]| & \rightarrow & |f := t_1; x := t_2; f^[x]| & \text{|t_1| or |t_2| not variable, fresh |f,x|} \\
  |t_1^(t_2)| & \rightarrow & |f := t_1; x := t_2; succeeds^{f^[x]}| & \text{|t_1| or |t_2| not variable, fresh |f,x|} \\
\end{array} \\
\\
\begin{array}{rcll}
\multicolumn{4}{l}{\textbf{Bindings |p := t|}} \\
  |_ : t| & \rightarrow & |x : t| & \text{fresh |x|} \\
  |p : t| & \rightarrow & |p := (: t)| \\
  |p^(a) := t| & \rightarrow & |p := function a t| \\
  |(p : t_1) := t_2| & \rightarrow & |p := oftype t_2 t_1| \\
  |(: t_1) := t_2| & \rightarrow & |(x : t_1) := t_2| & \text{fresh |x|} \\
  %% |(p?) := t| & \rightarrow & |p := option^{t}| \\
  |(p_1 squiggt p_2) := t| & \rightarrow & |p_1 := (x_1:any); p_2 := (x_2:any); (x_1 squiggt x_2) := t| & \text{if |p_1| or |p_2| not a variable} \\
  |array (p_1; xdots; p_n) := t| & \rightarrow &
  \begin{array}{ll}
    |array(x_1:any;xdots;x_n:any) == t;|\\
    |p_1 := x_1; xdots; p_n := x_n | & \text{none of |p_i| is |..p|}
  \end{array} \\[2mm]
\\
\multicolumn{4}{l}{\textbf{Array splice (terms and patterns)}} \\
  \multicolumn{3}{l}{\quad|array (t_1; xdots; t_km1; ..t_k; t_kp1; xdots; t_n)|} \\
  & \rightarrow & |append[array(t_1; xdots; t_km1), t_k, array(t_kp1; xdots; t_n)]|\\
  & \multicolumn{2}{l}{\text{where |append| is a reversible function appending 3 arrays}} \\
\\
\multicolumn{4}{l}{\textbf{Array notation}} \\
  |()| & \rightarrow & |array ()| \\
  |t_1, dots, t_n| & \rightarrow & |array (t_1; dots; t_n)| \\
\\
\multicolumn{4}{l}{\textbf{Function notation}} \\
  |type^{t}| & \rightarrow & |function (x:=t) x| & \text{fresh |x|}\\
  |e_1 eqgt e_2| & \rightarrow & |function e_1 e_2| \\
  |function (a_1 a_2 xdots a_n) b| & \rightarrow & |function a_1 (function (a_2 xdots a_n) b| \\
  |function () b| & \rightarrow & |functionKW (()) b| & \\
  |function (a (eff fx)) b| & \rightarrow & |function a (check fx b)| & \\
\\
\multicolumn{4}{l}{\textbf{Conditionals and for-loops}} \\
  |if{e}| & \rightarrow & |if(e) else false| \\
  |if(e_1) then e_2| & \rightarrow & |if(e_1) then e_2 else false| \\
  |if(e_1) else e_2| & \rightarrow & |if (x := e_1) then x else e_2| & \text{|x| fresh} \\
  |for{e}| & \rightarrow & |for (x := e) { x }| & \text{|x| fresh} \\
\end{array}
\end{array}
$$
\caption{Source Verse to Source Verse rewriting (1)} \label{fig:sv-to-sv-1}
\end{figure}

\begin{figure}
$$
\begin{array}{rcll}
  \multicolumn{1}{l}{\textbf{Operators}} \\
  |op_b e| & \rightarrow & |prefix op_b [e]| & \text{if |op_b| can fail}\\
  |op_b e| & \rightarrow & |prefix op_b (e)| \\
  |e op_a| & \rightarrow & |postfix op_a [e]| & \text{if |op_a| can fail}\\
  |e op_a| & \rightarrow & |postfix op_a (e)| \\
  |e_1 srcand e_2| & \rightarrow & |e_1; e_2| \\
  |e_1 srcor e_2| & \rightarrow & |if(e_1) else if (e_2) else :false| \\
  |!e| & \rightarrow & |if e then :false else false| \\
  |e_1 op_i e_2| & \rightarrow & |operator op_i [e_1, e_2]| & \text{if |op_i| can fail}\\
  |e_1 op_i e_2| & \rightarrow & |operator op_i (e_1, e_2)| \\
  \\
  \multicolumn{1}{l}{\textbf{Let, block, case}} \\
  |let(e) in b| & \rightarrow & |e; b| & \textit{see note} \\
  |block b| & \rightarrow & |b| & \textit{see note}  \\
  |case{e_1; dots e_n}| & \rightarrow & |(x:any) => case(x){e_1; dots e_n}| & \text{|x| fresh} \\
  |case(e){e_1; dots e_n}| & \rightarrow & |x:=e; e_1^[x] srcor dots srcor e_n^[x]| & \text{|x| fresh} \\
  \multicolumn{4}{l}{\lennart{This desugaring does not work for multivalued |e_i|.}} \\
  \\
  \multicolumn{1}{l}{\textbf{Misc}} \\
  |option^{}| & \rightarrow & |false| \\
  |option^{e}| & \rightarrow & |if(x:=e)then truth(x) else false| & \text{|x| fresh} \\
\end{array}
$$
{\em Note}: The desugaring assumes a scope correct Verse program.
This means that there can be no variable name clashes in |let| and |block|.
A more robust desugaring could \textalpha-convert such clashes.
\caption{Source Verse to Source Verse rewriting (2)} \label{fig:sv-to-sv-2}
\end{figure}


