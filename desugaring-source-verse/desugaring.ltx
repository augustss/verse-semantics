\rulename{msemi}   & |MMe m i (t_1 ; t_2)|    & = & |De t_1 ; MMe m i t_2| \\
\rulename{mchoice} & |MMe m i ((t_1 `choice` t_2))| & = & |(MMe m i t_1) `choice` (MMe m i t_2)| \\
\rulename{mif}     & |MMe m i (if(t_1) then t_2 else t_3)| & = &
    \multicolumn{2}{@@{}l}{|if (De t_1) then MMe m i t_2 else MMe m i t_3|} \\
\rulename{moftype} & |MMe m i ((oftype t_1 t_2))| & = & |oftype ((MMe m i t_1)) (De t_2)| \\
\rulename{mother}  & |MMe m i t|              & = & |i = (De t)| \\[0.02in]
                   & |oftype e t|             & = & |(voftype e t); (ioftype e t)| & \text{fresh |x|} \\
                   & |voftype e t|            & = & |verify (assert (t^[e]))|  \\
                   & |ioftype e t|            & = & |assume (forall x t^[x])| & \text{fresh |x|} \\
\end{array}$$

