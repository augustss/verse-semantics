      & \vb & |check fx t|      & \text{Effects check} \\
      & \vb & |array (t_1, dots, t_n)| & \text{Array}, n \geq 0 \\
      & \vb & |function a t|    & \text{Function} \\
      & \vb & |oftype a t|      & \text{Type annotation}
\\
\multicolumn{4}{l}{\text{\bf Blocks}} \\
  |b| & ::= & |t| \vb |{t_1; dots ; t_n}|  \\
\\
\multicolumn{4}{l}{\text{\bf Function arguments}} \\
  |a| & ::= & |(t)|  \vb |()| \vb |apeff a fx| \\
\\
\multicolumn{4}{l}{\text{{\bf Patterns: left hand side of a definition |(p := t)| or |(p:t)|}. Subset of |t|.}} \\
     |p| & ::= & x \vb |p a| %% \vb |p^hat|  \vb |p^?|
     \vb  |p_1 squiggt p_2| \\
