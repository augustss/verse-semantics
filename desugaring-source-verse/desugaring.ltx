\section{Desugaring Source Verse}

\Cref{fig:desugar-expr1} desugars Small Source Verse into Core Verse.


\begin{figure}
$$
\begin{array}{@@{}l}
\begin{array}{r@@{\;}c@@{\;}ll}
\multicolumn{4}{l}{\textbf{Desugaring expressions}} \\
  |De e| & = & |def x (Me x e)| \quad \quad |x| \not\in |e|\\
\multicolumn{4}{l}{\quad Optional (derived) rules} \\
|De k| & = & |k| \\
|De x| & = & |x| \\
|De (f^[x])| & = & |f^[x]| \\

\\
\multicolumn{4}{l}{\textbf{The heavy lifting:} $|Me i t| = |e|$} \\
\multicolumn{4}{l}{\quad \text{|i| is a variable, |t| is a Small Source Verse term,
and |e| is a BigCore expression}} \\
  |Me i k| & = & |i==k| \\
  |Me i x| & = & |i==x| \\
  |Me i (f^[x])| & = & |i==f^[x]| \\
  |Me i (x=t)| & = & |x = Me i t| \\
  |Me i (x:=t)| & = & |x := Me i t| \\
  |Me i ((y squiggt x):=t)| & = & |y := i; x := Me i t| \\
  |Me i (:t)| & = & |(De t)^(i)| & \\
  |Me i (t_1 ; t_2)| & = & |De t_1 ; Me i t_2| \\
  |Me i ((t_1 `choice` t_2))| & = & |(Me i t_1) `choice` (Me i t_2)| \\
  |Me i (check fx t)| & = & |check fx (Me i t)|  & \text{Is this right?}\\
  |Me i (array(t_1, xdots, t_n))| & = &
    \multicolumn{2}{l}{|def (x_1 xdots x_n)
      (Me x_1 t_1; xdots; Me x_n t_n;  i == arr (x_1, xdots, x_n))|} \\
  |Me i (if(e_1) then e_2 else e_3)| & = &
    \multicolumn{2}{l}{|if (De e_1) then Me i e_2 else Me i e_3|} \\
  |Me i (for(e_1){e_2}| & = & |i == for(De e_1){De e2}| \\
\end{array} \\
\\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
\multicolumn{4}{l}{\text{\bf Function translations}} \\    
%%  |Me i (function t_1 t_2)| & = & |i == (lam x (Me x t_1; De t_2))|) \\
%%  |Me i (function t_1 t_2)| & = & |lam x (z := Me x t_1; y := i^[z]; Me y t_2)| \\
|Me i (function t_1 (oftype t_2 t_3))| & = & |tlamt x (z := Me x t_1) (y := i^[z]; Me y t_2) (De t_3)| \\
|Me i (function t_1 t_2)| & = & |tlam x (z := Me x t_1) (y := i^[z]; Me y t_2)| \\
& \multicolumn{3}{l}{\text{Note: This does not work for actual function definitions.}} \\
& \multicolumn{3}{l}{\text{Perhaps these work?}} \\
|Me i (function t_1 (oftype t_2 t_3)| & = & |i == tlamt x (Me x t_1) (De t_2) (De t_3)| \\
|Me i (function t_1 t_2)| & = & |i == tlam x (Me x t_1) (De t_2)| \\
\end{array}
\end{array}
$$
\caption{Desugaring of expressions (1)} \label{fig:desugar-expr1}
\end{figure}


