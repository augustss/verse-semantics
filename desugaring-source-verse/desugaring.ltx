\multicolumn{4}{l}{\textbf{Desugaring expressions}} \\
&  |De e| & = & |def i (Me i e)| \quad \quad |i| \not\in |e|\\
\multicolumn{5}{l}{\quad \text{Optional (derived) rules}} \\
& |De k| & = & |k| \\
& |De x| & = & |x| \\
& |De (f^[x])| & = & |f^[x]| \\
& |De (e_1 == e_2)| & = & |De e_1 == De e_2| \\
& |De (x := e)| & = & |x := De e| \\
& |De (t_1 ; t_2)| & = & |De t_1 ; De t_2| \\
& |De (array(e_1; xdots; e_n))| & = & |array(De e_1 ; xdots; De e_n)| \\
& \text{and so on ...} \\

\\
\multicolumn{5}{l}{\textbf{The heavy lifting:} $|Me i t| = |e|$} \\
\multicolumn{5}{l}{\quad \text{|i| is a variable, |t| is a Small Source Verse term,
and |e| is a BigCore expression}} \\[1mm]
\rulename{mtype} &  |Me i (:t)| & = & |(De t)^(i)| & \\[2mm]
\rulename{mfun}  &  |Me i ((y squiggt x):=t)| & = & |x := Me i t; y := i| \\
\rulename{mbind} &  |Me i (x:=t)| & = & |x := Me i t| \\[2mm]
\rulename{meq} &  |Me i (t_1=t_2)| & = & |De t_1 = Me i t_2| \\
\rulename{msemi} &  |Me i (t_1 ; t_2)| & = & |De t_1 ; Me i t_2| \\
\rulename{mchoice} &  |Me i ((t_1 `choice` t_2))| & = & |(Me i t_1) `choice` (Me i t_2)| \\
\rulename{mif} &  |Me i (if(e_1) then e_2 else e_3)| & = &
    \multicolumn{2}{@@{}l}{|if (De e_1) then Me i e_2 else Me i e_3|} \\
\rulename{mtype} & |Me i ((oftype e_1 e_2))| & = & |oftype (Me i e_1) (De e_2)| \\
\rulename{mcheck} &  |Me i (check fx t)| & = & |check fx (Me i t)|  & \text{Is this right?}\\[2mm]

\rulename{mconst} &  |Me i k| & = & |i==k| \\
\rulename{mvar} &  |Me i x| & = & |i==x| \\
\rulename{mapply} &  |Me i (t_1^[t_2])| & = & |i==(De t_1)^[De t_2]| \\
\rulename{marray} &  |Me i (array(t_1, xdots, t_n))| & = &
\multicolumn{2}{@@{}l}{
  \begin{array}[t]{@@{}l}
    |def (x_1 xdots x_n) (Me x_1 t_1; xdots; Me x_n t_n;|\\
    |i == arr (x_1, xdots, x_n))|
   \end{array}} \\
\rulename{mfor} &  |Me i (for(e_1){e_2}| & = & |i == for(De e_1){De e_2}| \\
\end{array} \\
\\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
\multicolumn{4}{l}{\text{\bf Function translations}} \\    
