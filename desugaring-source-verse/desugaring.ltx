\rulename{exi-elim1} & |def x e| & \movesto & |e| & \text{if $|x| \notin \freevars{|e|}$}\\
\rulename{exi-elim2} & |def x (E^[x==v])| & \movesto & |E^[v]| & \text{if $|x| \notin \freevars{|E|}\cup \freevars{|v|}$}\\
\rulename{exi-float}^{\alpha} & |E^[def x e]| & \movesto & |def x E^[e]| & \text{if $x \notin \freevars{|E|} \cup \boundvars{|E|}$} \\
\rulename{seq-assoc} & |(e_1 ; e_2) ; e_3| & \movesto & |e_1; (e_2; e_3)| \\
\rulename{seq-float} & |v == (e_1 ; e_2)| & \movesto & |e_1; v == e_2| \\
\rulename{seq-elim} & |v ; e| & \movesto & |e| \\
\rulename{eq-float} & |v_1 == (v_2 == e)| & \movesto & |v_2 == e; v_1 == v_2| \\
\rulename{eq-swap} & |v == x| & \movesto & |x == v| & \text{May apply infinitely for |x==y|} \\

    \\[-0.6em]

\rulegroupname{Choice:}
\rulename{choice-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
% \rulename{fail} & |E^[fail]| & \movesto & |fail| \\
\rulename{choice-fail-l} & |fail choice e| & \movesto & |e| \\
\rulename{choice-fail-r} & |e choice fail| & \movesto & |e| \\
\rulename{choice} & |C^[e_1 choice e_2]| & \movesto & |C^[e_1] choice C^[e_2]| \\
\rulename{choice-fail} & |C^[fail]| & \movesto & |fail| \\

    \\[-0.6em]

\rulegroupname{One and All:}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice}  & |one (v choice e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)| \\

\end{array} \\
\\[-0.3em]
\text{\textit{Note}: In the rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.}
\end{array}$

