      & \vb & |e_1 ; e_2|       & \text{Sequencing} \\
      & \vb & |e_1^[e_2]|       & \text{Function application} \\
      & \vb & |x := e|          & \text{Definition} \\
      & \vb & |def x e|         & \text{Existential} \\
      & \vb & |e_1 `choice` e_2| & \text{Choice} \\
      & \vb & |e_1 = e_2|       & \text{Unification} \\
      & \vb & |if(e) then b_1 else b_2| & \text{Conditional expression} \\
      & \vb & |for(e) in b|     & \text{Finite loop} \\
