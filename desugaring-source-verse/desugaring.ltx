\section{Core Verse}

\Cref{fig:core-verse} gives the language into which we desugar.

\begin{figurebox}
$$
\begin{array}{rcll}
\multicolumn{4}{l}{\text{\bf Expressions}} \\
|e| & ::= & |x| \vb |k| \vb |e_1 ; e_2| \vb |e_1 e_2| \vb  |e_1 = e_2|
    \vb |e_1 `choice` e_2| \vb |def x e| \vb |lam x e| \\
      & \vb & |check r e|                 & \text{Effects check} \\
      & \vb & |if e_1 then e_2 else e_3| & \text{Conditional expression} \\
    & \vb & |for(e) in b|     & \text{Finite loop} \\
    \\
\multicolumn{4}{l}{\text{\bf Effects}} \\
|r| & ::= & |succeedsKW| \vb |decidesKW| \vb |iteratesKW|
\end{array}
$$
\caption{Core Verse expressions} \label{fig:core-verse}
\end{figurebox}

% ----------------------------------------------------------------
\section{Desugaring Source Verse}

\Cref{fig:desugar-expr1} desugars Source Verse into Core Verse.
\Cref{fig:desugar-expr2} rewrites Source Version into simpler Source Verse, ready for \Cref{fig:desugar-expr1}.

\begin{figurebox}
$$
\begin{array}{@@{}l}
\begin{array}{r@@{\;}c@@{\;}ll}
\multicolumn{4}{l}{\textbf{Desugaring expressions}} \\
  |De e| & = & |def x (Me x e)| \quad \quad |x| \not\in |e|\\
\\
\multicolumn{4}{l}{\textbf{The heavy lifting}} \\
  |Me i k| & = & |i=k| \\
  |Me i  x| & = & |i=x| \\
  |Me i (t_1:t_2)| & = & |Me (De t_2^(i)) t_1|  & \text{Is this right?}\\
  |Me i (:t)| & = & |(De t)(i)| & \text{Not sure here} \\
  |Me i (t_1 ; t_2)| & = & |De t_1 ; Me i t_2| \\
  |Me i (t_1 where t_2)| & = & |Me i t_1 ; De t_2| & \text{or the other way round?}\\
  |Me i ((t_1 `choice` t_2))| & = & |(Me i t_1) `choice` (Me i t_2)| \\
  |Me i (t_1 == t_2)| & = & |(Me i t_1) ; (Me i t_2)|  & \text{I think this is right}\\
  |Me i (t_1^[t_2])| & = & |i = ((De t_1) (De t_2))| \\
  |Me i (t_1^(t_2))| & = & |i = succeeds (((De t_1) (De t_2)))| \\
  |Me i (check r t)| & = & |check r (Me i t)|  & \text{Is this right?}\\
  |Me i (function t_1 t_2)| & = & |i = (lam x (Me x t_1); De t_2|) \\
  |Me i (array{t_1, dots, t_n})| & = &
    \multicolumn{2}{l}{|def (x_1 dots x_n) (i = arr (x_1, dots, x_n);
      Me x_1 t_1; dots; Me x_n t_n|} \\
    |Me i (if(e_1) then e_2 else e_3)| & = &
      \multicolumn{2}{l}{|if (De e_1) then Me i e_2 else Me i e_3|} \\
\end{array}
\end{array}
$$
\caption{Desugaring of expressions (1)} \label{fig:desugar-expr1}
\end{figurebox}

\begin{figurebox}
$$
\begin{array}{rcll}
\\
  |type^{t}| & \rightarrow & |function (y:t) y| \\
  |()| & \rightarrow & |array ()| \\
  |t_1, dots, t_n| & \rightarrow & |array (t_1, dots, t_n)| \\
  |e_1 eqgt e_2| & \rightarrow & |function e_1 () {e_2}| \\
  |function (a_1 a_2 dots a_n) b| & \rightarrow & |functionKW a_1 (functionKW a_2 dots a_n b)| \\
  |function () b| & \rightarrow & |functionKW (()) b)| & \\
  |function (a (eff r)) b| & \rightarrow & |function a (check r b)| & \\
  |if{e})| & \rightarrow & |if(e) else false| \\
  |if(e_1) then e_2| & \rightarrow & |if(e_1) then e_2 else false| \\
  |if(e_1) else e_2| & \rightarrow & |if (x := e_1) then x else e_2| & \text{|x| fresh} \\
  |for{e}| & \rightarrow & |for (x := e) in { x }| & \text{|x| fresh} \\
\\
  \multicolumn{1}{l}{\textbf{Operators}} \\
  |op_b e| & \rightarrow & |prefix op_b [e]| & \text{if |op_b| can fail}\\
  |op_b e| & \rightarrow & |prefix op_b (e)| \\
  |e op_a| & \rightarrow & |postfix op_a [e]| & \text{if |op_a| can fail}\\
  |e op_a| & \rightarrow & |postfix op_a (e)| \\
  |e_1 srcand e_2| & \rightarrow & |e_1; e_2| \\
  |e_1 srcor e_2| & \rightarrow & |if(e_1) else if (e_2) else :false| \\
  |!e| & \rightarrow & |if e then :false else false| \\
  |e_1 op_i e_2| & \rightarrow & |operator op_i [e_1, e_2]| & \text{if |op_i| can fail}\\
  |e_1 op_i e_2| & \rightarrow & |operator op_i (e_1, e_2)| \\
  \\
  \multicolumn{1}{l}{\textbf{Let, do, case}} \\
  |let(e) in b| & \rightarrow & |e; b| & \textit{see note} \\
  |do b| & \rightarrow & |b| & \textit{see note}  \\
  |case{e_1; dots e_n}| & \rightarrow & |(x:any) => case(x){e_1; dots e_n}| & \text{|x| fresh} \\
  |case(e){e_1; dots e_n}| & \rightarrow & |x:=e; e_1^[x] srcor dots srcor e_n^[x]| & \text{|x| fresh} \\
  \multicolumn{4}{l}{\lennart{This desugaring does not work for multivalued |e_i|.}} \\
  \\
  \multicolumn{1}{l}{\textbf{Misc}} \\
  |option^{})| & \rightarrow & |false| \\
  |option^{e}| & \rightarrow & |if(x:=e)then truth(x) else false| & \text{|x| fresh} \\
\end{array}
$$
{\em Note}: The desugaring assumes a scope correct Verse program.
This means that there can be no variable name clashes in |let| and |do|.
A more robust desugaring could \textalpha-convert such clashes.
\caption{Desugaring of expressions (2)} \label{fig:desugar-expr2}
\end{figurebox}


\begin{figurebox}

$$
  \begin{array}{rcll}
    |Cr|   & \multicolumn{3}{l}{ \text{ converts the limited Source Verse to Core.} } \\
    |Cr k| & = & |k| \\
    |Cr x| & = & |x| \\
    |Cr (array (e_1, dots, e_n))| & = &
    \begin{array}[t]{@@{}l}
    |defTwoLines (x_1,dots,x_n) (x_1=e_1; dots; x_n=e_n; arr (v_1, dots, v_n)| \\
    \end{array}
	& \text{|x_i| fresh} \\
    |Cr (e_1 ; e_2)| & = & |Cr e_1 ; Cr e_2| \\
    |Cr (e_1 = e_2)| & = & |Cr e_1 = Cr e_2| \\
    |Cr (x := :any)| & = & |x| \\
    |Cr (x := e)| & = & |x = Cr e| \\
    |Cr (e_1^[e_2])| & = & |def (x,y) (x = e_1; y = e_2; applyx (Cr e_1) (Cr e_2)| & \text{|x,y| fresh} \\
    |Cr (e_1^(e_2))| & = & |succeeds (Cr (e_1^[e_2]))| \\
    |Cr (e_1 `choice` e_2)| & = & |Bi e_1 `choice` Bi e_2| \\
    |Cr (if e_1 then e_2 else e_3)| & = &
    \begin{array}[t]{@@{}l}
    |defTwoLines x (x = one(Bi (e_1; Th e_2) `choice` Bi (Th e_3));applyx x ())|
    \end{array}
    & \text{|x| fresh} \\
    |Cr (for e_1 in e_2)| & = & |all(Bi(e_1 ; Th e_2))| \\
    |Cr (function(x:any)e)| & = & |x => Bi e| \\
%%    |Cr (type^{e})| & = & |x => Bi (x = e; x)| & \text{|x| fresh} \\
    \\
    |Th| & \multicolumn{3}{l}{ \text{creates a thunk, i.e., dummy function.} } \\
    |Th e| & = & |function(x:any)e| & \text{|x| fresh} \\
    \\
    |Bi| & \multicolumn{3}{l}{ \text{inserts |defKW| for all local bindings.} } \\
    |Bi e| & = & |def (Vr e) (Cr e)| \\
    \\
    |Vr| & \multicolumn{3}{l}{ \text{finds all locally defined variables.} } \\
    |Vr k| & = & |emp| \\
    |Vr x| & = & |emp| \\
    |Vr (array (e_1, dots, e_n))| & = & |Vr e_1, dots, Vr e_n| \\
    |Vr (e_1 ; e_2)| & = & |Vr e_1 , Vr e_2| \\
    |Vr (e_1 = e_2)| & = & |Vr e_1 , Vr e_2| \\
    |Vr (x := e)| & = & |x , Vr e| \\
    |Vr (e_1^[e_2])| & = & |Vr e_1 , Vr e_2| \\
    |Vr (e_1^(e_2))| & = & |Vr e_1 , Vr e_2| \\
    |Vr (e_1 `choice` e_2)| & = & |emp| \\
    |Vr (if e_1 then e_2 else e_3)| & = & |emp| \\
    |Vr (for e_1 in e_2)| & = & |emp| \\
    |Vr (function(x:any)e)| & = & |emp| \\
    |Vr (type^{e})| & = & |emp| \\
  \end{array}
  $$
\caption{Core conversion} \label{fig:core-conversion}
\end{figurebox}



\begin{figurebox}
$$
\begin{array}{rclll}
\multicolumn{5}{l}{\textbf{Desugar a definition |p := e| into simple definitions with just |x := e|}} \\
\ifdesugarops
  |Pd x e| & = & |x := e| \\
\fi
  |Pd (f a) e| & = & |Pd f ((De (function a () {e})))| \\
  |Pd (: t) e| & = & |Pd (x:t) e| & \text{|x| fresh} \\
  |Pd (p : t) e| & = & |Pd p ((De t^[e]))| \\
  |Pd (p ?) e| & = & |Pd p (De ((option^{e}))| \\
  |Pd (e_1^hat) e| & = & |assign^(De e_1,e)| \\
  |Pd (p_0, dots, p_n) e| & = &
    \multicolumn{2}{l}{|Pd p_0 x_0; dots; Pd p_n x_n; array (x_0:any,dots,x_n:any) = e|} & \text{|x_i| fresh} \\
  |Pd (p squiggt l) e| & = & |Ld (p squiggt l) (De (type^{e}))| \\
  \\
\multicolumn{5}{l}{\textbf{Desugar a type ascription |l : t|}} \\
  |Ld x t| & = & |def y x := t^[y]; y| & |y| \not\in |t| \;\;\;\; \text{``domain-oriented''}\\
  ~ & (or:) & |def y x := t^[y]| & |y| \not\in |t| \;\;\;\; \text{``range-oriented''} \\
  |Ld (l a) t| & = & |Ld l (arrow (function a () {t}))| \\
  |Ld (l^hat) t| & = & |Ld l ((new^(t)))| \\
  |Ld (l?) t| & = & |Ld l ((? t))| \\
  |Ld (l^arrayty) t| & = & |Ld l ((arrayty^t))| \\
  |Ld (p squiggt l) t| & = & |Pd p ((Ld l t))| \\
\end{array}
$$
\caption{Desugaring of expressions (3)} \label{fig:desugar-expr}
\end{figurebox}

\begin{figurebox}
\begin{code}
any    = (x => x)
int    = (x => applyx isInt x; x)
nat    = (x => applyx isInt x; x > (-1); x)
false  = array()
arrow  = (ft => f => y => applyx (applyx ft y) (applyx f y))
\end{code}

\caption{Core prelude} \label{fig:core-prelude}
\end{figurebox}




