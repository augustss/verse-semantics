%%  |Me i (function t_1 t_2)| & = & |lam x (z := Me x t_1; y := i^[z]; Me y t_2)| \\
|Me i (functionP t_1 t_2)| & = & |tlam x (z := Me x t_1) (y := i^[z]; Me y t_2)| \\
& \multicolumn{3}{l}{\text{Note: This does not work for actual function definitions.}} \\
& \multicolumn{3}{l}{\text{Perhaps this works?}} \\
|Me i (functionP t_1 t_2)| & = & |i == tlam x (Me x t_1) (De t_2)| \\
\end{array}
\end{array}
$$
