\Facts{|e_1 choice e_2|} & \doteq & \Facts{e_1} \cap \Facts{e_2}             \\
\Facts{|def x e|}   & \doteq & \Facts{|subst e x x'|} \quad \text{where}\ $|x'|$\ \text{is fresh} \\
\Facts{|e|}         & \doteq & \emptyset \\
