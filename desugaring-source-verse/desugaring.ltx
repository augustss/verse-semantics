\begin{figure}
$$
\begin{array}{rcll}
  |x,y,f| &     & \textit{Variable} \\
  |k| &     & \textit{Integer constant} \\
      \\

\multicolumn{4}{l}{\text{\bf Small Source Verse terms}} \\
