\end{figure}

\subsection{Effect analysis} \label{sec:effect-anal}

\begin{figure}
$$
\begin{array}{l}
\multicolumn{1}{c}{\large \fbox{
$|effects G e| = |fx|$
}} \\
\\
\begin{array}{rcll}
  |effects G_1 (scope xs G_2 e)| & = & |effects ((G_1,G_2)) e| \\
  |effects G (e_1 ; e_2)| & = & |andeffects (effects G e_1) (effects G e_2)| \\
  |effects G (x=v)| & = & S & \text{if $|equals S x v| \in |G|$} \\
  |effects G (x=k)| & = & |fails| & \text{if $|equals resolves x k'| \in |G|$ and $k \not= k'$}
\end{array} \\
\\
\multicolumn{1}{c}{\large \fbox{
$|andeffects fx_1 fx_2| = |fx|$
}} \\
\\
\begin{array}{lrcl}
\multicolumn{4}{c}{\text{All equations also apply with arguments swapped, and apply top-to-bottom}} \\
(E1) & |andeffects contradicts fx| & = & |contradicts| \\
(E2) & |andeffects fails fx|       & = & |fails| \\
(E3) & |andeffects succeeds fx|     & = & |fx| \\
(E4) & |andeffects abstracts fx|  & = & |abstracts| \\
(E5) & |andeffects iterates fx|   & = & |iterates| \\
(E6) & |andeffects resolves iterates| & = & |abstracts| \\
(E7) & |andeffects resolves fx|  & = & |resolves| \\
(E8) & |andeffects decides fx|   & = &  |decides|
\end{array}
\end{array}
$$
\caption{Effect analysis} \label{fig:effect-analysis}
\end{figure}
