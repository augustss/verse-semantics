\section{Block Rules}
This is an alternative runtime semantics.
In contrast to the other versions this uniquely identifies the next redex, so it is deterministic.

\begin{figure}[t]
  $$
\begin{array}{l}
\mbox{\em Syntax} \\
  \begin{array}{lrcl@@{}}
      \text{Integers} & k \\
      \text{Variables} & \multicolumn{2}{l}{x,y,z,f,g} \\
      \text{Set of variables} & \multicolumn{2}{l}{|xs,ys|} \\
      \text{Programs} & |p|  & ::=  & |beff ({diverges,reads,writes,allocs,interacts}) b| \quad \text{where} \; \freevars{b} = \{ \} \\
      \text{Blocks} & |b| & ::= & |fail| \vb |b_1 choice b_2| \vb |def xs (beq ; v)| \\
      \text{Equations} & |beq| & ::= & |lv == e ; beq| \vb |beff fxs beq ; beq| \vb \epsilon \\
      \text{Expressions} & |e| & ::= & |v| \vb |b| \vb |apply1N v_1 v_2| \vb |one b| \vb |all b| \\
      \text{Lvalues} & |lv| & ::= & |_| \vb |v| \\
      \text{Values} & |v| & ::= & |x| \vb |x_fx|  \vb \hnf \\
      \text{Head values} & \hnf & ::= & |k| \vb |op_fx| \vb |arr (v_1, xdots, v_n)| \vb |lam x b| \\
      \text{Prim operators} & |op|  & ::= & |add| \vb |sub| \vb |gt| \vb |isInt| \vb |read| \vb |write| \vb |print| \vb \ldots \\
      \text{Effects} & |fx| & ::= & |fails| \vb |chooses| \vb |diverges| \vb |reads| \vb |writes| \vb |allocs| \\
                     &      & \vb & |interacts| \vb |xdots|  \\
      \text{Set of effects} & |fxs| \\
  \end{array}
\\ \\
\mbox{\em Effects} \\
  \begin{array}{rcl}
    |beffects fail| & = & \{ |fails| \} \\
    |beffects (b_1 choice b_2)| & = & |beffects b_1| |`cup`| |beffects b_2| |`cup`| \{|chooses|\} \\
    |beffects (def xs beq)| & = & |beffects beq| \\
    |beffects v| & = & |emptyset| \\
    |beffects (apply1N v_1 v_2)| & = & |beffectsfun v_1| \\
    |beffects (one b)| & = & |beffects b| \setminus \{|fails,chooses|\} \\
    |beffects (all b)| & = & |beffects b| \setminus \{|fails,chooses|\} \\
    |beffects (lv == e ; beq)| & = & |beffects e| |`cup`| |beffects beq| \\
    |beffects (beff fxs beq_1 ; beq_2|) & = & |fxs `cup`| |beffects beq_2| \\
    \\
    |beffectsfun x| & = & \{|fails|,|diverges|,|xdots|\} \hspace{8em} \text{all effects} \\
    |beffectsfun x_fx| & = & |fxs| \\
    |beffectsfun k| & = & |emptyset| \\
    |beffectsfun op_fx| & = & |fxs| \\
    |beffectsfun (arr (v_1, xdots, v_n))| & = & |emptyset| \\
    |beffectsfun (lam x b)| & = & |beffects b| \\
  \end{array}
\\ \\
\end{array}
