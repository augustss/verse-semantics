\subsection{Rules}\label{sec:rules}

\begin{figure}[t]
$\begin{array}{@@{}l}
\begin{minipage}{12cm}
  \begin{itemize}
  \item |assume e| means that we can assume |e| neither gets stuck nor goes wrong.
  \item |verify e| checks that |e| neither gets stuck nor goes wrong.
\end{itemize}
\end{minipage} \\[3mm]

\begin{array}{@@{\hskip0.5em} l @@{} r @@{\;}c@@{\;} l l@@{}}


\multicolumn{5}{l}{\textit{Normalisation of |forallKW|:}} \\
\rulename{nu-elim} & |forall r e| & \movesto & |e| & \text{if $|r| \notin \freevars{e}$}\\
\rulename{nu-float}^{\alpha} & |E^[forall r e]| & \movesto & |forall r E^[e]| & \text{if $r \notin \freevars{|E|} \cup \boundvars{|E|}$} \\
\rulename{exi-nu} & |assume (def x e)|
  & \movesto & |forall r (assume (subst e x r))|
& |r| \not\in \freevars{|e|}
% \rulename{promote} & |r == v| & \movesto
%     & |forall s (x==s; r==v)| & |x| \in \freevars{v}, |s| \not\in \freevars{|v|} \\
\\[2mm]

\multicolumn{5}{l}{\textit{Assumptions:}} \\
\rulename{asm-seq} & |assume (eq_1 `eqsemi` eq_2)| & \movesto & |assume eq_1 `eqsemi` assume eq_2| \\

\\[-0.6em]

\multicolumn{5}{l}{\textit{Guard:}} \\
\rulename{guard-elim} & |v guard e| & \movesto & |e| \\
\rulename{guard-fail} & |fail guard e| & \movesto & |fail| \\
\rulename{guard-float} & |(assume eq_1 `eqsemi` eq_2) guard e_3| & \movesto &  |assume eq_1; (eq_2 guard e_3)| \\

\\[-0.6em]

\multicolumn{5}{l}{\textit{Check:}} \\
  \rulename{check-elim}   & |check fx e|  & \movesto & |e| & \text{if}\ \must{\mathit{fx}}{e} \\
  \rulename{rcheck-elim}   & |rcheck fx v|  & \movesto & |v|  & |fx| \in \{|succeeds|,|decides| \} \\
  \rulename{rcheck-elim}   & |rcheck decides fail|  & \movesto & |fail| \\
\\[-0.6em]

\multicolumn{5}{l}{\textit{Verify:}} \\
  \rulename{verify-elim} & |verify e|      & \movesto &
    |ok| & \text{if no |checkKW| in |e|} \\
  \rulename{verify-one}   & \multicolumn{3}{l}{|verify (V^[one ((r==v ; e_1) `choice` e_2)])|} & \text{if}\ \mustDecide{eq} \\
    & & \movesto &
         \multicolumn{2}{l}{\begin{array}[t]{l}
              |verify (V^[assume (r==v); one (e_1 `choice` e_2)]) eqsemiKW| \\
              |verify (V^[one e_2])| \\
         \end{array}} \\
\\
\multicolumn{5}{l}{\textit{Substitution:}} \\
\rulename{subst-asm} & |S^[assume (x==v)]| & \movesto & |subst S x v ^[assume (x==v)]|
  & \text{if $|v|\ne|V^[x]|$} \\
\rulename{subst-asm-rev} & |S^[assume (x==apply1N f v)]| & \movesto
   & |subst S (apply1N f v) x ^[assume (x==apply1N f v)]| \\
\end{array}\\
\end{array}$
\\[0.1in]
\caption{SPJ: TRS Verifier Rewrite Rules}
\label{fig:spj-verifier-rewrite-rules}
\end{figure}


\begin{figure}
  $\begin{array}{@@{}l}
    \begin{array}{lcll}
%  \must{|fails|}{|fail|}      & \doteq & true \\[1mm]
%   \must{|fx|}{|x|}               & \doteq & \mathit{true} \\
%   \must{|fx|}{|r|}               & \doteq & \mathit{true}  \\[1mm]
%   \must{|fx|}{k}                 & \doteq & \mathit{true}  \\
%   \must{|fx|}{|arr (v_1, xdots, v_n) |} & \doteq & \must{|fx|}{|v_1|} \wedge \dots \wedge \must{|fx|}{|v_n|} \\
%   \must{|fx|}{|lam r e|}         & \doteq & \mathit{true} \\
   \must{|fx|}{|v|}               & \doteq & \mathit{true} \\
   \must{|fx|}{|def x e|}         & \doteq & \mathit{false} \\
   \must{|fx|}{|forall r e|}         & \doteq & \must{|fx|}{e} \\
   \must{|fx|}{|eq_1; e_2|}        & \doteq & \must{|fx|}{|eq_1|} \wedge \must{|fx|}{|e_2|} \\[1mm]
   \must{|fx_1|}{|havoc fx_2|}        & \doteq & |fx_2| \subseteq |fx_1| \\[1mm]

   \must{|iterates|}{|one e|}           & \doteq & \mathit{true} \\
   \must{|succeeds|}{|one e|}           & \doteq & \must{|nofail|}{e} \\
   \must{|decides|}{|one e|}           & \doteq & \mathit{true} \\
   \must{|nofail|}{|one e|}           & \doteq & \must{|nofail|}{e} \\
   \must{|fx|}{|all e|}           & \doteq & \mathit{true} \\[1mm]
   \must{|iterates|}{|e_1 choice e_2|} & \doteq & \must{|iterates|}{e_1} \wedge \must{|iterates|}{e_2} \\
   \mustSucceed{|e_1 choice e_2|}  & \doteq & \mathit{false} \\
   \mustDecide{|e_1 choice e_2|}  & \doteq & \mathit{false} \\
   \must{|nofail|}{|e_1 choice e_2|}  & \doteq & \must{|iterates|}{e_1} \wedge\\
    && (\must{|nofail|}{e_1} \vee   \must{|nofail|}{e_2}) \\[1mm]

   \must{|fx|}{|apply1N op v|} & \doteq & \mustop{|fx|}{op} \\
   \must{|fx|}{|apply1N v_1 v_2|} & \doteq & \mathit{false} & \text{|v_1| is not |op|} \\

   \must{|fx|}{|eq_1 guard e_2|}     & \doteq & \mathit{false} & \text{Check!} \\[1mm]

   \must{|fx|}{|assume e|}        & \doteq & \mathit{true} \\[1mm]

   \must{|iterates|}{|v = e|}       & \doteq & \must{|iterates|}{e} \\
   \mustSucceed{|v = e|}       & \doteq & \mathit{false} \\
   \mustDecide{|v = e|}       & \doteq & \mustDecide{e} \\
   \must{|nofail|}{|v = e|}       & \doteq & \mathit{false} \\[1mm]

   \must{|fx_1|}{|check fx_2 e|} & \doteq & \multicolumn{2}{l}{\mathit{false} \hspace{5mm} \text{Conservative; checks aren't nested}}\\

  \\
  \mustop{|fx|}{|add|} & \doteq & \mathit{true} \\[1mm]
  \mustop{|succeeds|}{|isInt|} & \doteq & \mathit{false} \\
  \mustop{|decides|}{|isInt|} & \doteq & \mathit{true} \\
  \mustop{|nofail|}{|isInt|} & \doteq & \mathit{false} \\[1mm]
  \mustop{|succeeds|}{|isInt|} & \doteq & \mathit{false} \\
  \mustop{|decides|}{|isInt|} & \doteq & \mathit{true} \\
  \mustop{|nofail|}{|isInt|} & \doteq & \mathit{false} \\
%  \sucdec{|fx|} & \doteq & |fx| \in \{|succeeds|,|decides|, |nofail|\} \\
\end{array} \\
    \\
\text{Notes:}\\
\begin{array}{l}
 \text{Rules for choice are sound but not clever: |lam x (check succeeds (x==1 `choice` x==2))|} \\
 \text{Primitive |add| always succeeds, returning a number, even if given (say) string arguments} \\
\end{array}
\end{array}$
