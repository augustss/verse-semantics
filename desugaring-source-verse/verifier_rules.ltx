\begin{figure}
$\begin{array}{lcll}
  \must{|fails|}{|fail|}      & \doteq & true \\
  \\
   \must{|fx|}{n}                 & \doteq & \mathit{true}  & \sucdec{|fx|} \\
   \must{|fx|}{|arr (v_1, xdots, v_n) |} & \doteq & \must{|fx|}{|v_1|} \wedge \dots \\
   && \wedge \must{|fx|}{|v_n|} & \sucdec{|fx|} \\
   \must{|fx|}{|x|}               & \doteq & \mathit{false} & \sucdec{|fx|} \\
   \must{|fx|}{|r|}               & \doteq & \mathit{true} & \sucdec{|fx|} \\
   \must{|fx|}{|lam r e|}         & \doteq & \mathit{true} & \sucdec{|fx|} \\
   \must{|fx|}{|def x e|}         & \doteq & \must{|fx|}{e} \\
   \must{|fx|}{|forall r e|}         & \doteq & \must{|fx|}{e} \\
   \must{|fx|}{|assume e|}        & \doteq & \mathit{true} & \sucdec{|fx|} \\
   \must{|fx|}{|one e|}           & \doteq & \must{|fx|}{e} & \sucdec{|fx|} \\
   \must{|fx|}{|all e|}           & \doteq & \must{|fx|}{e} & \sucdec{|fx|} \\
   \must{|fx|}{|e_1; e_2|}        & \doteq & \must{|fx|}{e_1} \wedge \must{|fx|}{e_2} & \sucdec{|fx|} \\
   \mustSucceed{|e_1 choice e_2|}  & \doteq & \mustSucceed{e_1} \vee   \mustSucceed{e_2} \\
   \mustDecide{|e_1 choice e_2|}  & \doteq & \mustDecide{e_1} \wedge   \mustDecide{e_2} \\
   \mustSucceed{|e_1 = e_2|}       & \doteq & \mathit{false} \\
   \mustDecide{|e_1 = e_2|}       & \doteq & \mustDecide{e_1} \wedge \mustDecide{e_2} \\
   \mustSucceed{|apply1N op e|}     & \doteq & \mathit{false} \\
   \mustDecide{|apply1N op e|}     & \doteq & \mustDecide{e} \\
   \must{|fx|}{|e|}               & \doteq & \mathit{false} & \sucdec{|fx|}\\
  \\
  \sucdec{|fx|} & \doteq & |fx| = \{|succeeds|,|decides|\} \\
\end{array}$
\caption{Definitions of the $\mustKW$ predicates used in \cref{fig:verifier-rewrite-rules}.}
\end{figure}

