\begin{figure}
$\begin{array}{lcl}
  \toprule
  % \impl{e_1}{e_2} & \doteq & \ensuremath{\UnAssume{e_1} = \UnAssume{e_2}} \vee (e_1 \equiv |isInt x| \wedge e_2 \equiv |x = x|) \\
  % \midrule
  \mustSucceedKW & :: & (P, e) \rightarrow \{ \mathit{true}, \mathit{false} \} \\
  \midrule
   \mustSucceed{P}{n}                 & \doteq & \mathit{true} \\
   \mustSucceed{P}{|arr (v_1, xdots, v_n) |} & \doteq & \mustSucceed{P}{|v_1|} \wedge \dots \wedge \mustSucceed{P}{|v_n|} \\
   \mustSucceed{P}{|x|}               & \doteq & x \in \lamvars{P} \\
   \mustSucceed{P}{|lam x e|}         & \doteq & \mathit{true} \\
   \mustSucceed{P}{|assume e|}        & \doteq & \mathit{true} \\
   \mustSucceed{P}{|one e|}           & \doteq & \mustSucceed{P}{e} \\
   \mustSucceed{P}{|all e|}           & \doteq & \mustSucceed{P}{e} \\
   \mustSucceed{P}{|e_1; e_2|}        & \doteq & \mustSucceed{P}{e_1} \wedge \mustSucceed{P}{e_2} \\
   \mustSucceed{P}{|e_1 choice e_2|}  & \doteq & \mustSucceed{P}{e_1} \vee   \mustSucceed{P}{e_2} \\
   \mustSucceed{P}{|def x e|}         & \doteq & \mustSucceed{P}{e} \\
   \mustSucceed{P}{|e|}               & \doteq & \mathit{false} \\
   \bottomrule
\end{array}$
\caption{Definition of the $\mustSucceedKW$ predicate used in \cref{fig:verifier-rewrite-rules}.}
\end{figure}

\begin{figure}
$\begin{array}{lcl}
  \toprule
  \mustDecideKW & :: & (P, e) \rightarrow \{ \mathit{true}, \mathit{false} \} \\
  \midrule
  \mustDecide{P}{n}                 & \doteq & \mathit{true} \\
  \mustDecide{P}{|arr (v_1, xdots, v_n) |} & \doteq & \mustDecide{P}{|v_1|} \wedge \dots \wedge \mustDecide{P}{|v_n|} \\
  \mustDecide{P}{x}                 & \doteq & x \in \lamvars{P} \\
  \mustDecide{P}{|lam x e|}         & \doteq & \mathit{true} \\
  \mustDecide{P}{|assume e|}        & \doteq & \mathit{true} \\
  \mustDecide{P}{|one e|}           & \doteq & \mustDecide{P}{e} \\
  \mustDecide{P}{|all e|}           & \doteq & \mustDecide{P}{e} \\
  \mustDecide{P}{|e_1; e_2|}        & \doteq & \mustDecide{P}{e_1} \wedge \mustDecide{P}{e_2} \\
  \mustDecide{P}{|e_1 choice e_2|}  & \doteq & \mustDecide{P}{e_1} \wedge \mustDecide{P}{e_2} \\
  \mustDecide{P}{|op|}              & \doteq & \mathit{true} \\
  \mustDecide{P}{|e_1 = e_2|}       & \doteq & \mustDecide{P}{e_1} \wedge \mustDecide{P}{e_2} \\
 \mustDecide{P}{|apply1N op e|}     & \doteq & \mustDecide{P}{e} \\
  \mustDecide{P}{|e|}               & \doteq & \mathit{false} \\
  \bottomrule
\end{array}$
\caption{Definitions of the $\mustDecideKW$ predicates used in \cref{fig:verifier-rewrite-rules}.}
\end{figure}

