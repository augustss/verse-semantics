\subsection{Rules}\label{sec:rules}

\begin{figure}[t]
$\begin{array}{@@{}l}
\begin{minipage}{12cm}
  \begin{itemize}
  \item |assume e| means that we can assume |e| neither gets stuck nor goes wrong.
  \item |verify e| checks that |e| neither gets stuck nor goes wrong.
\end{itemize}
\end{minipage} \\[3mm]

\begin{array}{@@{\hskip0.5em} l @@{} r @@{\;}c@@{\;} l l@@{}}

\rulename{nu-float}^{\alpha} & |E^[forall x e]| & \movesto & |forall x E^[e]| & \text{if $x \notin \freevars{|E|} \cup \boundvars{|E|}$} \\[2mm]

\multicolumn{5}{l}{\textit{Guard:}} \\
\rulename{guard-elim} & |v guard e| & \movesto & |e| \\
\rulename{guard-fail} & |fail guard e| & \movesto & |fail| \\
\rulename{guard-float} & |(assume e ; e_1) guard e_2| & \movesto &  |assume e; (e_1 guard e_2)| \\

\\[-0.6em]

\multicolumn{5}{l}{\textit{Check:}} \\
  \rulename{check-elim}   & |check fx e|  & \movesto & |e| & \text{if}\ \must{\mathit{fx}}{e} \\
\\[-0.6em]

\multicolumn{5}{l}{\textit{Verify:}} \\
  \rulename{verify-elim} & |verify e|      & \movesto & |tup ()| & \text{if no |checkKW| outside |verifyKW| in |e|} \\
  \rulename{verify-if}   & |verify (E^[myite e_1 e_2 e_3])| & \movesto & |verify (E^[assume e_1; e_2]);| & \text{if}\ \mustDecide{e_1} \\
                         &                                  &          & |verify (E^[check fails e_1; e_3])|              & \\
  \\[-0.6em]

\multicolumn{5}{l}{\textit{Implies:}} \\
\rulename{substr} & |S^[x==apply1N f v]| & \movesto & |subst S (apply1N f v) x ^[x==apply1N f v]|
  & \text{if only skolems free in |v|} \\
\end{array}\\
\end{array}$
\\[0.1in]
\caption{SPJ: TRS Verifier Rewrite Rules}
\label{fig:spj-verifier-rewrite-rules}
\end{figure}


