#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { parseProgram, parseExpression, prettyPrintColored } = require('./dist/index.js');

// Parse command line arguments
function parseArgs() {
    const args = process.argv.slice(2);
    const options = {
        file: null,
        prettyPrint: false,
        format: false,
        help: false
    };

    for (let i = 0; i < args.length; i++) {
        const arg = args[i];
        if (arg === '-p' || arg === '--pretty') {
            options.prettyPrint = true;
        } else if (arg === '-f' || arg === '--format') {
            options.format = true;
        } else if (arg === '-h' || arg === '--help') {
            options.help = true;
        } else if (!arg.startsWith('-')) {
            options.file = arg;
        } else {
            console.error(`Unknown option: ${arg}`);
            printHelp();
            process.exit(1);
        }
    }

    return options;
}

// Print help message
function printHelp() {
    console.log(`verse - Verse language parser and formatter

Usage:
    verse [options] <file>

Options:
    -p, --pretty    Pretty print the file with syntax highlighting
    -f, --format    Format the file (not implemented yet)
    -h, --help      Show this help message

Examples:
    verse myfile.verse           # Parse the file and report any errors
    verse -p myfile.verse        # Pretty print with syntax highlighting
    verse -f myfile.verse        # Format the file (coming soon)

Description:
    By default, parses the Verse file and reports any syntax errors.
    With -p, displays the file with syntax highlighting.
    The -f option will format the file according to Verse style guidelines (not yet implemented).
`);
}

// Read file content
function readFile(filePath) {
    try {
        if (!fs.existsSync(filePath)) {
            console.error(`Error: File not found: ${filePath}`);
            process.exit(1);
        }
        return fs.readFileSync(filePath, 'utf8');
    } catch (error) {
        console.error(`Error reading file: ${error.message}`);
        process.exit(1);
    }
}

// Parse the file
function parseFile(content, fileName) {
    try {
        // Try parsing as a complete program first
        const ast = parseProgram(content);
        console.log(`✅ Successfully parsed: ${fileName}`);
        console.log(`   AST nodes: ${countNodes(ast)}`);
        return ast;
    } catch (error) {
        // If program parsing fails, try as expression
        try {
            const ast = parseExpression(content);
            console.log(`✅ Successfully parsed as expression: ${fileName}`);
            console.log(`   AST nodes: ${countNodes(ast)}`);
            return ast;
        } catch (exprError) {
            console.error(`❌ Parse error in ${fileName}:`);
            console.error(`   ${error.message || error}`);
            if (error.position) {
                const lines = content.split('\n');
                const line = error.position.line || 1;
                const column = error.position.column || 1;
                if (lines[line - 1]) {
                    console.error(`   Line ${line}: ${lines[line - 1]}`);
                    console.error(`   ${' '.repeat(column + 10)}^`);
                }
            }
            process.exit(1);
        }
    }
}

// Count AST nodes recursively
function countNodes(ast) {
    if (!ast) return 0;
    let count = 1;

    for (const key in ast) {
        if (key === 'offset' || key === 'length') continue;
        const value = ast[key];
        if (typeof value === 'object' && value !== null) {
            if (Array.isArray(value)) {
                value.forEach(item => {
                    count += countNodes(item);
                });
            } else {
                count += countNodes(value);
            }
        }
    }

    return count;
}

// Pretty print the file
function prettyPrint(content, fileName) {
    try {
        const colored = prettyPrintColored(content);
        console.log(colored);
    } catch (error) {
        console.error(`Error pretty printing ${fileName}: ${error.message}`);
        process.exit(1);
    }
}

// Format the file (placeholder)
function formatFile(content, fileName) {
    console.error('Error: The -f (format) option is not implemented yet.');
    console.error('This feature is coming soon!');
    process.exit(1);
}

// Main function
function main() {
    const options = parseArgs();

    if (options.help) {
        printHelp();
        process.exit(0);
    }

    if (!options.file) {
        console.error('Error: No file specified');
        printHelp();
        process.exit(1);
    }

    const filePath = path.resolve(options.file);
    const fileName = path.basename(filePath);
    const content = readFile(filePath);

    if (options.prettyPrint) {
        prettyPrint(content, fileName);
    } else if (options.format) {
        formatFile(content, fileName);
    } else {
        // Default: parse the file
        parseFile(content, fileName);
    }
}

// Run the script
main();