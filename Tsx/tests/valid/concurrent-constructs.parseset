# Concurrent Programming Constructs Test Suite
# Tests for spawn, race, sync, and branch expressions

#! Valid expression
# 1. Basic spawn with braces
spawn{DoWork()}

#! Valid expression
# 2. Spawn with complex expression
spawn{Player.Teleport(Location)}

#! Valid expression
# 3. Spawn with compound expression (single expression only for now)
spawn{DoWork()}

#! Valid expression
# 4. Spawn with indented form
spawn:
    Task1()
    Task2()
    Task3()

#! Valid expression
# 5. Nested spawn
spawn{spawn{InnerTask()}}

#! Valid Program
# 6. Spawn in function
TestSpawn():void=
    spawn{BackgroundWork()}
    Print("Main thread continues")

#! Valid Program
# 7. Multiple spawns in sequence
RunTasks():void=
    spawn{TaskA()}
    spawn{TaskB()}
    spawn{TaskC()}

#! Valid expression
# 8. Basic race with two branches
race:
    FastPath()
    SlowPath()

#! Valid expression
# 9. Race with multiple branches
race:
    Option1()
    Option2()
    Option3()
    TimeoutHandler()

#! Valid expression
# 10. Race with complex expressions
race:
    Player.WaitForInput()
    Sleep(5.0)
    Enemy.Attack()

#! Valid Program
# 11. Race with assignment
GetFirstResult():int=
    Result := race:
        ComputeFast()
        ComputeSlow()
        DefaultValue()

#! Valid Program
# 12. Nested race
TestNestedRace():void=
    race:
        spawn{LongTask()}
        race:
            QuickOption1()
            QuickOption2()

#! Valid expression
# 13. Basic sync
sync:
    UpdateA()
    UpdateB()

#! Valid expression
# 14. Sync with multiple operations
sync:
    Database.Write(Data1)
    Database.Write(Data2)
    Database.Write(Data3)
    Database.Commit()

#! Valid expression
# 15. Sync with complex expressions
sync:
    Player.Health := 100
    Player.Shield := 50
    Player.Status := "Ready"

#! Valid Program
# 16. Sync in transaction
PerformTransaction():void=
    sync:
        Account1.Debit(Amount)
        Account2.Credit(Amount)
        Log.Record(Transaction)

#! Valid expression
# 17. Basic branch
branch:
    Path1()
    Path2()

#! Valid expression
# 18. Branch with indented form (braces with comma not yet supported)
branch:
    PathA()
    PathB()
    PathC()

#! Valid expression
# 19. Branch with indented form
branch:
    ProcessRoute1()
    ProcessRoute2()
    ProcessRoute3()

#! Valid Program
# 20. Branch in game logic
HandlePlayerChoice():void=
    branch:
        GoLeft()
        GoRight()
        StayPut()

#! Valid Program
# 21. Combined concurrent constructs
ComplexAsync():void=
    spawn:
        race:
            FastCompute()
            SlowCompute()
    sync:
        UpdateUI()
        SaveState()

#! Valid Program
# 22. Spawn with lambda
TestLambdaSpawn():void=
    spawn{(X:int):int => X * 2}

#! Valid Program
# 23. Race with case expression
ProcessChoice():void=
    race:
        case(Input):
            1 => Action1()
            2 => Action2()
            _ => DefaultAction()
        Timeout()

#! Valid Program
# 24. Sync with for loop
BatchUpdate():void=
    sync:
        for(Item : Items):
            Item.Update()

#! Valid Program
# 25. Branch with if expression
ConditionalBranch(X:int):void=
    branch:
        if(X > 0):
            PositivePath()
        else:
            NegativePath()

#! Valid Program
# 26. Real-world spawn pattern from Fortnite
AudioController<public> := class:
    PlayQueuedVO<private>()<suspends>:void=
        loop:
            Sleep(0.5)
            spawn{AddPlayerToValidAudioTargets(MyAgent)}

#! Valid Program
# 27. Real-world race pattern
WaitForPlayerAction():void=
    WinnerResult := race:
        Button.InteractedWithEvent.Await()
        Sleep(30.0)

#! Valid Program
# 28. Complex spawn with object construction
SpawnWithObject():void=
    spawn:
        NewPlayer := player{Name := "Test", Score := 0}
        NewPlayer.Initialize()

#! Valid Program
# 29. Sync with set operations
SyncSet():void=
    sync:
        set Value1 = 10
        set Value2 = 20
        set Value3 = Value1 + Value2

#! Valid Program
# 30. Branch with array operations
BranchArray():void=
    branch:
        array{1, 2, 3}
        array{4, 5, 6}

#! Valid expression
# 31. Spawn as expression value
GetSpawnResult():spawn_type = spawn{DoWork()}

#! Valid expression
# 32. Race as expression value
FirstToComplete:result_type = race:
    SlowComputation()
    FastComputation()

#! Valid expression
# 33. Sync as expression value
TransactionResult:bool = sync:
    UpdateDatabase()
    true

#! Valid expression
# 34. Branch as expression value
SelectedPath:path_type = branch:
    PathA()
    PathB()

#! Valid Program
# 35. Spawn with return
SpawnReturn():int=
    spawn:
        return 42

#! Valid Program
# 36. Race with break in loop
LoopWithRace():void=
    loop:
        race:
            ProcessItem()
            break

#! Valid Program
# 37. Sync with continue
SyncContinue():void=
    for(X : Items):
        sync:
            if(X.Invalid[]):
                continue
            X.Process()

#! Valid Program
# 38. Multiple spawn in class
game_manager := class(creative_device):
    OnBegin<override>()<suspends>:void=
        spawn{PlayerLoop()}
        spawn{EnemyLoop()}
        spawn{TimerLoop()}

#! Valid Program
# 39. Race with member access
TestMemberRace(P:player):void=
    race:
        P.Health.Changed.Await()
        P.Shield.Changed.Await()

#! Valid Program
# 40. Sync with specifiers
TransactionalUpdate<transacts>():void=
    sync:
        Database.BeginTransaction()
        Database.Update(Data)
        Database.Commit()

#! Valid Program
# 41. Branch with decorators
@editable
BranchingLogic<public>():void=
    branch:
        MainPath()
        AlternatePath()

#! Valid Program
# 42. Spawn in data structure
spawner_config := struct:
    SpawnAction:spawn_type = spawn{DefaultSpawn()}
    SpawnRate:float = 1.0

#! Valid Program
# 43. Race in enum context
process_state := enum:
    Idle
    Processing
    Complete

ProcessWithTimeout():process_state=
    race:
        DoProcess()
        process_state.Complete

#! Valid Program
# 44. Nested sync operations
NestedSync():void=
    sync:
        sync:
            InnerOp1()
            InnerOp2()
        OuterOp()

#! Valid Program
# 45. Branch with option type
BranchOption():?int=
    branch:
        option{GetValue()}
        option{GetDefault()}

#! Valid Program
# 46. Race with failure context
RaceWithFailure()<transacts><decides>:void=
    race:
        MayFail?
        Fallback()

#! Valid Program
# 47. Sync with effect specifiers
SyncEffects()<suspends><transacts>:void=
    sync:
        SuspendableOp()
        TransactionalOp()

#! Valid Program
# 48. Complex real-world example
village_spawner := class(creative_device):
    OnPlayerSpawned(Agent:agent):void=
        spawn{CameraLoop(Agent)}
        race:
            StartSequence.StoppedEvent.Await()
            Sleep(10.0)
        sync:
            Camera.Reset()
            UI.Update()

#! Valid Program
# 49. All constructs combined
TestAllConcurrent():void=
    spawn:
        race:
            sync:
                branch:
                    Print("Deep nesting works!")
                    Print("Alternative branch")