# Valid Data Structures Test Suite
# Tests for classes, interfaces, structs, enums, and modules with various annotations, inheritance, and methods

#! Valid expression
# 1. Class name starting with keywords (but not exact match)
blocks := class { }

#! Valid expression
# 2. Simple class with boolean field
Config := class { enabled: bool = true }

#! Valid expression
# 3. Nested keywords in valid contexts
MyClass := class { Check():bool= not false }

#! Valid expression
# 4. Class inheritance with method
Player := class(Entity) { Update():= Move() }

#! Valid expression
# 5. Class with annotation and empty inheritance
MyClass := class<computes>():
    field1 : int

#! Valid expression
# 6. Class declaration with multiple fields
Rectangle := class { width := 10; height := 20 }

#! Valid expression
# 7. Class with multiple annotations
MyClass := class<abstract><public>:
    field1 : int

#! Valid expression
# 8. Class with computes annotation
class_1 := class<computes>:
    InstanceData1 : string

#! Valid expression
# 9. Class with annotation and inheritance
MyClass := class<computes>(BaseClass):
    field1 : int

#! Valid expression
# 10. Interface with annotation
MyInterface := interface<abstract>:
    Method() : void

#! Valid expression
# 11. Class with option type field
DataClass := class { value: option = None }

#! Valid expression
# 12. Interface with option type method
Storage := interface { Get(): option }

#! Valid expression
# 13. Struct with option type fields
Config := struct { timeout: option = Some(5.0) }

#! Valid expression
# 14. Class declaration with mixed members
Player := class { name := ""; score := 0; GetScore():= score }

#! Valid expression
# 15. Class with method calling other method
Calculator := class { Add(a, b):= a + b; Double(x):= Add(x, x) }

#! Valid expression
# 16. Class with boolean field
Test := class { var count:int= 0 }

#! Valid expression
# 17. Class with computes annotation and method with override
MyClass := class<computes>:
    Method1<override>() : string = "test"

#! Valid expression
# 18. Class with complex field initializers
Config := class { host := "localhost"; port := 8080; url := host + ":" + port }

#! Valid expression
# 19. Complex object with keyword-like names
blockManager := class {
  continueOperation():= true
  varStorage: int = 0
  ifCondition():= false
}

#! Valid expression
# 20. Class with decorators and specifiers
@editable
UIComponent := class {
  @editable
  var visible: bool = true

  OnBegin<override>()<suspends>: void = {
    Initialize();
    Wait(1.0)
  }

  Show<public>(): void = visible := true
  Hide<public>(): void = visible := false
}

#! Valid expression
# 21. Complex GameManager class
GameManager := class(BaseManager) {
  var players: []Player = array{}
  var isRunning: bool = false

  Start(): void = {
    isRunning := true;
    InitializePlayers()
  }

  AddPlayer(p: Player): bool = {
    if(not isRunning) then {
      players := players + array{p};
      true
    } else {
      false
    }
  }

  GetPlayerCount(): int = players.length
}

#! Valid expression
# 22. Field with braces
Test := class { x:int= 1 }

#! Valid expression
# 23. Multiple methods with braces
Test := class {
  GetX():int= x
  SetX(val:int):= x := val
}

#! Valid expression
# 24. Simple method with braces
Test := class { DoSomething():= x }

#! Valid expression
# 25. Method with specifiers and braces
Test := class { OnBegin<override>()<suspends>:void= x }

#! Valid expression
# 26. Class declaration with field
Point := class { x := 1 }

#! Valid expression
# 27. Brace block with var declarations
{ var x: int = 5; x * 2 }

#! Valid expression
# 28. Block with var declarations
{ var x : int = 5; x * 2 }

#! Valid expression
# 29. Multiple variable declarations in block
{
  var x : int = 10;
  var y : int = 20;
  x + y
}

#! Valid expression
# 30. Class with multiple methods
Calculator := class {
  Add(a:int, b:int): int = a + b
  Subtract(a:int, b:int): int = a - b
  IsPositive(x:int): bool = x > 0
}

#! Valid expression
# 31. Class with method parameters
Math := class { Add(a:int, b:int):int= a + b }

#! Valid expression
# 32. Class method returning boolean
Validator := class { IsValid(x:int): bool = x > 0 }

#! Valid expression
# 33. Builder pattern class
builder := class {
  value: string = ""

  Add(s: string): x = {
    value := value + s;
    this
  }

  Build(): string = value
}

#! Valid expression
# 35. Empty class with decorators
@public
MyClass := class { }

#! Valid expression
# 36. Class with decorator and field
@editable
@public
Component := class { x := 1 }

#! Valid expression
# 37. Class with multiple decorators and fields
@component
Widget := class {
  @editable
  var enabled: bool = true

  @editable
  name: string = "widget"
}

#! Valid expression
# 38. Class with indented structure
@editable
MyClass := class:
  x := 1
  y := 2
