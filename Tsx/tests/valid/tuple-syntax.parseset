# Valid Tuple Syntax Tests
# Tests for tuple literals, types, access, and expansion

#! Valid expression
# 1. Basic tuple literal with two elements
(1, 2)

#! Valid expression
# 2. Tuple literal with three elements
(1, 2, 3)

#! Valid expression
# 3. Tuple with mixed types
("hello", 42, true)

#! Valid expression
# 4. Nested tuples
((1, 2), (3, 4))

#! Valid expression
# 5. Tuple with expressions
(x + 1, y * 2, z - 3)

#! Valid expression
# 6. Tuple with function calls
(getValue(), process(data), calculate(x))

#! Valid expression
# 7. Single parenthesized expression (not a tuple)
(42)

#! Valid expression
# 8. Tuple element access with literal index
myTuple(0)

#! Valid expression
# 9. Tuple element access with different indices
coordinates(1)

#! Valid expression
# 10. Chained tuple access
nestedTuple(0)(1)

#! Valid expression
# 11. Tuple access with expression index
data(getIndex())

#! Valid expression
# 12. Tuple expansion in function call
processCoords(*point)

#! Valid expression
# 13. Multiple tuple expansions
combine(*first, *second)

#! Valid expression
# 14. Tuple expansion with regular arguments
transform(matrix, *coords, scale)

#! Valid expression
# 15. Nested tuple expansion
process(*getTuple())

#! Valid expression
# 16. Tuple in assignment
coords := (x, y, z)

#! Valid expression
# 17. Tuple as function return value
GetPosition() := (10, 20, 30)

#! Valid expression
# 18. Tuple creation for comparison
result := (a, b)

#! Valid expression
# 19. Tuple with range expressions
(0..5, 10..15)

#! Valid expression
# 20. Tuple with array expressions
(array{1, 2}, array{3, 4})

#! Valid expression
# 21. Empty tuple (edge case)
()

#! Valid expression
# 22. Tuple with whitespace and comments
(  # first element
  42,   # second element
  "test"  # third element
)

#! Valid expression
# 23. Tuple with newlines
(
  first,
  second,
  third
)

#! Valid expression
# 24. Complex nested structure
((getValue(), process()), (calculate(*data), transform()))

#! Valid expression
# 25. Tuple in conditional
if(condition) then { result := (x, y) }