# Valid Map Type Tests
# Tests for map type syntax [keytype]valuetype

#! Valid expression
# 1. Basic map type declaration
userMap: [string]int = GetDefaultMap()

#! Valid expression
# 2. Map with complex key type
complexMap: [UserID]UserData = CreateUserMap()

#! Valid expression
# 3. Map with array value type
arrayMap: [string][]int = GetStringToArrayMap()

#! Valid expression
# 4. Map with optional value type
optionalMap: [string]?User = GetOptionalUserMap()

#! Valid expression
# 5. Nested map types
nestedMap: [string][int]User = GetNestedMap()

#! Valid expression
# 6. Optional map type
maybeMap: ?[string]int = GetMapIfAvailable()

#! Valid expression
# 7. Array of maps
mapArray: [][string]User = CreateMapArray()

#! Valid expression
# 8. Function parameter with map type
ProcessUsers(users: [UserID]User): void = {}

#! Valid expression
# 9. Function returning map type
GetScores(): [string]int = CreateScoreMap()

#! Valid expression
# 10. Map with tuple key type
tupleKeyMap: [tuple(int, string)]User = CreateTupleMap()

#! Valid expression
# 11. Map with tuple value type
tupleValueMap: [string]tuple(int, string) = CreateValueMap()

#! Valid expression
# 12. Map type in class field
UserManager := class {
    activeUsers: [SessionID]User = GetInitialUsers()
}

#! Valid expression
# 13. Map type in struct
ConfigMap := struct {
    settings: [string]string
    values: [string]int
}

#! Valid expression
# 14. Map with generic-style key type
genericMap: [option<string>]int = CreateGenericMap()

#! Valid expression
# 15. Map with parameterized key type
weakMap: [weak_map(session, string)]int = GetWeakMap()

#! Valid expression
# 16. Complex nested map type
complexNested: [string]?[int][]tuple(string, User) = GetComplexMap()

#! Valid expression
# 17. Map type variable declaration
var userCache: [string]User = EmptyMap()

#! Valid expression
# 18. Map type assignment
scoreMap: [string]int = GetScoreMap()

#! Valid expression
# 19. Multiple map parameters
MergeUserMaps(primary: [UserID]User, secondary: [UserID]User): [UserID]User = CombineMaps(primary, secondary)

#! Valid expression
# 20. Map type in conditional
result := if(hasCache) then { cache: [string]Data = GetCache() } else { EmptyCache() }