# Dot Format Tests - Single-line if expressions with . syntax

#! Valid expression
if (X > 0). Print("Positive")

#! Valid expression
if (IsValid). Print("Starting"); DoWork(); Print("Done")

#! Valid expression
if (X > 0). Print("Positive") else. Print("Non-positive")

#! Valid expression
if (Player.IsAlive[]). Player.Heal(10); Player.ShowMessage("Healed") else. Player.Respawn()

#! Valid expression
if (true). DoSomething()

#! Valid expression
if (false). Action1(); Action2() else. Action3()

#! Valid expression
if (Count >= 10). Reset(); Log("Reset occurred")

#! Valid expression
if (User.HasPermission). Grant(); Log("Access granted") else. Deny(); Log("Access denied")

#! Valid expression
if (GameState == Running). Update(); Render()

#! Valid expression
if (Health <= 0). Die() else. Continue()

#! Valid expression - nested conditions
if (A > B). if (C < D). DoThis() else. DoThat()

#! Valid expression - complex boolean expression
if (A and B or C). Execute()

#! Valid expression - with array access
if (Items[0]). ProcessFirst()

#! Valid expression - with member access
if (Player.Status). CheckStatus()

#! Valid expression - with function call condition
if (IsReady()). Start() else. Wait()

#! Valid expression - multiple semicolon separated actions
if (Ready). Action1(); Action2(); Action3(); Action4()

#! Valid expression - else with multiple actions
if (Valid). Success() else. Error1(); Error2(); Error3()

#! Valid expression - empty then branch (just condition)
if (Flag). DoNothing() else. HandleFalse()

#! Valid expression - complex nested expression
if (Data.Items[Index].IsValid). Process(Data.Items[Index]) else. Skip()

#! Valid expression - boolean literals
if (true). Always() else. Never()