#! Valid expression
# 1. Array of booleans
flags := array{true, false, true, true}


#! Valid expression
# 2. Array-like function with object arguments
makeList[
  Item{id:=1, name:=sword},
  Item{id:=2, name:=shield},
  Item{id:=3, name:=potion}
]


#! Valid expression
# 3. Const with square bracket function call
items := getData[1, 2, 3]


#! Valid expression
# 4. Object with bracket-style function calls in fields
Settings{items:=getItems[0], count:=len[items]}


#! Valid expression
# 5. Object with mixed function call styles
Settings{
  items:=getItems[0],
  handler:=getHandler(),
  filters:=getFilters[all]
}


#! Valid expression
# 6. Object in bracket-style function call
process[Config{debug:=true, verbose:=false}]


#! Valid expression
# 7. Configuration with handler array
Config{
  handlers:=getHandlers[
    Handler{
      fn:=onCreate(),
      priority:=1
    }
  ]
}


#! Valid expression
# 8. Race with complex expressions
race:
    Player.WaitForInput()
    Sleep(5.0)
    Enemy.Attack()


#! Valid Program
# 9. Race with assignment
GetFirstResult():int=
    Result := race:
        ComputeFast()
        ComputeSlow()
        DefaultValue()


#! Valid Program
# 10. Nested race
TestNestedRace():void=
    race:
        spawn{LongTask()}
        race:
            QuickOption1()
            QuickOption2()


#! Valid expression
# 11. Sync with complex expressions
sync:
    Player.Health := 100
    Player.Shield := 50
    Player.Status := "Ready"


#! Valid Program
# 12. Sync in transaction
PerformTransaction():void=
    sync:
        Account1.Debit(Amount)
        Account2.Credit(Amount)
        Log.Record(Transaction)


#! Valid expression
# 13. Branch with indented form
branch:
    ProcessRoute1()
    ProcessRoute2()
    ProcessRoute3()


#! Valid Program
# 14. Branch in game logic
HandlePlayerChoice():void=
    branch:
        GoLeft()
        GoRight()
        StayPut()


#! Valid Program
# 15. Combined concurrent constructs
ComplexAsync():void=
    spawn:
        race:
            FastCompute()
            SlowCompute()
    sync:
        UpdateUI()
        SaveState()


#! Valid Program
# 16. Spawn with lambda
TestLambdaSpawn():void=
    spawn{(X:int):int => X * 2}


#! Valid Program
# 17. Race with case expression
ProcessChoice():void=
    race:
        case(Input):
            1 => Action1()
            2 => Action2()
            _ => DefaultAction()
        Timeout()


#! Valid Program
# 18. Sync with for loop
BatchUpdate():void=
    sync:
        for(Item : Items):
            Item.Update()


#! Valid Program
# 19. Branch with if expression
ConditionalBranch(X:int):void=
    branch:
        if(X > 0):
            PositivePath()
        else:
            NegativePath()


#! Valid Program
# 20. Real-world spawn pattern from Fortnite
AudioController<public> := class:
    PlayQueuedVO<private>()<suspends>:void=
        loop:
            Sleep(0.5)
            spawn{AddPlayerToValidAudioTargets(MyAgent)}


#! Valid Program
# 21. Real-world race pattern
WaitForPlayerAction():void=
    WinnerResult := race:
        Button.InteractedWithEvent.Await()
        Sleep(30.0)


#! Valid Program
# 22. Complex spawn with object construction
SpawnWithObject():void=
    spawn:
        NewPlayer := player{Name := "Test", Score := 0}
        NewPlayer.Initialize()


