#! Valid expression
# 1. Multiple empty lines with expression
42


#! Valid expression
# 2. Float literal with no integer part
.5


#! Valid expression
# 3. Float literal with no decimal part
5.


#! Valid expression
# 4. Float with positive exponent
1.5e+10


#! Valid expression
# 5. Float with negative exponent
1.5e-10


#! Valid expression
# 6. Range with same start and end
5..5


#! Valid expression
# 7. Integer with scientific notation becomes float
1e10


#! Valid expression
# 8. Keywords can appear in strings
"block and continue are keywords"


#! Valid expression
# 9. Boolean literal true
true


#! Valid expression
# 10. Boolean literal false
false


#! Valid expression
# 11. Basic string literal with double quotes
"Hello"


#! Valid expression
# 12. Empty tuple literal
()


#! Valid expression
# 13. Empty tuple in assignment
result := ()


#! Valid expression
# 14. Empty tuple in conditional
if(x) then () else ()


#! Valid expression
# 15. Lambda returning empty tuple
x => ()


#! Valid expression
# 16. Function returning empty tuple
f() := ()


#! Valid expression
# 17. Empty tuple in case expression
case(x): 1 => doSomething(), _ => ()


#! Valid expression
# 18. Empty tuple as function argument
process(())


#! Valid expression
# 19. Empty tuple in block expression
{ doSomething(); () }


#! Valid expression
# 20. Nested empty tuples (tuple containing empty tuple)
((), x, ())


