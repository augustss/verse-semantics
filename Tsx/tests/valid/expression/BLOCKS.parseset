#! Valid expression
# 1. Indented block style
block:
  x + 1
  y + 2
  z + 3


#! Valid expression
# 2. Indented block with semicolons
block:
  x + 1;
  y + 2;
  z + 3


#! Valid expression
# 3. Nested indented blocks
block:
  x + 1
  block:
    y + 2
    z + 3
  w + 4


#! Valid expression
# 4. Block with whitespace preservation
{  x  ;  y  ;  z  }


#! Valid expression
# 5. All semicolons in indented block
block:
  a;
  b;
  c;


#! Valid expression
# 6. No semicolons in indented block
block:
  a
  b
  c


#! Valid expression
# 7. Indented block with optional semicolons preserved
block:
  x + 1;
  y + 2
  z + 3;


#! Valid expression
# 8. Mixed semicolons preserved in nested indented blocks
block:
  outer1;
  block:
    inner1
    inner2;
  outer2


#! Valid expression
# 9. Empty brace block
{}


#! Valid expression
# 10. Block with single expression
{ x }


#! Valid expression
# 11. Empty statements in brace block
{ ;; x ;; }


#! Valid expression
# 12. Deeply nested blocks
{ { { { x } } } }


#! Valid expression
# 13. Block with only semicolon
{ ; }


#! Valid expression
# 14. Block with multiple statements and trailing semicolon
{ a; b; c; }


#! Valid expression
# 15. Empty block
{ }


#! Valid expression
# 16. Block with single statement
{x}


#! Valid expression
# 17. Block with many statements
{a; b; c; d; e; f; g; h; i; j; k}


#! Valid expression
# 18. Deeply nested blocks
{{{{{{{{{x}}}}}}}}}


#! Valid expression
# 19. Block with only semicolon
{;}


#! Valid expression
# 20. Nested empty blocks
{{}}


#! Valid expression
# 21. Indented block with comments
block: # block start
  x + 1  # first
  y + 2  # second
  z + 3  # third


