#! Valid expression
# 1. Array access
myArray[0]


#! Valid expression
# 2. Matrix access
matrix[i][j]


#! Valid expression
# 3. Array construction
array{1, 2, 3}


#! Valid expression
# 4. Array with strings
array{"a", "b", "c"}


#! Valid expression
# 5. Boolean in array
array{true, false, true}


#! Valid expression
# 6. Square bracket function calls
f[]


#! Valid expression
# 7. Function call with arguments
f[x]


#! Valid expression
# 8. Function call with multiple arguments
f[1, 2]


#! Valid expression
# 9. Function call with nested square brackets
f[g[x]]


#! Valid expression
# 10. Square bracket function call with three arguments
f[1, 2, 3]


#! Valid expression
# 11. Function call with square brackets and spacing
add[x, y]


#! Valid expression
# 12. Query operator on array access
items[0]?


#! Valid expression
# 13. Tuple with array expressions
(array{1, 2}, array{3, 4})


