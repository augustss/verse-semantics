#! Valid expression
# 1. Parentheses with whitespace
( x )


#! Valid expression
# 2. Parenthesized integer with whitespace
( 42 )


#! Valid expression
# 3. Simple parentheses
(x)


#! Valid expression
# 4. Parenthesized integer
(42)


#! Valid expression
# 5. Basic tuple literal with two elements
(1, 2)


#! Valid expression
# 6. Tuple literal with three elements
(1, 2, 3)


#! Valid expression
# 7. Tuple with mixed types
("hello", 42, true)


#! Valid expression
# 8. Tuple with whitespace and comments
(  # first element
  42,   # second element
  "test"  # third element
)


#! Valid expression
# 9. Tuple with newlines
(
  first,
  second,
  third
)


