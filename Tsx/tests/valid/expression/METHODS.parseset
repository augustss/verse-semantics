#! Valid expression
# 1. Member access with square bracket call
x.f[1, 2].y


#! Valid expression
# 2. Method call with square brackets
x.f[a, b, c]


#! Valid expression
# 3. Whitespace preservation
x . y . z


#! Valid expression
# 4. Simple member access
x.y


#! Valid expression
# 5. Chained member access
x.y.z


#! Valid expression
# 6. Range with member access
point.x..point.y


#! Valid expression
# 7. Query operator on member access
player.health?


#! Valid expression
# 8. continue as field access
data.continue


