#! Valid expression
# 1. If expression with negation
if(not isEmpty) then { process(data) }


#! Valid expression
# 2. If expression with logical operators
if(isEnabled and hasPermission) then { execute() } else { deny() }


#! Valid expression
# 3. Logical in if condition
if(a and b) then true else false


#! Valid expression
# 4. Complex nested control flow with break and continue
result := if(true and not false) then {
  for(i : 0..10) {
    if(i > 5) then { break } else { continue }
  }
} else {
  case(status):
    0 => false
    1 => true
    _ => not true
}


#! Valid expression
# 5. Logical expression with booleans
canProceed := isReady and not isBlocked or hasOverride


#! Valid expression - complex boolean expression
if (A and B or C). Execute()


#! Valid expression
# 7. Whitespace preservation
x  and  y  or  z


#! Valid expression
# 8. Boolean with logical operators
true and false


#! Valid expression
# 9. Boolean with not operator
not true


#! Valid expression
# 10. Logical with method calls
isReady() or canProceed()


#! Valid expression
# 11. Member access in logical expression
obj.isValid and obj.data.exists


#! Valid expression
# 12. Logical with parentheses
(a and b) or c


#! Valid expression
# 13. Complex precedence with all operators
f(x + y) * g(a - b) + h(c * d) / i(e / f) - j(not k and l or m)


#! Valid expression
# 14. Function calls in logical expression
isValid(x) and isReady(y) or hasPermission(user)


#! Valid expression
# 15. Nested boolean expressions
(true or false) and not false


#! Valid expression
# 16. Complex boolean logic
valid := (age >= 18 and age <= 65) and (not retired or hasException)


#! Valid expression
# 17. Mathematical expressions with precedence
result := not false or true and false or (true and not false)


#! Valid expression
# 18. Complex object construction
config := Config{
  maxPlayers := 100,
  enablePvP := true,
  gameMode := if(isRanked) then { "competitive" } else { "casual" },
  settings := Settings{
    graphics := "high",
    soundEnabled := not isMuted
  }
}


#! Valid expression
# 19. Boolean in operations
true and false or not true


#! Valid expression
# 20. Keywords in comments
x := 1 # using var or not


#! Valid expression
# 21. Comments with logical operators
x and # check y
y or # check z
z


