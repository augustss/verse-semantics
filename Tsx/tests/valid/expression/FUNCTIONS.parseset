#! Valid expression
# 1. Chained function calls with mixed bracket styles
getData()[0].process(x, y).getValue()


#! Valid expression
# 2. Mixed brackets
f(g[x])


#! Valid expression
# 3. Mixed brackets reverse
f[g(x)]


#! Valid expression
# 4. Mixed nested function calls
f[g(x, y), h[z]]


#! Valid expression
# 5. Deeply nested mixed brackets
f[g(h[i(j[k])])]


#! Valid expression
# 6. Basic spawn with braces
spawn{DoWork()}


#! Valid expression
# 7. Spawn with complex expression
spawn{Player.Teleport(Location)}


#! Valid expression
# 8. Spawn with indented form
spawn:
    Task1()
    Task2()
    Task3()


#! Valid expression
# 9. Basic race with two branches
race:
    FastPath()
    SlowPath()


#! Valid expression
# 10. Race with multiple branches
race:
    Option1()
    Option2()
    Option3()
    TimeoutHandler()


#! Valid expression
# 11. Basic sync
sync:
    UpdateA()
    UpdateB()


#! Valid expression
# 12. Sync with multiple operations
sync:
    Database.Write(Data1)
    Database.Write(Data2)
    Database.Write(Data3)
    Database.Commit()


#! Valid expression
# 13. Basic branch
branch:
    Path1()
    Path2()


#! Valid expression
# 14. Branch with indented form (braces with comma not yet supported)
branch:
    PathA()
    PathB()
    PathC()


#! Valid expression
# 15. Basic if expression with brace style
if(true) then { 42 }


#! Valid expression
# 16. If expression with simple condition
if(x) then { result }


#! Valid expression
# 17. Boolean in if condition - spaced parentheses
if ( true ) then { 32 }


#! Valid expression
# 18. If with no spaces
if(true)then{32}


#! Valid expression
# 19. If-else with braces
if (x) then { a } else { b }


#! Valid expression
# 20. If expression with spacing
if( condition ) then: result


#! Valid expression
# 21. Boolean false conditions
if(false) then { 0 } else { 1 }


#! Valid expression
# 22. If expression with object field condition
if(user.isActive) then { user.name }


#! Valid expression
# 23. If expression with variable conditions
if(flag) then { onValue } else { offValue }


#! Valid expression
# 24. If expression with function call condition
if(isValid(data)) then { process(data) }


#! Valid expression
# 25. If expression with function return conditions
if(checkStatus()) then { proceed() } else { abort() }


#! Valid expression
# 26. If expression with method calls
if(list.isEmpty()) then { createDefault() } else { list.first() }


#! Valid expression
# 27. If expression as argument
process(if(condition) then { value1 } else { value2 })


#! Valid expression
# 28. Empty if with braces
if(x) then {} else {}


#! Valid expression
# 29. If expression with empty then block
if(condition) then: {}


#! Valid expression
# 30. Complex conditional with nested if
if(condition1):
  if(condition2):
    if(condition3):
      result
    else:
      fallback1
  else:
    fallback2
else:
  fallback3


#! Valid expression
# 31. If-else with indentation
if (condition) then:
  actionA()
else:
  actionB()


#! Valid expression
# 32. Indented if expression style
if(condition) then:
  result


#! Valid expression
# 33. Indented if expression with else
if(condition) then:
  primaryValue
else:
  fallbackValue


#! Valid expression
# 34. Missing block content
if(condition) then:


#! Valid expression
# 35. Indented if expression with nested if
if(outer) then:
  if(inner) then:
    deepValue
  else:
    shallowValue
else:
  defaultValue


#! Valid expression
# 36. Basic for loop with empty body
for(x : items) {}


#! Valid expression
# 37. For loop with simple expression body
for(x : items) { x }


#! Valid expression
# 38. For-loop with range
for(i : 1..10) { i * 2 }


#! Valid expression
# 39. For-loop with array access body
for(i : 0..n) { arr[i] }


#! Valid expression
# 40. For with range
for(i : 1..10) { i * i }


#! Valid expression
# 41. For loop with function call as iterable
for(x : getItems()) { x }


#! Valid expression
# 42. For-loop with member access in iterable
for(x : object.items) { x }


#! Valid expression
# 43. For loop with spacing variations
for( x : items ) { f( x ) }


#! Valid expression
# 44. For-loop with function call body
for(x : items) { process(x) }


#! Valid expression
# 45. For loop with expression body
for(item : list) { item + 1 }


#! Valid expression
# 46. For loop with complex expression body
for(x : items) { f(x) + g(x) }


#! Valid expression
# 47. For loop with binary operations
for(x : items) { x + y - z * w }


#! Valid expression
# 48. For-loop with variable range
for(x : start..end) { process(x) }


#! Valid expression
# 49. For with method call result
for(x : getItems()) { process(x) }


#! Valid expression
# 50. For loop in expression context
sum + for(x : items) { x } + total


#! Valid expression
# 51. Nested for expressions
for(x : xs) { for(y : ys) { x + y } }


#! Valid expression
# 52. Complex range in for loop
for(i : arr.length - 1 .. 0) { arr[i] }


#! Valid expression
# 53. For loop as function argument
process(for(x : items) { transform(x) })


#! Valid expression
# 54. For with member access in collection
for(item : container.items) { item.value }


#! Valid expression
# 55. Nested for loops with ranges
for(x : 1..3):
  for(y : 1..3):
    x * y


#! Valid expression
# 56. For loop with complex iterable expression
for(x : items.filter(isValid)) { transform(x) }


#! Valid expression
# 57. Nested for expressions
for(x : items):
  for(y : x.children):
    process(y)


#! Valid expression
# 58. For with nested block
for(x : items) {
  for(y : x.children) { process(y) }
}


#! Valid expression
# 59. Precedence in for loop
for(x : start + offset..end - padding) { x * multiplier }


#! Valid expression
# 60. Complex for loop with range and operations
for(i : (start + 1)..(end - 1)):
  process(items[i] + offset)


#! Valid expression
# 61. Nested for loops in brace style
for(x : items) {
  for(y : x.children) {
    x.value + y.value
  }
}


#! Valid expression
# 62. Nested for loops with ranges
for(x : 1..10) {
  for(y : 1..x) {
    x * y
  }
}


#! Valid expression
# 63. Multiple statement body
for(x : items) { x; y; z }


#! Valid expression
# 64. Indented for loop style
for(x : items):
  x


#! Valid expression
# 65. For loop with range indentation style
for(i : 1..10):
  i * i


#! Valid expression
# 66. Indented for loop with nested for loops
for(x : items):
  for(y : x.children):
    process(x, y)


#! Valid expression
# 67. Nested range expressions
for(x : 1..(start + end)) { x }


#! Valid expression
# 68. Complex range in for loop
for(i : (min + offset)..(max - padding)):
  calculate(x * multiplier + base)


#! Valid expression
# 69. Continue in else block
if(skip) then { process() } else { continue }


#! Valid expression
# 70. Loop with break condition
loop {
  if(done) then { break }
}


#! Valid expression
if (IsValid). Print("Starting"); DoWork(); Print("Done")


#! Valid expression
if (Player.IsAlive[]). Player.Heal(10); Player.ShowMessage("Healed") else. Player.Respawn()


#! Valid expression
if (true). DoSomething()


#! Valid expression
if (false). Action1(); Action2() else. Action3()


#! Valid expression
if (User.HasPermission). Grant(); Log("Access granted") else. Deny(); Log("Access denied")


#! Valid expression - with array access
if (Items[0]). ProcessFirst()


#! Valid expression - with member access
if (Player.Status). CheckStatus()


#! Valid expression - with function call condition
if (IsReady()). Start() else. Wait()


#! Valid expression - multiple semicolon separated actions
if (Ready). Action1(); Action2(); Action3(); Action4()


#! Valid expression - else with multiple actions
if (Valid). Success() else. Error1(); Error2(); Error3()


#! Valid expression - empty then branch (just condition)
if (Flag). DoNothing() else. HandleFalse()


#! Valid expression - complex nested expression
if (Data.Items[Index].IsValid). Process(Data.Items[Index]) else. Skip()


#! Valid expression - boolean literals
if (true). Always() else. Never()


