#! Valid expression
# 1. Struct with option type fields
Config := struct { timeout: option = Some(5.0) }


#! Valid expression
# 2. Map type in struct
ConfigMap := struct {
    settings: [string]string
    values: [string]int
}


#! Valid expression
# 3. Struct method with visibility and behavior
Point := struct { Distance<public>(other:Point)<inline>:float = CalculateDistance(other) }


#! Valid expression
# 4. Tuple type in struct
Vector := struct {
    components: tuple(float, float, float)
}


#! Valid expression
# 5. Type{expression} in struct field
ProcessorConfig := struct {
    callback : type{getValue()}
    result : type{calculate(1, 2)}
}


