# Valid Visibility Specifier Tests
# Tests for the separation of visibility specifiers from behavior specifiers

#! Valid expression
# 1. Function with public visibility specifier
PublicFunc<public>():int = 42

#! Valid expression
# 2. Function with private visibility specifier
PrivateFunc<private>():string = "secret"

#! Valid expression
# 3. Function with protected visibility specifier
ProtectedFunc<protected>():logic = true

#! Valid expression
# 4. Function with internal visibility specifier
InternalFunc<internal>():void = {}

#! Valid expression
# 5. Function with scoped visibility specifier
ScopedFunc<scoped>():float = 3.14

#! Valid expression
# 6. Function with visibility and behavior specifiers
PublicDecides<public>(x:int)<decides>:logic = x > 0

#! Valid expression
# 7. Function with private and multiple behavior specifiers
PrivateComplex<private>(data:string)<decides><suspends>:string = ProcessData(data)

#! Valid expression
# 8. Function with visibility and override specifier
VirtualMethod<public>()<override>:void = BaseMethod()

#! Valid expression
# 9. Function with visibility and transacts specifier
UpdateState<public>(value:int)<transacts>:void = SetValue(value)

#! Valid expression
# 10. Function with behavior specifier before name
<decides>ValidateInput(x:int):logic = x >= 0

#! Valid expression
# 11. Function with multiple pre-specifiers
<decides><suspends>ProcessAsync():void = DoWork()

#! Valid expression
# 12. Function with behavior specifiers after parameters only
Calculate(a:int, b:int)<decides>:int = a + b

#! Valid expression
# 13. Function with override specifier after parameters
HandleEvent(event:Event)<override>:void = ProcessEvent(event)

#! Valid expression
# 14. Function with abstract specifier
DefineInterface()<abstract>:void = {}

#! Valid expression
# 15. Function with final specifier
SealedMethod()<final>:int = 100

#! Valid expression
# 16. Function with native specifier
SystemCall()<native>:void = {}

#! Valid expression
# 17. Function with inline specifier
FastOperation()<inline>:int = 1

#! Valid expression
# 18. Function with reads specifier
GetValue()<reads>:int = internalValue

#! Valid expression
# 19. Function with writes specifier
SetValue(x:int)<writes>:void = { internalValue = x }

#! Valid expression
# 20. Function with allocates specifier
CreateObject()<allocates>:Object = Object{}

#! Valid expression
# 21. Complex function with all specifier types
ComplexMethod<public>(input:string)<decides><suspends><override>:string = ProcessInput(input)

#! Valid expression
# 22. Function with visibility in class context
MyClass := class { Method<private>():int = GetPrivateData() }

#! Valid expression
# 23. Interface method with visibility
IService := interface { Process<public>(data:string):string }

#! Valid expression
# 24. Function with scoped visibility and parameters
ScopedProcess<scoped>(x:int, y:string)<decides>:logic = ValidateParams(x, y)

#! Valid expression
# 25. Function with protected visibility and return type
ProtectedGetter<protected>():?int = GetInternalValue()

#! Valid expression
# 26. Function with public visibility in compound expression
{ PublicAPI<public>():void = {}; PrivateHelper<private>():void = {} }

#! Valid expression
# 27. Function with visibility and complex parameters
DataProcessor<public>(items:[]string, config:ProcessConfig)<decides><transacts>:[]Result = ProcessItems(items, config)

#! Valid expression
# 28. Function with visibility and callback parameter
EventHandler<public>(callback:EventCallback)<suspends>:void = RegisterCallback(callback)

#! Valid expression
# 29. Function with visibility and optional parameters
OptionalProcessor<public>(required:int, optional:?string)<decides>:string = FormatResult(required, optional)

#! Valid expression
# 30. Function with internal visibility and array return type
InternalData<internal>():[]byte = GetRawData()