# Valid Type{Expression} Tests
# Tests for type{expression} construct support

#! Valid expression
# 1. Simple function call in type
Foo() : int = 0
Bar(X : type{Foo()}) : type{Foo()} = X

#! Valid expression
# 2. Type with identifier expression
getValue() : int = 42
result : type{getValue()} = getValue()

#! Valid expression
# 3. Type with binary expression
calculate(x : int, y : int) : int = x + y
operation : type{calculate(1, 2)} = calculate(3, 4)

#! Valid expression
# 4. Type with member access
obj.method() : string = "test"
memberType : type{obj.method()} = obj.method()

#! Valid expression
# 5. Type with array access
arr[0] : int = getValue()
arrayType : type{arr[0]} = arr[1]

#! Valid expression
# 6. Type with compound expression
process() : void = { print("done") }
blockType : type{process()} = process()

#! Valid expression
# 7. Type with conditional expression
getValue(flag : logic) : int = if flag then 1 else 0
conditionalType : type{getValue(true)} = getValue(false)

#! Valid expression
# 8. Type with lambda expression
transform := x => x * 2
lambdaType : type{transform(5)} = transform(10)

#! Valid expression
# 9. Type with tuple expression
makePair(x : int, y : int) : tuple(int, int) = (x, y)
tupleType : type{makePair(1, 2)} = makePair(3, 4)

#! Valid expression
# 10. Type with object constructor
Point{x := 1, y := 2}
pointType : type{Point{x := 3, y := 4}} = Point{x := 5, y := 6}

#! Valid expression
# 11. Function parameter with type{expression}
processValue(callback : type{_() : int}) : int = callback()

#! Valid expression
# 12. Function return type with type{expression}
getProcessor() : type{_() : int} = getValue

#! Valid expression
# 13. Variable declaration with type{expression}
var processor : type{getValue()} = getValue()

#! Valid expression
# 14. Constant assignment with type{expression}
processor := getValue
result : type{processor()} = processor()

#! Valid expression
# 15. Type{expression} with nested function calls
outer(inner() : int) : int = inner()
nestedType : type{outer(getValue())} = outer(getValue())

#! Valid expression
# 16. Optional type{expression}
maybeProcessor : ?type{getValue()} = getValue()

#! Valid expression
# 17. Array of type{expression}
processors : []type{getValue()} = array{getValue, getValue}

#! Valid expression
# 18. Map with type{expression} values
processMap : [string]type{getValue()} = map{"key" => getValue}

#! Valid expression
# 19. Type{expression} in class field
DataProcessor := class {
    handler : type{getValue()} = getValue()
}

#! Valid expression
# 20. Type{expression} in struct field
ProcessorConfig := struct {
    callback : type{getValue()}
    result : type{calculate(1, 2)}
}