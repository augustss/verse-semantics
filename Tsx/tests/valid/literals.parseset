# Valid Literals Test Suite
# Tests for literal values: integers, floats, strings, and booleans

#! Valid expression
# 1. Basic integer literal
42

#! Valid expression
# 2. Decimal number without leading digit
.5

#! Valid expression
# 3. Decimal number without trailing digits
5.

#! Valid expression
# 4. Boolean literal true
true

#! Valid expression
# 5. Boolean literal false
false

#! Valid expression
# 6. Basic string literal with double quotes
"Hello"

#! Valid expression
# 7. String literal with escaped double quote
"He said \"hello\""

#! Valid expression
# 8. String literal with multiple escape sequences
"Quote: \"\tTab\nNewline\\"

#! Valid expression
# 9. Scientific notation creates float literal
1e10

#! Valid expression
# 10. Float literal with positive exponent
1.5e+10

#! Valid expression
# 11. Float literal with negative exponent
1.5e-10

#! Valid expression
# 12. String literal containing Verse keywords
"block and continue are keywords"
