# Decorator test cases

# Simple decorator
@editable
MyClass := class { }
===
@editable
MyClass := class { }

# Decorator with empty parentheses
@deprecated()
OldClass := class { }
===
@deprecated()
OldClass := class { }

# Decorator with string argument
@doc("This is a test class")
TestClass := class { }
===
@doc("This is a test class")
TestClass := class { }

# Decorator with multiple arguments
@config(42, "test", true)
ConfigClass := class { }
===
@config(42, "test", true)
ConfigClass := class { }

# Multiple decorators
@serializable
@persistent
DataClass := class { }
===
@serializable
@persistent
DataClass := class { }

# Multiple decorators with arguments
@version(1)
@author("John Doe")
@doc("Main game class")
GameClass := class { }
===
@version(1)
@author("John Doe")
@doc("Main game class")
GameClass := class { }

# Decorator with whitespace and comments preserved
  @editable
  # This is a comment
  MyClass := class { }
===
  @editable
  # This is a comment
  MyClass := class { }

# Complex real-world example with body
@editable
capturepoint_lighting_control := class {
  var CapturePoint : capturepoint_device = capturepoint_device{}
}
===
@editable
capturepoint_lighting_control := class {
  var CapturePoint : capturepoint_device = capturepoint_device{}
}

# Module with decorator
@internal
MyModule := module { }
===
@internal
MyModule := module { }

# Interface with decorator
@public
IPlayer := interface { }
===
@public
IPlayer := interface { }

# Struct with decorator
@packed
Vec3 := struct { }
===
@packed
Vec3 := struct { }

# Enum with decorator
@flags
GameState := enum { }
===
@flags
GameState := enum { }

# Mixed decorators and types
@version(2)
@experimental
AdvancedSystem := module { }
===
@version(2)
@experimental
AdvancedSystem := module { }

# Decorator with arithmetic in arguments
@priority(10 + 5)
HighPriorityTask := class { }
===
@priority(10 + 5)
HighPriorityTask := class { }

# Decorator with function call in arguments
@tagged(getName())
DynamicClass := class { }
===
@tagged(getName())
DynamicClass := class { }

# Indentation-style class with decorator
@editable
MyClass := class:
  x := 1
  y := 2
===
@editable
MyClass := class:
  x := 1
  y := 2

# Module with decorator and indentation
@internal
MyModule := module:
  a := 1
  b := 2
===
@internal
MyModule := module:
  a := 1
  b := 2