#! Valid expression
# 1. Line comment tests
# this is a comment
42

#! Valid expression
42 # end of line comment

#! Valid expression
# 2. comment 1
x + y # comment 2

#! Valid expression
x + # inline comment
y

#! Valid expression
# 3. start comment
f(x) # middle
+ g(y) # end

#! Valid expression
Point{ # comment after brace
  x := 1, # after field
  y := 2
}

