#! Valid expression
# 1. Expression with various whitespace
x + y

#! Valid expression
# 2. Expression with tabs
x	+	y

#! Valid expression
# 3. Mixed spaces and tabs
x  	+  	y

#! Valid expression
# 4. Expression with trailing whitespace
x + y

#! Valid expression
# 5. Expression with leading whitespace
   x + y

#! Valid expression
# 6. Multi-line expression with preserved spacing
x +
  y +
    z

#! Valid expression
# 7. Function call with spaced arguments
f( x , y , z )

#! Valid expression
# 8. Object with varied spacing
Point{  x := 1  ,  y := 2  }

#! Valid expression
# 9. Indented object construction
Point:
  x := 1
  y := 2

#! Valid expression
# 10. Block with inconsistent indentation but valid structure
{
  x := 1;
    y := 2;
  x + y
}

#! Valid expression
# 11. For loop with spacing variations
for( x : items ) { f( x ) }

#! Valid expression
# 12. If expression with spacing
if( condition ) then: result

#! Valid expression
# 13. Complex spacing in nested expressions
f(  g(  x + y  ),  h(  a - b  )  )

#! Valid expression
# 14. Parentheses with internal spacing
( x + y )

#! Valid expression
# 15. Range with spacing
1 .. 10

#! Valid expression
# 16. Comments with surrounding whitespace
x  <# comment #>  + y

#! Valid expression
# 17. Line comments with spacing
x + y # this is a comment

#! Valid expression
# 18. Multi-line comment with spacing
<#
  This is a
  multi-line comment
#>
x + y

#! Valid expression
# 19. Deeply indented expression
{
    {
        {
            x + y
        }
    }
}

#! Valid expression
# 20. Expression with newlines and spaces
x
+
y

#! Valid expression
# 21. Object construction with varied indentation
Entity{
  name := "test",
    health := 100,
      position := Point{
        x := 0,
          y := 0
      }
}

#! Valid expression
# 22. Complex nested structure with mixed spacing
for(i : 1..10):
  if(i % 2 == 0):
    process(i)
  else:
    skip()

#! Valid expression
# 23. Function calls with no spacing
f(x,y,z)

#! Valid expression
# 24. Operations with no spacing
x+y*z-a/b