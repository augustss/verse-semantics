#! Valid
# String literal - no spaces
TestFunc75():void=
    "hello"

#! Valid
# String literal - leading spaces
TestFunc76():void=
    "hello"

#! Valid
# String literal - trailing spaces
TestFunc77():void=
    "hello"

#! Valid
# String literal - spaces on both sides
TestFunc78():void=
    "hello"

#! Valid
# String literal - tabs
TestFunc79():void=
	"hello"

#! Valid
# String with space - no external spaces
TestFunc80():void=
    "test string"

#! Valid
# String with space - leading spaces
TestFunc81():void=
    "test string"

#! Valid
# String with space - trailing spaces
TestFunc82():void=
