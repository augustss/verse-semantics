#! Valid
# Property access - double spaces
TestFunc106():void=
    player  .  Name

#! Valid
# Property access - triple spaces
TestFunc107():void=
    player   .   Name

#! Valid
# Property access - tabs
TestFunc108():void=
	player	.	Name

#! Valid
# Chained property access - no spaces
TestFunc109():void=
    obj.field.subfield

#! Valid
# Chained property access - single spaces
TestFunc110():void=
    obj . field . subfield

#! Valid
# Chained property access - double spaces
TestFunc111():void=
    obj  .  field  .  subfield

#! Valid
# Chained property access - triple spaces
TestFunc112():void=
    obj   .   field   .   subfield

#! Valid
# Alternative expression - no spaces (case not supported in function bodies)
TestFunc113():void=
    x:=if(true):result

#! Valid
# Alternative expression - spaces around parentheses
TestFunc114():void=
    x:=if( true ):result

#! Valid
# Alternative expression - spaces around all tokens
TestFunc115():void=
    x:=if ( true ) : result

#! Valid
# Alternative expression - double spaces
TestFunc116():void=
    x:=if  (  true  )  :  result

#! Valid
# Alternative expression - tabs
TestFunc117():void=
	x:=if	(	true	)	:	result

#! Valid
# Complex nested expression - no spaces
TestFunc118():void=
    (a+b)*(c-d)

#! Valid
# Complex nested expression - single spaces
TestFunc119():void=
    ( a + b ) * ( c - d )

#! Valid
# Complex nested expression - double spaces
TestFunc120():void=
    (  a  +  b  )  *  (  c  -  d  )

#! Valid
# Complex nested expression - triple spaces
TestFunc121():void=
    (   a   +   b   )   *   (   c   -   d   )

#! Valid
# Nested function calls - no spaces
TestFunc122():void=
    f(g(x),h(y))

#! Valid
# Nested function calls - single spaces
TestFunc123():void=
    f( g( x ), h( y ) )

#! Valid
# Nested function calls - double spaces
TestFunc124():void=
    f(  g(  x  ),  h(  y  )  )

#! Valid
# Nested function calls - triple spaces
TestFunc125():void=
    f(   g(   x   ),   h(   y   )   )

#! Valid
# Lambda with complex body - no spaces
TestFunc126():void=
    x=>(x+1)*2

#! Valid
# Lambda with complex body - single spaces
TestFunc127():void=
    x => ( x + 1 ) * 2

#! Valid
# Lambda with complex body - double spaces
TestFunc128():void=
    x  =>  (  x  +  1  )  *  2

#! Valid
# Lambda with complex body - triple spaces
TestFunc129():void=
    x   =>   (   x   +   1   )   *   2

#! Valid
# For loop with identifiers - no spaces
TestFunc130():void=
    for(i:=start..end):process(i)

#! Valid
# For loop with identifiers - single spaces
TestFunc131():void=
    for( i := start .. end ):process( i )

#! Valid
# For loop with identifiers - spaces around all tokens
TestFunc132():void=
    for ( i := start .. end ) : process ( i )

#! Valid
# For loop with identifiers - double spaces
TestFunc133():void=
    for  (  i  :=  start  ..  end  )  :  process  (  i  )

#! Valid
# If with logical operators - no spaces (except required around 'and')
TestFunc134():void=
    if(x>0 and y<100):true

