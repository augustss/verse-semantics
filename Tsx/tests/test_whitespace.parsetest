#! Valid
# If expression - no spaces
TestFunc84():void=
    if(x>0):true

#! Valid
# If expression - spaces around parentheses
TestFunc85():void=
    if( x > 0 ):true

#! Valid
# If expression - spaces around all tokens
TestFunc86():void=
    if ( x > 0 ) : true

#! Valid
# If expression - double spaces
TestFunc87():void=
    if  (  x  >  0  )  :  true

#! Valid
# If expression - triple spaces
TestFunc88():void=
    if   (   x   >   0   )   :   true

#! Valid
# If expression - tabs
TestFunc89():void=
	if	(	x	>	0	)	:	true

#! Valid
# For loop - no spaces
TestFunc90():void=
    for(i:=0..10):i

#! Valid
# For loop - spaces around parentheses
TestFunc91():void=
    for( i := 0 .. 10 ):i

#! Valid
# For loop - spaces around all tokens
TestFunc92():void=
    for ( i := 0 .. 10 ) : i

#! Valid
# For loop - double spaces
TestFunc93():void=
    for  (  i  :=  0  ..  10  )  :  i

#! Valid
# For loop - tabs
TestFunc94():void=
	for	(	i	:=	0	..	10	)	:	i

#! Valid
# Lambda - no spaces
TestFunc95():void=
    x=>x+1

#! Valid
# Lambda - spaces around arrow
TestFunc96():void=
    x => x + 1

#! Valid
# Lambda - double spaces
TestFunc97():void=
    x  =>  x  +  1

#! Valid
# Lambda - triple spaces
TestFunc98():void=
    x   =>   x   +   1

#! Valid
# Lambda - tabs
TestFunc99():void=
	x	=>	x	+	1

#! Valid
# Lambda with tuple params - no spaces
TestFunc100():void=
    (a,b)=>a*b

#! Valid
# Lambda with tuple params - single spaces
TestFunc101():void=
    ( a, b ) => a * b

#! Valid
# Lambda with tuple params - double spaces
TestFunc102():void=
    (  a,  b  )  =>  a  *  b

#! Valid
# Lambda with tuple params - triple spaces
TestFunc103():void=
    (   a,   b   )   =>   a   *   b

#! Valid
# Property access - no spaces
TestFunc104():void=
