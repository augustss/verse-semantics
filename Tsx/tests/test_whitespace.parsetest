#! Valid
# Specifier with identifier - no leading space
TestFunc65():void=
    <public>x

#! Valid
# Specifier with identifier - leading spaces
TestFunc66<public>():void=
    x

#! Valid
# Specifier with identifier - space after specifier
TestFunc67 <public>():void=
    x

#! Valid
# Specifier with identifier - spaces on both sides
TestFunc68 <public> ():void=
    x

