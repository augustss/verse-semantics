# Whitespace Variation Tests for Verse Parser - Wrapped in Functions
# Tests that the parser correctly handles various amounts of whitespace in function bodies

#! Valid
# Basic binary expression - no spaces
TestFunc1():void=
    5+3

#! Valid
# Basic binary expression - single spaces
TestFunc2():void=
    5 + 3

#! Valid
# Basic binary expression - double spaces
TestFunc3():void=
    5  +  3

#! Valid
# Basic binary expression - triple spaces
TestFunc4():void=
    5   +   3

#! Valid
# Basic binary expression - tabs
TestFunc5():void=
	5	+	3

#! Valid
# Basic binary expression - mixed whitespace
TestFunc6():void=
    5  +  3

#! Valid
# Compound expression - no spaces
TestFunc7():void=
    x*y+z

#! Valid
# Compound expression - single spaces
TestFunc8():void=
    x * y + z

#! Valid
# Compound expression - double spaces
TestFunc9():void=
    x  *  y  +  z

#! Valid
# Compound expression - triple spaces
TestFunc10():void=
    x   *   y   +   z

#! Valid
# Compound expression - tabs
TestFunc11():void=
	x	*	y	+	z

#! Valid
# Parenthesized expression - no spaces
TestFunc12():void=
    (a+b)*c

#! Valid
# Parenthesized expression - single spaces
TestFunc13():void=
    ( a + b ) * c

#! Valid
# Parenthesized expression - double spaces
TestFunc14():void=
    (  a  +  b  )  *  c

#! Valid
# Parenthesized expression - triple spaces
TestFunc15():void=
    (   a   +   b   )   *   c

#! Valid
# Parenthesized expression - tabs
TestFunc16():void=
	(	a	+	b	)	*	c

#! Valid
# Assignment - no spaces
TestFunc17():void=
    x=5

#! Valid
# Assignment - single spaces
TestFunc18():void=
    x = 5

#! Valid
# Assignment - double spaces
TestFunc19():void=
    x  =  5

#! Valid
# Assignment - triple spaces
TestFunc20():void=
    x   =   5

#! Valid
# Assignment - tabs
TestFunc21():void=
	x	=	5

#! Valid
# Assignment - mixed whitespace
TestFunc22():void=
    x  =  5

#! Valid
# Compound assignment - no spaces
TestFunc23():void=
    result=x+y

#! Valid
# Compound assignment - single spaces
TestFunc24():void=
    result = x + y

#! Valid
# Compound assignment - double spaces
TestFunc25():void=
    result  =  x  +  y

#! Valid
# Compound assignment - triple spaces
TestFunc26():void=
    result   =   x   +   y

#! Valid
# Function call - no spaces
TestFunc27():void=
    f(x,y)

#! Valid
# Function call - spaces around parentheses
TestFunc28():void=
    f( x, y )

#! Valid
# Function call - double spaces
TestFunc29():void=
    f(  x,  y  )

#! Valid
# Function call - triple spaces
TestFunc30():void=
    f(   x,   y   )

#! Valid
# Function call - tabs
TestFunc31():void=
	f	(	x	,	y	)

#! Valid
# Function call - mixed whitespace
TestFunc32():void=
    f  (  x  ,  y  )

#! Valid
# Method call - no spaces
TestFunc33():void=
    Math.Add(1,2)

#! Valid
# Method call - single spaces
TestFunc34():void=
    Math.Add( 1, 2 )

#! Valid
# Method call - double spaces
TestFunc35():void=
    Math.Add(  1,  2  )

#! Valid
# Method call - spaces around dot
TestFunc36():void=
    Math  .  Add  (  1  ,  2  )

#! Valid
# Logical and - single spaces
TestFunc37():void=
    x and y

#! Valid
# Logical and - double spaces
TestFunc38():void=
    x  and  y

#! Valid
# Logical and - triple spaces
TestFunc39():void=
    x   and   y

#! Valid
# Logical and - tabs
TestFunc40():void=
