# ==== Doc Comments Test Suite ====
# Tests for ## (doc comment) support

#! Valid TopLevel
# Basic doc comment before class
## This is a documentation comment
MyClass := class:
    Field : int = 5

#! Valid TopLevel
# Multiple doc comments
## First doc comment line
## Second doc comment line
MyFunction() : void = { }

#! Valid TopLevel
# Doc comment with regular comment
## Documentation comment
# Regular comment
TestClass := class:

#! Valid TopLevel
# Doc comment before method
MyClass := class:
    ## This method does something
    DoSomething() : void = { }

#! Valid TopLevel
# Doc comment before field
MyClass := class:
    ## The player's health value
    Health : int = 100

#! Valid TopLevel
# Mixed comments and doc comments
# Regular comment
## Doc comment
# Another regular comment
MyModule := module:
    Field := 10

#! Valid TopLevel
# Doc comment with special characters
## This is a doc comment with symbols: @param #value $test
SomeFunction(x: int) : int = x * 2

#! Valid TopLevel
# Empty doc comment
##
EmptyDocClass := class:

#! Valid TopLevel
# Doc comment at end of line (inline)
MyClass := class: ## Inline doc comment
    Field : int = 0

#! Valid TopLevel
# Doc comments in method body
MyClass := class:
    Method() : void =
        ## Doc inside method
        DoSomething()
        ## Another doc comment
        DoSomethingElse()

#! Valid TopLevel
# Doc comment before using statement
## Module documentation
using { /Fortnite.com/Devices }

#! Valid TopLevel
# Doc comment with indented content
## This class handles
##   - Feature A
##   - Feature B
##   - Feature C
ComplexClass := class:
    Field : int = 0

#! Valid TopLevel
# Nested doc comments in nested classes
## Outer class doc
OuterClass := class:
    ## Inner class doc
    InnerClass := class:
        ## Inner field doc
        InnerField : int = 5

#! Valid TopLevel
# Doc comment before decorator
## Main entry point
@main
MainFunction() : void = { }

#! Valid TopLevel
# Long doc comment
## This is a very long documentation comment that spans across the line and contains lots of information about the implementation details and usage patterns
LongDocClass := class:

#! Valid
# Doc comment in expression context
x := ## inline doc
     5

#! Valid TopLevel
# Doc comment with code example
## Example usage:
##   MyClass := MyClass{}
##   MyClass.DoSomething()
ExampleClass := class:
    DoSomething() : void = { }

#! Valid TopLevel
# Multiple consecutive doc comment blocks
## Block 1
##
## Block 2
##
## Block 3
MultiBlockClass := class:

#! Valid TopLevel
# Doc comment with markdown-like formatting
## # Heading
## **Bold text** and *italic text*
## `code snippet`
FormattedDocClass := class:

#! Valid TopLevel
# Doc comment before type alias
## Type alias for player ID
player_id := type{int}