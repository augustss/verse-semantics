#! Valid

f():=
	# hi
	
	1
	

#! Valid
# Basic variable declarations with correct syntax
var x : int = 5
var y := 10
var z = 15

#! Valid
# Optional types with correct assignment operator
var MyOptional : ?int = false
var Container : ?cancellable = false
var Result : ?string = false

#! Error
# Invalid: explicit type with := operator
var x : int := 5

#! Valid
# Generic type parameters
var TestMap : weak_map(int, string) = map{}
var MyList : list(float) = array{}
var Cache : map(string, int) = map{}

#! Valid
# Enum declarations with specifiers
TestEnum<public> := enum{First, Second, Third}
MyEnum := enum<persistable>{Active, Inactive, Pending}
SimpleEnum := enum{A, B, C}

#! Valid
# Multiple class parents
BaseClass<public> := class(creative_device, ITickable):
    OnBegin<override>()<suspends>:void=
        Print("Started")

#! Valid
# Class with single parent
MyDevice := class(creative_device):
    Score : int = 0
    Name : string = "Default"

#! Valid
# Complex field declarations
SomeClass := class:
    @editable
    PropToBuy: creative_prop = creative_prop{}

    @editable
    Barrier<private> : barrier_device = barrier_device{}

    Vector : vector3 = vector3{X:=19.0, Y:=45.0, Z:=580.0}

#! Valid
# Function declarations with specifiers
MyFunction<public>(Agent : agent)<suspends> : void =
    if (Agent.GetFortCharacter[]):
        Print("Character found")

#! Valid
# For loops
TestLoop():void=
    for (x : Items):
        Print("Item")
    for (i := 0..10):
        Print("Index")

#! Error
# Invalid: array is a keyword, cannot be used as identifier for indexing
array[5]

#! Valid
# Array indexing with valid identifiers
myArray[5]
obj.field[0]
GetArray()[index]

#! Valid
# If statements with complex conditions
TestConditions():void=
    if (Barrier.TeleportTo[Vector, rotation{}]):
        Print("Teleport successful")

    if (x > 5 and y < 10):
        DoSomething()

#! Error
# Import statements (not yet fully integrated)
import(/UnrealEngine.com)
import(/Fortnite.com/Devices)

#! Valid
# Using statements
using { /Fortnite.com/Characters }
using { /Verse.org/Simulation }

#! Valid
# Set operations
TestSet(Agent : agent):void=
    set Plr = option{Agent}
    set Character = option{Agent.GetFortCharacter[]}
    set Counter += 1

#! Error
# Invalid: Missing type in explicit type declaration
var x : = 5

#! Valid
# Module declarations
test_module<public> := module:
    TestFunction():void = Print("Hello")

#! Valid
# Constructor calls
TestConstructors():void=
    MyRotation := rotation{}
    MyVector := vector3{X:=1.0, Y:=2.0, Z:=3.0}
    MyTransform := transform{Translation:=vector3{}, Rotation:=rotation{}}

#! Valid
# Event declarations
RaceStartEvent<public>:event() = event{}
PlayerJoinedEvent:event(agent) = event(agent){}

#! Valid
# Lambda expressions
TestLambda():void=
    lambda x: x + 1
    lambda (a, b): a * b

#! Valid
# Case statements
TestCase(Value : int):void=
    case (Value):
        1 => Print("One")
        2 => Print("Two")
        _ => Print("Other")

#! Error
# Invalid: var with explicit type cannot use :=
var TestVar : weak_map(session, int) := map{}

#! Valid
# Correct generic type syntax
var TestVar : weak_map(session, int) = map{}
var TestVar2 := map{}

#! Valid
# Spawn blocks
TestSpawn(Agent : agent):void=
    spawn{AddPlayerToValidAudioTargets(Agent)}
    spawn{ProcessAsync()}

#! Valid
# String interpolation
TestStrings():void=
    Name := "Player"
    Print("Hello {Name}")
    Print("Score: {Score} points")

#! Valid
# Decorators
@editable
TestDevice : creative_device = creative_device{}

@editable{ToolTip := "This is a test"}
ComplexDecorator : button_device = button_device{}

#! Valid
# Array and map literals
TestLiterals():void=
    MyArray := array{1, 2, 3, 4, 5}
    MyMap := map{}
    EmptyArray := array{}
    EmptyMap := map{}

#! Valid
# Method chaining and property access
TestChaining():void=
    Result := Object.Method1().Method2().Property
    Value := GetPlayer().GetFortCharacter[].GetHealth()