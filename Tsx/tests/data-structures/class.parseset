  {
    expr: {
      type: ConstDeclaration
      name: { type: "identifier", value: "height", leadingTrivia: [], trailingTrivia: [{ type: "whitespace", value: " " }] }
      assignOp: { type: ":=", leadingTrivia: [], trailingTrivia: [{ type: "whitespace", value: " " }] }
      value: { type: "IntegerLiteral", token: { value: 20, leadingTrivia: [], trailingTrivia: [{ type: "whitespace", value: " " }] } }
      span: { start: 31, end: 42 }
