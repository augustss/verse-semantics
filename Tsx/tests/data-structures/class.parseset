style: "braces"
leftBrace: { type: "{", leadingTrivia: [], trailingTrivia: [{ type: "whitespace", value: " " }] }
body: [
  {
    expr: {
      type: ConstDeclaration
      name: { type: "identifier", value: "width", leadingTrivia: [], trailingTrivia: [{ type: "whitespace", value: " " }] }
      assignOp: { type: ":=", leadingTrivia: [], trailingTrivia: [{ type: "whitespace", value: " " }] }
      value: { type: "IntegerLiteral", token: { value: 10, leadingTrivia: [], trailingTrivia: [] } }
      span: { start: 19, end: 29 }
