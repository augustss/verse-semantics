# Complex Class Tests

#! Valid TopLevel
# 1. Complex class with multiple members (working version)
game_device := class(creative_device):
    @editable
    EnabledDevice:enabled_device = enabled_device{}

    @editable
    Score:int = 0

    OnEnabled(Agent:agent):void = Print("Device enabled")

#! Valid TopLevel
# 2. Class with inheritance and decorators
simple_device := class(creative_device):
    @editable
    value:int = 42

#! Valid TopLevel
# 3. Class with method specifiers
my_device := class:
    OnBegin<override>():void = Print("Starting")

#! Valid TopLevel
# 4. Class with suspends method
async_device := class:
    DoAsync<suspends>():void = Wait(1.0)