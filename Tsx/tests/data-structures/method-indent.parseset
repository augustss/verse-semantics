#! Valid TopLevel
# 1. Empty case branch - parser bug: currently passes when it should fail
# The _ => branch has no body, making the structure ambiguous
CaptureControl := class:
    @editable
    var CapturePoints : []capture_point = array{}

    OnBegin<override>()<suspends>:void=
        for (i -> EachCapPoint : CapturePoints):
            case (i):
                0 => EachCapPoint.ControlChangeEvent.Subscribe(CaptureChange_A)
                1 => EachCapPoint.ControlChangeEvent.Subscribe(CaptureChange_B)
                _ => 1

#! Error TopLevel
# 2. Empty case branch with wrong indentation - parser bug: currently passes when it should fail
# Done() is at the same indentation as case, not properly indented for the _ => branch
CaptureControl := class:
    OnBegin<override>()<suspends>:void=
            case (i):
                1 => EachCapPoint.ControlChangeEvent.Subscribe(CaptureChange_B)
                _ =>
            Done()

