# Test cases for interface, struct, and enum declarations

#! Valid TopLevel
# 1. Basic interface
MyInterface := interface {}


#! Valid TopLevel
# 2. Basic interfaces
MyInterface := interface {}
MyInterface2:=interface{

    }


#! Valid TopLevel
# 3. Interface with members (indentation style)
IPlayer := interface:
    GetHealth():int
    SetHealth(value:int):void

#! Valid TopLevel
# 4. Interface with properties (brace style)
IGameObject := interface {
    Position: vector3
    Rotation: quaternion
}

#! Valid TopLevel
# 5. Interface with inheritance
IAdvancedPlayer := interface(IPlayer):
    GetArmor():int
    SetArmor(value:int):void

#! Valid TopLevel
# 6. Interface with empty parentheses
ISimple := interface()
 
#! Valid TopLevel
# 7. Basic struct
Point := struct {}

#! Valid TopLevel
# 8. Struct with fields (indentation style)
Vector3 := struct:
    X: float
    Y: float
    Z: float

#! Valid TopLevel
# 9. Struct with fields (brace style)
Rectangle := struct {
    Width: float
    Height: float
}

#! Valid TopLevel
# 10. Struct with methods
ComplexNumber := struct:
    Real: float
    Imaginary: float
    Magnitude():float = Math.Sqrt(Real * Real + Imaginary * Imaginary)
    Add(other:ComplexNumber):ComplexNumber = ComplexNumber{Real: Real + other.Real, Imaginary: Imaginary + other.Imaginary}

#! Valid TopLevel
# 11. Struct with inheritance
ColoredPoint := struct(Point):
    Color: color

#! Valid TopLevel
# 12. Struct with empty parentheses
EmptyStruct := struct()
 
#! Valid TopLevel
# 13. Basic enum
Direction := enum {}

#! Valid TopLevel
# 14. Enum with values (indentation style)
CardSuit := enum:
    Hearts
    Diamonds
    Clubs
    Spades

#! Valid TopLevel
# 15. Enum with explicit values (brace style)
Priority := enum {
    Low,
    Medium,
    High
}

#! Valid TopLevel
# 16. Enum with mixed values
Status := enum:
    Idle
    Running
    Paused
    Stopped

#! Valid TopLevel
# 17. Interface with nested types
IContainer := interface:
    ItemType := struct {
        ID: int
        Name: string
    }
    AddItem(item:ItemType):void
    GetItem(id:int):ItemType?

#! Valid TopLevel
# 18. Module with interface, struct, and enum
GameTypes := module:
    Direction := enum {
        North
        South
        East
        West
    }
    Position := struct {
        X: int
        Y: int
    }
    IMovable := interface {
        GetPosition():Position
        Move(direction:Direction):void
    }

#! Valid TopLevel
# 19. Class implementing interface
Player := class(IPlayer):
    var Health:int = 100
    GetHealth():int = Health
    SetHealth(value:int):void = { Health = value }

#! Valid TopLevel
# 20. Struct with enum field
GameState := struct:
    CurrentStatus: Status
    Position: Vector3
    LastUpdate: float

#! Valid TopLevel
# 21. Empty interface with brace syntax
Empty1 := interface {}

#! Valid TopLevel
# 22. Empty interface with parentheses
Empty2 := interface()

#! Valid TopLevel
# 23. Empty interface with colon
Empty3 := interface():

#! Valid TopLevel
# 24. Empty struct with brace syntax
EmptyS1 := struct {}
  
#! Valid TopLevel
# 25. Empty enum with brace syntax
EmptyE1 := enum {}

#! Error TopLevel
# 26. Empty enum wi
EmptyE2 := enum

#! Valid TopLevel
# 27. Empty enum with colon
EmptyE3 := enum:

#! Valid TopLevel
# 28. Nested declarations in module
Container := module:
    Data := struct:
        InnerEnum := enum {
            OptionA
            OptionB
        }
        Value: InnerEnum
        Count: int