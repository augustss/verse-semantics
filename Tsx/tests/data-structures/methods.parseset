# Method Declaration Tests

#! Valid Expression
# 1. Simple method with braces (should work)
Test := class { DoSomething():= x }

#! Valid Expression
# 2. Method with indentation (currently fails - returns empty body)
Test := class:
    DoSomething():= x

#! Valid Expression
# 3. Field with braces (should work)
Test := class { x:int= 1 }

#! Valid Expression
# 4. Field with indentation (currently fails - returns empty body)
Test := class:
    x:int= 1

#! Valid Expression
# 5. Multiple methods with braces
Test := class {
    GetX():int= x
    SetX(val:int):= x := val
}

#! Valid Expression
# 6. Method with specifiers (braces)
Test := class { OnBegin<override>()<suspends>:void= x }

#! Valid Expression
# 7. Class inheritance with method
Player := class(Entity) { Update():= Move() }