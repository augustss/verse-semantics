# Class member test cases

# Simple field declaration
MyClass := class {
  name:string
}
===
MyClass := class {
  name:string
}

# Field with initializer
MyClass := class {
  count:int = 0
}
===
MyClass := class {
  count:int = 0
}

# Field with decorator
MyClass := class {
  @editable
  position:vector3
}
===
MyClass := class {
  @editable
  position:vector3
}

# Field with decorator and initializer
MyClass := class {
  @editable
  health:float = 100.0
}
===
MyClass := class {
  @editable
  health:float = 100.0
}

# Multiple fields
MyClass := class {
  name:string
  age:int = 0
  @editable
  position:vector3
}
===
MyClass := class {
  name:string
  age:int = 0
  @editable
  position:vector3
}

# Class with inheritance and field
Vehicle := class(BaseEntity) {
  speed:float = 0.0
}
===
Vehicle := class(BaseEntity) {
  speed:float = 0.0
}

# Field with complex type
MyClass := class {
  items:[]string = array{}
}
===
MyClass := class {
  items:[]string = array{}
}

# Field with type containing dots
MyClass := class {
  device:capture_area_device
}
===
MyClass := class {
  device:capture_area_device
}

# Indentation style with field
MyClass := class:
  name:string
===
MyClass := class:
  name:string

# Indentation style with multiple fields
MyClass := class:
  name:string
  age:int = 0
  @editable
  position:vector3
===
MyClass := class:
  name:string
  age:int = 0
  @editable
  position:vector3

# Real Verse example
capturepoint_lighting_control := class(creative_device):
  @editable
  CapturePoints:[]capture_area_device = array{}
===
capturepoint_lighting_control := class(creative_device):
  @editable
  CapturePoints:[]capture_area_device = array{}