        PlayersConnected : int = 0
        GameActive : logic = false

        StartGame() : void = {
            set GameActive = true
            Print("Game started with {PlayersConnected} players")
        }

        AddPlayer() : void = {
            set PlayersConnected = PlayersConnected + 1
            if (PlayersConnected >= 2) {
