#! Valid
# Deeply nested complex if-then-else
TestDeeplyNested():void=
    result := if (level1) then (
        if (level2a) then (
            if (level3a) then (
                if (level4) then deepValue1 else deepValue2
            ) else (
                midValue1
            )
        ) else if (level2b) then (
            if (level3b) then midValue2 else midValue3
        ) else (
            shallowValue
        )
    ) else (
        if (altCondition) then altValue else defaultValue
    )

