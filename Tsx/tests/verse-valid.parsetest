#! Valid
# Classes with nested curly brace blocks
TestNestedCurlyBraceBlocks():void=
    GameManager := class {
        Score : int = 0
        Lives : int = 3

        ProcessTurn(playerAction : string) : logic = {
            if (playerAction = "attack") {
                enemyHealth := 10
                damage := 5
                set enemyHealth = enemyHealth - damage

                if (enemyHealth <= 0) {
                    set Score = Score + 100
                    Print("Enemy defeated! Score: {Score}")
                    true
                } else {
                    Print("Enemy health: {enemyHealth}")
                    false
                }
            } else if (playerAction = "defend") {
                Print("Player defending")
                true
            } else {
                set Lives = Lives - 1
                if (Lives <= 0) {
                    Print("Game Over!")
                    false
                } else {
                    Print("Invalid action! Lives remaining: {Lives}")
                    true
                }
            }
        }
    }

#! Valid
# Classes with curly brace property accessors
TestCurlyBraceProperties():void=
    PlayerStats := class {
        var Health : int = 100
        var Mana : int = 50

        GetHealthPercent() : float = {
            Health / 100.0
        }

        SetHealth(newHealth : int) : void = {
            if (newHealth >= 0 and newHealth <= 100) {
                set Health = newHealth
            }
        }

        RestoreMana(amount : int) : void = {
            newMana := Mana + amount
            if (newMana > 100) {
                set Mana = 100
            } else {
                set Mana = newMana
            }
        }
    }

#! Valid
# Generic classes with curly braces
TestCurlyBraceGenerics():void=
    Container<T> := class {
        Items : []T = array{}
        Count : int = 0

        Add(item : T) : void = {
            set Items = Items + array{item}
            set Count = Count + 1
        }

        Get(index : int) : ?T = {
            if (index >= 0 and index < Count) {
                Items[index]
            } else {
                false
            }
        }

        Clear() : void = {
            set Items = array{}
            set Count = 0
        }
    }

#! Valid
# Classes with curly brace error handling
TestCurlyBraceErrorHandling():void=
    SafeCalculator := class {
        LastResult : ?float = false
        ErrorMessage : string = ""

        Divide(a : float, b : float) : ?float = {
            if (b = 0.0) {
                set ErrorMessage = "Division by zero"
                set LastResult = false
                false
            } else {
                result := a / b
                set LastResult = result
                set ErrorMessage = ""
                result
            }
        }

        SafeOperation(operation : string, x : float, y : float) : ?float = {
            try {
                if (operation = "divide") {
                    Divide(x, y)
                } else if (operation = "sqrt") {
                    if (x >= 0.0) {
                        result := x ^ 0.5
                        set LastResult = result
                        result
                    } else {
                        set ErrorMessage = "Negative square root"
                        false
                    }
                } else {
                    set ErrorMessage = "Unknown operation"
                    false
                }
            } catch {
                set ErrorMessage = "Operation failed"
                set LastResult = false
                false
            }
        }
    }

#! Valid
# Mixed colon and curly brace syntax in classes
TestMixedClassSyntax():void=
    HybridClass := class(creative_device): {
        # Colon for inheritance, curly brace for body
        PublicValue : int = 42

        Initialize() : void = {
            Print("Hybrid class initialized")
        }
    }

    AnotherHybrid := class {
        # Curly brace for main body
        Settings : map(string, int) = map{}

        ConfigureSettings() : void = {
            if (Settings.Length = 0): {
                # Colon for if condition, curly for body
                set Settings = map{"default" -> 1, "advanced" -> 2}
            }
        }

        ProcessConfig(mode : string) : void = {
            for (key : Settings.Keys) {
                if (key = mode) {
                    value := Settings[key]
                    Print("Processing {key} with value {value}")
                } else {
                    Print("Skipping {key}")
                }
            }
        }
    }

#! Valid
# Classes with curly brace loops and control flow
TestCurlyBraceControlFlow():void=
    LoopProcessor := class {
        Data : []int = array{1, 2, 3, 4, 5}
        var ProcessedCount : int = 0

        ProcessAllData() : void = {
            for (item : Data) {
                if (item > 2) {
                    Print("Processing item: {item}")
                    set ProcessedCount = ProcessedCount + 1
                } else {
                    Print("Skipping item: {item}")
                }
            }
        }

        ProcessWithWhile() : void = {
            var index :int= 0
            while (index < Data.Length) {
                current := Data[index]
                if (current % 2 = 0) {
                    Print("Even number: {current}")
                } else {
                    Print("Odd number: {current}")
                }
                set index = index + 1
            }
        }
    }

#! Valid
# Interface implementations with curly braces
TestCurlyBraceInterfaces():void=
    Drawable := interface {
        Draw() : void
        GetBounds() : vector3
    }

    Sprite := class(Drawable) {
        Position : vector3 = vector3{}
        Size : vector3 = vector3{X := 1.0, Y := 1.0, Z := 1.0}

        Draw() : void = {
            Print("Drawing sprite at {Position}")
        }

        GetBounds() : vector3 = {
            vector3{
                X := Position.X + Size.X,
                Y := Position.Y + Size.Y,
                Z := Position.Z + Size.Z
            }
        }
    }

