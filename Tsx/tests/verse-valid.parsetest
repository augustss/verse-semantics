#! Valid
# Struct with methods and computed properties
TestStructMethods():void=
    Rectangle := struct:
        Width : float = 1.0
        Height : float = 1.0

        GetArea():float = Width * Height
        GetPerimeter():float = 2.0 * (Width + Height)
