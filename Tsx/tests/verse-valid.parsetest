#! Valid
# Concurrent operations with specifiers
TestConcurrentSpecifiers():void=
    ParallelProcess(items:[]string)<suspends><writes><computes>:[]result =
        race:
            ProcessBatch1(items[0..items.Length()/2])<suspends><computes>
            ProcessBatch2(items[items.Length()/2..items.Length()])<suspends><computes>

    ConcurrentValidation(inputs:[]string)<decides><reads><suspends>:logic =
        spawn:
            for (input : inputs):
                if (not ValidateInput(input)<decides><reads>):
                    return false
        return true

