#! Valid
# Complex class hierarchy
TestClassHierarchy():void=
    Entity := class:
        Id : int = 0
        Active : logic = true

        Initialize(id:int):void = set Id = id
        Activate():void = set Active = true
        Deactivate():void = set Active = false

    GameObject := class(Entity):
        Transform : transform = transform{}

        SetPosition(pos:vector3):void =
            set Transform = transform{Translation := pos}

    Player := class(GameObject):
        Health : int = 100
        Name : string = ""

        TakeDamage(damage:int):void =
            set Health = Health - damage
            if (Health <= 0):
                OnDeath()

        OnDeath():void = Print("Player {Name} died")

#! Valid
# Abstract classes and virtual methods
TestAbstractClasses():void=
    Animal := class:
        Name : string = ""

       MakeSound <virtual>():void = Print("Generic animal sound")
       GetSpecies <abstract>():string

    Dog := class(Animal):
        MakeSound<overrides>():void = Print("Woof!")


#! Valid
# Enum classes and specialized types
TestSpecializedClasses():void=
    Color := enum:
        Red
        Green
        Blue

    StateEnum := enum<public>:
        Idle
        Running
        Jumping

    StatusClass := class:
        CurrentColor : Color = Color.Red
        State : StateEnum = StateEnum.Idle

#! Valid
# Classes with events and delegates
TestClassEvents():void=
    EventPublisher := class:
        PlayerJoined : event(agent) = event(agent){}
        ScoreChanged : event(int) = event(int){}

        AddPlayer(player:agent):void =
            PlayerJoined.Signal(player)

        UpdateScore(newScore:int):void =
            ScoreChanged.Signal(newScore)

#! Valid
# Mixin and trait-like patterns
TestMixinPatterns():void=
    Loggable := class:
        LogLevel : int = 1

        Log(message:string):void =
            if (LogLevel > 0):
                Print("[LOG] {message}")

    Configurable := class:
        Settings : map(string, string) = map{}

        GetSetting(key:string):?string =
            if (Value := Settings[key]):
                Value
            else:
                false

    Component := class(Loggable, Configurable):
        ComponentName : string = "Default"

        Initialize():void =
            Log("Initializing component {ComponentName}")

#! Valid
# Classes with operator overloading
TestOperatorOverloading():void=
    Vector := class:
        X : float = 0.0
        Y : float = 0.0

        operator+(other:Vector):Vector =
            Vector{X := X + other.X, Y := Y + other.Y}

        operator*(scalar:float):Vector =
            Vector{X := X * scalar, Y := Y * scalar}

#! Valid
# Class templates and specialization
TestClassTemplates():void=
    Stack<T> := class:
        Items : []T = array{}

        Push(item:T):void =
            set Items = Items + array{item}

        Pop():?T =
            if (Items.Length > 0):
                Result := Items[Items.Length - 1]
                set Items = Items.RemoveLast()
                Result
            else:
                false

#! Valid
# Function declarations with various specifiers
TestFunctionSpecifiers():void=
    DecideFunction()<decides>:logic = true
    SucceedFunction()<succeeds>:void = Print("Success")
    FailFunction()<fails>:void = Print("Fail")
    TransactFunction()<transacts>:void = DoTransaction()
    ComputeFunction()<computes>:int = 42
    AmbiguateFunction()<ambiguates>:int = RandomValue()
    ReadFunction()<reads>:string = GetStoredValue()
    WriteFunction()<writes>:void = SaveValue("data")
    AllocateFunction()<allocates>:object = CreateNewObject()
    SuspendFunction()<suspends>:void = WaitForEvent()
    ClosedFunction()<closed>:void = FinalizeOperation()

#! Valid
# Functions with multiple specifiers
TestMultipleSpecifiers():void=
    ComplexFunction()<suspends><transacts>:void =
        PerformAsyncTransaction()

    ReadWriteFunction()<reads><writes>:void =
        ProcessDataInPlace()

    DecideComputeFunction()<decides><computes>:int =
        CalculateDecision()

#! Valid
# Functions with specifiers and parameters
TestSpecifiersWithParameters():void=
    ProcessPlayer(player:agent)<suspends><writes>:void =
        UpdatePlayerData(player)

    CalculateScore(base:int, multiplier:float)<computes><reads>:int =
        GetStoredBonus() * base * multiplier

    ValidateInput(input:string)<decides><reads>:logic =
        IsValidAgainstRules(input)

#! Valid
# Functions with specifiers and return types
TestSpecifiersWithReturnTypes():void=
