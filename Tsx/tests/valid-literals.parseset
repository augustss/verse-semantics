# Valid Literals
# String literals, numbers, booleans

#! Valid expression
# 1. Integer literal
42

#! Valid expression
# 2. Float literal with no integer part
.5

#! Valid expression
# 3. Float literal with no decimal part
5.

#! Valid expression
# 4. Boolean true
true

#! Valid expression
# 5. Boolean false
false

#! Valid expression
# 6. String literal
"Hello"

#! Valid expression
# 7. String with escaped quote
"He said \"hello\""

#! Valid expression
# 8. String with multiple escapes
"Quote: \"\tTab\nNewline\\"

#! Valid expression
# 9. Integer with scientific notation becomes float
1e10

#! Valid expression
# 10. Float with positive exponent
1.5e+10

#! Valid expression
# 11. Float with negative exponent
1.5e-10

#! Valid expression
# 12. Keywords can appear in strings
"block and continue are keywords"
