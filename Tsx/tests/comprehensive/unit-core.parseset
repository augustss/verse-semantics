# Unit Tests from test-*.ts files
# Converted from TypeScript test files to parseset format

# ========================================
# Boolean Literal Tests
# ========================================

#! Valid Expression
# 1. Basic true literal
true

#! Valid Expression
# 2. Basic false literal
false

#! Valid Expression
# 3. Boolean in if condition
block:
  if(true) then { 42 }
  if ( true ) then { 32 }
  if true then { 23 }

#! Valid Expression
# 4. Boolean in comparison
x == true

#! Valid Expression
# 5. Boolean with logical operators
true and false

#! Valid Expression
# 6. Boolean with not operator
not true

#! Valid Expression
# 7. Nested boolean expressions
(true or false) and not false

#! Valid Expression
# 8. Boolean in array
array{true, false, true}

#! Valid Expression
# 9. Boolean const declaration
isActive := true

#! Error Expression
# 10. Reject true as identifier
true := 5

#! Valid Expression
# 11. Allow method call on boolean literal
false.method()

# ========================================
# Class Expression Tests
# ========================================

#! Valid Expression
# 12. Empty class with braces
MyClass := class { }

#! Valid Expression
# 13. Class with single method
Test := class { DoSomething():= x }

#! Valid Expression
# 14. Class with field
Test := class { x:int= 1 }

#! Valid Expression
# 15. Class with var field
Test := class { var count:int= 0 }

#! Valid Expression
# 16. Class with multiple members
Test := class {
  GetX():int= x
  SetX(val:int):= x := val
}

#! Valid Expression
# 17. Class with inheritance
Player := class(Entity) { Update():= Move() }

#! Valid Expression
# 18. Class with method specifiers
Test := class { OnBegin<override>()<suspends>:void= x }

#! Valid Expression
# 19. Class with indentation style
Test := class:
  DoSomething():= x

#! Valid Expression
# 20. Class with field initializer
Config := class { maxPlayers:int= 100 }

#! Valid Expression
# 21. Class with method parameters
Math := class { Add(a:int, b:int):int= a + b }

#! Valid Expression
# 22. Anonymous class
class { x:int }

#! Error Expression
# 23. Reject malformed class
Test := class

#! Error Expression
# 24. Reject class with invalid member
Test := class { 123 }

# ========================================
# Keyword Validation Tests
# ========================================

#! Error Expression
# 25. Reject var as identifier
var := 5

#! Error Expression
# 26. Reject if as identifier
if := 5

#! Error Expression
# 27. Reject then as identifier
then := 5

#! Error Expression
# 28. Reject else as identifier
else := 5

#! Error Expression
# 29. Reject for as identifier
for := 5

#! Error Expression
# 30. Reject case as identifier
case := 5

#! Error Expression
# 31. Reject block as identifier
block := 5

#! Error Expression
# 32. Reject using as identifier
using := 5

#! Error Expression
# 33. Reject module as identifier
module := 5

#! Error Expression
# 34. Reject class as identifier
class := 5

#! Error Expression
# 35. Reject interface as identifier
interface := 5

#! Error Expression
# 36. Reject enum as identifier
enum := 5

#! Error Expression
# 37. Reject struct as identifier
struct := 5

#! Error Expression
# 38. Reject function as identifier
function := 5

#! Error Expression
# 39. Reject return as identifier
return := 5

#! Error Expression
# 40. Reject break as identifier
break := 5

#! Error Expression
# 41. Reject continue as identifier
continue := 5

#! Error Expression
# 42. Reject not as identifier
not := 5

#! Error Expression
# 43. Reject and as identifier
and := 5

#! Error Expression
# 44. Reject or as identifier
or := 5

#! Error Expression
# 45. Reject array as identifier
array := 5

#! Error Expression
# 46. Reject true as identifier
true := 5

#! Error Expression
# 47. Reject false as identifier
false := 5

#! Valid Expression
# 48. Allow array construction
array{1, 2, 3}

#! Valid Expression
# 49. Allow class expression
MyClass := class { }

#! Valid Expression
# 50. Allow if expression
if(x > 0) then { x }

#! Valid Expression
# 51. Allow for expression
for(i : items) { print(i) }

#! Error Expression
# 52. Missing delimiter
case(x): 0 => "zero" _ => "other"

#! Valid Expression
# 53. Allow block expression
block:
  x := 1; x + 1 

#! Valid Expression
# 54. Allow var declaration
var x:int = 5

#! Valid Expression
# 55. Allow logical operators
a and b or c

#! Valid Expression
# 56. Allow not operator
not condition

#! Valid Expression
# 57. Allow keywords in strings
"class is a keyword"

#! Valid Expression
# 58. Allow regular identifiers
myVariable := 42

#! Valid Expression
# 59. Allow identifiers with underscores
my_var := 10

#! Valid Expression
# 60. Allow identifiers with numbers
var1 := 1

#! Valid Expression
# 61. Allow camelCase identifiers
myLongVariableName := "test"

#! Valid Expression
# 62. Allow PascalCase identifiers
MyClass := 123

#! Valid Expression
# 63. Allow keyword-like identifiers
classes := 5

#! Valid Expression
# 64. Allow keyword prefixes
ifCondition := true

#! Valid Expression
# 65. Allow keyword suffixes
valueFor := 10

#! Valid Expression
# 66. Complex expression with multiple keywords
if(true) then { array{1,2,3} } else {  { var x:int = 5; x } }

#! Valid Expression
# 67. Nested keywords in valid contexts
MyClass := class { Check():bool= not false }

# ========================================
# Integration Tests
# ========================================

#! Valid Expression
# 68. Simple class with boolean field
Config := class { enabled: bool = true }

#! Valid Expression
# 69. If expression with boolean literal
result := if(true) then { 42 } else { 0 }

#! Valid Expression
# 70. Class method returning boolean
Validator := class { IsValid(x:int): bool = x > 0 }

#! Valid Expression
# 71. Array of booleans
flags := array{true, false, true, true}

#! Valid Expression
# 72. Logical expression with booleans
canProceed := isReady and not isBlocked or hasOverride
 
#! Valid Expression
# 73. Complex boolean logic
valid := (age >= 18 and age <= 65) and (not retired or hasException)

#! Valid Expression
# 74. Class with multiple methods
Calculator := class {
  Add(a:int, b:int): int = a + b
  Subtract(a:int, b:int): int = a - b
  IsPositive(x:int): bool = x > 0
}

#! Valid Expression
# 75. Mathematical expressions with precedence
result := not false or true and false or (true and not false)

#! Error Expression
IsValid := (x: int): bool = x > 0 and x < 100

#! Valid Expression
# 76. Switch-like case with booleans
message := case(true):
  isError => "Error occurred"
  isWarning => "Warning"
  isInfo => "Information"
  _ => "Unknown"

#! Valid Expression
# 77. Complex GameManager class
GameManager := class(BaseManager) {
  var players: []Player = array{}
  var isRunning: bool = false

  Start(): void = {
    isRunning := true;
    InitializePlayers()
  }

  AddPlayer(p: Player): bool = {
    if(not isRunning) then {
      players := players + array{p};
      true
    } else {
      false
    }
  }

  GetPlayerCount(): int = players.length
}

#! Valid Expression
# 78. Nested control flow with booleans
result := if(true and not false) then {
  for(i : 0..10) {
    if(i > 5) then { break } else { continue }
  }
} else {
  case(status):
    0 => false
    1 => true
    _ => not true
}

#! Valid Expression
builder := class {
  value: string = ""

  Add(s: string): x = {
    value := value + s;
    this
  }

  Build(): string = value
}
 
#! Valid Expression
# 79. Class with decorators and specifiers
@editable
UIComponent := class {
  @editable
  var visible: bool = true

  OnBegin<override>()<suspends>: void = {
    Initialize();
    Wait(1.0)
  }

  Show<public>(): void = visible := true
  Hide<public>(): void = visible := false
}

#! Valid Expression
# 80. Complex object construction
config := Config{
  maxPlayers := 100,
  enablePvP := true,
  gameMode := if(isRanked) then { "competitive" } else { "casual" },
  settings := Settings{
    graphics := "high",
    soundEnabled := not isMuted
  }
}

#! Valid Expression
# 81. Class inheritance chain
Animal := class {
  Move(): void = print("moving")
}

Dog := class(Animal) {
  Bark(): void = print("woof")
}

Puppy := class(Dog) {
  Play(): void = {
    Bark();
    Move()
  }
}