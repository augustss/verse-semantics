# Additional Unit Tests from remaining test-*.ts files
# Converted from TypeScript test files to parseset format

# ========================================
# Invalid Syntax Tests
# ========================================

#! Error Expression
# 1. Variable declaration without name
var : int = 42

#! Error Expression
# 2. Variable declaration without type
var x = 42

#! Error Expression
# 3. Variable declaration without value
var x : int

#! Error Expression
# 4. Empty case expression (colon style)
case(x):

#! Error Expression
# 5. Empty case expression (brace style)
case(x) {}

#! Error Expression
# 6. Empty case expression with spaces
case(x) { }

#! Error Expression
# 7. Reserved keyword as identifier - if
if := 5

#! Error Expression
# 8. Reserved keyword as identifier - for
for : int = 10

#! Error Expression
# 9. Reserved keyword as identifier - var
var : int = 42

#! Error Expression
# 10. Reserved keyword as object type - case
case{x := 1}

#! Error Expression
# 11. Reserved keyword as object type - if
if{x := 1}

#! Error Expression
# 12. Reserved keyword as object type - var
var{x := 1}

# ========================================
# Valid Syntax Tests
# ========================================

#! Valid Expression
# 13. Proper variable declaration
var x : int = 42

#! Valid Expression
# 14. Case with single branch
case(x) { 1 => a }

#! Valid Expression
# 15. Case with default branch
case(x) { _ => }

#! Valid Expression
# 16. Case with multiple branches
case(x) { 1 => a, 2 => b, _ => c }

#! Valid Expression
# 17. If with empty then and else
if(condition) then:


else:
  default

#! Valid Expression
# 18. Complex for loop with nested if
for(item : items):
  result := process(item)
  if(result > 5) then:
    log("big")
    log("also big")
  else:
    log("small")

# ========================================
# Methods Tests
# ========================================

#! Valid Expression
# 19. Simple method with braces
Test := class { DoSomething():= x }

#! Valid Expression
# 20. Method with indentation
Test := class:
  DoSomething():= x

#! Valid Expression
# 21. Field with braces
Test := class { x:int= 1 }

#! Valid Expression
# 22. Field with indentation
Test := class:
  x:int= 1

#! Valid Expression
# 23. Multiple methods with braces
Test := class {
  GetX():int= x
  SetX(val:int):= x := val
}

#! Valid Expression
# 24. Method with specifiers (braces)
Test := class { OnBegin<override>()<suspends>:void= x }

#! Valid Expression
# 25. Class inheritance with method
Player := class(Entity) { Update():= Move() }

# ========================================
# Continue Statement Tests
# ========================================

#! Valid Expression
# 26. Continue as variable
continue

#! Valid Expression
# 27. Continue as function call
continue()

#! Valid Expression
# 28. Continue with arguments
continue(x, y)

#! Valid Expression
# 29. Continue in for loop
for(i : 1..10):
  if(i % 2 == 0) then:
    continue

#! Valid Expression
# 30. Continue in complex for loop
for(item : getData(config{host := "localhost", port := 8080})):
  result := process(item.value + offset)
  if(result > threshold) then:
    cache[item.id] := transform(result)
    log("Processed: " + item.name)
  else:
    skip(item)
    continue

#! Valid Expression
# 31. Continue in object
obj{continue := 1}

# ========================================
# Range Expression Tests
# ========================================

#! Valid Expression
# 32. Simple numeric range
1..10

#! Valid Expression
# 33. Range with spaces
1 .. 10

#! Valid Expression
# 34. Zero-based range
0..100

#! Valid Expression
# 35. Variable range
x..y

#! Valid Expression
# 36. Named variable range
start..end

#! Valid Expression
# 37. Expression range
a + 1 .. b - 1

#! Valid Expression
# 38. Parenthesized range
(x + 1)..(y - 1)

#! Valid Expression
# 39. Function call range
getStart()..getEnd()

#! Valid Expression
# 40. Member access range
config.min..config.max

#! Valid Expression
# 41. Range in for loop
for(i : 1..10) { i * 2 }

#! Valid Expression
# 42. Variable range in for loop
for(x : start..end) { process(x) }

#! Valid Expression
# 43. Array indexed range
for(i : 0..n) { arr[i] }

#! Valid Expression
# 44. Complex range in for loop
for(i : arr.length - 1 .. 0) { arr[i] }

#! Valid Expression
# 45. Range in assignment
range := 1..100

#! Valid Expression
# 46. Range in function call
process(1..10)

#! Valid Expression
# 47. Multiple ranges
combine(1..5, 10..20)

#! Valid Expression
# 48. For loop with range indentation style
for(i : 1..10):
  i * i

#! Valid Expression
# 49. Nested for loops with ranges
for(x : 1..3):
  for(y : 1..3):
    x * y

#! Valid Expression
# 50. Negative range
-10..10

#! Valid Expression
# 51. Single value range
1..1

#! Valid Expression
# 52. Range with comments
1 # start
.. # to
10 # end

# ========================================
# Lambda Expression Tests
# ========================================

#! Valid Expression
# 53. Simple lambda
x => x + 1

#! Valid Expression
# 54. Lambda with spaces
 x  =>  x + 1

#! Valid Expression
# 55. Lambda with multiplication
n => n * 2

#! Valid Expression
# 56. Lambda with member access
item => item.getValue()

#! Valid Expression
# 57. Lambda with function call
p => f(p, q)

#! Valid Expression
# 58. Lambda with parenthesized expression
n => (n + 1) * 2

#! Valid Expression
# 59. Nested lambdas (currying)
a => b => a + b

#! Valid Expression
# 60. Triple nested lambdas
a => b => c => a + b + c

#! Valid Expression
# 61. Lambda as map argument
map(x => x + 1)

#! Valid Expression
# 62. Lambda as filter argument
filter(item => item.isValid)

#! Valid Expression
# 63. Lambda as reduce argument
reduce(acc => acc + 1)

#! Valid Expression
# 64. Multiple lambdas in call
process(x => x * 2, y => y + 1)

#! Valid Expression
# 65. Lambda with method chain
x => x.trim().toUpper().split()

#! Valid Expression
# 66. Lambda with conditional
x => if(x > 0) then { x } else { -x }

#! Valid Expression
# 67. Lambda with array access
i => arr[i]

#! Valid Expression
# 68. Lambda with object construction
x => Point{x := x, y := x * 2}

#! Valid Expression
# 69. Lambda with inline comments
x <# comment #> => <# another #> x + 1

#! Valid Expression
# 70. Lambda with line comments
x => # increment
x + 1

#! Valid Expression
# 71. Lambda in assignment
increment := x => x + 1

#! Valid Expression
# 72. Lambda in array
array{x => x + 1, y => y * 2}

#! Valid Expression
# 73. Lambda chained with call
transform(data.map(x => x + 1))

#! Valid Expression
# 74. Lambda with filter and map
process(items.filter(i => i.active).map(i => i.value))

#! Valid Expression
# 75. Lambda in expression
1 + (x => x + 1)(5)

#! Valid Expression
# 76. Lambda with immediate application
(x => x * 2)(10)

#! Valid Expression
# 77. Lambda returning lambda
x => (y => x + y)

#! Error Expression
# 78. Lambda with empty body expression
x => ()

# ========================================
# Class Declaration Tests
# ========================================

#! Valid Expression
# 79. Empty class expression
class { }

#! Valid Expression
# 80. Class with field
class { x := 1 }

#! Valid Expression
# 81. Class with method
class { DoSomething():= x }

#! Valid Expression
# 82. Class with multiple members
class { x := 1; DoSomething():= x + 1 }

#! Valid Expression
# 83. Empty class declaration
MyClass := class { }

#! Valid Expression
# 84. Class declaration with field
Point := class { x := 1 }

#! Valid Expression
# 85. Class declaration with method
Test := class { DoSomething():= x }

#! Valid Expression
# 86. Class declaration with multiple fields
Rectangle := class { width := 10; height := 20 }

#! Valid Expression
# 87. Class declaration with mixed members
Player := class { name := ""; score := 0; GetScore():= score }

#! Valid Expression
# 88. Class declaration indentation style
Player := class:
  name := ""
  score := 0
  GetScore():= score

#! Valid Expression
# 89. Class expression indentation style
class:
  x := 1
  y := 2

#! Valid Expression
# 90. Class assigned to variable
x := class { field := 1 }

#! Error Expression
# 91. Nested class
Outer := class { Inner := class { x := 1 } }

#! Valid Expression
# 92. Class with complex field initializers
Config := class { host := "localhost"; port := 8080; url := host + ":" + port }

#! Valid Expression
# 93. Class with method calling other method
Calculator := class { Add(a, b):= a + b; Double(x):= Add(x, x) }
 
#! Error Expression
# 94. Reserved keyword as class name
if := class { }

# ========================================
# Test-All-Fixes Tests
# ========================================

#! Valid Expression
# 95. Leading comment
# Leading comment
x := 1
 

#! Valid Expression
# 96. Multiple comments
# First comment
# Second comment
x := 1

#! Valid Expression
# 97. Nested if statements with multiple statements
for(x : items):
  if(a > 5) then:
    log("first")
    log("second")

#! Valid Expression
# 98. Stop parsing indented block at else keyword
if(x) then:
  a := 1
else:
  b := 2

#! Valid Expression
# 99. For loop with object construction
for(item : getData(config{host := "localhost"})):
  process(item)

#! Valid Expression
# 100. Nested if-else in for loop
for(item : items):
  if(item > 5) then:
    log("big")
  else:
    log("small")

#! Valid Expression
# 101. Complex nested structure with comments
for(item : getData(config{host := "localhost", port := 8080})):
  result := process(item.value + offset)
  if(result > threshold) then:
    value := transform(result)
    log("Processed")
  else:
    skip(item)

#! Valid Expression
# 102. For expression indentation
for(i : 1..10):
  x := i * 2

#! Valid Expression
# 103. Block expression
block:
  a := 1
  b := 2

#! Valid Expression
# 104. Const declaration simple
x := 1

#! Valid Expression
# 105. Const declaration in for loop
for(i : items):
  x := 1

#! Valid Expression
# 106. Const declaration in if
if(a) then:
  x := 1

#! Valid Expression
# 107. Const declaration in block
block:
  x := 1

#! Valid Expression
# 108. Deeply nested structures
for(a : items):
  for(b : items):
    if(a > b) then:
      if(b > 0) then:
        log("nested")

#! Valid Expression
# 109. Mixed indentation and brace styles
if(x) then { a := 1 } else: b := 2

#! Valid Expression
# 110. Empty for loop with braces
for(x : items) {}

#! Valid Expression
# 111. Empty if with braces
if(x) then {} else {}

#! Error Expression
# 112. Empty block
block {}