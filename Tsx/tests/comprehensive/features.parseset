# Tests for newly implemented features
# =====================================

# ========================================
# Decorator Support on Classes
# ========================================

# Simple decorator on anonymous class
#! Valid Expression
@editable
class { }

# Decorator on named class assignment
#! Valid TopLevel
@public
MyClass := class { }

# Multiple decorators on class
#! Valid TopLevel
@editable
@public
Component := class { x := 1 }

# Decorator with whitespace preservation
#! Valid Expression
@editable
class {
  x := 1
}

# Decorator on class with inheritance
#! Valid TopLevel
@override
DerivedClass := class(BaseClass) { }

# Decorator on indentation-style class
#! Valid TopLevel
@editable
MyClass := class:
  x := 1
  y := 2

# Class with decorated fields (no return types)
#! Valid TopLevel
@component
Widget := class {
  @editable
  var enabled: bool = true

  @readonly
  name: string = "widget"
}
 

# ========================================
# Plain Brace Blocks (without 'block' keyword)
# ========================================

#! Valid Expression
# 1. Empty brace block
{}

#! Valid Expression
# 2. Single expression in braces
{ x }

#! Valid Expression
# 3. Single statement in braces
{ x := 1 }

#! Valid Expression
# 4. Multiple statements in braces
{ x := 1; y := 2; x + y }

#! Valid Expression
# 5. Nested brace blocks
{ a := 1; { b := 2; a + b } }

#! Valid Expression
# 6. Brace block with var declarations
{ var x: int = 5; x * 2 }

#! Valid Expression
# 7. Brace block in if expression
if(test) then { x := 1; x } else { y := 2; y }

#! Valid Expression
# 8. Brace block as function body
f():= { x := getValue(); process(x); x }

#! Valid Expression
# 9. Complex nested blocks
{
  outer := 1;
  {
    inner := 2;
    outer + inner
  }
}

# Block with keyword and colon
#! Valid Expression
block:
  x := 1
  x + 1

# ========================================
# Keyword Restrictions
# ========================================

#! Error Expression
# 10. Cannot assign to block keyword
block := 5

#! Error Expression
# 11. Cannot assign to continue keyword
continue := 5

#! Error Expression
# 12. Cannot assign to true
true := 5

#! Error Expression
# 13. Cannot assign to false
false := 10

#! Error Expression
# 14. Cannot use var as identifier
var := 5

#! Error Expression
# 15. Cannot use if as identifier
if := 5

#! Error Expression
# 16. Cannot use for as identifier
for := 5

#! Valid Expression
# 17. Continue as standalone expression (variable reference)
continue

#! Valid Expression
# 18. Continue as function call
continue()

#! Valid Expression
# 19. Continue with arguments
continue(x, y)

# Block followed by colon is valid
#! Valid Expression
block:
  x := 1
 

#! Error Expression
# 20. Block cannot be followed by :=
block := { x }

# ========================================
# Mixed Features
# ========================================

# Decorated class with plain brace blocks in methods
#! Valid TopLevel
@service
Calculator := class {
  Add(a: int, b: int):= {
    result := a + b;
    log("Added");
    result
  }
}

# Class with decorated members and blocks
#! Valid TopLevel
@entity
Player := class {
  @replicated
  var health: int = 100

  TakeDamage(amount: int):= {
    health := health - amount;
    if(health <= 0) then {
      Die()
    }
  }
}

# Complex expression with all features
#! Valid TopLevel
@main
Game := class {
  Start():= block:
    Initialize()
    {
      var players: int = 0;
      LoadPlayers();
      players
    }
}

# ========================================
# Edge Cases
# ========================================

# Decorator followed immediately by class
#! Valid Expression
@inline class { }
 
#! Valid Expression
# 21. Empty statements in brace block
{ ;; x ;; }

#! Valid Expression
# 22. Deeply nested blocks
{ { { { x } } } }

#! Valid Expression
# 23. Class name starting with keywords (but not exact match)
blocks := class { }

#! Valid Expression
# 24. Class name with continue prefix
continued := class { }

#! Valid Expression
# 25. Variable names similar to keywords
blocking := 1
 