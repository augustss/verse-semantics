#! Valid expression
# 1. Empty line with only spaces
for(x : items):
  a := x

  b := a + 1

#! Valid expression
# 2. Empty line with tabs
for(x : items):
  a := x

  b := a + 1

#! Valid expression
# 3. Multiple consecutive empty lines
if(condition) then:
  start()



  end()

#! Error expression
# 4. Empty line with different indentation level
for(x : items):
  process(x)

    continue()

#! Error expression
# 5. Empty line followed by outdented code
for(x : items):
  process(x)

outdented := true

#! Valid expression
# 6. Empty line at very beginning
if(condition) then:

  result
else:
  default

#! Valid expression
# 7. Empty line at very end
if(condition) then:
  result

else:
  default

#! Valid expression
# 8. Only empty lines in block
if(condition) then:


else:
  default

#! Valid expression
# 9. Mixed whitespace empty lines
for(x : items):
  a := x

  b := a

  c := b

  c

#! Valid expression
# 10. Empty line breaking up assignment chain
{
  a := getValue();

  b := transform(a);

  c := process(b);
  c
}

#! Valid expression
# 11. Empty line in nested object construction
Entity:
  name := "test"

  stats := Stats:
    health := 100

    mana := 50

  position := Point{x := 0, y := 0}

#! Valid expression
# 12. Empty lines with varying indentation in nested structure
if(outer) then:
  setup()

  for(x : items):
    process(x)

    if(x.isValid):
      validate(x)

      result := x.getValue()
    else:
      skip()

  cleanup()

#! Valid expression
# 13. Empty line before and after nested block
for(x : items):
  prepare()

  {
    temp := process(x);
    result := finalize(temp);
    result
  }

  cleanup()

#! Valid expression
# 14. Comment-only line treated as empty
for(x : items):
  start := x
  # This is a comment line
  end := start + 1

#! Valid expression
# 15. Empty line with mixed comment styles
if(condition) then:
  <# block comment #>

  # line comment

  result
else:
  default

#! Valid expression
# 16. Very deep nesting with empty lines
if(a) then:
  if(b) then:

    if(c) then:

      if(d) then:

        result
      else:

        default4
    else:

      default3
  else:

    default2
else:

  default1

#! Valid expression
# 17. Empty line preserving exact whitespace
for(x : items):
  a := x + 1

  b := a * 2

#! Valid expression
# 18. Multiple empty lines with comments
for(x : items):
  process(x)

  # Middle comment

  finalize(x)

#! Valid expression
# 19. Empty line in function call arguments (if multiline supported)
calculate(
  getValue(),

  getOtherValue(),

  getThirdValue()
)

#! Valid expression
# 20. Empty line in object construction arguments
Point{
  x := getValue(),

  y := getOtherValue(),

  z := getThirdValue()
}