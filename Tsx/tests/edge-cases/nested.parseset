#! Valid expression
# 1. Nested parenthesized expressions
((x + y) * (a - b))

#! Valid expression
# 2. Deeply nested parentheses
(((((x)))))

#! Valid expression
# 3. Mixed function calls and parentheses
f(g(h(x + y)))

#! Valid expression
# 4. Nested function calls with multiple arguments
f(g(x, y), h(a, b))

#! Valid expression
# 5. Function call with nested expressions
calculate(((a + b) * c), ((d - e) / f))

#! Valid expression
# 6. Nested object construction
Player{
  position := Point{x := 10, y := 20},
  health := 100
}

#! Valid expression
# 7. Function call with object construction
createEntity(Player{name := "Hero", level := 1})

#! Valid expression
# 8. Nested range expressions
for(x : 1..(start + end)) { x }

#! Valid expression
# 9. Complex nested if expressions
if(condition1):
  if(condition2):
    if(condition3):
      result
    else:
      fallback1
  else:
    fallback2
else:
  fallback3

#! Valid expression
# 10. Nested for expressions
for(x : items):
  for(y : x.children):
    process(y)

#! Valid expression
# 11. Mixed brackets and parentheses deeply nested
f[g(h[i(j[k])])]

#! Valid expression
# 12. Complex arithmetic with nested function calls
((f(x) + g(y)) * (h(a) - i(b))) / (j(c) + k(d))

#! Valid expression
# 13. Nested comments with expressions
<# outer comment #>
f(
  <# inner comment #>
  g(x) + h(y) <# end comment #>
)

#! Valid expression
# 14. Deeply nested block expressions
{
  {
    {
      x + y
    }
  }
}

#! Valid expression
# 15. Complex nested assignment chains
{
  a := f(x);
  b := g(a + y);
  c := h(b * z);
  c
}