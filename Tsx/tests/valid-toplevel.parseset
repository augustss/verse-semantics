#! Valid TopLevel
# 77. Full Fortnite device example
teleporter_device := class(creative_device):
    @editable
    TriggerDevice:trigger_device = trigger_device{}

    @editable
    TeleportDestination:teleporter_device_island_rift = teleporter_device_island_rift{}

    OnBegin<override>()<suspends>:void=
        TriggerDevice.TriggeredEvent.Subscribe(OnTriggered)

    OnTriggered(Agent:agent):void=
        if (FortCharacter := Agent.GetFortCharacter[]):
            TeleportDestination.Teleport(Agent)

