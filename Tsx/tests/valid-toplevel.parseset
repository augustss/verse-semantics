# Valid TopLevel Tests
# All valid toplevel tests consolidated

# Complex

#! Valid TopLevel
# 1. Test case
@public
MyClass := class { }

#! Valid TopLevel
# 2. Test case
@editable
@public
Component := class { x := 1 }

#! Valid TopLevel
# 3. Test case
@override
DerivedClass := class(BaseClass) { }

#! Valid TopLevel
# 4. Test case
@editable
MyClass := class:
  x := 1
  y := 2

#! Valid TopLevel
# 5. Test case
@component
Widget := class {
  @editable
  var enabled: bool = true

  @readonly
  name: string = "widget"
}

#! Valid TopLevel
# 6. Test case
@service
Calculator := class {
  Add(a: int, b: int):= {
    result := a + b;
    log("Added");
    result
  }
}

#! Valid TopLevel
# 7. Test case
@entity
Player := class {
  @replicated
  var health: int = 100

  TakeDamage(amount: int):= {
    health := health - amount;
    if(health <= 0) then {
      Die()
    }
  }
}

#! Valid TopLevel
# 8. Test case
@main
Game := class {
  Start():= block:
    Initialize()
    {
      var players: int = 0;
      LoadPlayers();
      players
    }
}

