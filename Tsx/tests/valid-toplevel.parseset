#! Valid TopLevel
# 14. Struct with methods
ComplexNumber := struct:
    Real: float
    Imaginary: float
    Magnitude():float = Math.Sqrt(Real * Real + Imaginary * Imaginary)
    Add(other:ComplexNumber):ComplexNumber = ComplexNumber{Real: Real + other.Real, Imaginary: Imaginary + other.Imaginary}

