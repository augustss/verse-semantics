#! Valid Expression
# 1. Simple and operator
x and y

#! Valid Expression
# 2. Simple or operator
x or y

#! Valid Expression
# 3. Simple not operator
not x

#! Valid Expression
# 4. Chained and
a and b and c

#! Valid Expression
# 5. Chained or
a or b or c

#! Valid Expression
# 6. Mixed logical operators
a and b or c

#! Valid Expression
# 7. Logical with comparison
x > 0 and y < 10

#! Valid Expression
# 8. Complex logical expression
(a > 0 and b < 10) or (c == 0)

#! Valid Expression
# 9. Not with comparison
not (x > 0)

#! Valid Expression
# 10. Double negation
not not ready

#! Valid Expression
# 11. Logical in if condition
if(a and b) then true else false

#! Valid Expression
# 12. Logical with member access
item.isValid and item.value > 0

#! Valid Expression
# 13. Logical with method calls
isReady() or canProceed()

#! Valid Expression
# 14. Whitespace preservation
x  and  y  or  z

#! Valid Expression
# 15. Comments with logical operators
x and # check y
y or # check z
z

#! Valid Expression
# 16. Multiline comments
x <# and #> and <# y #> y

#! Error Expression
# 17. Invalid operator (&&)
x && y

#! Error Expression
# 18. Invalid operator (||)
x || y

#! Error Expression
# 19. Invalid operator (!)
!x