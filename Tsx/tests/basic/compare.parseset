#! Valid Expression
# 1. Greater than
x > 0

#! Valid Expression
# 2. Less than
x < 10

#! Valid Expression
# 3. Greater than or equal
x >= 5

#! Valid Expression
# 4. Less than or equal
x <= 20

#! Valid Expression
# 5. Equal
x == y

#! Valid Expression
# 6. Not equal
x != y

#! Valid Expression
# 7. Chained comparisons
a > b > c

#! Valid Expression
# 8. Comparison with arithmetic
x + 1 > y - 1

#! Valid Expression
# 9. Comparison with member access
item.value > threshold

#! Valid Expression
# 10. Comparison with method call
getValue() < getLimit()

#! Valid Expression
# 11. Comparison in if expression
if(x > 0) then positive else nonPositive

#! Valid Expression
# 12. Multiple comparisons with logical
x > 0 and x < 10

#! Valid Expression
# 13. Comparison with parentheses
(x + y) > (a + b)

#! Valid Expression
# 14. Whitespace preservation
x  >  0  and  y  <  10

#! Valid Expression
# 15. Comments with comparisons
x > # greater than
0 and # and
y < # less than
10

#! Valid Expression
# 16. Multiline comments
x <# greater #> > <# zero #> 0

#! Valid Expression
# 17. Greater than without spaces
x>0

#! Valid Expression
# 18. Less than without spaces
x<10

#! Valid Expression
# 19. Greater equal without spaces
x>=5

#! Valid Expression
# 20. Less equal without spaces
x<=20

#! Valid Expression
# 21. Equal without spaces
x==y

#! Valid Expression
# 22. Not equal without spaces
x!=y

#! Valid Expression
# 23. Multiple comparisons without spaces
x>0 and y<10

#! Valid Expression
# 24. Mixed spacing in comparisons
x>0 and y < 10

#! Valid Expression
# 25. Extra spaces in comparisons
x  >  0

#! Valid Expression
# 26. Variables with comparison operators and spaces
a > b

#! Valid Expression
# 27. Variables with comparison operators without spaces
a>b

#! Valid Expression
# 28. Complex comparison with arithmetic
x + 1 > y * 2

#! Valid Expression
# 29. Complex comparison without spaces
x+1>y*2

#! Valid Expression
# 30. Comparison with function calls and spaces
f(x) > g(y)

#! Valid Expression
# 31. Comparison with function calls without spaces
f(x)>g(y)

#! Valid Expression
# 32. Comparison with member access and spaces
obj.a > obj.b

#! Valid Expression
# 33. Comparison with member access without spaces
obj.a>obj.b

#! Valid Expression
# 34. Comparison with float literals
x > 1.5

#! Valid Expression
# 35. Comparison with string literals
name == "test" 