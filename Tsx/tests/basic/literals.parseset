#! Valid Expression
# 1. Integer literal
42

#! Valid Expression
# 2. Float literal with decimal
3.14

#! Valid Expression
# 3. Float literal with no integer part
.5

#! Valid Expression
# 4. Float literal with no decimal part
5.

#! Valid Expression
# 5. Float with scientific notation
1.5e10

#! Valid Expression
# 6. Float with capital E
1.5E10

#! Valid Expression
# 7. Float with positive exponent
1.5e+10

#! Valid Expression
# 8. Float with negative exponent
1.5e-10

#! Valid Expression
# 9. Integer with scientific notation becomes float
1e10

#! Valid Expression
# 10. Simple string literal
"hello"

#! Valid Expression
# 11. String with spaces
"hello world"

#! Valid Expression
# 12. String with escape sequences
"line1\nline2"

#! Valid Expression
# 13. String with tab
"col1\tcol2"

#! Valid Expression
# 14. String with escaped quote
"He said \"hello\""

#! Valid Expression
# 15. String with escaped backslash
"path\\to\\file"

#! Valid Expression
# 16. String with multiple escapes
"Quote: \"\tTab\nNewline\\"

#! Valid Expression
# 17. Empty string
""

#! Valid Expression
# 18. String in comparison
name == "test"

#! Valid Expression
# 19. Float in arithmetic
x + 3.14

#! Valid Expression
# 20. String in function call
print("hello")

#! Valid Expression
# 21. Whitespace preservation with literals
42  +  3.14  +  "test"

#! Valid Expression
# 22. Comments with literals
42 # integer
+ 3.14 # float
+ "test" # string

#! Valid Expression
# 23. Multiline comments with literals
<# int #>42 + <# float #>3.14

#! Error Expression
# 24. Invalid escape sequence
"invalid\x"

#! Error Expression
# 25. Unterminated string
"hello