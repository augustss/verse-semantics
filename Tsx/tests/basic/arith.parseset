#! Valid Expression
# 1. Simple addition
1 + 2

#! Valid Expression
# 2. Simple subtraction
5 - 3

#! Valid Expression
# 3. Simple multiplication
3 * 4

#! Valid Expression
# 4. Simple division
8 / 2

#! Valid Expression
# 5. Operator precedence: multiplication before addition
2 + 3 * 4

#! Valid Expression
# 6. Operator precedence: division before subtraction
10 - 8 / 2

#! Valid Expression
# 7. Left associativity of addition
1 + 2 + 3

#! Valid Expression
# 8. Left associativity of subtraction
10 - 5 - 2

#! Valid Expression
# 9. Left associativity of multiplication
2 * 3 * 4

#! Valid Expression
# 10. Left associativity of division
24 / 4 / 2

#! Valid Expression
# 11. Mixed operators with precedence
a + b * c - d / e

#! Valid Expression
# 12. Parentheses override precedence
(2 + 3) * 4

#! Valid Expression
# 13. Nested arithmetic expressions
(a + b) * (c - d)

#! Valid Expression
# 14. Complex expression with variables
x + y * z - w / v

#! Valid Expression
# 15. Arithmetic with function calls
f(x) + g(y) * h(z)

#! Valid Expression
# 16. Arithmetic with object fields
obj.x + obj.y * 2

#! Valid Expression
# 17. Addition without spaces
1+2

#! Valid Expression
# 18. Subtraction without spaces
5-3

#! Valid Expression
# 19. Multiplication without spaces
3*4

#! Valid Expression
# 20. Division without spaces
8/2

#! Valid Expression
# 21. Mixed spacing - some with, some without
1+2 * 3-4

#! Valid Expression
# 22. Addition with extra spaces
1  +  2

#! Valid Expression
# 23. Multiplication with extra spaces
3  *  4

#! Valid Expression
# 24. Complex expression without spaces
a+b*c-d/e

#! Valid Expression
# 25. Variables with spaces around operators
x + y

#! Valid Expression
# 26. Variables without spaces around operators
x+y

#! Valid Expression
# 27. Multiplication with variables and spaces
x * y

#! Valid Expression
# 28. Multiplication with variables without spaces
x*y

#! Valid Expression
# 29. Complex variables with mixed spacing
a + b*c - d / e

#! Valid Expression
# 30. Unary minus with variable
-x

#! Valid Expression
# 31. Unary minus with number
-42

#! Valid Expression
# 32. Unary minus in expression with spaces
x + -y

#! Valid Expression
# 33. Unary minus in expression without spaces
x+-y

#! Valid Expression
# 34. Multiple unary minus
--x

#! Valid Expression
# 35. Arithmetic with unary minus and spaces
a * -b + c

#! Valid Expression
# 36. Arithmetic with unary minus without spaces
a*-b+c

#! Valid Expression
# 37. Parentheses with spacing variations
( x + y ) * ( a - b )

#! Valid Expression
# 38. Parentheses without spaces
(x+y)*(a-b)

#! Valid Expression
# 39. Function calls in arithmetic with spaces
f(x) + g(y)

#! Valid Expression
# 40. Function calls in arithmetic without spaces
f(x)+g(y)

#! Valid Expression
# 41. Member access in arithmetic with spaces
obj.a + obj.b

#! Valid Expression
# 42. Member access in arithmetic without spaces
obj.a+obj.b