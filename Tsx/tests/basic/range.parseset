#! Valid Expression
# 1. Basic integer range
1..10

#! Valid Expression
# 2. Range with variables
x..y

#! Valid Expression
# 3. Range with expressions
a + 1 .. b - 1

#! Valid Expression
# 4. Range with parenthesized expressions
(x + 1)..(y - 1)

#! Valid Expression
# 5. Range with spaces
1 .. 10

#! Valid Expression
# 6. Range from zero
0..100

#! Valid Expression
# 7. Range with identifiers
start..end

#! Valid Expression
# 8. Range in for loop
for(i : 1..10) { i * 2 }

#! Valid Expression
# 9. Range with variable bounds
for(x : 0..n) { arr[x] }

#! Valid Expression
# 10. Nested range in for loop
for(x : 1..10) {
  for(y : 1..x) {
    x * y
  }
}

#! Error Expression
# 11. Range with method calls TODO check
list.size()..array.length()

#! Valid Expression
# 12. Range with member access
point.x..point.y

#! Error Expression
# 13. Incomplete range (missing end)
1..

#! Error Expression
# 14. Incomplete range (missing start)
..10

#! Error Expression
# 15. Triple dot (invalid)
1...10