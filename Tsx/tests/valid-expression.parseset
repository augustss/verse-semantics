# Valid expression Tests
# All valid expression tests consolidated

# Whitespace

#! Valid expression
# 1. Addition with extra spaces
1  +  2

#! Valid expression
# 2. Multiplication with extra spaces
3  *  4

#! Valid expression
# 3. Addition without spaces
1+2

#! Valid expression
# 4. Subtraction without spaces
5-3

#! Valid expression
# 5. Multiplication without spaces
3*4

#! Valid expression
# 6. Division without spaces
8/2

#! Valid expression
# 7. Complex expression without spaces
a+b*c-d/e

#! Valid expression
# 8. Unary minus in expression with spaces
x + -y

#! Valid expression
# 9. Unary minus in expression without spaces
x+-y

#! Valid expression
# 10. Arithmetic with unary minus and spaces
a * -b + c

#! Valid expression
# 11. Arithmetic with unary minus without spaces
a*-b+c

#! Valid expression
# 12. Parentheses without spaces
(x+y)*(a-b)

#! Valid expression
# 13. Function calls in arithmetic with spaces
f(x) + g(y)

#! Valid expression
# 14. Function calls in arithmetic without spaces
f(x)+g(y)

#! Valid expression
# 15. Member access in arithmetic with spaces
obj.a + obj.b

#! Valid expression
# 16. Member access in arithmetic without spaces
obj.a+obj.b

#! Valid expression
# 17. Parentheses with whitespace
( x )

#! Valid expression
# 18. Parenthesized integer with whitespace
( 42 )

#! Valid expression
# 19. Parenthesized expression with whitespace
( x  +  y )

#! Valid expression
# 20. Nested parentheses with whitespace
( ( x ) )

#! Valid expression
# 21. Complex parenthesized expression with whitespace
( x  +  ( y  -  z ) )

#! Valid expression
# 22. Mixed operators with extensive whitespace
a  +  ( b  +  c )  -  ( d  -  e )

#! Valid expression
# 23. Greater than without spaces
x>0

#! Valid expression
# 24. Less than without spaces
x<10

#! Valid expression
# 25. Greater equal without spaces
x>=5

#! Valid expression
# 26. Less equal without spaces
x<=20

#! Valid expression
# 27. Multiple comparisons without spaces
x>0 and y<10

#! Valid expression
# 28. Complex comparison without spaces
x+1>y*2

#! Valid expression
# 29. Comparison with function calls and spaces
f(x) > g(y)

#! Valid expression
# 30. Comparison with function calls without spaces
f(x)>g(y)

#! Valid expression
# 31. Comparison with member access and spaces
obj.a > obj.b

#! Valid expression
# 32. Comparison with member access without spaces
obj.a>obj.b

#! Valid expression
# 33. Whitespace preservation with literals
42  +  3.14  +  "test"

#! Valid expression
# 34. Whitespace preservation
x  and  y  or  z

#! Valid expression
# 35. Whitespace preservation
x . y . z

#! Valid expression
# 36. Block with inconsistent indentation but valid structure
{
  x := 1;
    y := 2;
  x + y
}

#! Valid expression
# 37. Method with indentation (currently fails - returns empty body)
Test := class:
    DoSomething():= x

#! Valid expression
# 38. Field with indentation (currently fails - returns empty body)
Test := class:
    x:int= 1

#! Valid expression
# 39. Lambda with spaces
x  =>  x + 1

#! Valid expression
# 40. Object with indentation style syntax
Point:
  x := 1
  y := 2

#! Valid expression
# 41. Mixed indentation and brace styles
if(x) then { a := 1 } else: b := 2

#! Valid expression
# 42. Whitespace preservation in blocks
{  x  :=  1  ;  y  :=  2  ;  x  +  y  }

#! Valid expression
# 43. Indented block style
block:
  x + 1
  y + 2
  z + 3

#! Valid expression
# 44. Indented block with semicolons
block:
  x + 1;
  y + 2;
  z + 3

#! Valid expression
# 45. Indented block with mixed content
block:
  f(x)
  Point{x:=10, y:=20}
  a + b

#! Valid expression
# 46. Nested indented blocks
block:
  x + 1
  block:
    y + 2
    z + 3
  w + 4

#! Valid expression
# 47. Block with whitespace preservation
{  x  ;  y  ;  z  }

#! Valid expression
# 48. All semicolons in indented block
block:
  a;
  b;
  c;

#! Valid expression
# 49. No semicolons in indented block
block:
  a
  b
  c

#! Valid expression
# 50. Single field object without spaces
Point{x:=1}

#! Valid expression
# 51. Single field object with spaces
Point{ x := 1 }

#! Valid expression
# 52. Two field object with spaces
Point{ x := 1, y := 2 }

#! Valid expression
# 53. Three field object without spaces
Point{x:=1,y:=2,z:=3}

#! Valid expression
# 54. Three field object with spaces
Point{ x := 1 , y := 2 , z := 3 }

#! Valid expression
# 55. Object fields with spaced arithmetic expressions
vec3{ x := a + b, y := f(c), z := d - e }

#! Valid expression
# 57. Indentation style object in binary expression
a + Point:
  x := 1
  y := 2

#! Valid expression
# 58. Empty indented block at end of input
else:

#! Valid expression
# 59. Indentation style with arithmetic
Rectangle:
  width := 100 + 50
  height := 200 - 50

#! Valid expression
# 60. Indentation style with function calls
Config:
  debug := isDebug()
  port := getPort()

#! Valid expression
# 61. Mixed indentation and brace styles
Player:
  pos := Point{x:=0, y:=0}
  velocity := Vector{x:=1, y:=0, z:=0}

#! Valid expression
# 62. Complex indentation style with mixed constructs
GameState:
  player := Player{name:=hero, level:=10}
  enemies := count[hostiles]
  score := points + bonus
  time := getCurrentTime()

#! Valid expression
# 63. Mixed indentation and brace styles in nesting
GameState:
  player := Player{
    name := heroName,
    inventory := Inventory{
      items := getItems(),
      capacity := 20
    }
  }
  world := World{
    size := worldSize
  }

#! Valid expression
# 64. Pure indentation style nesting
World:
  terrain := Terrain:
    height := 100
    width := 100
  player := Player:
    x := 50
    y := 50

#! Valid expression
# 65. Mixed indentation and brace style deep nesting
Game:
  state := Running{
    time := 0,
    score := Score{
      current := 0,
      high := getHighScore()
    }
  }

#! Valid expression
# 66. Expression with maximum whitespace preservation
x   +   y   *   z   /   w   -   q

#! Valid expression
# 67. Complex whitespace preservation
x    +    y    *    z

#! Valid expression
# 68. Empty line with only spaces
for(x : items):
  a := x

  b := a + 1

#! Valid expression
# 69. Mixed whitespace empty lines
for(x : items):
  a := x

  b := a

  c := b

  c

#! Valid expression
# 70. Empty line preserving exact whitespace
for(x : items):
  a := x + 1

  b := a * 2

#! Valid expression
# 71. Single indented expression
block:
    result := x + y

#! Valid expression
# 72. Multiple expressions at consistent indentation
for:
    a := 1
    b := 2
    c := 3
    d := 4

#! Valid expression
# 75. Deeply nested indented compounds
if:
    outer := true
    then:
        middle := process()
        if:
            inner := validate()
            then:
                result := finalize()

#! Valid expression
# 76. Indented compound with function calls
for:
    start := begin()
    middle := process(start)
    end := finalize(middle)

#! Valid expression
# 78. Indented compound with assignments
block:
    x := 1
    y := x + 2
    z := y * 3
    result := z / 2

#! Valid expression
# 79. Indented compound with member access
if:
    player := getPlayer()
    health := player.health
    position := player.position.x

#! Valid expression
# 80. Indented compound with array access
for:
    items := getItems()
    first := items[0]
    last := items[items.length - 1]

#! Valid expression
# 81. Indented compound with lambda expressions
block:
    mapper := (x => x * 2)
    filter := (x => x > 0)
    result := collection.map(mapper).filter(filter)

#! Valid expression
# 82. Indented compound with range expressions
for:
    start := 1
    end := 10
    range := start..end

#! Valid expression
# 83. Very deep nesting with consistent indentation
if:
    level1 := true
    then:
        level2 := process()
        if:
            level3 := validate()
            then:
                level4 := finalize()
                block:
                    level5 := complete()

#! Valid expression
# 85. Indented compound with operator expressions
block:
    sum := a + b
    difference := x - y
    product := m * n
    quotient := p / q
    remainder := r % s

#! Valid expression
# 89. Object construction with empty lines in indented style
Player:
  name := "Hero"

  health := 100

  position := Point:
    x := 0

    y := 0

#! Valid expression
# 90. Empty lines at start of indented block
if(condition) then:

  result := getValue()
  result

#! Valid expression
# 91. Empty lines at end of indented block
if(condition) then:
  result := getValue()

else:
  defaultValue

#! Valid expression
# 92. Function call with spaced arguments
f( x , y , z )

#! Valid expression
# 93. Const with type and spaces
x   :   int   =   42

#! Valid expression
# 94. Const with nested indented object
config := Player:
  name := playerName
  x := 10
  y := 20

#! Valid expression
# 95. Function with indented body
f() :=
  x + y

#! Valid expression
# 96. Function with whitespace preservation
f  (  x  ,  y  )  :=  x + y

#! Valid expression
# 97. Function with indented object body
makePoint(x, y) := Point:
  x := x
  y := y

#! Valid expression
# 98. Variables with spaces around operators
x + y

#! Valid expression
# 99. Variables without spaces around operators
x+y

#! Valid expression
# 100. Multiplication with variables and spaces
x * y

#! Valid expression
# 101. Multiplication with variables without spaces
x*y

#! Valid expression
# 102. Variables with comparison operators and spaces
a > b

#! Valid expression
# 103. Variables with comparison operators without spaces
a>b

#! Valid expression
# 104. For loop with range indentation style
for(i : 1..10):
  i * i

#! Valid expression
# 105. Class declaration indentation style
Player := class:
  name := ""
  score := 0
  GetScore():= score

#! Valid expression
# 106. Stop parsing indented block at else keyword
if(x) then:
  a := 1
else:
  b := 2

#! Valid expression
# 107. For expression indentation
for(i : 1..10):
  x := i * 2

#! Valid expression
# 108. Indented block with optional semicolons preserved
block:
  x + 1;
  y + 2
  z + 3;

#! Valid expression
# 109. Mixed semicolons preserved in nested indented blocks
block:
  outer1;
  block:
    inner1
    inner2;
  outer2

#! Valid expression
# 110. Boolean in if condition - spaced parentheses
if ( true ) then { 32 }

#! Valid expression
# 111. For-loop with whitespace preservation
for ( x : items ) { x }

#! Valid expression
# 112. Indentation style for-loop
for(x : items):
  x * 2

#! Valid expression
# 113. Indented for loop with indexed iteration
for(i -> x : items):
  x + i

#! Valid expression
# 114. For with indentation and block
for(x : items):
  { y := x + 1; y * 2 }

#! Valid expression
# 115. For loop with whitespace preservation
for( x : items ) { x }

#! Valid expression
# 116. For loop with whitespace in indexed form
for( i -> x : items ) { x + i }

#! Valid expression
# 117. For loop with extensive whitespace
for    (   x   :   items   )   {   x   +   1   }

#! Valid expression
# 118. Indented for loop style
for(x : items):
  x

#! Valid expression
# 119. Indented for loop with multiple statements
for(x : items):
  y := x + 1
  f(y)

#! Valid expression
# 120. Indented for loop with complex body
for(item : collection):
  result := process(item)
  if(result.isValid):
    result.value
  else:
    defaultValue

#! Valid expression
# 121. Indented for loop with nested for loops
for(x : items):
  for(y : x.children):
    process(x, y)

#! Valid expression
# 122. Indented for loop with object construction
for(item : items):
  Point{
    x := item.x,
    y := item.y
  }

#! Valid expression
# 123. If with no spaces
if(true)then{32}

#! Valid expression
# 124. If with indentation style
if (x) then:
  result

#! Valid expression
# 125. If-else with indentation
if (condition) then:
  actionA()
else:
  actionB()

#! Valid expression
# 126. If expression with whitespace preservation
if( condition ) then { value }

#! Valid expression
# 127. If expression with extensive whitespace
if   (   condition   )   then   {   result   }   else   {   fallback   }

#! Valid expression
# 128. Indented if expression style
if(condition) then:
  result

#! Valid expression
# 129. Indented if expression with else
if(condition) then:
  primaryValue
else:
  fallbackValue

#! Valid expression
# 130. Indented if expression with else if
if(x > 0) then:
  positive
else if(x < 0) then:
  negative
else:
  zero

#! Valid expression
# 131. Indented if expression with complex body
if(isReady) then:
  data := fetchData()
  process(data)
  result

#! Valid expression
# 132. Indented if expression with nested if
if(outer) then:
  if(inner) then:
    deepValue
  else:
    shallowValue
else:
  defaultValue

#! Valid expression
# 133. Indentation style with variable assignments
Player:
  name := playerName
  x := 10
  y := 20

#! Valid expression
# 134. Empty lines with varying indentation in nested structure
if(outer) then:
  setup()

  for(x : items):
    process(x)

    if(x.isValid):
      validate(x)

      result := x.getValue()
    else:
      skip()

  cleanup()

#! Valid expression
# 135. For loop with empty line in indented body
for(x : items):
  result := process(x)

  output(result)

#! Valid expression
# 136. Multiple empty lines with varying indentation
for(x : items):
  a := x + 1



  b := a * 2



  c := b - 1
  c

#! Valid expression
# 137. Object construction with varied indentation
Entity{
  name := "test",
    health := 100,
      position := Point{
        x := 0,
          y := 0
      }
}

