  var players: []Player = array{}
  var isRunning: bool = false

  Start(): void = {
    isRunning := true;
    InitializePlayers()
  }

  AddPlayer(p: Player): bool = {
    if(not isRunning) then {
      players := players + array{p};
      true
    } else {
      false
    }
  }

  GetPlayerCount(): int = players.length
}

