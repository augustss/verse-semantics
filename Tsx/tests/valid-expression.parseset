if(condition) then: # check the condition
  result # return this value
else: # otherwise
  fallback # return fallback

#! Valid expression
# 724. Multi-line comment with spacing (exact format)
<# This is a
  multi-line comment #>
x + y

#! Valid expression
# 725. Comment before object
Point{
  x := 1, # comment after field
  y := 2  # another comment
} # end comment

#! Valid expression
# 726. If expression with comments and empty lines
if(isReady) then:
  # Initialize
  data := fetchData()

  # Process the data
  result := process(data)

  # Return result
  result
else:
  # Use default
  defaultValue

#! Valid expression
# 727. Keywords in comments
x := 1 # using var or not

#! Valid expression
# 728. Variable with comments
var x # name
  : int # type
  = 42 # value

#! Valid expression
# 729. Variable with multiline comment
var x <# variable #> : int = 42

#! Valid expression
# 730. Comments with comparisons
x > # greater than
0 and # and
y < # less than
10

#! Valid expression
# 731. Multiline comments
x <# greater #> > <# zero #> 0

#! Valid expression
# 732. Comments with literals
42 # integer
+ 3.14 # float
+ "test" # string

#! Valid expression
# 733. Multiline comments with literals
<# int #>42 + <# float #>3.14

#! Valid expression
# 734. Comments with logical operators
x and # check y
y or # check z
z

#! Valid expression
# 735. Multiline comments
x <# and #> and <# y #> y

#! Valid expression
# 736. Comments with member access
x. # member
y. # another
z

#! Valid expression
# 737. Multiline comments
x.<# member #>y

#! Valid expression
# 738. Range with comments
1 # start
.. # to
10 # end

#! Valid expression
# 739. Lambda with inline comments
x <# comment #> => <# another #> x + 1

#! Valid expression
# 740. Lambda with line comments
x => # increment
x + 1

#! Valid expression
# 741. Complex nested structure with comments
for(item : getData(config{host := "localhost", port := 8080})):
  result := process(item.value + offset)
  if(result > threshold) then:
    value := transform(result)
    log("Processed")
  else:
    skip(item)

#! Valid expression
# 742. Comments in blocks
{ # start
  x := 1; # assign x
  y := 2; # assign y
  x + y # result
}

#! Valid expression
# 743. Multiline comments in blocks
{ <# setup #> x := 1; <# compute #> x * 2 }

#! Valid expression
# 744. Block with comments
{
  # first statement
  x + 1;
  # second statement
  y + 2  # inline comment
}

#! Valid expression
# 745. Indented block with comments
block: # block start
  x + 1  # first
  y + 2  # second
  z + 3  # third

#! Valid expression
# 746. Object with trailing spaces and line comment
Point{  x:=1  ,  y:=2  }  # end comment

#! Valid expression
# 747. Object with inline comments
Person{ # creating person
  name := userName, # user's name
  age := 25 # default age
}

#! Valid expression
# 748. Indentation style with comments
Person: # creating person
  name := userName # user's name
  age := 25 # default age

#! Valid expression
# 749. Object with multiline comment
Point{<# coordinates #>x:=1, y:=2}

#! Valid expression
# 750. Nested objects with extensive comments
Player{ # main player
  pos:=Point{ # position
    x:=0, # x coordinate
    y:=0  # y coordinate
  },
  stats:=Stats{ # player stats
    health:=100
  }
}

#! Valid expression
# 751. Minimal comment
<##> x

#! Valid expression
# 752. Very long comment
<# This is an extremely long comment that tests the parser's ability to handle lengthy comment blocks without any issues or problems whatsoever and should work correctly #>42

#! Valid expression
# 753. Comment with special characters
<# !@#$%^&*()_+-=[]{}|;:'"<>?,./ #>x

#! Valid expression
# 754. Nested comment delimiters (but not actual nesting)
<# comment with <# and #> inside #>x

#! Valid expression
# 755. Multiple line comments
<# comment 1 #><# comment 2 #><# comment 3 #>x

#! Valid expression
# 756. Mixed comment styles
<# block comment #>x

#! Valid expression
# 757. Mixed comment styles with complex expression
<# Block comment #>
calculate( # inline comment
  x + y, # argument 1
  a * b  # argument 2
) # end comment

#! Valid expression
# 758. Comment-only line treated as empty
for(x : items):
  start := x
  # This is a comment line
  end := start + 1

#! Valid expression
# 759. Empty line with mixed comment styles
if(condition) then:
  <# block comment #>

  # line comment

  result
else:
  default

#! Valid expression
# 760. Multiple empty lines with comments
for(x : items):
  process(x)

  # Middle comment

  finalize(x)

#! Valid expression
# 761. Nested comments with expressions
<# outer comment #>
f(
  <# inner comment #>
  g(x) + h(y) <# end comment #>
)

#! Valid expression
# 762. Comments within indented compound
if:
    # This is a comment
    x := 1
    # Another comment
    y := 2

#! Valid expression
# 763. Multiline comments within indented compound
block:
    <# This is a
       multiline comment #>
    result := process()

#! Valid expression
# 764. Empty indented compound with comments
else:
    # Just a comment
    # Another comment

#! Valid expression
# 765. Comments with surrounding whitespace
x  <# comment #>  + y

#! Valid expression
# 766. Comment 1
x + y # comment 2

#! Valid expression
# 767. Start comment
f(x) # middle
+ g(y) # end

#! Valid expression
# 768. Mixed empty lines and comments
for(item : items):
  # Start processing

  temp := process(item)
  # Middle comment

  result := finalize(temp)
  # End comment

  result

#! Valid expression
# 769. Simple multi-line comment
<# comment #>
x + y

#! Valid expression
# 770. Multi-line comment with newlines
<# This spans
multiple lines #>
x + y

#! Valid expression
# 771. Nested multi-line comments
<# outer <# inner #> outer #>
x + y

#! Valid expression
# 772. Mixed single and multi-line comments
<# Block comment #>
x + y

#! Valid expression
# 773. Multi-line comment at end
x + y <# trailing comment #>

#! Valid expression
# 774. Empty multi-line comment
<##>
x + y

#! Valid expression
# 775. Multi-line comment with special characters
<# Comment with symbols: @#$%^&*()[]{}|\ #>
x + y

#! Valid expression
# 776. Line comments with spacing
x + y # this is a comment

#! Valid expression
# 778. Const with comments
x # name
  := # assignment
  42 # value

#! Valid expression
# 779. Const with type and comments
x # name
  : int # type
  = 42 # value

#! Valid expression
# 780. Const with multiline comment
x <# const declaration #> := 42

#! Valid expression
# 781. Const with line comment
y := 10 # initial value

#! Valid expression
# 782. Function with comments
f # function name
  (x) # param
  := # assignment
  x + 1 # body

#! Valid expression
# 783. Function with return type and comments
add # function
  (x, y) # params
  : int # return type
  = # equals
  x + y # body

#! Valid expression
# 74. Nested indented compounds
if:
    condition := check()
    then:
        action1 := do()
        action2 := finish()

#! Valid expression
# 87. Loop with indented style
loop:
  continue

#! Valid expression
# 88. Loop with multiple statements (indented)
loop:
  x := 1
  break

#! Valid expression
# 243. Continue as function call
continue()

#! Valid expression
# 244. Continue with arguments
continue(x, y)

#! Valid expression
# 260. Complex nested control flow with break and continue
result := if(true and not false) then {
  for(i : 0..10) {
    if(i > 5) then { break } else { continue }
  }
} else {
  case(status):
    0 => false
    1 => true
    _ => not true
}

#! Valid expression
# 266. Complex nested expression combining all features
for(item : getData(config{host := "localhost", port := 8080})):
  result := process(item.value + offset)
  if(result > threshold) then:
    cache[item.id] := transform(result)
    log("Processed: " + item.name)
  else:
    skip(item)
    continue

#! Valid expression
# 313. Continue in else block
if(skip) then { process() } else { continue }

#! Valid expression
# 314. Nested loops with break
for(i : 0..10) {
  for(j : 0..10) {
    if(i + j > 10) then { break }
  }
}

#! Valid expression
# 455. Basic loop with braces
loop { break }

#! Valid expression
# 456. Loop with break condition
loop {
  if(done) then { break }
}

#! Valid expression
# 457. Loop with continue condition
loop {
  if(skip) then { continue }
  process()
}

#! Valid expression
# 458. Nested loops
loop {
  for(i : 0..10) {
    if(i > 5) then { break }
  }
}

#! Valid expression
# 459. Loop with complex body
loop:
  count := count + 1
  if(count > 100) then { break }
  result := calculate(count)

#! Valid expression
# 537. Continue as standalone expression (variable reference)
continue

#! Valid expression
# 606. Break and continue in for loop
for(i : 0..10) {
  if(i > 5) then { break } else { continue }
}
