#! Valid expression
# 1. Basic for loop with empty body
for(x : items) {}

#! Valid expression
# 2. For loop with simple expression body
for(x : items) { x }

#! Valid expression
# 3. For loop with indexed iteration
for(i -> x : items) { x }

#! Valid expression
# 4. For loop with expression body
for(item : list) { item + 1 }

#! Valid expression
# 5. For loop with indexed expression body
for(idx -> item : collection) { item * idx }

#! Valid expression
# 6. For loop with complex expression body
for(x : items) { f(x) + g(x) }

#! Valid expression
# 7. For loop with multiple statements in body
for(x : items) {
  y := x + 1;
  f(y)
}

#! Valid expression
# 8. For loop with nested expressions
for(x : items) {
  for(y : x.children) { process(y) }
}

#! Valid expression
# 9. For loop with object construction
for(item : items) {
  Point{x:=item.x, y:=item.y}
}

#! Valid expression
# 10. For loop with whitespace preservation
for( x : items ) { x }

#! Valid expression
# 11. For loop with whitespace in indexed form
for( i -> x : items ) { x + i }

#! Valid expression
# 12. For loop with extensive whitespace
for    (   x   :   items   )   {   x   +   1   }

#! Valid expression
# 13. For loop with comments
for(x <# item #> : items <# collection #>) { <# body #> x }

#! Valid expression
# 14. Indented for loop style
for(x : items):
  x

#! Valid expression
# 15. Indented for loop with indexed iteration
for(i -> x : items):
  x + i

#! Valid expression
# 16. Indented for loop with multiple statements
for(x : items):
  y := x + 1
  f(y)

#! Valid expression
# 17. Indented for loop with complex body
for(item : collection):
  result := process(item)
  if(result.isValid):
    result.value
  else:
    defaultValue

#! Valid expression
# 18. Indented for loop with nested for loops
for(x : items):
  for(y : x.children):
    process(x, y)

#! Valid expression
# 19. Indented for loop with object construction
for(item : items):
  Point{
    x := item.x,
    y := item.y
  }

#! Valid expression
# 20. For loop with function call as iterable
for(x : getItems()) { x }

#! Valid expression
# 21. For loop with complex iterable expression
for(x : items.filter(isValid)) { transform(x) }

#! Valid expression
# 22. For loop in expression context
sum + for(x : items) { x } + total

#! Valid expression
# 23. For loop as function argument
process(for(x : items) { transform(x) })
 
#! Valid expression
# 24. For loop with binary operations
for(x : items) { x + y - z * w }

#! Valid expression
# 25. Nested for loops in brace style
for(x : items) {
  for(y : x.children) {
    x.value + y.value
  }
}

#! Valid expression
# 26. For loop with line comments
for(x : items): # iterate over items
  x + 1  # add one to each item