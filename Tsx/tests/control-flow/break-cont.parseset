# Break and Continue Expression Tests

#! Valid Expression
# 1. Simple break
break

#! Valid Expression
# 2. Simple continue
continue

#! Valid Expression
# 3. Break in if block
if(done) then { break }

#! Valid Expression
# 4. Continue in else block
if(skip) then { process() } else { continue }

#! Valid Expression
# 5. Break and continue in for loop
for(i : 0..10) {
  if(i > 5) then { break } else { continue }
}

#! Valid Expression
# 6. Nested loops with break
for(i : 0..10) {
  for(j : 0..10) {
    if(i + j > 10) then { break }
  }
}

#! Valid Expression
# 7. Complex nested control flow with break and continue
result := if(true and not false) then {
  for(i : 0..10) {
    if(i > 5) then { break } else { continue }
  }
} else {
  case(status):
    0 => false
    1 => true
    _ => not true
}