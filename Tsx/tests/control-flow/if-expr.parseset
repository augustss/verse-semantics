# If Expression Tests

#! Valid Expression
# 1. If with parentheses and braces
if ( true ) then { 32 }

#! Valid Expression
# 2. If with no spaces
if(true)then{32}

#! Valid Expression
# 3. If with complex condition
if ( x > 5 ) then { x * 2 }

#! Valid Expression
# 4. If-else with braces
if (x) then { a } else { b }

#! Valid Expression
# 5. If with indentation style
if (x) then:
  result

#! Valid Expression
# 6. If-else with indentation
if (condition) then:
  actionA()
else:
  actionB()

#! Valid Expression
# 7. If without parentheses
if true then { 23 }

#! Valid Expression
# 8. If without parentheses with identifier
if condition then { result }