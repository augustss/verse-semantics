#! Valid Expression
# 1. Simple for with single expression
for(x : items) { x }

#! Valid Expression
# 2. For with empty block
for(x : items) {}

#! Valid Expression
# 3. For with block containing statements
for(x : items) { y := x + 1; f(y) }

#! Valid Expression
# 4. For with index
for(i -> x : items) { x + i }

#! Valid Expression
# 5. For with complex body
for(item : collection) { result := process(item); if(result.isValid) then result.value else defaultValue }

#! Valid Expression
# 6. Nested for expressions
for(x : xs) { for(y : ys) { x + y } }

#! Valid Expression
# 7. For with indentation style
for(x : items):
  x * 2

#! Valid Expression
# 8. For with indentation and block
for(x : items):
  { y := x + 1; y * 2 }

#! Valid Expression
# 9. For with range
for(i : 1..10) { i * i }

#! Valid Expression
# 10. For with member access in collection
for(item : container.items) { item.value }

#! Valid Expression
# 11. For with method call result
for(x : getItems()) { process(x) }

#! Valid Expression
# 12. For with if expression in body
for(x : items) { if(x > 0) then x else -x }

#! Valid Expression
# 13. For with nested block
for(x : items) { { y := x; z := y + 1; z } }

#! Valid Expression
# 14. For with whitespace preservation
for ( x  :  items ) { x }

#! Valid Expression
# 15. For with comments
for(# comment
  x : items) { # body
  x # value
}

#! Valid Expression
# 16. For with multiline comment
for(<# iterator #> x : items) { <# body #> x }

#! Error Expression
# 17. Missing colon
for(x items) { x }

#! Error Expression
# 18. Missing iterable
for(x : ) { x }

#! Error Expression
# 19. Missing body
for(x : items)