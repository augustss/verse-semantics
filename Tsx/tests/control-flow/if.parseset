#! Valid expression
# 1. Basic if expression with brace style
if(true) then { 42 }

#! Valid expression
# 2. If expression with else brace style
if(condition) then { value1 } else { value2 }

#! Valid expression
# 3. If expression with else if brace style
if(x > 0) then { positive } else if(x < 0) then { negative } else { zero }

#! Valid expression
# 4. If expression with simple condition
if(x) then { result }

#! Valid expression
# 5. If expression with complex condition
if(x > 0 and y < 10) then { process(x, y) }

#! Valid expression
# 6. If expression with function call condition
if(isValid(data)) then { process(data) }

#! Valid expression
# 7. If expression with parenthesized condition
if((x + y) > threshold) then { action() }

#! Valid expression
# 8. If expression with object field condition
if(user.isActive) then { user.name }

#! Valid expression
# 9. If expression with nested if in body
if(condition) then {
  if(nestedCondition) then { innerValue } else { defaultInner }
}

#! Valid expression
# 10. If expression with multiple statements in body
if(ready) then {
  x := prepare();
  execute(x);
  result
}

#! Valid expression
# 11. If expression with whitespace preservation
if( condition ) then { value }

#! Valid expression
# 12. If expression with extensive whitespace
if   (   condition   )   then   {   result   }   else   {   fallback   }

#! Valid expression
# 13. If expression with comments
if(condition <# check #>) then { <# then #> value } else { <# else #> fallback }

#! Valid expression
# 14. Indented if expression style
if(condition) then:
  result

#! Valid expression
# 15. Indented if expression with else
if(condition) then:
  primaryValue
else:
  fallbackValue

#! Valid expression
# 16. Indented if expression with else if
if(x > 0) then:
  positive
else if(x < 0) then:
  negative
else:
  zero

#! Valid expression
# 17. Indented if expression with complex body
if(isReady) then:
  data := fetchData()
  process(data)
  result

#! Valid expression
# 18. Indented if expression with nested if
if(outer) then:
  if(inner) then:
    deepValue
  else:
    shallowValue
else:
  defaultValue

#! Valid expression
# 19. If expression with object construction
if(shouldCreate) then {
  Point{x:=10, y:=20}
} else {
  Point{x:=0, y:=0}
}

#! Valid expression
# 20. If expression with for loop in body
if(hasItems) then {
  for(item : items) { process(item) }
} else {
  defaultResult
}

#! Valid expression
# 21. If expression with block expressions
if(condition) then {
  {
    x := calculate();
    x + 1
  }
}

#! Valid expression
# 22. If expression as argument
process(if(condition) then { value1 } else { value2 })

#! Valid expression
# 23. If expression in arithmetic
x + if(condition) then { bonus } else { penalty } + y

#! Valid expression
# 24. If expression with comparison operators
if(a == b) then { equal } else if(a > b) then { greater } else { lesser }

#! Valid expression
# 25. If expression with logical operators
if(isEnabled and hasPermission) then { execute() } else { deny() }

#! Valid expression
# 26. If expression with negation
if(not isEmpty) then { process(data) }

#! Valid expression
# 27. If expression with method calls
if(list.isEmpty()) then { createDefault() } else { list.first() }

#! Valid expression
# 28. Complex nested if expression
if(user.isLoggedIn) then:
  if(user.hasPermission) then:
    if(resource.isAvailable) then:
      processResource(resource)
    else:
      waitForResource()
  else:
    requestPermission()
else:
  redirectToLogin()

#! Valid expression
# 29. If expression with line comments
if(condition) then: # check the condition
  result # return this value
else: # otherwise
  fallback # return fallback

#! Valid expression
# 30. If expression with string conditions
if(status == "active") then { enabled } else { disabled }

#! Valid expression
# 31. If expression with numeric conditions
if(count > 0) then { count } else { 0 }

#! Valid expression
# 32. If expression with boolean literals
if(true) then { alwaysTrue } else { neverReached }

#! Valid expression
# 33. If expression with variable conditions
if(flag) then { onValue } else { offValue }

#! Valid expression
# 34. If expression with function return conditions
if(checkStatus()) then { proceed() } else { abort() }