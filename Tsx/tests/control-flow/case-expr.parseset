#! Valid Expression
case(x):
    0 => "zero"
    _ => "other"

#! Valid Expression
case(value) { 0 => result, _ => default }

#! Valid TopLevel
Test := class:
    Method():void=
        case(input):
            1 => DoSomething()
            _ => 0

#! Valid Expression
for(i -> item : items):
    case(i):
        0 => item.Process()
        _ => item.Skip()