#! Valid Expression
# 1. Empty block
{}

#! Valid Expression
# 2. Block with single expression
{ x }

#! Valid Expression
# 3. Block with single statement
{ x := 1; x }

#! Valid Expression
# 4. Block with multiple statements
{ x := 1; y := 2; x + y }

#! Valid Expression
# 5. Block with const declarations
{ a := 10; b := 20; a + b }

#! Valid Expression
# 6. Block with var declarations
{ var x : int = 5; x * 2 }

#! Valid Expression
# 7. Block with mixed declarations
{ var a : int = 1; b := 2; c : int = 3; a + b + c }

#! Valid Expression
# 8. Nested blocks
{ x := 1; { y := 2; x + y } }

#! Valid Expression
# 9. Block in if expression
if(test) then { a := 1; a } else { b := 2; b }

#! Valid Expression
# 10. Block in for expression
for(x : items) { y := x * 2; y }

#! Valid Expression
# 11. Block with function calls
{ x := getValue(); process(x); x }

#! Valid Expression
# 12. Block with if expression
{ x := getValue(); if(x > 0) then x else -x }

#! Valid Expression
# 13. Block with for expression
{ items := getItems(); for(x : items) { x * 2 } }

#! Valid Expression
# 14. Block indentation style
block:
  x := 1
  y := 2
  x + y

#! Valid Expression
# 15. Whitespace preservation in blocks
{  x  :=  1  ;  y  :=  2  ;  x  +  y  }

#! Valid Expression
# 16. Comments in blocks
{ # start
  x := 1; # assign x
  y := 2; # assign y
  x + y # result
}

#! Valid Expression
# 17. Multiline comments in blocks
{ <# setup #> x := 1; <# compute #> x * 2 }

#! Valid Expression
# 18. Block with no semicolon on last expression
{ x := 1; y := 2; x + y }

#! Valid Expression
# 19. Block with complex expressions
{
  data := getData();
  result := for(item : data.items) {
    if(item.isValid) then item.value else 0
  };
  result
}

#! Valid Expression
# 20. Block with only semicolon
{ ; }

#! Valid Expression
# 21. Block with trailing semicolon
{ x := 1; }