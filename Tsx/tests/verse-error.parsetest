#! Error
# Invalid: explicit type with := operator
var x : int := 5

#! Error
# Invalid: array is a keyword, cannot be used as identifier for indexing
array[5]

#! Error
# Import statements (not yet fully integrated)
import(/UnrealEngine.com)
import(/Fortnite.com/Devices)

#! Error
# Invalid: Missing type in explicit type declaration
var x : = 5

#! Error
# Invalid: var with explicit type cannot use :=
var TestVar : weak_map(session, int) := map{}

#! Error
# Invalid: Empty character literal
''

#! Error
# Invalid: Multiple characters in char literal
'ab'

#! Error
# Invalid: Unclosed string
"unclosed string

#! Error
# Invalid: Invalid escape sequence
"invalid \q escape"

#! Error
# Invalid: Mismatched parentheses
(x + y

#! Error
# Invalid: Missing operator
x y

#! Error
# Invalid: Double operators
x ++ y

#! Error
# Invalid: Assignment in expression context without parentheses
x + y := 5

#! Error
# Invalid: break outside loop
break

#! Error
# Invalid: continue outside loop
continue

#! Error
# Invalid: Incomplete generic syntax
Container<>

#! Error
# Invalid: Missing closing bracket in generic
Container<int

#! Error
# Invalid: Missing colon after module keyword
TestModule := module
    Something()

#! Error
# Invalid: Missing then keyword
TestMissingThen():void=
    result := if (condition) value else other

#! Error
# Invalid: Missing condition
TestMissingCondition():void=
    result := if then value else other

#! Error
# Invalid: Missing else value in expression context
TestIncompleteExpression():void=
    result := if (condition) then value else

#! Error
# Invalid: Mismatched parentheses in condition
TestMismatchedParens():void=
    result := if (condition then value else other

#! Error
# Invalid: Empty condition
TestEmptyCondition():void=
    result := if () then value else other

#! Error
# Invalid: Using assignment operator in condition without parentheses
TestAssignmentInCondition():void=
    result := if x := getValue() then x else 0

#! Error
# Invalid: Missing opening curly brace
TestMissingOpenCurly():void=
    if (condition) then
        DoSomething()
    }

#! Error
# Invalid: Missing closing curly brace
TestMissingCloseCurly():void=
    if (condition) then {
        DoSomething()

#! Error
# Invalid: Mismatched curly braces
TestMismatchedCurlyBraces():void=
    if (condition) then {
        DoSomething()
    } else }
        DoSomethingElse()
    }
