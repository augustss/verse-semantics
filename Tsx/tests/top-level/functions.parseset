#! Valid expression
# 1. Simple function without args or type
f() := 42

#! Valid expression
# 2. Function with single argument
f(x) := x + 1

#! Valid expression
# 3. Function with multiple arguments
add(x, y) := x + y

#! Valid expression
# 4. Function with return type
f() : int = 42

#! Valid expression
# 5. Function with args and return type
add(x, y) : int = x + y

#! Valid expression
# 6. Function with block body
f() := { x + 1; y + 2 }

#! Valid expression
# 7. Function with indented body
f() :=
  x + y

#! Valid expression
# 8. Function with specifier
f <public> () := 42

#! Valid expression
# 9. Function with multiple specifiers
f <public> <inline> () := x + y

#! Valid expression
# 10. Function with specifier and return type
f <export> (x) : int = x * 2

#! Valid expression
# 11. Function with whitespace preservation
f  (  x  ,  y  )  :=  x + y

#! Valid expression
# 12. Function with comments
f # function name
  (x) # param
  := # assignment
  x + 1 # body

#! Valid expression
# 13. Function with return type and comments
add # function
  (x, y) # params
  : int # return type
  = # equals
  x + y # body

#! Valid expression
# 14. Function with object construction body
makePoint(x, y) := Point{x:=x, y:=y}

#! Valid expression
# 15. Function with indented object body
makePoint(x, y) := Point:
  x := x
  y := y

#! Valid expression
# 16. Function with nested function call
compose(f, g, x) := f(g(x))

#! Valid expression
# 17. Function with block containing multiple statements
process(x) := {
  val := x * 2;
  result := val + 10;
  result
}

#! Valid expression
# 18. Multiple functions in block
{
  f(x) := x + 1;
  g(y) := y * 2;
  f(g(5))
}

#! Valid expression
# 19. Function with no parameters
getRandom() := 42

#! Valid expression
# 20. Function with trailing comma in params
f(x, y,) := x + y

#! Valid expression
# 21. Function with specifier argument
process <path(input.txt)> () := readFile()

#! Valid expression
# 22. Function returning another function
makeAdder(x) := f(y) := x + y