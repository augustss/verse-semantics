# Verse Module Declaration Tests
# Tests for module declarations (basic support only)

#! Valid TopLevel
# 1. Simple module declaration
MyModule := module:

#! Valid TopLevel
# 2. Another module declaration
GameModule := module:

#! Valid TopLevel
# 3. Module with empty body (colon style)
EmptyModule := module:

#! Valid TopLevel
# 4. Module names with underscores
my_module := module:

#! Valid TopLevel
# 5. Module with complex name
game_logic_module := module:

