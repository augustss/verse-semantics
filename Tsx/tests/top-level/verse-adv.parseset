# Verse Advanced Features Tests
# Tests for more complex Verse language constructs

#! Valid Expression
# 1. For loops with arrow patterns
for (i -> item : items):
    Print(item)

#! Valid Expression
# 2. For loop with index-value pattern
for (index -> value : myArray):
    Process(value)

#! Valid Expression
# 3. If expression with colon style
if (x > 0):
    DoSomething()

#! Valid Expression
# 4. If-else expression
if (condition):
    ActionA()
else:
    ActionB()

#! Valid Expression
# 5. Empty array literal
array{}

#! Valid Expression
# 6. Array with numbers
array{1, 2, 3}

#! Valid Expression
# 7. Array with strings
array{"a", "b", "c"}

#! Valid TopLevel
# 8. Class with calculated method
MyClass := class:
    Calculate():int=
        x + y * z

#! Valid TopLevel
# 9. Class with conditional in method
MyClass := class:
    Process():void=
        if (x > 0):
            DoWork()
 
#! Valid Expression
# 10. Method chaining
object.Method1().Method2().Method3()

#! Valid TopLevel
# 11. Simple assignment
x := 5

#! Valid TopLevel
# 12. Assignment with function call
result := Calculate(10, 20)

#! Valid Expression
# 13. Block expression with braces
{
    x := 5
    y := 10
    x + y
}
 

#! Valid Expression
# 14. Greater than comparison
x > y

#! Valid Expression
# 15. Less than or equal comparison
a <= b

#! Valid Expression
# 16. Equality check
value = 10

#! Valid Expression
# 17. Logical AND
x and y

#! Valid Expression
# 18. Logical OR
a or b

#! Valid Expression
# 19. Logical NOT
not condition

#! Valid Expression
# 20. Array access
myArray[0]

#! Valid Expression
# 21. Matrix access
matrix[i][j]

#! Valid Expression
# 22. Function call with string
Print("Hello")

#! Valid Expression
# 23. Function call with multiple args
Calculate(x, y, z)

#! Valid Expression
# 24. Member access
object.field

#! Valid Expression
# 25. Chained member access with method call
device.EnabledEvent.Subscribe(Handler)