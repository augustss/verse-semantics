# Verse Using Statement Tests
# Tests for import/using statements

#! Valid TopLevel
# 1. Single using statement
using { /Fortnite.com/Devices }

#! Valid TopLevel
# 2. Another single using statement
using { /Verse.org/Simulation }

#! Valid TopLevel
# 3. Using statement with deeper path
using { /UnrealEngine.com/Temporary/SpatialMath }

#! Valid TopLevel
# 4. Multiple using statements
using { /Fortnite.com/Devices }
using { /Verse.org/Simulation }

#! Valid TopLevel
# 5. Three using statements
using { /Fortnite.com/Devices }
using { /Verse.org/Simulation }
using { /Fortnite.com/Characters }

#! Valid TopLevel
# 6. Using statements with class definition
using { /Fortnite.com/Devices }

MyClass := class{}

#! Valid TopLevel
# 7. Using statements with device class
using { /Fortnite.com/Devices }
using { /Verse.org/Simulation }

MyDevice := class(creative_device):
    @editable
    MyField:int = 5

#! Valid TopLevel
# 8. Using statements with blank lines
using { /Fortnite.com/Devices }


MyClass := class{}

#! Valid TopLevel
# 9. Using statement for Teams
using { /Fortnite.com/Teams }

#! Valid TopLevel
# 10. Using statement for Playspaces
using { /Fortnite.com/Playspaces }

#! Valid TopLevel
# 11. Using statement for Diagnostics
using { /UnrealEngine.com/Temporary/Diagnostics }

#! Valid TopLevel
# 12. Using statement for UI
using { /UnrealEngine.com/Temporary/UI }

#! Valid TopLevel
# 13. Using statement for Random
using { /Verse.org/Random }

#! Valid TopLevel
# 14. Using statement with nested path
using { /Verse.org/Simulation/Tags }

#! Valid TopLevel
# 15. Complete program with using statements
using { /Fortnite.com/Devices }
using { /Verse.org/Simulation }

teleporter_device := class(creative_device):
    @editable
    TriggerDevice:trigger_device = trigger_device{}

    OnBegin<override>()<suspends>:void=
        TriggerDevice.TriggeredEvent.Subscribe(OnTriggered)

    OnTriggered(Agent:agent):void=
        TeleportPlayer(Agent)