# Verse Class Declaration Tests
# Tests for class declarations with inheritance and various features

#! Valid TopLevel
# 1. Simple class declaration
MyClass := class{}

#! Valid TopLevel
# 2. Class with parentheses instead of braces
MyDevice := class()

#! Valid TopLevel
# 3. Class with inheritance
MyDevice := class(creative_device){}

#! Valid TopLevel
# 4. Class with inheritance and colon
MyDevice := class(creative_device):

#! Valid TopLevel
# 5. Class with field
Player := class:
    Name:string = "Unknown"

#! Valid TopLevel
# 6. Class with multiple fields
Player := class:
    Name:string = "Unknown"
    Health:int = 100
    Position:vector3 = vector3{}

#! Valid TopLevel
# 7. Class with decorated field
teleporter_device := class(creative_device):
    @editable
    TriggerDevice:trigger_device = trigger_device{}

#! Valid TopLevel
# 8. Class with method (simple)
MyClass := class:
    GetValue():int=
        42

#! Valid TopLevel
# 9. Class with method (indented body)
MyClass := class:
    Calculate():int=
        x + y

#! Valid TopLevel
# 10. Class with method having specifiers
teleporter_device := class(creative_device):
    OnBegin<override>()<suspends>:void=
        Print("Started")

#! Valid TopLevel
# 11. Complex class with multiple members
game_device := class(creative_device):
    @editable
    EnabledDevice:enabled_device = enabled_device{}

    @editable
    Score:int = 0

    OnBegin<override>()<suspends>:void=
        EnabledDevice.EnabledEvent.Subscribe(OnEnabled)

    OnEnabled(Agent:agent):void=
        Print("Device enabled")

#! Valid TopLevel
# 12. Class with public specifier
DominationSpawnTags<public> := class{}

#! Valid TopLevel
# 13. Public class with inheritance
domination_spawn_tags<public> := class(tag){}

#! Valid TopLevel
# 14. Class inheriting from tag
Tag_Player := class(tag){}

#! Valid TopLevel
# 15. Empty class with various syntaxes
EmptyClass1 := class{}

#! Valid TopLevel
EmptyClass2 := class()

#! Valid TopLevel
EmptyClass3 := class:

#! Valid TopLevel
# 16. Nested class-like structure
Outer := class:
    Inner := class:
        Value:int = 5

#! Valid TopLevel
# 17. Class with const field
Settings := class:
    MaxPlayers<const>:int = 100

#! Valid TopLevel
# 18. Class with multiple decorators
ui_device := class(creative_device):
    @editable
    @replicated
    UIText:string = "Hello"

#! Valid TopLevel
# 19. Class with constructor-like method
player_manager := class:
    Initialize(Name:string):void=
        SetName(Name)

#! Valid TopLevel
# 20. Full Fortnite device example
teleporter_device := class(creative_device):
    @editable
    TriggerDevice:trigger_device = trigger_device{}

    @editable
    TeleportDestination:teleporter_device_island_rift = teleporter_device_island_rift{}

    OnBegin<override>()<suspends>:void=
        TriggerDevice.TriggeredEvent.Subscribe(OnTriggered)

    OnTriggered(Agent:agent):void=
        if (FortCharacter := Agent.GetFortCharacter[]):
            TeleportDestination.Teleport(Agent)