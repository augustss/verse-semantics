# Set Statement Tests

#! Valid Expression
# 1. Basic set statement
set x = 5

#! Valid Expression
# 2. Set statement with expression
set result = x + y * 2

#! Valid Expression
# 3. Set statement with variable containing underscore
set my_var = 100

#! Valid Expression
# 4. Set statement with function call
set value = calculateSum(a, b)

#! Valid Expression
# 5. Set statement with boolean expression
set flag = x > 5 and y < 10

#! Valid Expression
# 6. Set statement with string literal
set message = "Hello World"

#! Valid Expression
# 7. Set statement with float
set ratio = 3.14159

#! Valid Expression
# 8. Set statement with complex expression
set final = (x + y) * (z - w) / 2