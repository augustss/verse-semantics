# Annotation Tests

#! Valid Expression
# 1. Function with decides annotation
<decides>
MyFunction() : logic = true

#! Valid Expression
# 2. Function with transacts annotation
<transacts>
UpdateScore() : void = { }

#! Valid Expression
# 3. Function with both decides and transacts
<decides><transacts>
ProcessAction() : logic = false

#! Valid Expression
# 4. Function with decides in class method
TestClass := class:
  <decides>
  CanPerformAction() : logic = true

#! Valid Expression
# 5. Function with transacts in class method
GameManager := class:
  <transacts>
  ModifyState() : void = { }

#! Valid Expression
# 6. Complex function with annotation
<decides>
ValidateInput(value : int) : logic = value > 0 and value < 100

#! Valid Expression
# 7. Method with annotation and parameters
PlayerController := class:
  <transacts>
  MovePlayer(direction : Vector3, speed : float) : void = { }