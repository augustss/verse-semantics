%  -------------------------- Syntax -----------------------
\newcommand{\figureSyntax}{
\begin{figure}[t]
    $$
    \begin{array}{l}
      \textbf{Syntax} \\
      \begin{array}{lr@@{\;}c@@{\;}l}
      \text{Integers} & k \\
      \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
      \text{Programs} & p  & ::=  & |one e| \quad \text{where} \; \freevars{e} = \emptyset \\
      \text{Expressions}   & e     & ::= & |v| \vb |eu ; e| \vb |def x e| \vb |fail|
                                           \vb |e_1 choice e_2| \vb |apply1N v_1 v_2|
                             \vb |one e| \vb |all e| \\
                             & eu     & ::= & |e| \vb |v == e| \quad \quad
                                       \text{``$eu$'' is pronounced ``expression or unification''} \\
  %    \text{Expressions} & e  & ::=  & |v| \vb |apply1N v_1 v_2|
  %       \vb |e_1 == e_2| \vb |e_1 ; e_2| \vb  |def x e|
  %    \vb  |e_1 choice e_2| \vb |fail| \vb |one e| \vb |all e| \\
  % SPJ Omitting for now
  \iffullverse
      && \vb & |succeeds e| \vb |decides e| \\
  \fi
      \text{Values} & v & ::= & x  \vb \hnf \\
      \text{Head values} & \hnf & ::= & k \vb op \vb |arr (v_1, dots, v_n)| \vb |lam x e| \\
      \text{Primops} & op  & ::= & |gt| \vb |add|
  \iffullverse
      \vb |isInt|
  \fi
      \end{array} \\
      \\[-3mm]
      \text{\emph{Concrete syntax}:} \;\;
      \begin{array}[t]{l}
            \text{``|choice|'' and ``;'' are right-associative} \\
            \text{``|choice|'' and ``|=|'' bind more tightly than ``;''} \\
            \text{``$\lambda$'', ``|defKW|'' scope as far to the right as possible} \\
            \hspace{4mm} \text{{\eg}, |(lam y (def x (x=1; x+y)))| means |(lam y ((def x (((x=1); (x+y))))))|} \\
      \end{array} \\
      \text{Parentheses may be used freely to aid readability and override default precedence}
  \\
      \textbf{Desugaring} \\
    \begin{array}{rcll}
%%      |emptytup| & \text{means} & |arr ()|\\
%%      |tup (v_1, dots, v_n)| & \text{means} & |arr (v_1,dots, v_n)| \quad n \geq 2 \\
      v_1 + v_2 & \text{means} & |applyN add ( v_1, v_2 ) | & \\
      v_1 > v_2 & \text{means} & |applyN gt ( v_1, v_2 ) | & \\
      |def (x_1 ^^ x_2 dots x_n) e| & \text{means} & |def x_1 (def x_2 (dots ^ def x_n e))| & \\
      |e_1 e_2| & \text{means} & |def (f^^ x) (f == e_1 ; x == e_2; apply1N f x)|  & |f,x|\ \text{fresh} \\
      |tup (e_1, dots, e_n)| & \text{means} &
          |def (x_1 ^^ x_2 dots x_n) (x_1=e_1; dots; x_n=e_n; tup (x_1,dots, x_n)| & \text{|x_i| fresh} \\
      |e_1 == e_2|      & \text{means} & |def x (x == e_1 ; x == e_2; x)|       & |x|\ \text{fresh} \\
%      |e_1 ; e_2|      & \text{means} & |def x (e_1; x == e_2 ; x)|       & |x|\ \text{fresh} \\

      |if e_1 then e_2 else e_3| & \text{means}
      & |def y (y == one( (e_1; thunk e_2) choice (thunk e_3)); apply0 y)| & \text{|x,y| fresh} \\
%       |for^(e_1) do e_2| & \text{means} & |def v (v == all (e_1; thunk e_2); applyN map (lam z (apply0 z), v))|
      |x := e_1; e_2| & \text{means} & |def x (x == e_1; e_2)| \\
      |lamhdr (tup(x,y))^^ e| & \text{means} & |lam p (def (x ^^ y) (p = tup (x,y); e)| & \text{|p| fresh}
    \end{array} \\
  \\[-2mm]
  \text{$\freevars{e}$ means the free variable of $e$; in \versecalc{}, $\lambda$ and |defKW| are the only binders.}
  %\text{$S_1 \disjoint S_2$ means that set $S_1$ is disjoint from $S_2$.}
  \end{array}
  $$
  \caption{\textbf{\calcname: Syntax}} \label{fig:syntax}
\end{figure}
}

