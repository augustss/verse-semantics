%  -------------------------- Syntax -----------------------
\newcommand{\figureSyntax}{
\begin{figure}[t]
    $$
  \begin{array}{l}
      \textbf{Syntax} \\
      \begin{array}{lr@@{\;}c@@{\;}l}
      \text{Integers} & k \\
      \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
      \text{Programs} & p  & ::=  & |one e| \quad \text{where} \; \freevars{e} = \emptyset \\
      \text{Expressions}   & e     & ::= & |v| \vb |eq ; e| \vb |def x e| \vb |fail|
                                           \vb |e_1 choice e_2| \vb |apply1N v_1 v_2|
                             \vb |one e| \vb |all e| \\
                             & |eq|     & ::= & |e| \vb |v == e| \quad \quad
                                       \text{Note: ``|eq|'' is pronounced ``expression or equation''} \\
  %    \text{Expressions} & e  & ::=  & |v| \vb |apply1N v_1 v_2|
  %       \vb |e_1 == e_2| \vb |e_1 ; e_2| \vb  |def x e|
  %    \vb  |e_1 choice e_2| \vb |fail| \vb |one e| \vb |all e| \\
  % SPJ Omitting for now
  \iffullverse
      && \vb & |succeeds e| \vb |decides e| \\
  \fi
      \text{Values} & |v| & ::= & x  \vb \hnf \\
      \text{Head values} & \hnf & ::= & k \vb op \vb |arr (v_1, xdots, v_n)| \vb |lam x e| \\
      \text{Primops} & op  & ::= & |gt| \vb |add|
  \iffullverse
      \vb |isInt|
  \fi
      \end{array} \\
      \\[-0.9em]
      \text{\emph{Concrete syntax}:} \;\;
      \begin{array}[t]{l}
            \text{``|choice|'' and ``;'' are right-associative} \\
            \text{``|choice|'' and ``|==|'' bind more tightly than ``;''} \\
            \text{``$\lambda$'', ``|defKW|'' scope as far to the right as possible} \\
            \hspace{1.2em} \text{{\eg}, |(lam y (def x (x==1; x+y)))| means |(lam y ((def x (((x==1); (x+y))))))|} \\
      \end{array} \\
      \text{Parentheses may be used freely to aid readability and override default precedence}\\
  \\[-0.6em]
      \textbf{Desugaring} \\
    \begin{array}{rcll}
%%      |emptytup| & \text{means} & |arr ()|\\
%%      |tup (v_1, dots, v_n)| & \text{means} & |arr (v_1,dots, v_n)| \quad n \geq 2 \\
\iffalse
% Do not use := when defining sugar
      |v_1 + v_2| & \text{means} & |applyN add ( v_1, v_2 ) | & \\
      |v_1 > v_2| & \text{means} & |applyN gt ( v_1, v_2 ) | & \\
      |def (x_1 ^^ x_2 xdots x_n) e| & \text{means} & |def x_1 (def x_2 (xdots ^ def x_n e))| & \\
      |e_1 e_2| & \text{means} & |def (f^^ x) (f == e_1 ; x == e_2; apply1N f x)|  & |f,x|\ \text{fresh} \\
      |tup (e_1, xdots, e_n)| & \text{means} &
          |def (x_1 ^^ x_2 xdots x_n) (x_1==e_1; xdots; x_n==e_n; tup (x_1,xdots, x_n))| & \text{|x_i| fresh} \\
      |e_1 == e_2|      & \text{means} & |def x (x == e_1 ; x == e_2; x)|       & |x|\ \text{fresh} \\
%      |e_1 ; e_2|      & \text{means} & |def x (e_1; x == e_2 ; x)|       & |x|\ \text{fresh} \\

%       |for^(e_1) do e_2| & \text{means} & |def v (v == all (e_1; thunk e_2); applyN map (lam z (apply0 z), v))|
      |x :== e_1; e_2| & \text{means} & |def x (x == e_1; e_2)| \\
      |lamhdr emptytup^^ e| & \text{means} & |lam p (p == emptytup; e)| & \text{|p| fresh} \\
      |lamhdr (tup(x,y))^^ e| & \text{means} & |lam p (def (x ^^ y) (p == tup (x,y); e))| & \text{|p| fresh} \\
      |if e_1 then e_2 else e_3| & \text{means}
      & |def y (y == one( (e_1; thunk e_2) choice (thunk e_3)); apply0 y)| & \text{|y| fresh} \\
\else
% Use := when defining sugar
      |e_1 + e_2| & \text{means} & |applyN add ( e_1, e_2 ) | & \\
      |e_1 > e_2| & \text{means} & |applyN gt ( e_1, e_2 ) | & \\
      |def (x_1 ^^ x_2 xdots x_n) e| & \text{means} & |def x_1 (def x_2 (xdots ^ def x_n e))| & \\
      |x :== e_1; e_2| & \text{means} & |def x (x == e_1; e_2)| \\
      |e_1 e_2| & \text{means} & |f :== e_1 ; x :== e_2; apply1N f x|  & |f,x|\ \text{fresh} \\
      |tup (e_1, xdots, e_n)| & \text{means} &
          |x_1:==e_1; xdots; x_n:==e_n; tup (x_1,xdots, x_n)| & \text{|x_i| fresh} \\
      |e_1 == e_2|      & \text{means} & |x :== e_1 ; x == e_2; x|       & |x|\ \text{fresh} \\

%       |for^(e_1) do e_2| & \text{means} & |def v (v == all (e_1; thunk e_2); applyN map (lam z (apply0 z), v))|
      |lamhdr emptytup^^ e| & \text{means} & |lam p (p == emptytup; e)| & \text{|p| fresh} \\
      |lamhdr (tup(x,y))^^ e| & \text{means} & |lam p (def (x ^^ y) (p == tup (x,y); e))| & \text{|p| fresh} \\
%      |if e_1 then e_2 else e_3| & \text{means}
%         & |y :== one( (e_1; thunk e_2) choice (thunk e_3)); apply0 y| & \text{|y| fresh} \\
      |if (def (x_1^^xdots^^x_n) e_1) then e_2 else e_3| & \text{means}
         & |apply0(one( (def (x_1^^xdots^^x_n) e_1; thunk e_2) choice (thunk e_3)))| \\
\fi
    \end{array} \\
  \\[-0.6em]
  \text{$\freevars{e}$ means the free variable of $e$; in \versecalc{}, $\lambda$ and |defKW| are the only binders.}
  %\text{$S_1 \disjoint S_2$ means that set $S_1$ is disjoint from $S_2$.}
  \end{array}
  $$
  \caption{\textbf{\calcname: Syntax}} \label{fig:syntax}
  \Description{A table that exhibits a BNF grammar for the syntax of the Verse Calculus, some rules about resolving parsing ambiguity,
      and a list of rules for desugaring constructs that are notationally convenient but not part of the Verse Calculus proper}
\end{figure}
}

