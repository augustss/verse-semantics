\rulegroupname{Normalization:~\rcon}
\rulename{norm-val}       & |v ; e|               & \movesto & |e|                   & \\
\rulename{norm-seq-assoc} & |(eu ; e_1) ; e_2|   & \movesto & |eu ; (e_1 ; e_2)|    & \\
\rulename{norm-seq-swap1} & |eu ; (x = v; e)|    & \movesto & |x == v; (eu; e)|     & if |eu| not of form |x' == v'|\\
\rulename{norm-seq-swap2} & |eu ; (x = s; e)|    & \movesto & |x == s; (eu; e)|     & if |eu| not of form |x' == s'|\\
% \rulename{norm-eq}        & |e ; x=v|            & \movesto & |e ; (x=v; x)|            & \\
\rulename{norm-eq-swap}   & |hnf == x|            & \movesto & |x == hnf|            & \\
\rulename{norm-seq-defr}  & |(def x e_1); e_2|    & \movesto & |def x ((e_1 ; e_2))|    & if $|x| \not \in \freevars{|e_2|}$\\
\rulename{norm-seq-defl}  & |eu ; (def x e)|   & \movesto & |def x (eu ; e)|    & if $|x| \not \in \freevars{|eu|}$\\
\rulename{norm-defr}      & |v == (def y e_1); e_2|      & \movesto & |def y (v == e_1; e_2)|   & if $|y| \not \in \freevars{|v,e_2|}$ \\
\rulename{norm-seqr}      & |v == (eu ; e_1); e_2|    & \movesto & |eu ; v == e_1; e_2| \\
% \rulename{norm-unifyr}    & |v_1 == (v_2 == e_1); e_2|   & \movesto & |def x (x == v_1; x == v_2; x == e_1; e_2)|   & $|x|$ fresh \\[0.05in]

\rulegroupname{Fail Propagation:~\rfail}
\rulename{fail-seql}      & |fail ; e|            & \movesto & |fail| \\
\rulename{fail-seqr}      & |e ; fail|            & \movesto & |fail| \\
\rulename{fail-eq}        & |v == fail|           & \movesto & |fail| \\[0.5mm]
\rulegroupname{Garbage Collection:~$\rgc$}
\rulename{elim-def}     & |e_1| & \movesto & \multicolumn{2}{l}
         {|e_2| \quad \quad if $\wff{\emptyset}{|e_1|}{|xs|}{|cs|}{|e_2|}$
             and $|xs| \not\in \freevars{|e_2|}$} \\
\rulegroupname{Structural rules}
        \rulename{swap-d} & |def x (def y e)| & \equiv & |def y (def x e)| &  \\
        \rulename{swap-c} & |x_1=v_1; x_2 = v_2; e| & \equiv & |x_2 = v_2; x_1=v_1; e|
\end{longtable}
