\newcommand{\alphamark}{use $\alpha$}

% ------------------ ICFP rewrite rules -------------------

\newcommand{\figureRewriteRules}{
  \begin{figure}
    $\begin{array}{l}
    \begin{array}{@@{\quad} l @@{\hspace{-.5em}} r @@{\;}c@@{\;} l l}
    % The quad indents the lines
    % The \hspace{-..} removes redundant space between rule name column and LHS column
    % that arises because the longest rule name and the longer LHS are not on the same line
    % The \; reduces the spacing around the arrow

    % \rulegroupname{Primitive operations}

    \iffullverse
        \rulename{p-isInt} & |apply1 isInt hnf| & \movesto &
        $\left\{\begin{array}{@@{}ll}
          |()| & \text{if |hnf| is an integer} \\
          |fail| & \text{otherwise}
          \end{array}\right.$
    \fi

\rulegroupname{Application:~\rapp}
\rulename{app-add} & |applyN add (k_1 ,k_2)| & \movesto & |k_3| & \text{where $k_3 = k_1 + k_2$}\\
\rulename{app-gt}      & |applyN gt (k_1,k_2)|   & \movesto & |k_1| &  \text{if $k_1 > k_2$} \\
\rulename{app-gt-fail} & |applyN gt (k_1,k_2)|   & \movesto & |fail| &  \text{if $k_1 \leq k_2$} \\
\rulename{app-beta} & |apply1 (lam x e) v| & \movesto & |def x (x==v; e)|
              & \text{if $x \not\in \freevars{|v|}$, \alphamark} \\
\rulename{app-tup} & |apply1 (tup (v_0,dots v_n)) v| & \movesto &
         \multicolumn{2}{@@{}l}{|def x (x==v; (x = 0; v_0) choice dots choice (x = n; v_n))| \quad\quad \text{|x| fresh}} \\
\rulename{app-tup-0} & |apply1 emptytup v| & \movesto & |fail| \\

    \\[-2mm]

\rulegroupname{Unification:~\runi}
  \rulename{u-lit}   & |k_1 == k_2; e| & \movesto & |e| & \text{if $k_1=k_2$} \\
  \rulename{u-tup} & \hspace{-8mm} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e| & \movesto & |v_1==v1';xdots;v_n=v_n'; e| \\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & |fail| & \text{if \rulename{u-lit}, \rulename{u-tup} do not match} \\
  \rulename{u-occurs} & |x=V^[x]; e| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
  \rulename{subst} & |X^[x==v;e]| & \movesto & |(subst X x v)^[x==v; subst e x v]| \hspace*{-1mm}
    & \text{if $|x| \in \freevars{|X,e|}$, $|x| \notin \freevars{v}$} \\
  \rulename{hnf-swap} & |hnf==x; e|    & \movesto & |x==hnf; e| \\
  \rulename{var-swap} & |y==x; e|    & \movesto & |x==y; e| & \text{if |x| $\prec$ |y| } \\
%%  \rulename{var-swap-subst} & |X^[x==y; e]| & \movesto & |subst X y x^[y==x; subst e y x]| & \text{if |y| $\prec$ |x| } \\
%%  \rulename{val-swap-ord} & |eu_1; eu_2; e| & \movesto & |eu_2; eu_1; e| & \text{if |eu_2| $\prec$ |eu_1| } \\
  \rulename{val-swap} & |eu_1; eu_2; e| & \movesto & |eu_2; eu_1; e| & \text{if $|eu_1| \in |ceu| \lor |eu_2| \in |ceu|$} \\

    \\[-2mm]

\rulegroupname{Normalization:~\rcon}
\rulename{norm-exi} & |X^[def x e]| & \movesto & |def x (X^[e])| & \text{if $|X| \ne \hole,\,  x \notin \freevars{|X|}$, \alphamark}\\
\rulename{norm-seq} & |(eu ; e_1) ; e_2| & \movesto & |eu ; (e_1 ; e_2)| \\
\rulename{norm-seqr} & |v == (eu ; e_1); e_2| & \movesto & |eu ; (v == e_1; e_2)| \\
\rulename{exi-swap} & |def x (def y e)| & \movesto & |def y (def x e)| & \text{\textit{Note}: structural} \\
% \rulename{norm-unifyr} & |v_1 == (v_2 == e)| & \movesto & |v_1 == v_2; v_1 == e| \\

    \\[-2mm]

\rulegroupname{Elimination:~\rgc}
\rulename{elim-val} & |v ; e| & \movesto & |e| \\
\rulename{elim-exi} & |def x e| & \movesto & |e|
  & \text{if $|x| \notin \freevars{|e|}$}\\
% This uses \overline
%\rulename{exi-eliml} & |def (x ys) (X^[x==v; e])| & \movesto & |def ys (X^[e])|
%  & \text{if $|x| \notin \freevars{|X|}\cup \freevars{|v|} \cup |{ys}|$} \\
% without \overline
\rulename{exi-eliml} & |def x (X^[x==v;e])| & \movesto & |X^[e]| & \text{if $|x| \notin \freevars{|X^[v;e]|}$} \\
\rulename{elim-fail} & |X^[fail]| & \movesto & |fail| & \text{if $|X| \ne \hole$} \\

    \\[-2mm]

\rulegroupname{Speculation:~\rspc}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice} & |one (v `choice` e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-value}  & |all v| & \movesto & |tup v| \\
\rulename{all-choice} & |all (v_1 choice dots choice v_n)| & \movesto & |tup (v_1, dots, v_n)| \\
\rulename{choose-r} & |fail choice e| & \movesto & |e| \\
\rulename{choose-l} & |e choice fail| & \movesto & |e| \\
\rulename{choose-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
\rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & \text{if}~|CX| \ne \hole \\


\end{array} \\
\\    
\text{\textit{Note}: In the rules marked with ``\alphamark'', use $\alpha$-conversion to avoid name capture.}
\end{array}$
\iffullverse
$$\begin{array}{l}
  \textit{Effects} \\
    \begin{array}{lr@@{\;}c@@{\;}l}
      \rulename{succ-value} & |succeeds v| & \movesto & |v| \\
      \rulename{dec-fail} & |decides fail| & \movesto & |fail| \\
      \rulename{dec-value} & |decides v| & \movesto & |v| \\
    \end{array} \\
  \end{array}$$
\fi
\caption{\textbf{The \vcname: Rewrite rules}} \label{fig:rules}
\end{figure}
}

