\vspace*{-0.5em}
\begin{code}
rules lhs  =   "APP-ADD"    `name`  (do  Op Add :@: Tup [Int k1, Int k2] <- [lhs]
                                         pure (Int (k1+k2)))

           <>  "EXI-SWAP"   `name`  (do  EXI x (EXI y e) <- [lhs]
                                         pure (EXI y (EXI x e)))

           <>  "EQN-ELIM"   `name`  (do  EXI x a <- [lhs]
                                         (ctx, (Var x' :=: Val v) :>: e) <- execX a
                                         guard (x == x' && x `notElem` free (ctx (v :>: e)))
                                         pure (ctx e))
