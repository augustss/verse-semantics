\subsection{Unification} % --------------------------------------------------------------------------

\begin{lemma}[$\runi$-Confluent]\label{lem:u-c}
    $\runi$ is confluent.
\end{lemma}

\begin{proof}
	By \cref{lem:ord-confluent} and \cref{lem:closure} we have $\rord^{*}$ is confluent.
	Hence, as $\runi^{*} = \rord^{*}$, we can conclude that $\runi$ is confluent.
\end{proof}


\begin{lemma}[$\runi$-$\rapp$-Comm]\label{lem:u-a-c}
    $\runi$ and $\rapp$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ 2-commutes with $\rapp$ and hence commutes via \cref{lem:k-comm}.
%
Let $\tx{\runi}$ and $\tx{\rapp}$ denote the reducts for $\runi$ and $\rapp$ respectively.

\begin{description}
\item[Case: $\rdx{\runi}$ and $\rdx{\rapp}$ disjoint]
Here $e \equiv \ldots \rdx{\runi} \ldots \rdx{\rapp} \ldots$. Hence, we have
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
\[\begin{tikzcd}
	& {\ldots \rdx{\runi} \ldots \rdx{\rapp} \ldots} \\
	{\ldots \rdx{\runi}' \ldots \rdx{\rapp} \ldots} && {\ldots \rdx{\runi} \ldots \rdx{\rapp}' \ldots} \\
	& {\ldots \rdx{\runi}' \ldots \rdx{\rapp}' \ldots}
	\arrow["\rapp", from=1-2, to=2-3]
	\arrow["\runi"', from=1-2, to=2-1]
	\arrow[dotted, from=2-1, to=3-2]
	\arrow[dotted, from=2-3, to=3-2]
\end{tikzcd}\]

\item[Case: $\rdx{\runi} \subset \rdx{\rapp}$]
Let $\rdx{\rapp} \equiv |apply1N (lam x e) v|$. There are two sub-cases.

\begin{description}
	\item[Case: $\rdx{\rapp} \subset |v|$] \ie $|v| \equiv V[\rdx{\rapp}]$
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
\[\begin{tikzcd}
	& {(\lambda x. e)\ V[\rdx{\runi}]} \\
	{\exists x.\ x = V[\rdx{\runi}];\ e} && {(\lambda x. e)\ V[\rdx{\runi}']} \\
	& {\exists x.\ x = V[\rdx{\runi}'];\ e}
	\arrow["\runi", from=1-2, to=2-3]
	\arrow["\rapp"', from=1-2, to=2-1]
	\arrow["\runi", dotted, from=2-1, to=3-2]
	\arrow["\rapp", dotted, from=2-3, to=3-2]
\end{tikzcd}\]

	\item[Case: $\rdx{\rapp} \subset |e|$] \ie $|e| \equiv E[\rdx{\rapp}]$
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
\[\begin{tikzcd}
	& {(\lambda x. E[\rdx{\runi}])\ v} \\
	{\exists x.\ x = v;\ E[\rdx{\runi}]} && {(\lambda x. E[\rdx{\runi}'])\ v} \\
	& {\exists x.\ x = v;\ E[\rdx{\runi}']}
	\arrow["\runi", from=1-2, to=2-3]
	\arrow["\rapp"', from=1-2, to=2-1]
	\arrow["\runi", dotted, from=2-1, to=3-2]
	\arrow["\rapp"', dotted, from=2-3, to=3-2]
\end{tikzcd}\]
\end{description}

\item[Case: $\rdx{\rapp} \subset \rdx{\runi}$] Let $\rapp \equiv |apply1N (lam y e_1) v_1|$. Split cases on $\runi$ reduction

\begin{description}
	\item[Case: (\rulename{u-*}) $\rdx{\runi} \equiv |c; e| \movesto |c'; e| \equiv \rdx{\runi}'$]
	%
	If $\rdx{\rapp} \subset e$ \ie $e \equiv E_1[\rdx{\rapp}]$
	then join at $|c';| E_1[\rdx{\rapp}']$ (which may be $|fail|$ if $|c'|$ is $|fail|$).
	%
	If $\rdx{\rapp} \subset c$ (\rulename{ulam}) then join at |fail|.

	\item[Case: (\rulename{deref-s}) $\rdx{\runi} \equiv |x == s; E^[x]|$]
	%
	Here $\rdx{\rapp} \subset |E^[x]|$ as we cannot have a $\beta$-redex inside a scalar $s$.
    %
	Split cases on where $x$ occurs relative to $\rdx{\rapp}$
	%
	\begin{description}
		\item[Case: $\rdx{\runi} \equiv |x == s;| \ldots |x| \ldots \rdx{\rapp} \ldots$]
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=s;\ \ldots x \ldots \rdx{\rapp} \ldots} \\
		{x=s;\ \ldots x \ldots \rdx{\rapp}' \ldots} && {x=s;\ \ldots s \ldots \rdx{\rapp} \ldots} \\
		& {x=s;\ \ldots s \ldots \rdx{\rapp} \ldots}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi", dotted, from=2-1, to=3-2]
		\arrow["\rapp"', dotted, from=2-3, to=3-2]
		\end{tikzcd}\]

		\item[Case: $\rdx{\runi} \equiv |x == s; E^[apply1N (lam y e_1) V_1^[x]]|$]
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=s;\ E[(\lambda y. e_1)\ V_1[x] ] } \\
		{x = s;\ E[\exists y.\ y = V_1[x];\ e_1]} && {x=s;\ E[(\lambda y. e_1)\ V_1[s] ] } \\
		& {x = s;\ E[\exists y.\ y = V_1[s];\ e_1]}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi", dotted, from=2-1, to=3-2]
		\arrow["\rapp"', dotted, from=2-3, to=3-2]
		\end{tikzcd}\]

		\item[Case: $\rdx{\runi} \equiv |x == s; E^[apply1N (lam y E_1^[x]) v_1]|$]
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=s;\ E[(\lambda y. E_1[x])\ v_1] } \\
		{x = s;\ E[\exists y.\ y = v_1;\ E_1[x]]} && {x=s;\ E[(\lambda y. E_1[s])\ v_1] } \\
		& {x = s;\ E[\exists y.\ y = v_1;\ E_1[s]]}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi", dotted, from=2-1, to=3-2]
		\arrow["\rapp"', dotted, from=2-3, to=3-2]
		\end{tikzcd}\]
	\end{description}

	\item[Case: (\rulename{deref-v}) $\rdx{\runi} \equiv |x == v; A^[x]|$]
	Split cases on where $\rdx{\rapp}$ occurs in $v$ or $|A^[x]|$.

	\begin{description}
		\item[Case:] $v \equiv V[\rdx{\rapp}]$ In this case we have
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=V[\rdx{\rapp}];\ A[x] } \\
		{x=V[\rdx{\rapp}'];\ A[x] } && {x=V[\rdx{\rapp}];\ A[V[\rdx{\rapp}]] } \\
		&& {x=V[\rdx{\rapp}'];\ A[V[\rdx{\rapp}]] } \\
		& {x=V[\rdx{\rapp}'];\ A[V[\rdx{\rapp}']] }
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\rapp", dotted, from=2-3, to=3-3]
		\arrow["\rapp", dotted, from=3-3, to=4-2]
		\arrow["\runi"', dotted, from=2-1, to=4-2]
		\end{tikzcd}\]

		\item[Case:] $A[x] \equiv \ldots x \ldots \rdx{\rapp}$ (|x| occurs outside $\rapp$) Trivial.
        % https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
        \[\begin{tikzcd}
        	& {x=v;\ \ldots x \ldots \rdx{\rapp} \ldots} \\
        	{x=v;\ \ldots x \ldots \rdx{\rapp}' \ldots} && {x=v;\ \ldots v \ldots \rdx{\rapp} \ldots} \\
        	& {x = v; \ldots v \ldots \rdx{\rapp}' \ldots}
        	\arrow["\runi", from=1-2, to=2-3]
        	\arrow["\rapp"', from=1-2, to=2-1]
        	\arrow["\runi"', dotted, from=2-1, to=3-2]
        	\arrow["\rapp", dotted, from=2-3, to=3-2]
        \end{tikzcd}\]

		\item[Case:] $A[x] \equiv A[(\lambda y_1. A_1[x]) v_1]$ (|x| occurs inside $\rapp$'s $\lambda$)
		Impossible as application contexts do not go under a $\lambda$.

		\item[Case:] $A[x] \equiv A[(\lambda y_1. e_1) V_1[x]]$ (|x| occurs inside $\rapp$'s argument)
		By definition of application context, the only possible case is when $V_1[x] \equiv x$.
		In this case we have
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=v;\ A[(\lambda y. e_1)\ x]} \\
		{x=v;\ A[\exists y.\ y = x;\ e_1]} && {x=v;\ A[(\lambda y. e_1)\ v]} \\
		& {x=v;\ A[\exists y.\ y = v;\ e_1]}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi"', dotted, from=2-1, to=3-2]
		\arrow["\rapp", dotted, from=2-3, to=3-2]
		\end{tikzcd}\]
	\end{description}
\end{description}
\end{description}
\end{proof}


