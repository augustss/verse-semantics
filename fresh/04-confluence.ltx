\begin{lemma}[Join-S-S] \label{lem:join-s-s}
If $e_1 \equiv {s_1 = s_2; E[s_1]}$ and $e_2 \equiv {s_1 = s_2; E[s_2]}$
then $\rsteps{\rord}{e_1,e_2}{|fail|}$ or $\rsteps{\rord}{e_1,e_2}{s_1=s_2; E[s]}$.
\end{lemma}

\begin{proof}
If $s_1 \equiv s_2$ then $e_1, e_2$ are trivially joined.
Suppose that $s_1 \not \equiv s_2$ and split cases on whether they are variables or literals.

\begin{description}
\item[Case $s_1 \equiv k_1$ and $s_2 \equiv k_2$] Join at $|fail|$ as $k_1 \not \equiv k_2$.
\item[Case $s_1 \equiv k$ and $s_2 \equiv x$] Join at $e_1$ as $\rstep{}{k = x; E[x]}{k = x; E[k]}$.
\item[Case $s_1 \equiv x$ and $s_2 \equiv k$] Join at $e_2$ as $\rstep{}{k = x; E[x]}{k = x; E[k]}$.
\item[Case $s_1 \equiv x_1$ and $s_2 \equiv x_2$] Join at $e_{3-j}$ where $\rnk{x_j} < \rnk{x_{3-j}}$, as $\rstep{}{x_1 = x_2; E[x_j]}{x_1 = x_2; E[x_{3-j}]}$.
\end{description}
\end{proof}

\begin{lemma}[Join-H-H] \label{lem:join-h-h}
Let $h$ and $h'$ be two heap values.
If $e \equiv {h = h'; E[h]}$ and
   $e' \equiv {h = h'; E[h']}$
then $\rsteps{\rord}{e,e'}{|fail|}$ or
     $\rsteps{\rord}{e,e'}{s_1 = s_1'; \ldots; s_n = s_n'; E[h^*]}$.
\end{lemma}

\begin{proof}
If either $h$ or $h'$ are $\lambda$-terms then we can join at $|fail|$.
%
If $h$ and $h'$ are tuples of \emph{different} sizes we can join at $|fail|$.
%
Hence, assume that $h \equiv |arr (s_1, dots, s_n)|$ and $h' \equiv |arr (s'_1, dots, s'_n)|$.
%
Via \rulename{u-tup} $e$ and $e'$ respectively to $s_1 = s_1'; \ldots; s_n = s_n'; E[h]$
and $s_1 = s_1'; \ldots; s_n = s_n'; E[h']$.
%
From \cref{lem:join-s-s} we have that for all $0 \leq i \leq n$ the terms
	$e_i \equiv s_i == s_i'; s_i$ and $e_i' \equiv s_i = s_i'; s_i'$
	join at $|fail|$ or at some $s_i = s_i'; s_i^{*}$.
%
If there exists some $i$ at which $e_i$ and $e_i'$ join at $|fail|$
then we can join $e$ and $e'$ at $|fail|$ via \cref{lem:eq-scalar-fail}.
%
Otherwise, we can join $e$ and $e'$ at $e^* \equiv s_1 = s_1'; \ldots; s_n = s_n'; E[\langle s_1^*, \ldots, s_n^{*} \rangle]$
using $n$ applications of \cref{lem:eq-scalar}.
%
% \begin{verbatim}
% e -> ... -> e_i -> ... -> e_n == e^* <- e_n' <- ... <- e_i' <- ... <- e'
% where ei := s_1 = s_1'; ...; s_i = s_i'; E<s1*...si*, s_{i+1}, ..., sn>] and
% 	  ei' := s_1 = s_1'; ...; s_i = s_i'; E<s1*...si*, s'_{i+1}, ..., sn'>>
% 	  and each step follows from lem:eq-scalar with
% 	  	s_{i+1} = s_{i+1}'; s_{i+1}  & E = E[<s1*...si*, HOLE, ... sn>]
% 	  	s_{i+1} = s_{i+1}'; s_{i+1}' & E = E[<s1*...si*, HOLE, ... sn'>]
% \end{verbatim}
%
\end{proof}

\begin{lemma}[Eq-Scalar-Fail]\label{lem:eq-scalar-fail}
	If $\rsteps{}{s=s'; s}{|fail|}$ then $\rsteps{}{s=s'; e}{|fail|}$.
\end{lemma}
\begin{proof}
Premise only holds when $s \equiv k$ and $s' \equiv k'$ and $k \not = k$.
\end{proof}

\begin{lemma}[Eq-Scalar]\label{lem:eq-scalar}
	If $\rstep{\rord}{s=s'; s}{s=s'; s'}$ then $\rstep{\rord}{s=s'; E[s]}{s=s'; E[s']}$.
\end{lemma}
\begin{proof}
Split cases on $s$ and $s'$ and use \rulename{deref-s}.
\end{proof}

\begin{lemma}[$\rord$-Noetherian]\label{lem:ord-term}
    $\rord$ is Noetherian.
\end{lemma}

\begin{proof}
Each term has a finite number of free variable occurrences.
%
Every reduction in $\rord$ makes progress by doing one of the following:
%
(1)~replaces a variable with a heap value (under which no further heap substitutions occur);
%
(2)~replaces a variable with a scalar value (under which no further scalar substitutions occur);
%
(3)~replaces a variable with a higher-ranked variable;
%
or
%
(4)~destructs a pair of unified tuples, replacing them with their components.
%
Each of the above can only occur finitely often, thereby ensuring
that $\rord$ terminates, \ie is Noetherian.
\end{proof}

\begin{corollary}[$\rord$-Confluent]\label{lem:ord-confluent}
    $\rord$ is confluent.
\end{corollary}

\begin{proof}
	Via \cref{lem:ord-lc} and \cref{lem:ord-term} and Newman's lemma \cref{lem:local}.
\end{proof}


\subsection{Unification} % --------------------------------------------------------------------------

\begin{lemma}[$\runi$-Confluent]\label{lem:u-c}
    $\runi$ is confluent.
\end{lemma}

\begin{proof}
	By \cref{lem:ord-confluent} and \cref{lem:closure} we have $\rord^{*}$ is confluent.
	Hence, as $\runi^{*} = \rord^{*}$, we can conclude that $\runi$ is confluent.
\end{proof}


\begin{lemma}[$\runi$-$\rapp$-Comm]\label{lem:u-a-c}
    $\runi$ and $\rapp$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ $*$-commutes with $\rapp$ and hence commutes via \cref{lem:star-comm}.
%
Let $\tx{\runi}$ and $\tx{\rapp}$ denote the reducts for $\runi$ and $\rapp$ respectively.

\begin{description}
\item[Case: $\rdx{\runi}$ and $\rdx{\rapp}$ disjoint]
Here $e \equiv \ldots \rdx{\runi} \ldots \rdx{\rapp} \ldots$. Hence, we have
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
\[\begin{tikzcd}
	& {\ldots \rdx{\runi} \ldots \rdx{\rapp} \ldots} \\
	{\ldots \rdx{\runi}' \ldots \rdx{\rapp} \ldots} && {\ldots \rdx{\runi} \ldots \rdx{\rapp}' \ldots} \\
	& {\ldots \rdx{\runi}' \ldots \rdx{\rapp}' \ldots}
	\arrow["\rapp", from=1-2, to=2-3]
	\arrow["\runi"', from=1-2, to=2-1]
	\arrow[dotted, from=2-1, to=3-2]
	\arrow[dotted, from=2-3, to=3-2]
\end{tikzcd}\]

\item[Case: $\rdx{\runi} \subset \rdx{\rapp}$]
Let $\rdx{\rapp} \equiv |apply1N (lam x e) v|$. There are two sub-cases.

\begin{description}
	\item[Case: $\rdx{\rapp} \subset |v|$] \ie $|v| \equiv V[\rdx{\rapp}]$
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
\[\begin{tikzcd}
	& {(\lambda x. e)\ V[\rdx{\runi}]} \\
	{\exists x.\ x = V[\rdx{\runi}];\ e} && {(\lambda x. e)\ V[\rdx{\runi}']} \\
	& {\exists x.\ x = V[\rdx{\runi}'];\ e}
	\arrow["\runi", from=1-2, to=2-3]
	\arrow["\rapp"', from=1-2, to=2-1]
	\arrow["\runi", dotted, from=2-1, to=3-2]
	\arrow["\rapp", dotted, from=2-3, to=3-2]
\end{tikzcd}\]

	\item[Case: $\rdx{\rapp} \subset |e|$] \ie $|e| \equiv E[\rdx{\rapp}]$
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
\[\begin{tikzcd}
	& {(\lambda x. E[\rdx{\runi}])\ v} \\
	{\exists x.\ x = v;\ E[\rdx{\runi}]} && {(\lambda x. E[\rdx{\runi}'])\ v} \\
	& {\exists x.\ x = v;\ E[\rdx{\runi}']}
	\arrow["\runi", from=1-2, to=2-3]
	\arrow["\rapp"', from=1-2, to=2-1]
	\arrow["\runi", dotted, from=2-1, to=3-2]
	\arrow["\rapp"', dotted, from=2-3, to=3-2]
\end{tikzcd}\]
\end{description}

\item[Case: $\rdx{\rapp} \subset \rdx{\runi}$] Let $\rapp \equiv |apply1N (lam y e_1) v_1|$. Split cases on $\runi$ reduction

\begin{description}
	\item[Case: (\rulename{u-*}) $\rdx{\runi} \equiv |c; e| \movesto |c'; e| \equiv \rdx{\runi}'$]
	%
	If $\rdx{\rapp} \subset e$ \ie $e \equiv E_1[\rdx{\rapp}]$
	then join at $|c';| E_1[\rdx{\rapp}']$ (which may be $|fail|$ if $|c'|$ is $|fail|$).
	%
	If $\rdx{\rapp} \subset c$ (\rulename{ulam}) then join at |fail|.

	\item[Case: (\rulename{deref-s}) $\rdx{\runi} \equiv |x == s; E^[x]|$]
	%
	Here $\rdx{\rapp} \subset |E^[x]|$ as we cannot have a $\beta$-redex inside a scalar $s$.
    %
	Split cases on where $x$ occurs relative to $\rdx{\rapp}$
	%
	\begin{description}
		\item[Case: $\rdx{\runi} \equiv |x == s;| \ldots |x| \ldots \rdx{\rapp} \ldots$]
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=s;\ \ldots x \ldots \rdx{\rapp} \ldots} \\
		{x=s;\ \ldots x \ldots \rdx{\rapp}' \ldots} && {x=s;\ \ldots s \ldots \rdx{\rapp} \ldots} \\
		& {x=s;\ \ldots s \ldots \rdx{\rapp} \ldots}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi", dotted, from=2-1, to=3-2]
		\arrow["\rapp"', dotted, from=2-3, to=3-2]
		\end{tikzcd}\]

		\item[Case: $\rdx{\runi} \equiv |x == s; E^[apply1N (lam y e_1) V_1^[x]]|$]
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=s;\ E[(\lambda y. e_1)\ V_1[x] ] } \\
		{x = s;\ E[\exists y.\ y = V_1[x];\ e_1]} && {x=s;\ E[(\lambda y. e_1)\ V_1[s] ] } \\
		& {x = s;\ E[\exists y.\ y = V_1[s];\ e_1]}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi", dotted, from=2-1, to=3-2]
		\arrow["\rapp"', dotted, from=2-3, to=3-2]
		\end{tikzcd}\]

		\item[Case: $\rdx{\runi} \equiv |x == s; E^[apply1N (lam y E_1^[x]) v_1]|$]
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=s;\ E[(\lambda y. E_1[x])\ v_1] } \\
		{x = s;\ E[\exists y.\ y = v_1;\ E_1[x]]} && {x=s;\ E[(\lambda y. E_1[s])\ v_1] } \\
		& {x = s;\ E[\exists y.\ y = v_1;\ E_1[s]]}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi", dotted, from=2-1, to=3-2]
		\arrow["\rapp"', dotted, from=2-3, to=3-2]
		\end{tikzcd}\]
	\end{description}

	\item[Case: (\rulename{deref-h}) $\rdx{\runi} \equiv |x == v; A^[x]|$]
	Split cases on where $\rdx{\rapp}$ occurs in $v$ or $|A^[x]|$.

	\begin{description}
		\item[Case:] $v \equiv V[\rdx{\rapp}]$ In this case we have
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=V[\rdx{\rapp}];\ A[x] } \\
		{x=V[\rdx{\rapp}'];\ A[x] } && {x=V[\rdx{\rapp}];\ A[V[\rdx{\rapp}]] } \\
		&& {x=V[\rdx{\rapp}'];\ A[V[\rdx{\rapp}]] } \\
		& {x=V[\rdx{\rapp}'];\ A[V[\rdx{\rapp}']] }
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\rapp", dotted, from=2-3, to=3-3]
		\arrow["\rapp", dotted, from=3-3, to=4-2]
		\arrow["\runi"', dotted, from=2-1, to=4-2]
		\end{tikzcd}\]

		\item[Case:] $A[x] \equiv \ldots x \ldots \rdx{\rapp}$ (|x| occurs outside $\rapp$) Trivial.
        % https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
        \[\begin{tikzcd}
        	& {x=v;\ \ldots x \ldots \rdx{\rapp} \ldots} \\
        	{x=v;\ \ldots x \ldots \rdx{\rapp}' \ldots} && {x=v;\ \ldots v \ldots \rdx{\rapp} \ldots} \\
        	& {x = v; \ldots v \ldots \rdx{\rapp}' \ldots}
        	\arrow["\runi", from=1-2, to=2-3]
        	\arrow["\rapp"', from=1-2, to=2-1]
        	\arrow["\runi"', dotted, from=2-1, to=3-2]
        	\arrow["\rapp", dotted, from=2-3, to=3-2]
        \end{tikzcd}\]

		\item[Case:] $A[x] \equiv A[(\lambda y_1. A_1[x]) v_1]$ (|x| occurs inside $\rapp$'s $\lambda$)
		Impossible as application contexts do not go under a $\lambda$.

		\item[Case:] $A[x] \equiv A[(\lambda y_1. e_1) V_1[x]]$ (|x| occurs inside $\rapp$'s argument)
		By definition of application context, the only possible case is when $V_1[x] \equiv x$.
		In this case we have
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2F26d6237c689e2e0a66907fdf266fa5e9775efdc7%2Ffresh_macros.tex
		\[\begin{tikzcd}
		& {x=v;\ A[(\lambda y. e_1)\ x]} \\
		{x=v;\ A[\exists y.\ y = x;\ e_1]} && {x=v;\ A[(\lambda y. e_1)\ v]} \\
		& {x=v;\ A[\exists y.\ y = v;\ e_1]}
		\arrow["\runi", from=1-2, to=2-3]
		\arrow["\rapp"', from=1-2, to=2-1]
		\arrow["\runi"', dotted, from=2-1, to=3-2]
		\arrow["\rapp", dotted, from=2-3, to=3-2]
		\end{tikzcd}\]
	\end{description}
\end{description}
\end{description}
\end{proof}


\begin{lemma}[$\runi-\rcon$-Comm] \label{lem:u-c-c}
	$\runi$ and $\rcon$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ $*$-commutes with $\rcon$ and hence commutes via \cref{lem:star-comm}.
%
Let $\tx{\runi}$ and $\tx{\rcon}$ denote the reducts for $\runi$ and $\rcon$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rcon}$ or vice versa.


\begin{description}
\item[Case $\rdx{runi} \subset \rdx{\rcon}$:] Split cases on the rule used in $\rcon$.
	\begin{description}
	\item[Case:] \rulename{norm-val} \ie $\tx{\rcon} \equiv |v; e| \movesto |e|$.
		If $\rdx{\runi} \subset |v|$, \ie $\runi : |v| \movesto |v'|$, then join at $|e|$.
		If $\rdx{\runi} \subset |e|$, \ie $\runi : |e| \movesto |e'|$, then join at $|e'|$.
	\item[Case:] \rulename{norm-seq-assoc} \ie $\tx{\rcon} \equiv (e_1; e_2); e_3 \movesto e_1; (e_2 ; e_3)$.
		If $\rdx{\runi} \subset e_1$, \ie $\runi : e_1 \movesto e_1'$, then join at $(e_1'; (e_2; e_3)$.
		If $\rdx{\runi} \subset e_2$, \ie $\runi : e_2 \movesto e_2'$, then join at $(e_1; (e_2'; e_3)$.
		If $\rdx{\runi} \subset e_3$, \ie $\runi : e_3 \movesto e_3'$, then join at $(e_1; (e_2; e_3'))$.
		If $\rdx{\runi} \subset (e_1; e_2)$, \ie $\runi : (e_1; e_2) \movesto (e_1'; e_2')$, then join at $(e_1'; (e_2'; e_3))$.
	\item[Case:] \rulename{norm-seq-swap} \ie $\tx{\rcon} \equiv |e_1; x == v; e_2| \movesto |x == v; e_1; e_2|$.
		If $\rdx{\runi} \subset |e_1|$, \ie $\runi : e_1 \movesto e_1'$, then join at $x = |v|; e_1'; e_2$.
		If $\rdx{\runi} \subset |e_2|$, \ie $\runi : e_2 \movesto e_2'$, then join at $x = |v|; e_1; e_2'$.
		If $\rdx{\runi} \subset |x == v; e_2|$, \ie $\runi : |x == v| \movesto x = |v|; e_2'$, then join at $x = |v|; e_1; e_2'$.
	\item[Case:] \rulename{norm-swap-eq} \ie $\tx{\rcon} \equiv \hnf = x \movesto x = \hnf$.
		Here $\rdx{\runi} \subset \hnf$, \ie $\runi : \hnf \movesto \hnf'$, hence join at $x = \hnf'$.
	\item[Case:] \rulename{norm-seq-def}, \rulename{norm-defr}, \rulename{norm-seqr}, \rulename{norm-unifyr}]
		In this case $\tx{\rcon} \equiv C[e_1, e_2] \movesto C'[e_1, e_2]$.
		If $\rdx{\runi} \subset e_1$, \ie $\runi : e_1 \movesto e_1'$, then join at $C'[e_1', e_2]$.
		If $\rdx{\runi} \subset e_2$, \ie $\runi : e_2 \movesto e_2'$, then join at $C'[e_1, e_2']$.
	\end{description}

\item[Case $\rdx{\rcon} \subset \rdx{\runi}$:] Split cases on the rule used in $\runi$.
	\begin{description}
	\item[Case:] \rulename{deref-*} \ie $\tx{\runi} \equiv x = |v|; E[x] \movesto x = |v|; E[|v|]$.
		If $\rdx{\rcon} \subset |v|$, \ie $\rcon : |v| \movesto |v'|$, then join (with two $\rcon$ steps) at $x = |v'|; E[|v'|]$.
		If $\rdx{\rcon} \subset E[|x|]$, \ie $\rcon : E[|x|] \movesto E'[|x|]$, then join at $x = |v|; E'[|v|]$.
	\item[Case:] \rulename{u-tup} \ie $\rcon \not \subset \runi$.
	\item[Case:] \rulename{u-*} \ie~$\tx{\runi} \equiv c \movesto |fail|$; so join at |fail|.
	\end{description}
\end{description}
\end{proof}

\begin{lemma}[$\runi-\rfail$-Comm] \label{lem:u-f-c}
	$\runi$ and $\rfail$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ strongly commutes wth $\rfail$.
%
Let $\tx{\runi}$ and $\tx{\rfail}$ denote the reducts for $\runi$ and $\rfail$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rfail}$ or vice versa.
%
\begin{description}
	\item[Case] $\rdx{\runi} \subset \rdx{\rfail}$: Split cases on the rule used in $\rfail$.
	\begin{description}
		\item[Case] \rulename{fail-seq-l} \ie $\tx{\rfail} \equiv |fail|; e \movesto |fail|$.
		  	Here $\rdx{\runi} \subset e$ so join at $|fail|$.
		\item[Case] \rulename{fail-seq-l} \ie $\tx{\rfail} \equiv e; |fail| \movesto |fail|$.
		  	Here $\rdx{\runi} \subset e$ so join at $|fail|$.
		\item[Case] \rulename{fail-eq} \ie $\tx{\rfail} \equiv x = |fail| \movesto |fail|$.
			Here $\rdx{\runi} \not \subset \rdx{\rfail}$.
	\end{description}

	\item[Case] $\rdx{\rfail} \subset \rdx{\runi}$: Same as $\rdx{\rcon} \subset \rdx{\runi}$ case of \cref{lem:u-c-c}.
\end{description}
\end{proof}


\begin{lemma}[$\runi-\rgc$-Comm] \label{lem:u-g-c}
	$\runi$ and $\rgc$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ strongly commutes wth $\rgc$.
%
Let $\tx{\runi}$ and $\tx{\rgc}$ denote the reducts for $\runi$ and $\rgc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rgc}$ or vice versa.
%
\begin{description}
	\item[Case] $\rdx{\runi} \subset \rdx{\rgc}$:
		Suppose that $\tx{\rgc} \equiv \exists x_1,\ldots. x_1=v_1; \ldots; e \movesto e$, where no $x_i \in \freevars{e}$.
		If $\rdx{\runi} \subset e$, \ie $\runi : e \movesto e'$, then as $\freevars{e'} \subset \freevars{e}$ we can join at $e'$.
		If $\rdx{\runi} \subset v_i$, \ie $\runi : v_i \movesto v_i'$, then we can join at $e$.
		If $\rdx{\runi}$ spans some $x_i, v_i$ and $e$, then $\runi$ is via a \rulename{deref-*}, \ie
		$\tx{\runi} \equiv x_i = |v_i|; E[x_i] \movesto x_i = |v_i|; E[|v_i|]$.
		However, this $E[x_i]$ is disjoint from $e$ as $x_i \not \in \freevars{e}$,
		so we can still join at $e$.
	\item[Case] $\rdx{\rgc} \subset \rdx{\runi}$: Same as $\rdx{\rcon} \subset \rdx{\runi}$ case of \cref{lem:u-c-c}.
\end{description}
%
\end{proof}

\begin{lemma}[$\runi-\rspc$-Comm] \label{lem:u-s-c}
	$\runi$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
We show that $\rspc$ $*$-commutes with $\runi$, and hence by \cref{lem:star-comm}, $\runi$ commutes wth $\rspc$.
%
Let $\tx{\runi}$ and $\tx{\rspc}$ denote the reducts for $\runi$ and $\rspc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rspc}$ or vice versa.
%
\begin{description}
\item[Case] $\rdx{\runi} \subset \rdx{\rspc}$ Split cases on the rule used in $\rspc$
	\begin{description}
	\item[Case] \rulename{choose} \ie $\tx{\rspc} \equiv SX[CX[|e_1 choice e_2|]] \movesto SX[CX[e_1] |choice| CX[e_2]]$.
	Let us split cases on where $\rdx{\runi}$ occurs.
		\begin{description}
		\item[Case] $\rdx{\runi} \subset e_1$, \ie $\runi : e_1 \movesto e_1'$ so join at $SX[CX[e_1'] |choice| CX[e_2]]$.
		\item[Case] $\rdx{\runi} \subset e_2$, \ie $\runi : e_2 \movesto e_2'$ so join at $SX[CX[e_1] |choice| CX[e_2']]$.
		\item[Case] $\rdx{\runi} \subset CX$ :

		Here, $|CX^[e_1 choice e_2]| \equiv \cdots \rdx{\runi} \cdots |e_1 choice e_2|$
		so
		with two $\runi$ steps we can join at $|SX^[e_1' choice e_2']|$ where
		$e_i' \equiv \cdots \rdx{\runi}' \cdots e_i$.
		\end{description}


	\item[Case] \rulename{choose-assoc} \ie $\tx{\rspc} \equiv SX[(e_1 |choice| e_2) |choice| e_3] \movesto SX[e_1 |choice| (e_2 |choice| e_3)]$.
	Let us split cases on where $\rdx{\runi}$ occurs.
		\begin{description}
		\item[Case] $\rdx{\runi} \subset e_1$, \ie $\runi : e_1 \movesto e_1'$ so join at $SX[e_1' |choice| (e_2 |choice| e_3)]$.
		\item[Case] $\rdx{\runi} \subset e_2$, \ie $\runi : e_2 \movesto e_2'$ so join at $SX[e_1 |choice| (e_2' |choice| e_3)]$.
		\item[Case] $\rdx{\runi} \subset e_3$, \ie $\runi : e_3 \movesto e_3'$ so join at $SX[e_1 |choice| (e_2 |choice| e_3')]$.
		\end{description}

	\item[Case] \rulename{choose-l} (symmetric \rulename{choose-r}) \ie $\tx{\rspc} \equiv SX[|fail choice e|] \movesto SX[e]$.
	Here, $\rdx{\runi} \subset e$, \ie $\runi : e \movesto e'$ so join at $SX[e']$.

	\item[Case] \rulename{one-choice} (symmetric \rulename{one-value}, \rulename{all-value})
	Here $\tx{\rspc} \equiv |one (e_1 `choice` e_2)| \movesto e_1$ where $\wff{\emptyset}{e_1}{|xs|}{|cs|}{\hnf}$.
	Hence, by \cref{lem:gc-result}, $\rdx{\runi} \subset e_2$ so join at $e_1'$.

	\item[Case] \rulename{all-choice}
	Here $\tx{\rspc} \equiv |all (e_1 `choice` dots `choice` e_n)| \movesto e$ where $\wff{\emptyset}{e_i}{|xs|}{|cs|}{\hnf_i}$.
	Hence, by \cref{lem:gc-result}, $\rdx{\runi} \not \subset \rdx{\rspc}$.

	\item[Case] \rulename{one-fail} (symmetric \rulename{all-fail})
	Trivially $\rdx{\runi} \not \subset \rdx{\rspc}$.
	\end{description}

\item[Case] $\rdx{\rspc} \subset \rdx{\runi}$ Split cases on the rule used in $\runi$
\begin{description}
	\item[Case:] \rulename{deref-*} \ie $\tx{\runi} \equiv x = |v|; E[x] \movesto x = |v|; E[|v|]$.
		If $\rdx{\rspc} \subset |v|$, \ie $\rspc : |v| \movesto |v'|$, then join (with two $\rspc$ steps) at $x = |v'|; E[|v'|]$.
		If $\rdx{\rcon} \subset E[|x|]$, \ie $\rcon : E[|x|] \movesto E'[|x|]$, then join at $x = |v|; E'[|v|]$.
	\item[Case:] \rulename{u-tup} \ie $\rspc \not \subset \runi$.
	\item[Case:] \rulename{u-*} \ie~$\tx{\runi} \equiv c \movesto |fail|$; so join at |fail|.
\end{description}
\end{description}
\end{proof}

\begin{lemma}[GC-Result] \label{lem:gc-result}
If $\wff{\emptyset}{e}{|xs|}{|xs|}{\hnf}$ then $e$ is a $\runi$-Normal Form.
\end{lemma}

