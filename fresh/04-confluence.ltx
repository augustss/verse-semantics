\begin{theorem}[Confluence] \label{thm:confluence}
The reduction relation $\rr$ is confluent.
\end{theorem}

\begin{proof}
First, we partition $\rr$ into the relations $\runi$, $\rapp$, $\rcon$, $\rfail$,
$\rgc$ and $\rspc$.
%
Next, we show that each of these relations is confluent and pairwise
commutative.
%
Finally, we use \cref{lem:comm-n} to prove their union $\rr$ is confluent.
\end{proof}

\subsection{Ordered Unification} % --------------------------------------------------------------------------

We will use Newman's lemma \ref{lem:local} to prove that $\runi$ is confluent (\cref{lem:u-c}).
However, $\runi$ is not Noetherian. For example, it has infinite reduction sequences which
``toggle'' between equal variables
%
$$ |x == y; x| \movesto |x == y; y| \movesto \ldots \movesto |x == y; x| \movesto \ldots$$
%
Thus, we will establish confluence of $\runi$ in two steps.
%
First, we define a \emph{ordered} sub-relation $\rord$ of $\runi$ which
\emph{is} Noetherian and locally confluent, and hence confluent by
Newman's lemma.
%
Next, we show that $\runi$ is confluent by showing that it is
is the transitive closure of $\rord$ (\cref{lem:closure}).


\begin{definition}[Ordered Unification] \label{def:ordered-unification}
%
A \emph{rank function} $\rnk$ is an injective (one-to-one) function from the set
of variable identifiers to the set of natural numbers.
%
Let $\runi_\rnk$ be the unification relation induced by restricting
the rule $\rulename{deref-s}$ to $\rulename{deref-s-\rnk}$
%
$$\rulename{deref-s-\rnk} \quad |x == y ;  E^[x]| \ \movesto\ |x == y ; E^[y]| \quad\ \mbox{if}\ \rnk(x) < \rnk(y)$$
%
Let $\rord$ be the reduction relation $\rord \equiv \exists \rnk. \runi_\rnk$.
\end{definition}

\begin{lemma}[$\rord$-Local-Confluent]\label{lem:ord-lc}
    $\rord$ is locally confluent.
\end{lemma}

\begin{proof}
\verb|TODO: [Deref-Com-1]| and \verb|TODO: [Deref-Com-2]|
(which depends on \verb|TODO: [Eq-Join]|) we show that $\rord$ is \emph{locally} confluent.
\end{proof}


\begin{definition}[Def-Use] \label{def:def-use}
%
Let $|x == s ; E^[x]|$ (resp. $|x == v ; A^[v]|$)
be a redex for \rulename{deref-s} (resp. \rulename{deref-v}).
%
We respectively call $x$ the \emph{variable}
the constraint $|x == s|$ (resp. $|x == v|$) the \emph{definition}
and the occurrence of $x$ in $E[x]$ (resp. $A[x]$) the \emph{use} of
the redex.
%
\end{definition}

\mypara{Notation:} In the sequel, we will use superscripts
like $x^1$ or $x^2$ to denote distinct occurrences of the
\emph{same} variable $x$.

\begin{lemma}[Deref-Comm-1] \label{lem:deref-comm-1}
If $\rstep{\rord}{e}{e_1}$ and $\rstep{\rord}{e}{e_2}$ are two \rulename{deref-*} reductions
with the same variable $x$, then $\join{\rord}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
Let $\txi{1}$ and $\txi{2}$ denote the reducts for the two reductions
$\rstep{\rord}{e}{e_1}$ and $\rstep{\rord}{e}{e_2}$ respectively.

The case when the constraints for $\rdx{1}$ and $\rdx{2}$
are the same is trivial, so let us assume we have two
separate constraints, $|x == v_1|$ and $|x == v_2|$.
%
The case when the reducts are disjoint is trivial, as
${e \equiv \ldots \rdx{1} \ldots \rdx{2} \ldots}$,
${e_1 \equiv \ldots \rdx{1}' \ldots \rdx{2} \ldots}$,
${e_2 \equiv \ldots \rdx{1} \ldots \rdx{2}' \ldots}$,
and $e_1$ and $e_2$ can be joined at
${\ldots \rdx{1}' \ldots \rdx{2}' \ldots}$.

Consider the case where $\rdx{2} \subset \rdx{1}$
(the case where $\rdx{1} \subset \rdx{2}$ is symmetric.)
There are two possibilities.
%
First, $\rdx{1} \equiv x == v_1; \ldots \rdx{2} \ldots C[x]$
where $C$ is either an $E$ or $A$ depending on whether $v_1$
is a scalar or not.
Here, we join the terms at $x == v_1; \ldots \rdx{2}' \ldots C[v_1]$.

Second, where the two redexes $\rdx{1}$ and $\rdx{2}$ overlap \ie
$e \equiv |x == v_1; x == v_2; e'|$.
%
Let us split cases on whether $v_1$ and $v_2$ are scalars ($k$ or $y$)
or non-scalars ($\lambda$s or tuples).

\begin{description}
