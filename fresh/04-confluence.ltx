\begin{lemma}[Join-S-S] \label{lem:join-s-s}
If $e_1 \equiv {s_1 = s_2; E[s_1]}$ and $e_2 \equiv {s_1 = s_2; E[s_2]}$
then $\rsteps{\rord}{e_1,e_2}{|fail|}$ or $\rsteps{\rord}{e_1,e_2}{s_1=s_2; E[s]}$.
\end{lemma}

\begin{proof}
If $s_1 \equiv s_2$ then $e_1, e_2$ are trivially joined.
Suppose that $s_1 \not \equiv s_2$ and split cases on whether they are variables or literals.

\begin{description}
\item[Case $s_1 \equiv k_1$ and $s_2 \equiv k_2$] Join at $|fail|$ as $k_1 \not \equiv k_2$.
\item[Case $s_1 \equiv k$ and $s_2 \equiv x$] Join at $e_1$ as $\rstep{}{k = x; E[x]}{k = x; E[k]}$.
\item[Case $s_1 \equiv x$ and $s_2 \equiv k$] Join at $e_2$ as $\rstep{}{k = x; E[x]}{k = x; E[k]}$.
\item[Case $s_1 \equiv x_1$ and $s_2 \equiv x_2$] Join at $e_{3-j}$ where $\rnk{x_j} < \rnk{x_{3-j}}$, as $\rstep{}{x_1 = x_2; E[x_j]}{x_1 = x_2; E[x_{3-j}]}$.
\end{description}
\end{proof}

\begin{lemma}[Join-V-V] \label{lem:join-v-v}
Let $v$ and $v'$ be two non-scalars.
If $e \equiv {v = v'; E[v]}$ and
   $e' \equiv {v = v'; E[v']}$
then $\rsteps{\rord}{e,e'}{|fail|}$ or
     $\rsteps{\rord}{e,e'}{s_1 = s_1'; \ldots; s_n = s_n'; E[v^*]}$.
\end{lemma}

\begin{proof}
If either $v$ or $v'$ are $\lambda$-terms then we can join at $|fail|$.
%
If $v$ and $v'$ are tuples of \emph{different} sizes we can join at $|fail|$.
%
Hence, assume that $v \equiv |arr (s_1, dots, s_n)|$ and $v' \equiv |arr (s'_1, dots, s'_n)|$.
%
Via \rulename{u-tup} $e$ and $e'$ respectively to $s_1 = s_1'; \ldots; s_n = s_n'; E[v]$
and $s_1 = s_1'; \ldots; s_n = s_n'; E[v']$.
%
From \cref{lem:join-s-s} we have that for all $0 \leq i \leq n$ the terms
	$e_i \equiv s_i == s_i'; s_i$ and $e_i' \equiv s_i = s_i'; s_i'$
	join at $|fail|$ or at some $s_i = s_i'; s_i^{*}$.
%
If there exists some $i$ at which $e_i$ and $e_i'$ join at $|fail|$ then we can join $e$ and $e'$ at $|fail|$ via \cref{lem:eq-scalar-fail}.
%
Otherwise, we can join $e$ and $e'$ at $e^* \equiv s_1 = s_1'; \ldots; s_n = s_n'; E[\langle s_1^*, \ldots, s_n^{*} \rangle]$ using $n$ applications
of \cref{lem:eq-scalar}.
%
