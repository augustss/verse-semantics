\begin{theorem}[Confluence] \label{thm:confluence}
The reduction relation $\rr$ is confluent.
\end{theorem}

\begin{proof}
First, we partition $\rr$ into the relations $\runi$, $\rapp$, $\rcon$, $\rexc$,
$\reli$ and $\rspc$.
%
Next, we show that each of these relations is confluent, and pairwise
\emph{strongly} commutative.
%
Finally, we use \cref{lem:comm-n} to prove their union $\rr$ is confluent.
\end{proof}

\subsubsection{Unification and Application}

\begin{lemma}[$\runi$-Confluent]\label{lem:uni-conf}
    $\runi$ is confluent.
\end{lemma}

\begin{proof}
	By \cref{lem:uni-conf-1} and \cref{lem:uni-conf-2}.
\end{proof}






\subsubsection{Application}
\begin{lemma}[$\rapp$-Confluent]\label{lem:app-conf}
    $\rapp$ is confluent.
\end{lemma}

\begin{lemma}[$\rspc$-Confluent]\label{lem:spc-conf}
    $\rspc$ is confluent.
\end{lemma}

\begin{lemma}[$\runi$-$\rapp$-Commute]\label{lem:uni-app-com}
    $\runi$ and $\rapp$ strongly commute.
\end{lemma}
