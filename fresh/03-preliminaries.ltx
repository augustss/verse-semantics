\begin{lemma}[Diamond~\cite{Barendregt}] \label{lem:diamond}
    If $\rr$ satisfies the diamond property then $\rr$ is confluent.
\end{lemma}

\begin{lemma}[Unicity~\cite{Barendregt}] \label{lem:nf}
    If $\rr$ is confluent then every term reduces to at most one normal form.
\end{lemma}

\begin{lemma}[Closure~\cite{Barendregt}] \label{lem:closure}
    If $\rr$ is confluent then $\rr^{*}$ is confluent.
\end{lemma}

\begin{definition}[Noetherian Reduction]
A reduction $\rr$ is \emph{Noetherian} if there is no infinite
sequence $a_0 \go{\rr} a_1 \go{\rr} \ldots \go{\rr} a_n \go{\rr} \ldots$.
\end{definition}

\begin{definition}[Local Confluence]
%
A reduction $\rr$ is \emph{locally confluent} if whenever
$\rstep{\rr}{a}{b}$ and $\rstep{\rr}{a}{c}$, we have $\join{\rr}{b}{c}$.
%
\end{definition}

The following result is known as Newman's Lemma \cite{Barendregt, Huet80}.

\begin{lemma}[Newman's Lemma] \label{lem:local}
If $\rr$ is locally confluent and Noetherian then $\rr$ is confluent.
\end{lemma}

\begin{definition}[Strong Confluence]
%
A reduction is \emph{strongly confluent} if whenever
$\rstep{}{a}{b}$ and $\rstep{}{a}{c}$, either $\rsteps{}{b}{c}$ or
there is a $d$ such that $\rsteps{}{b}{d}$ and $\rstep{}{c}{d}$.
\end{definition}

\begin{lemma}[\cite{Huet80}] \label{lem:strong}
	If $\rr$ is strongly confluent then $\rr$ is confluent.
\end{lemma}


\subsection{Commutativity} \label{sec:commutativity}

\begin{definition}[Commutativity]
%
A reduction $R$ \emph{commutes} with $S$ if for all terms
$a, b, c$ such that $\rsteps{R}{a}{b}$ and $\rsteps{S}{a}{c}$
there exists $d$ such that $\rsteps{S}{b}{d}$ and $\rsteps{R}{c}{d}$,
as illustrated on the left in \cref{fig:commutativity}.
%
A reduction $R$ \emph{strongly commutes} with $S$ if for all terms
$a, b, c$ such that $\rstep{R}{a}{b}$ and $\rstep{R}{a}{c}$
there exists $d$ such that $\rstep{S}{b}{d}$ and $\rstep{R}{c}{d}$,
as illustrated in the middle in \cref{fig:commutativity}.
\end{definition}

