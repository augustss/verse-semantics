\begin{lemma}[Diamond-Confluence \cite{Barendregt}] \label{lem:diamond}
    If $\rr$ satisfies the diamond property then $\rr$ is confluent.
\end{lemma}

% [Barendregt 1976] [Huet 1980]
\begin{lemma}[Confluent-NF \cite{Barendregt}] \label{lem:nf}
    If $\rr$ is confluent then every term reduces to at most one normal form.
\end{lemma}

% [Barendregt 1976] [Huet 1980]
\begin{lemma}[Confluent-Closure \cite{Barendregt}] \label{lem:closure}
    If $\rr$ is confluent then $\rr^{*}$ is confluent.
\end{lemma}

\subsection{Commutativity} \label{sec:commutativity}

\begin{definition}[Commutativity]
A reduction $R$ \emph{commutes} with $S$ if for all terms
$a, b, c$ such that $\rsteps{R}{a}{b}$ and $\rsteps{S}{a}{c}$
there exists $d$ such that $\rsteps{S}{b}{d}$ and $\rsteps{R}{c}{d}$,
as illustrated on the left in \cref{fig:commutativity}.
\end{definition}

\begin{definition}[Strong Commutativity]
A reduction $R$ \emph{strongly commutes} with $S$ if for all terms
$a, b, c$ such that $\rstep{R}{a}{b}$ and $\rstep{R}{a}{c}$
there exists $d$ such that $\rstep{S}{b}{d}$ and $\rstep{R}{c}{d}$,
as illustrated in the middle in \cref{fig:commutativity}.
\end{definition}

