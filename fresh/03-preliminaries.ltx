\section{Preliminaries} \label{sec:preliminaries}

\begin{definition}[Reductions] A \emph{reduction} \rr is a binary relation on a set of terms \univ.
We write $\rr^{k}$ for the $k$-step closure of $\rr$ and $\rr^{*}$ for the reflexive
and transitive closure of $\rr$, \ie $\rr^{*} \equiv \cup_{0 \leq k} \rr^k$.
%
We write
%
\begin{itemize}
%
\item $\rstep{\rr}{a}{b}$ ($a$ \emph{steps to} $b$) if $(a, b) \in \rr$,
\item $\rsteps{\rr}{a}{b}$ ($a$ \emph{reduces to} $b$) if $(x, y) \in \rr^{*}$.
\item $\rstepk{\rr}{k}{a}{b}$ ($a$ \emph{$k$-steps to} $b$) if $(a, b) \in \rr^{k}$, and
%
\end{itemize}
\end{definition}

\begin{definition}[Size] The \emph{size} of a reduction $\rsteps{}{a}{b}$
is the smallest $i$ such that $\rstepk{}{i}{a}{b}$.
\end{definition}

\begin{definition}[Normal Forms]
A term $a$ is an $\rr$-\emph{Normal Form} if there does not exist any $b$
such that $\rstep{\rr}{a}{b}$.
\end{definition}

For clarity, we will omit the reduction $\rr$ when it is clear from the context.

\begin{definition}[Diamond Property]
%
A reduction satisfies the \emph{diamond} property if whenever
$\rstep{}{a}{b}$ and $\rstep{}{a}{c}$, there is a $d$ such
that $\rstep{}{b}{d}$ and $\rstep{}{c}{d}$.
%
\end{definition}

\begin{definition}[Confluence]
%
Two terms $b$, $c$ can be $\rr$-\emph{joined} written $\join{\rr}{b}{c}$,
if there is a $d$ such that $\rsteps{\rr}{b}{d}$ and $\rsteps{\rr}{c}{d}$.
%
A reduction $\rr$ is \emph{confluent} if whenever
$\rsteps{\rr}{a}{b}$ and $\rsteps{\rr}{a}{c}$, we have $\join{\rr}{b}{c}$.
\end{definition}


