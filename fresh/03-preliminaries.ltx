\begin{lemma}[Union] \label{lem:comm-union}
    If $R$ and $S_1$ commute and $R$ and $S_2$ commute then $R$ and $S_1 \cup S_2$ commute.
\end{lemma}

\begin{proof}
Via the following chase diagram (probably well known?)

% https://q.uiver.app/?
\[\begin{tikzcd}
	\bullet & \bullet & \bullet & \bullet & \bullet & \bullet \\
	\bullet & \bullet & \bullet & \bullet & \bullet & \bullet
	\arrow["{S_1}", two heads, from=1-1, to=1-2]
	\arrow["{S_2}", two heads, from=1-2, to=1-3]
	\arrow[dashed, two heads, from=1-3, to=1-4]
	\arrow["R"', two heads, from=1-1, to=2-1]
	\arrow["{S_1}", dotted, two heads, from=2-1, to=2-2]
	\arrow["R"', dotted, two heads, from=1-2, to=2-2]
	\arrow["{S_2}", dotted, two heads, from=2-2, to=2-3]
	\arrow[dotted, two heads, from=2-3, to=2-4]
	\arrow["R"', dotted, two heads, from=1-3, to=2-3]
	\arrow["R"', dotted, two heads, from=1-4, to=2-4]
	\arrow["{S_1}", two heads, from=1-4, to=1-5]
	\arrow["{S_2}", two heads, from=1-5, to=1-6]
	\arrow["R"', dotted, two heads, from=1-5, to=2-5]
	\arrow["R"', dotted, two heads, from=1-6, to=2-6]
	\arrow["{S_1}", dotted, two heads, from=2-4, to=2-5]
	\arrow["{S_2}", dotted, two heads, from=2-5, to=2-6]
\end{tikzcd}\]
\end{proof}


\subsection{$*$-Commutativity}

\begin{definition}[$*$-Commutativity] \label{def:star-comm}
A reduction $R$ $*$-commutes with $S$ if for all terms
$a, b, c$ such that $\rstep{R}{a}{b}$ and $\rstep{S}{a}{c}$
there exists $d$ such that $\rsteps{S}{b}{d}$ and $\rstep{R}{c}{d}$
(right in \cref{fig:commutativity}.)
\end{definition}


\begin{lemma}  \label{lem:star-comm-1}
	If $R$ $*$-commutes with $S$ then for all $a, b, c$ if $\rstep{R}{a}{b}$ and $\rsteps{S}{a}{c}$
	then there exists $d$ such that $\rsteps{S}{b}{d}$ and $\rstep{R}{c}{d}$.
\end{lemma}

\begin{proof}
By induction on the size of the reduction $\rsteps{S}{a}{c}$.

\begin{description}

\item[(Base case)] Here $c$ is the same as $a$, so just pick $d = b$.

\item[(Ind. case)] Assume the lemma for reductions of size less than or equal to $n$.
Suppose that $\rstepk{S}{n+1}{a}{c}$. Then there exists $c'$ such that
$\rstepk{S}{n}{a}{c'}$ and $\rstep{S}{c'}{c}$. The proof is completed by the diagram:
% https://q.uiver.app/?
\[\begin{tikzcd}
	& a \\
	b && {c'} \\
	& {d'} && c \\
	&& d
	\arrow["{S^n}", two heads, from=1-2, to=2-3]
	\arrow["R"', from=1-2, to=2-1]
	\arrow["S"', dotted, two heads, from=2-1, to=3-2]
	\arrow["R", dotted, from=2-3, to=3-2]
	\arrow["IH"{description, pos=0.9}, draw=none, from=1-2, to=3-2]
	\arrow["S", from=2-3, to=3-4]
	\arrow["{S}"', two heads, dotted, from=3-2, to=4-3]
	\arrow["R", dotted, from=3-4, to=4-3]
	\arrow["\ref{def:star-comm}"{description, pos=0.9}, draw=none, from=2-3, to=4-3]
\end{tikzcd}\]

\end{description}

\end{proof}

\begin{lemma}  \label{lem:star-comm-2}
	If $R$ $*$-commutes with $S$ then for all $a, b, c$ if $\rsteps{R}{a}{b}$ and $\rstep{S}{a}{c}$
	then there exists $d$ such that $\rsteps{S}{b}{d}$ and $\rsteps{R}{c}{d}$.
\end{lemma}

\begin{proof}
By induction on the size of the reduction $\rsteps{R}{a}{b}$.

\begin{description}

\item[(Base case)] Here $b$ is the same as $a$, so just pick $d = c$.

\item[(Ind. case)] Assume the lemma for reductions of size less than or equal to $n$.
Suppose that $\rstepk{R}{n+1}{a}{b}$. Then there exists some $b'$ such that
$\rstepk{R}{n}{a}{b'}$ and $\rstep{R}{b'}{b}$. The proof is completed by the diagram below.

% https://q.uiver.app/?
\[\begin{tikzcd}
	&& a \\
	& {b'} && c \\
	b && {d'} \\
	& d
	\arrow["S", from=1-3, to=2-4]
	\arrow["{R^n}"', two heads, from=1-3, to=2-2]
	\arrow["S"', dotted, two heads, from=2-2, to=3-3]
	\arrow["R", dotted, two heads, from=2-4, to=3-3]
	\arrow["R"', from=2-2, to=3-1]
	\arrow["S"', dotted, two heads, from=3-1, to=4-2]
	\arrow["R", dotted, from=3-3, to=4-2]
	\arrow["IH"{description, pos=0.9}, draw=none, from=1-3, to=3-3]
	\arrow["\ref{lem:star-comm-1}"{description, pos=0.9}, draw=none, from=2-2, to=4-2]
\end{tikzcd}\]
\end{description}
\end{proof}

% Probably known but ???
\begin{lemma}[$*$-Commutativity] \label{lem:star-comm}
	If $R$ $*$-commutes with $S$ then $R$ commutes with $S$.
\end{lemma}

\begin{proof}
By induction on the size of the reduction $\rsteps{S}{a}{c}$.

\begin{description}
\item[(Base case)] Here $c$ is the same as $a$, so just pick $d = b$.

\item[(Ind. case)] Assume the lemma for reductions of size less than or equal to $n$.
Suppose that $\rstepk{S}{n+1}{a}{c}$. Then there exists some $c'$ such that $\rstepk{S}{n}{a}{c'}$
and $\rstep{S}{c'}{c}$. The proof is completed by the diagram below.
% https://q.uiver.app/?
\[\begin{tikzcd}
	& a \\
	b && {c'} \\
	& {d'} && c \\
	&& d
	\arrow["{S^n}", two heads, from=1-2, to=2-3]
	\arrow["R"', two heads, from=1-2, to=2-1]
	\arrow["S"', dotted, two heads, from=2-1, to=3-2]
	\arrow["R", dotted, two heads, from=2-3, to=3-2]
	\arrow["IH"{description, pos=0.9}, draw=none, from=1-2, to=3-2]
	\arrow["S", from=2-3, to=3-4]
	\arrow["S"', dotted, two heads, from=3-2, to=4-3]
	\arrow["R", dotted, two heads, from=3-4, to=4-3]
	\arrow["\ref{lem:star-comm-2}"'{description, pos=0.9}, draw=none, from=2-3, to=4-3]
\end{tikzcd}\]
\end{description}
\end{proof}

\subsection{Commutativity and Confluence}

% Classical "commutativity lemma"
\begin{lemma}[Commutativity] \label{lem:comm}
If $R$ and $S$ are confluent and commute, then $R \cup S$ is confluent.
\end{lemma}

% Generalize to N relations
\begin{lemma}[N-Commutativity] \label{lem:comm-n}
If
%
(i)~$\forall 0 \leq i \leq n$, the reduction $R_i$ is confluent, and
%
(ii)~$\forall 0 \leq i < j \leq n$, the reductions $R_i$ and $R_j$ commute
%
then $\cup_{i=0}^n R_i$ is confluent.
\end{lemma}

\begin{proof}
    By induction on $n$ using \cref{lem:comm} and \cref{lem:comm-union}.
\end{proof}