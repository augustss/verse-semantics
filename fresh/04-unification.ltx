then there exists $\rdx{2}''$ such that
   $\rsteps{\runi}{\rdx{2}'}{\rdx{2}''}$ and
   $\rstep{\runi}{E[\rdx{1}']}{\rdx{2}''}$.
\end{lemma}

\begin{proof}
