\begin{lemma}[Exchange] \label{lem:exch}
\begin{itemize}
\item If $\runders{\reprg{g}{E}}{e_1}{e_2}$ then $\runders{g}{E[e_1]}{E[e_2]}$
\item If $\runders{\reprg{g}{E}}{E_1}{E_2}$ then $\runders{g}{E[E_1]}{E[E_2]}$
\end{itemize}
\end{lemma}

\begin{proof}
By induction on the derivation of $\runders{\reprg{g}{E}}{\cdot}{\cdot}$ using \cref{lem:exch-one}.
\end{proof}

\begin{lemma}[Exchange-1]\label{lem:exch-one}
    If $\runder{\reprg{g}{E}}{e_1}{e_2}$ then $\runder{g}{E[e_1]}{E[e_2]}$.
\end{lemma}

\begin{proof} By induction on the structure of $E$.

\begin{description}
\item[Case] $E \equiv |hole|$ Immediate as the consequence is the same as the hypothesis.
\item[Case] $E \equiv x=y; E'$ Given
    \begin{align*}
        & \runder{\reprg{g}{x = y; E'}}{e_1}{e_2} \\
        \intertext{by the definition of $\reprg{}{}$}
        & \runder{\reprg{\union{g}{x}{y}}{E'}}{e_1}{e_2} \\
        \intertext{by the IH}
        & \runder{\reprg{\union{g}{x}{y}}}{E'[e_1]}{E'[e_2]} \\
        \intertext{by \cref{lem:exch-x-y}}
        & \runder{g}{x = y; E'[e_1]}{x = y; E'[e_2]} \\
        \intertext{\ie $\runder{g}{E[e_1]}{E[e_2]}$}
    \end{align*}

\item[Case] $E \equiv S[E']$ where $\skipc{S}$ Given
    \begin{align*}
        & \runder{\reprg{g}{S[E']}}{e_1}{e_2} \\
        \intertext{by the definition of $\reprg{}{}$ as $\skipc{S}$}
        & \runder{\reprg{g}{E'}}{e_1}{e_2} \\
        \intertext{by the IH}
        & \runder{g}{E'[e_1]}{E'[e_2]} \\
        \intertext{by \cref{lem:exch-id} using $S$}
        & \runder{g}{E[e_1]}{E[e_2]}
    \end{align*}
\end{description}
\end{proof}

\begin{lemma}[exch-id] \label{lem:exch-id}
    If $\reprg{g}{C} = g$ and $\runder{g}{e_1}{e_2}$ then $\runder{g}{C[e_1]}{C[e_2]}$.
\end{lemma}
\begin{proof} Any reduction step
    \begin{align*}
        \runder{g}{e_1}{e_2} & \equiv \runder{g}{E[x = y; E'[x]]}{E[x = y; E'[y]]} \\
        \intertext{where $\live{\reprg{g}{E}}{y}$. As $\reprg{g}{C[E]} = \reprg{\reprg{g}{C}}{E}$ via \cref{lem:repr}
        and $\reprg{g}{C} = g$ we have}
        & \live{\reprg{g}{C[E]}{y}} \\
        \intertext{Hence, the following redux is also valid completing the proof}
        \runder{g}{C[e_1]}{C[e_2]} & \equiv \runder{g}{C[E[x = y; E'[x]]]}{C[E[x = y; E'[y]]]}
    \end{align*}
\end{proof}

\begin{lemma}[repr] \label{lem:repr}
$\reprg{g}{E_1[E_2]} = \reprg{\reprg{g}{E_1}}{E_2}$.
\end{lemma}
\begin{proof}
    By induction on $E_1$.
\end{proof}

\begin{lemma}[exch-x-y] \label{lem:exch-x-y}
\begin{itemize}
\item If $\runders{\union{g}{x}{y}}{e}{e'}$ then \runders{g}{ x = y; e }{x = y; e'}.
\item If $\runders{\union{g}{x}{y}}{E}{E'}$ then \runders{g}{ x = y; E }{x = y; E'}.
\end{itemize}
\end{lemma}

\begin{proof}
By the definition of the $\reprg{g}{E}$ function (\ie by the definition $\runder{g}{\cdot}{\cdot}$ relation.
\end{proof}

\begin{lemma}[Wrap] \label{lem:wrap}
If $\runder{g}{E[x]}{E[y]}$ then $\runder{g}{E[E_1[x]]}{E[E_1[y]]}$.
\end{lemma}
\begin{proof}
Assume $\runder{g}{E[x]}{E[y]}$. By inversion we have
\begin{align*}
    E & \equiv E'[x = y; E'']  \\
    \intertext{that is the original reduction is of the form}
    \runder{g}{E[x]}{E[y]} & \equiv \runder{g}{E'[x = y; E''[x]]}{E'[x=y; E''[y]]}  \\
    \intertext{where $\live{\reprg{g}{E'}}{y}$. Hence the following reduction is also valid}
      & \runder{g}{E'[x = y; E''[E_1[x]]]}{E'[x=y; E''[E_1[y]]]}  \\
    \intertext{that is}
      & \runder{g}{E[E_1[x]]}{E[E_1[y]]}
\end{align*}
\end{proof}

\mypara{Lowering Reductions} Recall that $\rlive$ operates at a ``whole term''
level, meaning that $\rstep{\rlive}{e}{e'}$ \emph{does not} imply that
$\rstep{\rlive}{E[e_1]}{E[e_2]}$ for any surrounding context $E$.
%
However we show that \emph{if} all the variables in $e$ are \emph{live}
with respect to $\repr{E}$ then in fact, $\rstep{\rlive}{E[e_1]}{E[e_2]}$.
%
This is captured more generally by the following lemma which generalizes
the surrounding context $E$ with its UF graph $g$.

% crucial
\begin{lemma}[Steps Under] \label{lem:steps-under}
\begin{itemize}
    \item If $\live{g}{e}$ and $\rsteps{\rlive}{e}{e'}$ then $\runders{g}{e}{e'}$.
    \item If $\live{g}{E}$ and $\rsteps{\rlive}{E}{E'}$ then $\runders{g}{E}{E'}$.
\end{itemize}
\end{lemma}

\begin{proof}
By induction on the derivation of $\rsteps{\rlive}{e}{e'}$ (resp. $\rsteps{\rlive}{E}{E'}$)
using \cref{lem:step-under}.
\end{proof}

\begin{lemma}[Step Under] \label{lem:step-under}
    If $\live{g}{e}$ and $\rstep{\rlive}{e}{e'}$ then $\runder{g}{e}{e'}$.
\end{lemma}

\begin{proof}
By inversion
\begin{align*}
    \rstep{\rlive}{e}{e'} & \equiv \rstep{\rlive}{C[x=y; E[x]]}{C[x=y; E[y]]} \\
    \intertext{where $\live{\repr{C}}{y}$. As $\live{g}{e}$ we have}
      & \live{g}{C} \\
      & \live{g}{y} \\
    \intertext{and so by \cref{lem:live-under} we get}
      & \live{\reprg{g}{C}}{y} \\
    \intertext{Let $\hat{C}$ be any context such that $\repr{\hat{C}} = g$. By \cref{lem:repr}} \\
      \repr{\hat{C}[C]} & = \reprg{g}{C} \\
    \intertext{and hence we have}
      & \live{\repr{\hat{C}[C]}}{y} \\
    \intertext{Hence, the following reduction is also valid}
      & \rstep{\rlive}{\hat{C}[C[x=y; E[x]]]}{\hat{C}[C[x=y; E[y]]]} \\
    \intertext{\ie $\rstep{\rlive}{\hat{C}[e]}{\hat{C}[e']}$.}
\end{align*}
\end{proof}


\begin{lemma}[Live Under] \label{lem:live-under}
    If $\live{g}{e}$ and $\live{g}{x}$ and $\live{\repr{E}}{x}$ then $\live{\reprg{g}{E}}{x}$.
\end{lemma}
\begin{proof}
    By \cref{lem:live-dep} $\reprg{g}{E} = \appg{g}{\repr{E}}$.
    As $\live{g}{x}$, we have $x \not \in \dom{g}$.
    As $\live{\repr{E}}{x}$, we have $x \not \in \dom{\repr{E}}$.
    Hence, $x \not \in \dom{\appg{g}{\repr{E}}}$, \ie
    $x \not \in \dom{\reprg{g}{E}}$, and so $\live{\reprg{g}{E}}{x}$.
\end{proof}

\begin{lemma}[Live Dep] \label{lem:live-dep}
    If $\live{g}{e}$ then $\reprg{g}{E} = \appg{g}{\repr{E}}$.
\end{lemma}
\begin{proof}
    Follows from \cref{lem:live-dep-ind}, with $g' = \emptyset$.
\end{proof}

\begin{lemma} \label{lem:live-dep-ind}
    If $\live{g}{e}$ then $\reprg{\appg{g}{g'}}{E} = \appg{g}{\reprg{g'}{E}}$.
\end{lemma}
\begin{proof}
    By induction on the structure of $E$, using the fact (from \cref{lem:find}) that
    forall $g, x$ if $\live{g}{x}$ then $\find{\appg{g}{g'}}{x} = \find{g'}{x}$.
    %RJ: TODO copy from my notes.
\end{proof}


