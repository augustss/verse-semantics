\section{Confluence of Unification}

We start by proving confluence of $\runi$:
the reduction relation defined by the $\runi$
rules in \cref{fig:rewrite-rules}.

$\runi$ does not enjoy the \emph{diamond} property, as \eg
the term $e \equiv x = |arr (a, b)|; x = |arr (c, d)|; x = |(10, 20)|; a + d$
can step to $e_1 \equiv x = |arr (a, b)|; x = |arr (c, d)|; |arr (a, b)| = |arr (10, 20)|; a + d$
or to $e_2 \equiv x = |arr (a, b)|; x = |arr (c, d)|; |arr (c, d)| = |arr (10, 20)|; a + d$ which
require multiple steps to join.

We cannot use Newman's lemma \ref{lem:local} to establish confluence
as  $\runi$ is non-terminating, as shown by
%
$$ |x == y; y == x; x| \movesto |x == y; y == x; y| \movesto \ldots \movesto |x == y; y == x; x| \movesto \ldots$$
%

\mypara{Strategy: Confluence via Kernel} We prove confluence of $\runi$ by defining
a confluent relation $\rduni$ (``directed unification'') that is a \emph{kernel} of
$\runi$ after which the confluence of \runi follows from \cref{thm:kernel-confluence}.

\begin{lemma}[$\runi$-Confluent] \label{lem:u-c}
$\runi$ is confluent.
\end{lemma}

\begin{proof}
Immediate from \cref{lem:d-kernel}, \cref{lem:d-c} and \cref{thm:kernel-confluence}.
\end{proof}

\subsection{Union-Find Graphs}

Let us recall the notion of union-find graphs, a directed-graph
based representation of equivalence classes \cite{CLRS}.

\begin{definition}[UF] A \emph{union-find graph} (abbreviated to just graph)
    $g$ is a sequence of bindings $[x_1 \mapsto x_1', \ldots, x_n \mapsto x_n']$
    such that
%
\begin{enumerate}
%
\item (Finite Map) $x_1, \ldots, x_n$ are distinct,
%
\item (Acyclic) forall $i \leq j$, we have $x_i \not \equiv x_j'$.
%
\end{enumerate}
We write $\dom{g}$ for the domain of $g$, \ie the set $\{x_1, \ldots, x_n\}$.
\end{definition}



\begin{definition}[FIND]
%
Let $g$ be a UF graph.
%
We define the \emph{parent} (resp. \emph{representative})
of $x$ in $g$ written $\parent{g}{x}$ (resp. $\find{g}{x}$)
as:
%
$$\begin{array}{rcl}
\find{g}[b_1,\ldots,b_n] & \doteq & \begin{cases}
    \find{[b_{i+1},\ldots,b_n]}{x'} & \text{if } \exists b_i \equiv x \mapsto x' \\
    x & \text{otherwise}
\end{cases}
% \parent{g}{x} & \doteq & \begin{cases}
%                         y & \text{if}\ x \mapsto y \in g \\
%                         x & \text{otherwise}
%                     \end{cases} \\
% \find{g}{x} & \doteq & \begin{cases}
%                         \find{g}{y} & \text{if}\ x \mapsto y \in g \\
%                         x & \text{otherwise}
%                     \end{cases} \\
\end{array}$$
\end{definition}

The \emph{Acyclic} and finite map invariants ensure the following property of $\find{g}{\cdot}$.

\begin{lemma} \label{lem:find}
If $x \not \in \dom{g}$ then $\find{\appg{g}{g'}}{x} = \find{g'}{x}$.
\end{lemma}
\begin{proof}
    Immediate from the definition of $\find{g}{\cdot}$.
\end{proof}

% \begin{lemma}[UF] \label{lem:uf-find}
% Forall $g \equiv \appg{[x \mapsto y]}{g'}$, we have $\find{g}{x} = \find{g}{y}$.
% \end{lemma}

\begin{definition}[UNION]
Let $g$ be a UF graph and $x, y$ be distinct variables. Define the new graph $g' = \union{g}{x}{y}$ as:
%
$$\begin{array}{rcl}
\union{g}{x}{y} & \doteq & \begin{cases}
    g, x' \mapsto y' & \text{if}\ x' = \find{g}{x}, y' = \find{g}{y}, x' \not \equiv y' \\
    g & \text{otherwise}
\end{cases}
\end{array}$$
\end{definition}

\subsection{Directed Unification: $\rduni$}

We will use UF graphs to define a directed unification relation $\rduni$ as follows.

\begin{definition}[Representatives]
We define the \emph{representatives}
of an expression context $\repr{E}$
as the UF graph
%
$$\begin{array}{lcl}
\repr{E} & \doteq & \reprg{\emptyset}{E} \\[0.05in]
\reprg{g}{|hole|}        & \doteq & g  \\
\reprg{g}{|x = y; E|}    & \doteq & \union{g}{x}{y} \\
\reprg{g}{S[E]}          & \doteq & \reprg{g}{E} \text{where} $\skipc{S}$\\

% \reprg{g}{|x = E; e|}    & \doteq & \reprg{g}{E} \\
% \reprg{g}{|ue; E|}       & \doteq & \reprg{g}{E} \\
% \reprg{g}{|E v|}         & \doteq & \reprg{g}{E} \\
% \reprg{g}{|v E|}         & \doteq & \reprg{g}{E} \\
% \reprg{g}{|def x E|}     & \doteq & \reprg{g}{E}  \\
% \reprg{g}{|E choice e|}  & \doteq & \reprg{g}{E}  \\
% \reprg{g}{|e choice E|}  & \doteq & \reprg{g}{E}  \\
% \reprg{g}{|all E|}       & \doteq & \reprg{g}{E}  \\
% \reprg{g}{|one E|}       & \doteq & \reprg{g}{E}  \\[0.05in]

\skipc{|x = hole; e|}    & \doteq & \text{true} \\
\skipc{|ue; hole|}       & \doteq & \text{true} \\
\skipc{|hole v|}         & \doteq & \text{true} \\
\skipc{|v hole|}         & \doteq & \text{true} \\
\skipc{|def x hole|}     & \doteq & \text{true}  \\
\skipc{|hole choice e|}  & \doteq & \text{true}  \\
\skipc{|e choice hole|}  & \doteq & \text{true}  \\
\skipc{|all hole|}       & \doteq & \text{true}  \\
\skipc{|one hole|}       & \doteq & \text{true}  \\
\skipc{E}                & \doteq & \text{false}  \\[0.05in]
\end{array}$$
\end{definition}

\begin{definition}[Live Variables]
%
A variable $x$ is \emph{live} in a UF graph $g$, written $\live{g}{x}$ if $x = \find{g}{x}$.
%
A scalar $s$ is \emph{live} in $g$ if it is a literal or it is a variable that is live in $g$.
%
An expression $e$ is \emph{live} in a UF graph $g$, written $\live{g}{e}$ if $\forall x \in \freevars{e}$ we have $\live{g}{x}$.
%
A context $E$ is \emph{live} in a UF graph $g$, written $\live{g}{E}$ if $\forall x \in \freevars{E}$ we have $\live{g}{x}$.
%
We define a \emph{live dereference} reduction as
%
$$\begin{array}{rrcll}
\rulename{deref-s-live} & E[x = s; E'[x]] & \movesto_{\rlive} & E[x = s; E'[s]] & \text{if} $\live{\reprg{\emptyset}{E}}{s}$ \\
\end{array}$$
%
Where $\rlive$ denotes the reduction relation induced by \rulename{deref-x-live}
\textbf{NOTE:} $e \movesto_{\rlive} e'$ via the above rule only
when the \emph{entire} expression $e$ moves to $e'$.
\end{definition}


\begin{definition}[Directed Unification]
The \emph{directed unification} relation $\rduni$ is defined as the reduction relation obtained from the rules
$$\rduni \doteq \runi - \rulename{deref-s} + \rulename{deref-*-live}$$
\end{definition}

\begin{lemma} $\rduni \subseteq \runi$. \label{lem:rduni-subset-runi}
\end{lemma}

\begin{proof}
Immediate as the every $\rduni$ reduction is trivially an $\runi$ reduction.
\end{proof}

\begin{lemma}[$\rduni$-Noetherian] \label{lem:d-noetherian}
    $\rduni$ is Noetherian.
\end{lemma}

\begin{proof}
Define the following \emph{size} function for any term $e$.
$$\begin{array}{lcl}
\mathsf{Size}(e)     & \doteq & (\mathsf{FunVars}(e) + \mathsf{HeapVars}(e), \mathsf{Tuples}(e), \mathsf{DeadVars}(e), \mathsf{Vars}(e)) \\[0.05in]
\mathsf{FunVars}(e)  & \doteq & \text{number of sub-terms of $e$ of the form $x |v|$} \\
\mathsf{HeapVars}(e) & \doteq & \text{number of sub-terms of $e$ of the form $|x == h|$} \\
\mathsf{Tuples}(e)   & \doteq & \text{number of sub-terms of $e$ of the form $|arr (dots)|$} \\
\mathsf{DeadVars}(e) & \doteq & \text{cardinality of the set} \{ E[x] \vb e \equiv E[x], x \ \text{is dead in}\ E \} \\
\mathsf{Vars}(e)     & \doteq & \text{number of variable occurrences in} $e$ \\
\end{array}$$
%
Each $\rduni$ step $\rstep{\rduni}{e}{e'}$ is such that $\mathsf{Size}(e) < \mathsf{Size}(e')$ \ie each step
strictly decreases the size of $e$ per the \emph{lexicographic ordering} of tuples thereby proving that $\rduni$
is well-founded and hence Noetherian.
\end{proof}


\subsection{Canonicalization}

To prove that $\rduni$ is a kernel of $\runi$ we first establish
a more general \emph{canonicalization} property of $\rduni$ which
says that given any term of the form $C[E[x]]$ where $E$ is an outer
context and $E'$ an inner one, we can use $\rlive$ to
%
(1) \emph{Canonicalize} the outer context into $E^{*}$ where the equations
    follow a left-to-right order and
%
(2) Replace the variable $x$ in $E'$ with its canonical \emph{representative}
    in $E^{*}$.

\begin{theorem}[Canon] \label{thm:canon}
$\rsteps{\rlive}{E[E'[x]]}{\cnn{E}{}[E'{x^{*}}]}$ where $x^{*} = \find{\repr{E}}{x}$.
\end{theorem}

\begin{proof}
The above is a corollary of \cref{thm:canon-ctx} and \cref{thm:canon-var}
which respectively show how to canonicalize a context $E$ and a variable $x$
but under an arbitrary set of equations summarized by a UF graph $g$.
\end{proof}

\mypara{Reduction Under a Graph}
%
Recall that $e \movesto_{\rlive} e'$ only holds for entire expressions.
So unlike other reductions, we cannot assume that $\rsteps{\rlive}{e_1}{e_2}$
implies that $\rsteps{\rlive}{E[e_1]}{E[e_2]}$.
%
We say $\runders{g}{e_1}{e_2}$ or $e_1$ $\rlive$-steps $e_2$ under $g$ if
\emph{forall} contexts $E$ such that $\repr{E} = g$
we have $\rsteps{\rlive}{E[e_1]}{E[e_2]}$.

The following fact follows from the above definitions.

\begin{lemma}[Reduction in Context] \label{lem:reduction-in-graph}
    $\runders{\repr{E}}{e_1}{e_2}$ iff $\rsteps{\rlive}{E[e_1]}{E[e_2]}$.
\end{lemma}

\begin{proof}
    By induction on the structure of $E$.
\end{proof}

\mypara{Reducing Contexts}
%
We lift the notion of reduction to contexts as follows: define
$\rstep{\rlive}{E_1}{E_2}$ if for some special variable $\xhole$
that does not appear anywhere in $E_1$, we have $\rstep{\rlive}{E_1[\xhole]}{E_2[\xhole]}$.

\begin{lemma}[Context-Step] If $\rstep{\rlive}{E_1}{E_2}$
    then for all $e$, we have $\rstep{\rlive}{E_1[e]}{E_2[e]}$.
\end{lemma}

\begin{proof}
By induction on the structure of $E_1$.
\begin{description}

\item[Case $E_1 \equiv |hole|$] Impossible.

\item[Case $E_1 \equiv x = y; E_1'$]
    Here we have $\rstep{\rlive}{x = y; E_1'[\xhole]}{x=y; E_2'[\xhole]}$.
    By the IH we get $\rstep{\rlive}{x=y; E_1'[e]}{x = y; E_2'[e]}$ \ie
    $\rstep{\rlive}{E_1[e]}{E_2[e]}$.

\item[Case] $E_1 \equiv S[E_1']$ where $\skipc{S}$
    Here we split cases on whether the reduction is in $S$ or $E_1'$.
    \begin{description}
    \item[Case reduction in $E_1'$] we have
    \begin{align*}
        & \rstep{\rlive}{S[E_1'[\xhole]]}{S[E_2'[\xhole]]} \\
        \intertext{ by \cref{lem:reduction-in-graph} }
        & \runder{\repr{S}}{E_1'[\xhole]}{E_2'[\xhole]} \\
        \intertext{ as $\repr{S} = \emptyset$ whenever $\skipc{S}$ we get}
        & \runder{\emptyset}{E_1'[\xhole]}{E_2'[\xhole]}{E_2'[\xhole]} \\
        \intertext{ By the definition of $\rlive$ }
        & \rstep{\rlive}{E_1'[\xhole]}{E_2'[\xhole]} \\
        \intertext{ by IH }
        & \rstep{\rlive}{E_1'[e]}{E_2'[e]} \\
        \intertext{ by the definition of $\rlive$ and as $\repr{S} = \emptyset$ }
        & \rstep{\rlive}{S[E_1'[e]]}{S[E_2'[e]]} \\
    \end{align*}

    \item[Case reduction in $S$] we have from the definition of $\rlive$
    \begin{align*}
       & \rstep{\rlive}{S[E_1'[\xhole]]}{S'[E_1'[x0]]} \text{ where $\skipc{S'}$ } \\
       \intertext{ by IH, using $e' \equiv E_1'[e]$ }
       & \rstep{\rlive}{S[E_1'[e]]}{S'[E_1'[e]]} \\
    \end{align*}
    \end{description}
\end{description}
\end{proof}

\begin{lemma}[Under-Trans] \label{lem:under-trans}
\begin{itemize}
\item If $\runders{g}{e_1}{e_2}$ and $\runders{g}{e_2}{e_3}$ then $\runders{g}{e_1}{e_3}$.
\item If $\runders{g}{E_1}{E_2}$ and $\runders{g}{E_2}{E_3}$ then $\runders{g}{E_1}{E_3}$.
\end{itemize}
\end{lemma}

\begin{proof} By induction on the derivations of $\runders{g}{e_1}{e_2}$ and $\runders{g}{E_1}{E_2}$.
\end{proof}

\begin{definition}[Canonical Context]
A context $E$ is canonical under $g$, written $\canon{g}{E}$, if
$$\begin{array}{rcl}
    \canon{g}{|hole|}    & \doteq & \text{true} \\
    \canon{g}{x = y; E'} & \doteq & \live{g}{x} \wedge \live{g}{y} \wedge \canon{\union{g}{x}{y}}{E'} \\
    \canon{g}{S[E']}     & \doteq & \canon{g}{E'} \ \text{if}\ \skipc{S}  \\
\end{array}
$$
\end{definition}

\begin{theorem}[Canon-Var] \label{thm:canon-var}
If $\canon{g}{E}$ and $\live{g}{x}$ then
(a) $\runders{g}{E[E'[x]]}{E[E'[x^{*}]]}$ where
(b) $x^{*} = \find{(\reprg{g}{E})}{x}$.
\end{theorem}

\begin{proof}
By induction on the structure of $E$.
\begin{description}
\item[Case] $E \equiv |hole|$ Trivial as
        \begin{align*}
           x^{*} & \equiv \find{(\reprg{g}{|hole|})}{x} \\
        \intertext{ by definition of $\reprg{g}{|hole|}$ }
                 & = \find{g}{x} \\
        \intertext{ as $\live{g}{x}$ }
                 & = x \\
        \end{align*}

\item[Case] $E \equiv x = z; E_1$
        By the definition of $\rlive$  \\
        \begin{align}
               & \rstep{\rlive}{x = z; E_1[x]}{x = z; E_1[z]} \nonumber \\
        \intertext{ As $\live{g}{x = z; E_1[x]}$ \cref{lem:step-under} yields }
               & \runder{g}{x = z; E_1[x]}{x = z; E_1[z]} \nonumber \\
        \intertext{ By \cref{lem:wrap} we get }
               & \runder{g}{x = z; E_1[E[x]]}{x = z; E_1'[E[z]]}    \label{eq:canon-var-1} \\
        \intertext{As $\canon{g}{E}$ we have $\live{g}{z}$. Let}
            g' & \doteq \union{g}{x}{z} \equiv \extg{g}{x}{z} \nonumber \\
        \intertext{Hence, $\live{g'}{z}$ and so by the IH we get}
               & \runders{g'}{E_1[z]}{E_1[z^{*}]}   \label{eq:canon-var-2} \\
        \intertext{where}
        z^{*}  & = \find{(\reprg{g'}{E_1})}{z} = \find{(\reprg{g}{E})}{x} \label{eq:canon-var-3} \\
        \intertext{By \cref{lem:exch}  the \cref{eq:canon-var-2} yields}
               & \runders{g}{x = z; E_1[z]}{x = z; E_1[z^{*}]}   \label{eq:canon-var-4}
        \end{align}
        Sequencing \cref{eq:canon-var-1} and \cref{eq:canon-var-4}
        using\cref{lem:under-trans} and \cref{eq:canon-var-3}
        completes the proof.

\item[Case] $E \equiv y = z; E_1$ where $y \not \equiv x$.
        As $\canon{g}{E}$ we have $\live{g}{y, z}$. Let
        \begin{align}
            g' & \doteq \union{g}{y}{z} \equiv \extg{g}{y}{z} \nonumber \\
        \intertext{As $y \not \equiv x$ we have $\live{g'}{x}$ and by definition $\canon{g'}{E_1}$ so by IH we get}
               & \runders{g'}{E_1[x]}{E_1[x^{*}]} \label{eq:canon-var-5} \\
        \intertext{where}
        x^{*}  & = \find{(\reprg{g'}{E_1})}{x} = \find{(\reprg{g}{E})}{x} \label{eq:canon-var-6} \\
        \intertext{via \cref{eq:canon-var-5} and \cref{lem:exch} we get the goal}
               & \runders{g}{y = z; E_1[x]}{y = z; E_1[x^{*}]} \nonumber
        \end{align}

\item[Case] $E \equiv S[E_1]$ where $\skipc{S}$ Let
        \begin{align}
        g' & \doteq \reprg{g}{S} = g \nonumber
        \intertext{as $\skipc{S}$. Hence $\canon{g}{E_1}$ and by IH we get}
           & \runders{g}{E_1[x]}{E_1[x^{*}]} \label{eq:canon-var-7} \\
        \intertext{where}
        x^{*} & = \find{(\reprg{g}{E_1})}{x} \label{eq:canon-var-8} \\
        \intertext{Via \cref{lem:exch} we get}
           & \runders{g}{S[E_1[x]]}{S[E_1[x^{*}]]} \nonumber
        \end{align}
        which with \cref{eq:canon-var-7} completes the proof.
\end{description}
\end{proof}

\begin{theorem}[Canon-Ctx] \label{thm:canon-ctx}
If \live{g}{E} there is a $\cnn{g}{E}$ such that
%
(1) $\canon{g}{\cnn{g}{E}}$ and
%
(2) $\runders{g}{E}{\cnn{g}{E}}$
%
(3) $\reprg{g}{E} = \reprg{g}{\cnn{g}{E}}$.
\end{theorem}

\begin{proof} By induction on the height of $E$ \cref{def:height}.
    The following function $\mkcnn{g}{E}$ \emph{computes} $\cnn{g}{E}$.

$$\begin{array}{lcl}
\mkcnn{g}{|hole|} & \doteq & |hole| \\[0.05in]

\mkcnn{g}{S[E]}   & \doteq & S[E^{*}]  \\
\quad \text{where} &   & \\
\quad \quad E^{*}  & = & \mkcnn{g}{E} \\[0.05in]

\mkcnn{g}{x=y;E}   & \doteq & x=y; \mkcnn{g'}{E'} \\
\quad \text{where} & & \\
\quad \quad g'     & = & \union{g}{x}{y} \\
\quad \quad E'     & = & \subst{E}{x}{y} \\
\quad \quad E^{*}  & = & \mkcnn{g'}{E'} \\[0.05in]

\subst{E}{x}{y} & \doteq & \text{replace all free occurrences of $x$ in $E$ with $y$} \\
\end{array}$$

\begin{description}
\item[Case] $E \equiv |hole|$
    Let $\cnn{g}{|hole|} \equiv |hole|$; facts (1), (2) and (3) follow trivially.

\item[Case] $E \equiv S[E_1]$ where $\skipc{S}$ Let
    \begin{align}
    \cnn{g}{E_1} & \doteq \mkcnn{g}{E_1} \nonumber \\
    \intertext{As $\live{g}{E}$ we have $\live{g}{E_1}$ and so by the IH we get}
        & \canon{g}{\cnn{g}{E_1}} \label{eq:canon-ctx-1} \\
        & \runders{g}{E_1}{\cnn{g}{E_1}} \label{eq:canon-ctx-2} \\
        & \reprg{g}{E_1} = \reprg{g}{\cnn{g}{E_1}} \label{eq:canon-ctx-2-r} \\
    \intertext{Now let}
    \cnn{g}{E} & \doteq S[\cnn{g}{E_1}] \nonumber
    \intertext{From \cref{eq:canon-ctx-2} and the definition of $\canon{}{}$ we get}
        \canon{g}{S[\cnn{g}{E_1}]} \ldots (1) \nonumber \\
    \intertext{as $\skipc{S}$ we have $\reprg{g}{S} = g$ and \cref{eq:canon-ctx-2} is}
        & \runders{\reprg{g}{S}}{E_1}{\cnn{g}{E_1}} \nonumber \\
    \intertext{which by \cref{lem:exch} is}
        & \runders{g}{S[E_1]}{S[\cnn{g}{E_1}]} \ldots (2) \nonumber
    \intertext{and (3) follows from \cref{eq:canon-ctx-2-r}, $\skipc{S}$ and the definition of $\reprg{}{}$.}
    \end{align}

\item[Case] $E \equiv x = y; E_1$ Let
    \begin{align}
    E_1'    & \doteq \subst{E_1}{x}{y} \nonumber \\
    g'      & \doteq \union{g}{x}{y} \nonumber \\
    E_1^{*} & \doteq \mkcnn{g'}{E_1'} \nonumber \\
    \intertext{By \cref{lem:subst-live} we have}
        & \rsteps{\rlive}{x = y}{E_1}{x = y}{E_1'} \nonumber \\
    \intertext{As $\live{g}{x=y;E_1}$ by \cref{lem:steps-under} we get}
        & \runders{g}{x = y}{E_1}{x = y}{E_1'} \label{eq:canon-ctx-var-a} \\
    \intertext{As $x$ is not free in $E_1'$ we have}
        & \live{g'}{E_1'} \label{eq:canon-ctx-var-b} \\
    \intertext{Hence by the IH we get}
        & \canon{g'}{E_1^{*}} \label{eq:canon-ctx-var-c} \\
        & \runders{g'}{E_1'}{E_1^{*}} \nonumber \\
        & \reprg{g'}{E_1'} = \reprg{g'}{E_1^{*}} \label{eq:canon-ctx-g}\\
    \intertext{which \cref{lem:exch} turns into}
        & \runders{g}{x = y; E_1'}{x = y; E_1^{*}} \label{eq:canon-ctx-var-d}\\
    \intertext{Let}
    \cnn{g}{E} & \doteq x = y; \cnn{g'}{E_1^{*}} \nonumber
    \intertext{By \cref{eq:canon-ctx-var-a} and the definition of $g'$ and $\canon{}{}$ we get}
        & \canon{g}{\cnn{g}{E}} \ldots (1) \nonumber \\
    \intertext{By sequencing \cref{eq:canon-ctx-var-a} and \cref{eq:canon-ctx-var-d} with \cref{lem:under-trans} we get}
        & \runders{g}{E}{\cnn{g}{E}} \ldots (2) \nonumber
    \intertext{and (3) follows from \cref{eq:canon-ctx-g}, the definition of $\reprg{}{}$ and $\live{g}{x}$, $\live{g}{y}$.}
    \end{align}

\end{description}
\end{proof}

\begin{lemma}[subst] \label{lem:subst-live}
    $\rsteps{\rlive}{x = y; E}{x = y; \subst{E}{x}{y}}$.
\end{lemma}
\begin{proof} $y$ is trivially live and so we simply sequentially
    substitute all the free occurrences of $x$ with $y$
    using \rulename{deref-x-live} until none remain.
\end{proof}

