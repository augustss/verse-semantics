\end{proof}


\begin{lemma}[Under-$\runi$] \label{lem:under-u}
Let $\rr' \equiv \rr - \runi$.
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rr'}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\runi}''}$.
\end{lemma}

\begin{proof}
Split cases on the top-level $\runi$ rule.
%
If it is any \rulename{u-lit}, \rulename{u-tup}
or \rulename{u-fail} the property holds trivially.
%
If it is \rulename{s-choose} then use \cref{lem:under-choose}.
%
Thus, the interesting cases are \rulename{deref-sh}.
%
There are two cases: either the $\runi$ "hole" is outside the $\rdx{}$,
in which the result follows via \cref{lem:p-shuffle}, or the hole is
inside the $\rdx{}$.
%
Next, we split cases on the $\rr'$ rule
and show that in each case, if the \rulename{deref-sh} hole
is in the $\rdx{}$ then we can join the reductions via one
of the patterns
"shuffle" (\cref{lem:p-shuffle}),
"p-dup" (\cref{lem:p-dup}), or
"p-del" (\cref{lem:p-dup}).
\begin{description}
\item[Case $\rr$ via \rulename{u-tup}, \rulename{u-fail}]
    Impossible as no |A| under $h$ or $|hnf|$.
\item[Case $\rr$ via \rulename{choose}]
    Via \cref{lem:p-shuffle} if the hole is in $e_1$ or $e_2$
    or \cref{lem:p-dup} if the hole is in the |CX|.
\item[Case $\rr$ via \rulename{app-beta}, \rulename{app-tup}]
    Via \cref{lem:p-shuffle}, as hole is under $|v|$.
\item[Case $\rr$ via \rulename{app-tup0}]
    Via \cref{lem:p-del}, as hole is under $|v|$.
\item[Case $\rr$ via \rulename{app-add}, \rulename{app-gt}, \rulename{app-gt-fail}]
    Impossible as no |A| under literal.
\item[Case $\rr$ via \rulename{choose-assoc}, \rulename{choose-*}, \rulename{one-value}, \rulename{all-choice}]
    Via \cref{lem:p-shuffle}.
\item[Case $\rr$ via \rulename{one-choice}]
    Via \cref{lem:p-shuffle} (if the hole is in $e_1$)
    or \cref{lem:p-del} if the hole is in $e_2$.
\item[Case $\rr$ via \rulename{one-fail}, \rulename{all-fail}]
    Impossible as no hole in |fail|.
\item[Case $\rr$ via \rulename{norm-val}]
    Via \cref{lem:p-del} if hole is in $|v|$ else \cref{lem:p-shuffle}.
\item[Case $\rr$ via \rulename{norm-*}]
    Via \cref{lem:p-shuffle}.
\item[Case $\rr$ via \rulename{fail-seq*}]
    Via \cref{lem:p-del}.
\item[Case $\rr$ via \rulename{elim-def}]
    Via \cref{lem:p-shuffle} if hole is in $e_2$ else \cref{lem:p-del}.
\end{description}
\end{proof}

\begin{lemma}[Under-\rulename{choose}] \label{lem:under-choose}
If $\rdx{2} \equiv \rstep{}{SX[CX[e_1 \vb e_2]]}{SX[CX[e_1] \vb CX[e_2]]} \equiv \rdx{2}'$ and
   $\rdx{2} \equiv E[\rdx{1}]$ and
   $\rstep{\rr}{\rdx{1}}{\rdx{1}'}$
then there exists $\rdx{2}''$ such that
   $\rsteps{\rr}{\rdx{2}'}{\rdx{2}''}$ and
   $\rstep{\rulename{choice}}{E[\rdx{1}']}{\rdx{2}''}$.
\end{lemma}

\begin{proof}
By the definition of $SX$ and $CX$, we have that if
$\rdx{2} \equiv E[\rdx{1}]$ \ie $\rdx{1} \subset \rdx{2}$
then $\rstep{\rr}{E[\rdx{1}]}{E[\rdx{1}']}$ falls under one
of the following cases -- depending on whether the step changes
$CX$ or $e_1$ or $e_2$ -- with the shown diagram completing
the proof for that case. We show this by splitting cases on
the possible $\rr$ reduction:

\begin{description}
\item[Case: $\rr$ via \rulename{deref-*}, \rulename{u-tup}, \rulename{u-lit}, \rulename{u-fail}]
\cref{lem:spec-under-cx} or \cref{lem:spec-under-1} or \cref{lem:spec-under-2} depending
on whether the step modifies $CX$ or $e_1$ or $e_2$.
%
Note that the \rulename{u-fail} redex must be under $CX$ or $e_1$ or $e_2$ \ie cannot contain
$(e_1 \vb e_2)$ as $CX$ does not go under values.


\item[Case: $\rr$ via \rulename{app-*}]
%
\cref{lem:spec-under-cx} or \cref{lem:spec-under-1} or \cref{lem:spec-under-2} depending
on whether the step modifies $CX$ or $e_1$ or $e_2$.

\item[Case: $\rr$ via \rulename{choose-assoc}, \rulename{choose-r}, \rulename{choose-l}]
%
Either the redex occurs under a $ce$ in $CX$ (\cref{lem:spec-under-cx})
or under $e_1$ or $e_2$ (\cref{lem:spec-under-1} or \cref{lem:spec-under-2}).
%
The only way the redex can contain $e_1 \vb e_2$ is if $e_1 \equiv (e_1' \vb e_1'')$
and $CX \equiv |hole|$ which is impossible by the definition of \rulename{choose}.

\item[Case: $\rr$ via \rulename{one-*}, \rulename{all-*}]
Either the redex occurs under a $ce$ in $CX$ (\cref{lem:spec-under-cx})
or under $e_1$ or $e_2$ (\cref{lem:spec-under-1} or \cref{lem:spec-under-2}).
%
The |one| and |all| constructs ensure that the redex cannot contain
$(e_1 \vb e_2)$ as $CX$ does not go under |one| or |all|.

\item[Case: $\rr$ via \rulename{norm-*}]
%
Each rule ensures the redex is either under $e_1$ or $e_2$, or
occurs under a $ce$ in $CX$ and remains choice-free after
the reduction \cref{lem:ce-step}, or contains a subterm
$e \equiv CX'[e_1 \vb e_2]$ that is preserved after the
step allowing us to use \cref{lem:under-cx}.

\item[Case: $\rr$ via \rulename{fail-seq*}]
%
Either the redex occurs under a $ce$ in $CX$
or under an $e$ in $CX$ (\cref{lem:spec-under-cx}),
or under $e_1$ (\cref{lem:spec-under-1})
or under $e_2$ (\cref{lem:spec-under-2})
or occurs at the \emph{top-level} of $CX$
(\ie $|CX| \equiv |hole; fail|$ or $|CX| \equiv |fail; hole|$)
in which case we join at $SX[|fail|]$ after two $\rr$ steps.


\item[Case: $\rr$ via \rulename{elim-def}]
%
Note that the \rulename{elim-def} redex must be under $CX$ or $e_1$ or $e_2$ \ie cannot contain
$(e_1 \vb e_2)$ as $CX$ does not go under values.

\item[Case: $\rr$ via \rulename{choose}]
The tricky case is when $\rdx{1} \movesto \rdx{1}$
is also a \rulename{choose} step.
\cref{lem:choice-under-choice} shows that
the pair of reduction still falls under one
of the three patterns above.
%
Case (a) is trivial as the $\rdx{2}'' = \rdx{2}'$.
Case (b,c,d,e) fall into the \cref{lem:spec-under-1} and \cref{lem:spec-under-2} patterns.
Case (f,g) fall in the \cref{lem:spec-under-cx} pattern.
Case (h,i) fall in the \cref{lem:spec-under-cx} pattern via \cref{lem:ce-step}.
%
\end{description}
\end{proof}


\begin{lemma}[spec-under-CX] \label{lem:spec-under-CX}
If for all $e$, we have $\rstep{\rr}{CX[e]}{CX'[e]}$.
% https://q.uiver.app/?
\[\begin{tikzcd}
	{SX[CX[e_1 \vb e_2]]} && {SX[CX[e_1] \vb  CX[e_2]]} \\
	\\
	{SX[CX'[e_1 \vb e_2]]} && {SX[CX'[e_1] \vb CX'[e_2]]}
	\arrow["{\rulename{choose}}", from=1-1, to=1-3]
	\arrow["\rr", dotted, two heads, from=1-3, to=3-3]
	\arrow["\rr"', from=1-1, to=3-1]
	\arrow["{\rulename{choose}}", dotted, from=3-1, to=3-3]
\end{tikzcd}\]
\end{lemma}

\begin{lemma}[spec-under-$e_1$] \label{lem:spec-under-1}
If for all $e_1, e_2$ we have if $\rstep{\rr}{CX[e_1 \vb e_2]}{CX[e_1' \vb e_2]}$
then $\rstep{\rr}{CX[e_1]}{CX[e_1']}$.
% https://q.uiver.app/?
\[\begin{tikzcd}
	{SX[CX[e_1 \vb e_2]]} && {SX[CX[e_1] \vb CX[e_2]]} \\
	\\
	{SX[CX[e_1' \vb e_2]]} && {SX[CX[e_1'] \vb CX[e_2]]}
	\arrow["{\rulename{choose}}", from=1-1, to=1-3]
	\arrow["\rr", dotted, from=1-3, to=3-3]
	\arrow["\rr"', from=1-1, to=3-1]
	\arrow["{\rulename{choose}}", dotted, from=3-1, to=3-3]
\end{tikzcd}\]
\end{lemma}

\begin{lemma}[spec-under-$e_2$] \label{lem:spec-under-2}
If for all $e_1, e_2$ we have if $\rstep{\rr}{CX[e_1 \vb e_2]}{CX[e_1 \vb e_2']}$
then $\rstep{\rr}{CX[e_2]}{CX[e_2']}$.
% https://q.uiver.app/?
\[\begin{tikzcd}
	{SX[CX[e_1 \vb e_2]]} && {SX[CX[e_1] \vb CX[e_2]]} \\
	\\
	{SX[CX[e_1 \vb e_2']]} && {SX[CX[e_1] \vb CX[e_2']]}
	\arrow["{\rulename{choose}}", from=1-1, to=1-3]
	\arrow["\rr"', from=1-1, to=3-1]
	\arrow["\rr", dotted, from=1-3, to=3-3]
	\arrow["{\rulename{choose}}"', from=3-1, to=3-3]
\end{tikzcd}\]
\end{lemma}

\begin{lemma}[$ce$-step] \label{lem:ce-step}
If $\rstep{\rulename{choose}}{|ce|}{e'}$ then $e'$ is also a choice-free expression.
\end{lemma}
\begin{proof}
By induction on the structure of $|ce|$.
Note that \rulename{one-value} eliminates a |one| but only does
so when the underlying $e$ is a choice-free sequence of constraints
and a tail-value, and hence produces a choice-free expression.
\end{proof}

\begin{lemma}[Unique-CX] \label{lem:unique-cx}
If $CX_1[e_{11} \vb e_{12}] = CX_2[e_{21} \vb e_{22}]$
then $CX_1 = CX_2$ and $e_{11} = e_{21}$ and $e_{12} = e_{22}$.
\end{lemma}
\begin{proof}
By simultaneous induction on the structure of $CX_1$ and $CX_2$, using \cref{lem:ce-not-cx}.
\begin{description}
\item[Case] $CX_1 \equiv |hole|, CX_2 \equiv |hole|$: Trivial.
\item[Case] $CX_1 \equiv |CX_1' = e|, CX_2 \equiv |CX_2' = e|$: By IH.
\item[Case] $CX_1 \equiv |CX_1' = e|, CX_2 \equiv |ce = CX_2'|$: Impossible by \cref{lem:ce-not-cx}.
\item[Case] $CX_1 \equiv |ce = CX_1'|, CX_2 \equiv |ce = CX_2'|$: By IH.
\item[Case] $CX_1 \equiv |CX_1' ; e|, CX_2 \equiv |CX_2' ; e|$: By IH.
\item[Case] $CX_1 \equiv |CX_1' ; e|, CX_2 \equiv |ce ; CX_2'|$: Impossible by \cref{lem:ce-not-cx}.
\item[Case] $CX_1 \equiv |ce ; CX_1'|, CX_2 \equiv |ce ; CX_2'|$: By IH.
\item[Case] $CX_1 \equiv |def x CX_1'|, CX_2 \equiv |def x CX_2'|$: By IH.
\end{description}
\end{proof}

\begin{lemma}[ce-not-CX] \label{lem:ce-not-cx}
$ce \not\equiv CX[e_1 \vb e_2]$.
\end{lemma}

\begin{proof}
By induction on the structure of |ce|.
\begin{description}
\item[Case] $|ce| \equiv |v|$: impossible by splitting cases on structure of $|CX|$.
\item[Case] $|ce| \equiv |ce = ce'|$ (symmetric to $|ce; ce'|$):
    Only possible if $|ce = ce'| \equiv CX'[\ldots] = ce'$ \emph{or}
                     $|ce = ce'| \equiv ce' = CX'[\ldots]$
    both of which are impossible by IH.
\item[Case] $|ce| \equiv |one e|$ (symmetric to $|all e|$):
    impossible as |one| not allowed at top-level of $CX$.
\end{description}
\end{proof}
