\subsection{\rduni is a Kernel of $\runi$}

\begin{lemma}[$\rduni$-Kernel] \label{lem:d-kernel}
    $\rduni$ is a kernel of $\runi$
\end{lemma}

\begin{proof}
$\rduni \subseteq \runi$ is trivial, as every reduction in the former is included in the latter.
%
Next, we show that whenever $\rstep{\runi}{e_1}{e_2}$ there exists an $e_3$ such that
$\rsteps{\rduni}{e_1,e_2}{e_3}$.
%
\begin{description}
    \item[Case] $\rstep{\rduni}{e_1}{e_2}$, here simply pick $e_3 = e_2$.
    \item[Case] Not $\rstep{\rduni}{e_1}{e_2}$. By inversion we have that
    \begin{align*}
        \rstep{\runi}{e_1}{e_2} & \equiv E[x = y; E'[x]] \movesto E[x = y; E'[y]] \text{where not}\ \live{E}{y} \\
        \intertext{Here, we define}
        E^* & = \cnn{}{E} \\
        x^* & = \find{(E^*)}{x} \\
        y^* & = \find{(E^*)}{y} \\
        e_3 & = E^*[x^* = y^*; E'[y^*]] \\
        \intertext{and by repeated applications of \cref{thm:canonical} we have}
        & \rsteps{\runi}{e_1,e_2}{e_3}
    \end{align*}
\end{description}
\end{proof}

