\begin{lemma}[$\runi$-Locally Confluent] \label{lem:u-lc-a}
If $\rstep{\runi}{e}{e_1, e_2}$ then $\rsteps{\runi}{e_1, e_2}{e'}$.
\end{lemma}

\begin{proof}
We split cases on where the reductions occur.
If they are disjoint, the terms $e_1$ and $e_2$ can be trivially joined.
If they are overlapping, they can by joined via \cref{lem:u-under-u}.
\end{proof}

