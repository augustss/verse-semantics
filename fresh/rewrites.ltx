\newcommand{\rulegroupname}[1]{\multicolumn{5}{l}{\textit{#1}}\\}
\newcommand{\largerhs}[1]{\multicolumn{2}{l}{#1}}

\newcommand{\wf}[1]{\ensuremath{\vdash #1}}
\newcommand{\wff}[4]{\ensuremath{\vdash #1 \rightsquigarrow (#2 \mid #3 \mid #4)}}


\newcommand{\figureSyntaxI}{
\begin{figure}[t]
$$\begin{array}{lr@@{\;}c@@{\;}l}
\textit{Integers}     & k \\
\textit{Variables}    & \multicolumn{3}{l}{x,y,z,f,g} \\
\textit{Tuples}       & s, t  & ::= & k \vb x \vb |arr (t_1, dots, t_n)| \\
\textit{Values}       & v     & ::= & t \vb |lam x e| \\
\textit{Constraints}  & c     & ::= & |v_1 == v_2| \\
\textit{Expressions}  & e     & ::= & |fail| \vb |v| \vb |def x e| \vb |c ; e| \vb |apply1N e_1 e_2| \vb
                                    |e_1 choice e_2| \vb |one e| \vb |all e| \\
\textit{Programs}     & p     & ::= & |one e| \quad \text{where} \; \freevars{e} = \emptyset \\[0.05in]
\textit{Results}      & r     & ::= & v \vb |(x == lam y e) ; r| \vb |def x r| \\
\end{array}$$
\caption{\textbf{\calcname: Syntax.} Note no $\lambda$-terms in tuples.}
\label{fig:syntax}
\end{figure}

% \mypara{Note:} Values can have arbitrarily nested tuples but $\lambda$-terms are never inside a tuple.

\begin{figure}[t]
$$\begin{array}{lcl}
\mbox{\vcname} &        & \mbox{\calcname} \\
\midrule
|e_1 == e_2|   & \equiv & |llet x_1 e_1 (llet x_2 e_2 (x_1 == x_2; x_1))| \\
|e_1; e_2|     & \equiv & |llet _   e_1 e_2                          | \\
\end{array}$$
%
\caption{\textbf{Desugaring VC into \calcshort.} We write |llet x e_1 e_2| to abbreviate |apply1N (lam x e_2) e_1|.}
\label{fig:desugar}
%
\end{figure}

\begin{figure}
$$\begin{array}{lrcl}
        \rulename{swap-e} & |v_1 == v_2|     & \equiv & |v_2 == v_1| \\
        \rulename{swap-d} & |def (x ^^ y) e| & \equiv & |def (y ^^ x) e| \\
        \rulename{swap-c} & c_1; c_2; e    & \equiv & c_2; c_1; e \\
\end{array}$$
\caption{\textbf{Structural Equivalences}}\label{fig:structural-equiv}
\end{figure}
}

\newcommand{\figureRulesI}{
\begin{figure}
\begin{longtable}{@@{\quad} l @@{\hspace{-.5em}} r >{$}c<{$} l l}
\rulegroupname{Unification}
\rulename{ulit} & |k == k ; e|                                    & \movesto & e \\
\rulename{utup} & |tup (v_1,dots,v_n) == tup (v1',dots,v_n') ; e| & \movesto & \largerhs{|v_1==v1';dots;v_n==v_n'; e|} \\[0.05in]

\rulegroupname{Substitution}
\rulename{subst-t}         & |x == t ;  E^[x]|         & \movesto & |x == t ; E^[t]| \\
\rulename{subst-$\lambda$} & |x == (lam y e) ;  A^[x]| & \movesto & \largerhs{|x == (lam y e) ; A^[lam y e]|} \\[0.05in]

\rulegroupname{Application}
\rulename{app-beta} & |apply1 (lam x e) v| & \movesto & |def x (x=v; e)|  & if $|x| \not \in \freevars{|v|}$ \\[0.05in]
% \rulename{app-tup} & |apply1 (tup (v_0,dots v_n)) v| & \movesto & \largerhs{|(v = 0; v_0) choice dots choice (v = n; v_n)|} \\

\rulegroupname{Conjunction}
\rulename{conj-def}     & |c ; def x e|             & \movesto & |def x (c ; e)|          & if $|x| \not \in \freevars{|c|}$\\
\rulename{conj-fun-cst} & |apply1 (c ; e_1) e_2|    & \movesto & |c; apply1 e_1 e_2| \\
\rulename{conj-fun-def} & |apply1 (def x e_1) e_2|  & \movesto & |def x (apply1 e_1 e_2)| & if $|x| \not \in \freevars{|e_2|}$ \\
\rulename{conj-arg-cst} & |apply1 e_1 (c ; e_2)|    & \movesto & |c ; apply1 e_1 e_2| \\
\rulename{conj-arg-def} & |apply1 e_1 (def x e_2)|  & \movesto & |def x (apply1 e_1 e_2)| & if $|x| \not \in \freevars{|e_1|}$ \\[0.05in]

\rulegroupname{Elimination}
\rulename{elim-def}     & |def x e| & \movesto & |e| & if $|x| \not \in \freevars{|e|}$ \\
\rulename{elim-rec}     & |def (x_1 ^^ dots) x_1 == (lam y_1 e_1); dots; e| & \movesto & |e| & if every $|x_i| \not \in \freevars{|e|}$\\[0.05in]

\rulegroupname{Explosion}
\rulename{fail-t-l}       & |k == tup (dots) ; e| & \movesto & |fail| \\
\rulename{fail-l-l}       & |k_1 == k_2 ; e |     & \movesto & |fail| & if $k_1 \not = k_2$ \\
\rulename{fail-$\lambda$} & |v == lam y e ; e'|   & \movesto & |fail| & if $|v| \not \equiv |x|$ \\
\rulename{fail-occ}       & |x == t ; e|          & \movesto & |fail| & if $x \in \freevars{t}$ and $x \not \equiv t$ \\
\rulename{fail-cst}       & |fail ; e|            & \movesto & |fail| \\
\rulename{fail-exp}       & |c ; fail|            & \movesto & |fail| \\
\rulename{fail-def}       & |def x fail|          & \movesto & |fail| \\[0.05in]

\rulegroupname{Decision}
\rulename{choose}     & |CX^[e_1 choice e_2]| & \movesto & |CX^[e_1] choice CX^[e_2]| \\
\rulename{choose-l}   & |e choice fail|       & \movesto & |e| \\
\rulename{choose-r}   & |fail choice e|       & \movesto & |e| \\[0.05in]

\rulegroupname{Collection}
\rulename{one-fail}   & |one fail|           & \movesto & |fail| \\
\rulename{one-choice} & |one (r `choice` e)| & \movesto & |r| & if \wf{r} \\
\rulename{one-value}  & |one r|              & \movesto & |r| & if \wf{r} \\
\rulename{all-fail}   & |all fail|                  & \movesto & |tup ()| \\
\rulename{all-choice} & |all (r_1 choice dots choice r_n)| & \movesto & |def xs cs ; tup (vs)|  & if \wff{|rs|}{|xs|}{|cs|}{|vs|} \\
\rulename{all-value}  & |all r|                     & \movesto & |def xs cs ; tup v|     & if \wff{r}{|xs|}{|cs|}{|v|}\\
\end{longtable}
% \caption{\textbf{\calcname: Rules for Unification, Substitution and Application}}\label{fig:rulesI}
\caption{\textbf{\calcname: Rules for Evaluation}}\label{fig:rulesI}
\end{figure}
}

\newcommand{\figureRulesII}{
\begin{figure}
\begin{longtable}{@@{\quad} l r >{$}c<{$} l l}
  \rulegroupname{Decision}
    \rulename{choose}     & |CX^[e_1 choice e_2]| & \movesto & |CX^[e_1] choice CX^[e_2]| \\
    \rulename{choose-l}   & |e choice fail|       & \movesto & |e| \\
    \rulename{choose-r}   & |fail choice e|       & \movesto & |e| \\[0.05in]

  \rulegroupname{Collection}
    \rulename{one-fail}   & |one fail|           & \movesto & |fail| \\
    \rulename{one-choice} & |one (r `choice` e)| & \movesto & |r| & if \wf{r} \\
    \rulename{one-value}  & |one r|              & \movesto & |r| & if \wf{r} \\
    \rulename{all-fail}   & |all fail|                         & \movesto & |tup ()| \\
    \rulename{all-choice} & |all (r_1 choice dots choice r_n)| & \movesto & |def xs cs ; tup (v_1, dots, v_n)|  & if \wff{|r_1 dots r_n|}{|xs|}{|cs|}{|v_1 dots v_n|} \\
    \rulename{all-value}  & |all r|                            & \movesto & |def xs cs ; tup v|                 & if \wff{r}{|xs|}{|cs|}{|v|}\\
\end{longtable}
\caption{\textbf{\calcname: Rules for Decision and Collection}}\label{fig:rulesII}
\end{figure}
}

