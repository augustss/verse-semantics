\newcommand{\figureRulesPOPL}{
\begin{figure}
\begin{longtable}{@@{\quad} l @@{\hspace{-.5em}} r >{$}c<{$} l l}
\rulegroupname{Unification:~\runi}
\rulename{deref-s}  & |x == s ;  E^[x]| & \movesto & |x == s ; E^[s]| \\
\rulename{deref-h}  & |x == h ;  A^[h]| & \movesto & |x == h ; A^[h]| \\
\rulename{u-lit}    & |k == k |                                    & \movesto & k \\
\rulename{u-tup}    & |tup (v_1,dots,v_n) == tup (v1',dots,v_n')| & \movesto & \largerhs{|v_1==v1';dots;v_n==v_n'|} \\
\rulename{u-fail-t} & |tup (v_1,dots,v_n) == tup (v1',dots,v_m')| & \movesto & |fail|& if $n \not = m$ \\
\rulename{u-fail-l}   & |k_1 == k_2  |     & \movesto & |fail| & if $k_1 \not = k_2$ \\
\rulename{u-fail-f} & |lam x_1 e_1 == lam x_2 e_2 |   & \movesto & |fail| & \\
\rulename{u-fail-l-h} & |k == h | & \movesto & |fail| \\
\rulename{u-fail-t-f} & |tup (dots) == lam y e |   & \movesto & |fail| & \\[0.05in]


\rulegroupname{Application:~\rapp}
\rulename{app-beta} & |apply1N (lam x e_1) e_2| & \movesto & |def x (x=e_2; e_1)|  & if $|x| \not \in \freevars{|e_2|}$ \\[0.05in]
% \rulename{app-tup} & |apply1N (tup (v_0,dots v_n)) v| & \movesto & \largerhs{|(v = 0; v_0) choice dots choice (v = n; v_n)|} \\

\rulegroupname{Garbage Collection:~$\rgc$}
\rulename{elim-def}     & |def x e| & \movesto & |e| & if $|x| \not \in \freevars{|e|}$ \\
\rulename{elim-cst}     & |def (x_1 ^^ dots) x_1 == h_1; dots; e| & \movesto & |e| & if every $|x_i| \not \in \freevars{|e|}$\\[0.05in]

\rulegroupname{Fail Propagation:~\rfail}
\rulename{fail-cst}       & |fail ; e|            & \movesto & |fail| \\
\rulename{fail-exp}       & |c ; fail|            & \movesto & |fail| \\
\rulename{fail-def}       & |def x fail|          & \movesto & |fail| \\[0.05in]

\rulegroupname{Speculation:~\rspc}
\rulename{choose}     & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & if $|CX| \ne \hole$ \\
\rulename{choose-assoc} & |SX^[(e_1 choice e_2) choice e_3]| & \movesto & |SX^[e_1 choice (e_2 choice e_3)]| \\
\rulename{choose-r}   & |SX^[fail choice e]|       & \movesto & |SX^[e]| \\
\rulename{choose-l}   & |SX^[e choice fail]|       & \movesto & |SX^[e]| \\
\rulename{one-fail}   & |one fail|           & \movesto & |fail| \\
\rulename{one-choice} & |one (e_1 `choice` e_2)| & \movesto & |e_1| & if \wff{\emptyset}{|e_1|}{|xs|}{|cs|}{|v|} \\
\rulename{one-value}  & |one e|              & \movesto & |e| & if \wff{\emptyset}{|e|}{|xs|}{|cs|}{|v|} \\
\rulename{all-fail}   & |all fail|           & \movesto & |tup ()| \\
\rulename{all-choice} & |all (e_1 choice dots choice e_n)| & \movesto & |def xs cs ; tup (vs)|  & if \wff{\emptyset}{|es|}{|xs|}{|cs|}{|vs|} \\
\rulename{all-value}  & |all e|              & \movesto & |def xs cs ; tup v|     & if \wff{\emptyset}{e}{|xs|}{|cs|}{|v|}
\end{longtable}
\caption{\textbf{POPL-style rules for Evaluation}}\label{fig:popl-rulesI}
\end{figure}
}

