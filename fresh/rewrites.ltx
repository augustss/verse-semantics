\newcommand{\rulegroupname}[1]{\multicolumn{5}{l}{\textit{#1}}\\}
\newcommand{\largerhs}[1]{\multicolumn{2}{l}{#1}}

\newcommand{\wf}[1]{\ensuremath{\vdash #1}}
\newcommand{\wff}[4]{\ensuremath{\vdash #1 \rightsquigarrow (#2 \mid #3 \mid #4)}}
\newcommand{\lvc}[1]{\colorbox{lightgray}{#1}}
\newcommand{\relDescription}[1]{\ensuremath{\textrm{\textbf{#1}}}}
\newcommand{\judgementHead}[2]{\ensuremath{\relDescription{#1}\hfill\fbox{#2}}}
\newcommand{\judgementHeadNameOnly}[1]{\ensuremath{\relDescription{#1}\hfill}}


\newcommand{\figureSyntaxI}{
\begin{figure}[t]
$$\begin{array}{lr@@{\;}c@@{\;}l}
\textit{Integers}     & k \\
\textit{Variables}    & \multicolumn{3}{l}{x,y,z,f,g} \\
\textit{Tuples}       & s, t  & ::= & k \vb x \vb |arr (t_1, dots, t_n)| \\
\textit{Values}       & v     & ::= & t \vb |lam x e| \\
\textit{Constraints}  & c     & ::= & |v_1 == v_2| \vb \lvc{|v == e|} \\
\textit{Expressions}  & e     & ::= & |fail| \vb |v| \vb |def x e| \vb |c ; e| \vb |apply1N e_1 e_2| \vb
                                    |e_1 choice e_2| \vb |one e| \vb |all e| \\
\textit{Programs}     & p     & ::= & |one e| \quad \text{where} \; \freevars{e} = \emptyset \\
\textit{Results}      & r     & ::= & v \vb |(x == lam y e) ; r| \vb |def x r| \\
\end{array}$$
\caption{\textbf{Syntax.} \lvc{Grey text} indicates \emph{lenient} extension. Tuples are $\lambda$-free.}
\label{fig:syntax}
\end{figure}

