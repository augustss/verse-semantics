}

\newcommand{\figureRulesI}{
\begin{figure}
% \begin{longtable}{l r >{$}c<{$} l l}
\begin{longtable}{@@{\quad} l @@{\hspace{-.5em}} r >{$}c<{$} l l}
% \begin{longtable}{lrcll}
% The quad indents the lines
% The \hspace{-..} removes redundant space between rule name column and LHS column
% that arises because the longest rule name and the longer LHS are not on the same line
% The \; reduces the spacing around the arrow
% The >{$} turns on math mode for the arrow column

\rulegroupname{Unification}

\rulename{ulit} & |k == k ; e|                                    & \movesto & e \\
\rulename{utup} & |tup (v_1,dots,v_n) == tup (v1',dots,v_n') ; e| & \movesto & |v_1==v1';dots;v_n==v_n'; e| \\[0.05in]

\rulegroupname{Substitution}

\rulename{subst-t}         & |x == t ;  E^[x]| & \movesto & |x == t ; E^[t]| \\
\rulename{subst-$\lambda$} & |x == (lam y e) ;  A^[x]| & \movesto & |x == (lam y e) ; A^[lam y e]| \\[0.05in]

\rulegroupname{Application}

\rulename{app-beta} & |apply1 (lam x e) v| & \movesto & |def x (x=v; e)|  & if $|x| \not \in \freevars{|v|}$ \\[0.05in]
% \rulename{app-tup} & |apply1 (tup (v_0,dots v_n)) v| & \movesto & \largerhs{|(v = 0; v_0) choice dots choice (v = n; v_n)|} \\

\rulegroupname{Consolidation}

\rulename{cons-def}     & |c ; def x e|             & \movesto & |def x (c ; e)|          & if $|x| \not \in \freevars{|c|}$\\
\rulename{cons-fun-cst} & |apply1 (c ; e_1) e_2|    & \movesto & |c; apply1 e_1 e_2| \\
\rulename{cons-fun-def} & |apply1 (def x e_1) e_2|  & \movesto & |def x (apply1 e_1 e_2)| & if $|x| \not \in \freevars{|e_2|}$ \\
\rulename{cons-arg-cst} & |apply1 e_1 (c ; e_2)|    & \movesto & |c ; apply1 e_1 e_2| \\
\rulename{cons-arg-def} & |apply1 e_1 (def x e_2)|  & \movesto & |def x (apply1 e_1 e_2)| & if $|x| \not \in \freevars{|e_1|}$ \\[0.05in]

\rulegroupname{Elimination}
\rulename{elim-def}     & |def x e| & \movesto & |e| & if $|x| \not \in \freevars{|e|}$ \\
\rulename{elim-rec}     & |def (x_1 ^^ dots) x_1 == (lam y_1 e_1); dots; e| & \movesto & |e| & if $\forall i. |x_i| \not \in \freevars{|e|}$\\[0.05in]

\rulegroupname{Obliteration}
% [FAIL-U]   l = <...>; e    -> FAIL
% [FAIL-U]   l = l’; e       -> FAIL
% [FAIL-U]   \_._ = \_._ ; e -> FAIL
% [FAIL-U]   \_._ = <…> ; e  -> FAIL
% [FAIL-OCC] x=t; e          -> FAIL                  IF x in FV(t), x != v
% [FAIL-C]   FAIL; e         -> FAIL
% [FAIL-E]   c; FAIL         -> FAIL
% [FAIL-D]   ex x. FAIL      -> FAIL
\end{longtable}
\caption{\textbf{\calcname: Rewrite Rules.}}\label{fig:rules}
\end{figure}
}

\newcommand{\figureContexts}{
\begin{figure}
  $$
    \begin{array}{lr@@{\;}c@@{\;}l}
    \text{Execution contexts} & X & ::= & \hole \vb |X == e| \vb |e == X| \vb |X ; e| \vb |e; X| \\
    \text{Value contexts} & V & ::= & \hole \vb |tup (v_1, dots ,V, dots, v_n)|\\
    \text{Scope contexts} & SX & ::= & |hole choice e| \vb |e choice hole |
    \vb |one hole| \vb |all hole| \\
\iffullverse
    && \vb & |succeeds hole| \vb |decides hole| \\
\fi
    \text{Choice contexts} & CX & ::= & \hole \vb |CX == e| \vb |ce == CX| \vb |CX ; e| \vb |ce; CX| \vb |def x CX| \\
    \text{Choice-free exprs} & ce  & ::=  & |v| \vb |ce_1 == ce_2| \vb |ce_1 ; ce_2|
    \vb |one e| \vb |all e|
  \end{array}
   $$
  \caption{The syntax of contexts}
    \label{fig:contexts}
\end{figure}
}

\newcommand{\figureRulesII}{
\begin{figure}
  $$
  \begin{array}{l}
    \textit{One and all} \\
    \begin{array}[t]{lr@@{\;}c@@{\;}l}
    \rulename{one-fail} & |one fail| & \movesto & |fail| \\
    \rulename{one-choice} & |one (v `choice` e)| & \movesto & |v| \\
    \rulename{one-value} & |one v| & \movesto & |v| \\
    \end{array} \hspace{5mm}
    \begin{array}[t]{lr@@{\;}c@@{\;}l}
    \rulename{all-fail} & |all fail| & \movesto & |tup ()| \\
    \rulename{all-choice} &
      |all (v_1 choice dots choice v_n)| & \movesto & |tup (v_1, dots, v_n)| \\
    \rulename{all-value} & |all v| & \movesto & |tup v| \\
    \end{array} \\

    \\[-2mm]

    \textit{Choice} \\
    \begin{array}{lr@@{\;}c@@{\;}ll}
    \rulename{fail-l} & |SX^[fail choice e]| & \movesto & |SX^[e]| \\
    \rulename{fail-r} & |SX^[e choice fail]| & \movesto & |SX^[e]| \\
    \rulename{assoc-choice} & |SX^[(e_1 choice e_2) choice e_3]| & \movesto & |SX^[e_1 choice (e_2 choice e_3)]| \\
    \rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & \text{if}~|CX| \ne \hole
    \end{array} \\

\iffullverse
    \\[-2mm]

    \textit{Effects} \\
    \begin{array}{lr@@{\;}c@@{\;}l}
    \rulename{succ-value} & |succeeds v| & \movesto & |v| \\
    \rulename{dec-fail} & |decides fail| & \movesto & |fail| \\
    \rulename{dec-value} & |decides v| & \movesto & |v| \\
    \end{array} \\
\fi
   \end{array}
   $$
  \caption{The Verse calculus: rewrite rules (2)}
    \label{fig:rules2}  \label{fig:choice}
\end{figure}
}