\newcommand{\figureContexts}{
\begin{figure}
$$\begin{array}{lr@@{\;}c@@{\;}l}
\textit{Value Context}       & V  & ::= & \hole \vb |tup (t_1, dots ,V, dots, t_n)| \vb |lam x E| \\
\textit{Constraint Context}  & C  & ::= & |V == v| \vb |v == V| \vb \lvc{|V == e|} \vb \lvc{|v == E|} \\
\textit{Expression Context}  & E  & ::= & V \vb |def x E| \vb |C ; e| \vb |c ; E| \vb |apply1N E e| \vb |apply1N e E| \\
                             &    & \vb & |E choice e| \vb |e choice E| \vb |all E| \vb |one E| \\
\textit{Application Context} & A  & ::= & |hole e| \vb |hole == hnf; e| \vb |def x A | \vb |c; A| \vb |A e| \vb |e A| \vb \lvc{|v = A; e|} \\
\textit{Choice Context}      & CX & ::= & \hole \vb |def x CX| \vb |v == v' ; CX| \vb |apply1N CX e| \vb |apply1N ce CX| \\
                             &    & \vb & \lvc{|v == CX; e|} \vb \lvc{|v == ce; CX|} \\
\textit{Scope Context}       & SX & ::= & |hole choice e| \vb |e choice hole| \vb |one hole| \vb |all hole| \\[0.05in]

\textit{Head Values}         & hnf & ::= & k \vb |tup (t_1, dots t_n)| \vb |lam x e| \\
\textit{Choice-free Expr.}   & ce  & ::= & v \vb |v == v' ; ce| \vb |def x ce| \vb |ce ce| \vb |one e| \vb |all e| \\
\end{array}$$
\caption{\textbf{The Syntax of Contexts}} \label{fig:contexts}
\end{figure}
}

\newcommand{\figureWellformed}{
\begin{figure}
% \judgementHead{Wellformedness of Results}{\wf{r}}
\begin{mathpar}
\inferrule
  { \wff{r}{|xs|}{|cs|}{|v|}}
  { \wf{r} }
  { \rulename{WF} }

\inferrule
  { }
  { \wff{|v|}{\emptyset}{\emptyset}{|v|} }
  { \rulename{WF-Val}}

\inferrule
  { \wff{r}{|xs|}{|cs|}{|v|} }
  { \wff{|def x r|}{|x,xs|}{|cs|}{|v|} }
  { \rulename{WF-Def} }

\inferrule
  {\wff{r}{|xs|}{|cs|}{|v|} \quad
   x \not \in |xs|
  }
  {\wff{|x == lam y e; r|}{|xs|}{|x == lam y e, cs|}{|v|}}
  {\rulename{WF-Lam}}

\inferrule
  { \wff{r}{\overline{x}}{\overline{c}}{|v|}
    \wff{rs}{\overline{x'}}{\overline{c'}}{|vs|}
  }
  { \wff{r,rs}{\overline{x},\overline{x'}}{\overline{c},\overline{c'}}{|v,vs|} }
  {\rulename{WF-many}}
\end{mathpar}
\caption{\textbf{Well-formedness of Results}}
\end{figure}
}
