    \textbf{Syntax extension} \\
    \begin{array}{lrcl}
      \text{References}         & r \\
      \text{Expressions}        & e   & ::= & \cdots \vb |store s e| \\
      \text{Primops}            & op  & ::= & \cdots \vb |alloc| \vb |read| \vb |write| \\
      \text{Head values}        & hnf & ::= & \cdots \vb r \\
      \text{Execution contexts} & X   & ::= & \cdots \vb |store s X| \\
      \text{Store}              & s   & ::= & |cell r v| \vb |s,s| \vb |emp| \\
