  \textbf{Axiom extensions} \\
  \textit{Reference ops} \\
  \begin{array}{lrcll}
    \rulename{ref-alloc} & |store s (apply1 alloc v)| & \movesto & |store (s, cell r v) r| & \text{|r| fresh} \\
    \rulename{ref-read} & |store (S^[cell r v]) (apply1 read r)| & \movesto & |store (S^[cell r v]) v| \\
    \rulename{ref-write} &
        | store (S^[cell r v_1]) (applyN write (r,v_2))|
        & \movesto & |store (S^[cell r v_2]) emptytup| \\
  \end{array} \\
    \\
  \textit{Store propagation} \\
  \begin{array}{lrcll}
    % SEQ
    \rulename{st-seq-in} & |store s (e_1; e_2)|  & \movesto & |store s e_1; e_2| \\
    \rulename{st-seq-r} & |store s v; e|  & \movesto & |v; store s e| \\
    % UNIFY
    \rulename{st-unify-in} & |store s (e_1 = e_2)|  & \movesto & |store s e_1 = e_2| \\
    \rulename{st-unify-r} & |store s v = e|  & \movesto & |v = store s e| \\
    \rulename{st-unify} & |v_1 = store s v_2|  & \movesto & |v_1 = v_2; store s v_1| \\
    % CHOICE
    \rulename{st-choice} & |store s (e_1 `choice` e_2)| & \movesto & |store s e_1 `choice` e_2| \\
    % DEF
    \rulename{st-def-in} & |store s (def x e)| & \movesto & |def x (store s e)| & e \not\in v \\
    \rulename{st-def-out} & |def x (store s v)| & \movesto & |store s (def x v)| \\
    % SPLIT
    \rulename{st-split-value} & |split (store s v) f g| & \movesto &
        |store s (split v f g)| \\

    \rulename{st-split-choice} & |split (store s (v `choice` e)) f g| & \movesto &
      |store s (split (v `choice` e) f g)| \\

