\section{Syntax}

\begin{figure}[t]
$$
\begin{array}{l}
  \textbf{Abstract syntax} \\
    \begin{array}{lrcl}
    \textit{Integers}      & k \\
    \textit{Variables}     & \multicolumn{3}{l}{x,y,z,f,g} \\
    \textit{Primops}       & \op   & ::= & |gt| \vb |add| \\
    \textit{Values}        & |v|   & ::= & x \vb k \vb op \vb |tup (s_1, dots, s_n)| \vb |lam x e| \\
    \textit{Expressions}   & e     & ::= & |v| \vb |eu ; e| \vb |def x e| \vb |fail|
                                             \vb |e_1 choice e_2| \vb |apply1N v_1 v_2| \vb |one e| \vb |all e| \\
                           & eu     & ::= & |e| \vb |v == e| \\
\end{array}
    \\
    \textbf{Desugaring} \\
    \begin{array}{rcll}
%%      |emptytup| & \text{means} & |arr ()|\\
%%      |tup (v_1, dots, v_n)| & \text{means} & |arr (v_1,dots, v_n)| \quad n \geq 2 \\
      v_1 + v_2 & \text{means} & |applyN add ( v_1, v_2 ) | & \\
      v_1 > v_2 & \text{means} & |applyN gt ( v_1, v_2 ) | & \\
      |def (x_1 ^^ x_2 dots x_n) e| & \text{means} & |def x_1 (def x_2 (dots ^ def x_n e))| & \\
      |apply1 e_1 e_2| & \text{means} & |def (f a) (f == e_1 ; a == e_2; apply1 f a)|  & |f,a|\ \text{fresh} \\
      |tup (e_1, dots, e_n)| & \text{means} &
          |def (x_1 ^^ x_2 dots x_n) (x_1=e_1; dots; x_n=e_n; tup (x_1,dots, x_n)| & \text{|x_i| fresh} \\
      |e_1 == e_2|      & \text{means} & |def x (x == e_1 ; x == e_2; x)|       & |x|\ \text{fresh} \\
%      |e_1 ; e_2|      & \text{means} & |def x (e_1; x == e_2 ; x)|       & |x|\ \text{fresh} \\

      |if e_1 then e_2 else e_3| & \text{means}
      & |def y (y == one( (e_1; thunk e_2) choice (thunk e_3)); apply0 y)| & \text{|x,y| fresh} \\
      |for e| & \text{means}  & |all e| \\
      |for^(e_1) do e_2| & \text{means} & |def y (y == all (e_1; thunk e_2); applyN map (lam z (apply0 z), y))| \\
%       |for^(e_1) do e_2| & \text{means} & |def v (v == all (e_1; thunk e_2); applyN map (lam z (apply0 z), v))|
      |x := e_1; e_2| & \text{means} & |def x (x == e_1; e_2)| \\
     \end{array} \\
\end{array}
$$
\caption{\textbf{The Verse Calculus: Syntax}}
\label{fig:syntax}
\end{figure}


