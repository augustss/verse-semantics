$$\begin{array}{lr@@{\;}c@@{\;}l}
\textit{Expression context}     & E  & ::= & \hole \vb |tup (s_1, dots , hole , dots, s_n)| \vb |lam x E| \vb |def x E| 
                                              \vb |E == e| \vb |e == E| \\
                                &    & \vb & |E ; e| \vb |e ; E| \vb |apply1N E v| \vb |apply1N v E|
                                       \vb |E choice e| \vb |e choice E| \vb |all E| \vb |one E| \\
\textit{Application context}    & A  & ::= & |apply1N hole v| \vb |apply1N op hole| \vb |hole == hnf| \vb |v == A| \vb |def x A| \vb |A ; e| \vb |e ; A| \\
                                &    & \vb & |A choice e| \vb |e choice A| \vb |all A| \vb |one A| \\
\textit{Scope context}          & SX & ::= & |hole choice e| \vb |e choice hole| \vb |one hole| \vb |all hole| \\
\textit{Choice context}         & CX & ::= & \hole \vb |v == CX| \vb |CX; e| \vb |ce ; CX|  \vb |def x CX| \\
\textit{Choice-free expr}      & ce & ::= & |v| \vb |v == ce| \vb |ce_1 ; ce_2| \vb |one e| \vb |all e|
                                             %%% NOTE: the following is not in the POPL submission,
                                             %%% but needed to make progress in (1,2)[x:int]
                                             \vb |apply1 op v|
                                             \vb |def x ce| \\
\textit{Bound variables} & \multicolumn{3}{l}{
  \boundvars{E} =
  \begin{array}[t]{l}
      \text{The variables that are bound by |E| at the hole} \\
      \text{e.g. $\boundvars{|(def x (x=3)) `choice` (def y (hole = 4)))|} = \{y\}$}
  \end{array}
   }
\end{array}$$

