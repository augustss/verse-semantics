%% ----------- DPS Verse -------------
%format scope (op) = "\{" op "\}"
%format dpslam q (fx)(i)(e1)(hw)(e2)y = "\lambda_{" q "}\langle" fx "\rangle" i ".(" e1 ")(" hw ")\{" e2 "\}(" y ")"
%format nop = "\textbf{nop}"
%format dpsall (op) y = allKW "\{" op "\}(" y ")"
%format dpsone (op) y = oneKW "\{" op "\}(" y ")"
%format dpsfor (op1) (op2) y = forKW "(" op1 ")\{" op2 "\}(" y ")"

%% Translation from Mini Verse to DPS Verse
%format DpsT (e) r = "\mathcal{T}\llbracket" e "\rrbracket{}" r

