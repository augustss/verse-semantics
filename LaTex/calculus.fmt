% ----------------------
%% Stuff for TimCore

%format timlam h fx i x s0 j y s1 = "\textbf{tlam}(" h "," fx ")\," i "," x "\{" s0 "\}" j "," y "\{" s1 "\}"
%format lam2 x r e = "\lambda" x "\shortrightarrow{}" r ".\," e
%format timscope (vs) (stuff) (e) = "\textbf{scope}(" vs ";" stuff ").\," e

%% 'g' inferences
%format edge v w = v "\leftarrow" w
%format fails s v  = s "\{" v==fail "\}"
%format equals s v w  = s "\{" v==w "\}"
%format lengthis s y z = s "\{" length^[y]==z "\}"
%format dominates s v w = s "\{" v "\twoheadleftarrow" w "\}"

%format fvs e = "\mathsf{fvs}" e

%format effects (g) (e) = "\mathcal{FX}(" g "," e ")"
%format empty = " "

%format beffects (s) (e) = "\textit{effects}_{" s "}(" e ")"
%format beffectsfun (e) = "\textit{effectsfun}(" e ")"
%format bnext (s) (a) (v) (e) = "\textit{next}_{" s "}(" a "," v "," e ")"
%format bcombine (x) (y) = "\textit{combine}(" x "," y ")"
%format bcommutes (x) (y) = "\textit{commutes}(" x "," y ")"
%format biter (e) = "\textit{iter}(" e ")"
%format g_diverges = "\textit{g}_{diverges}"

%% --------- Effects ------------
%format fx = "\omega"
%format fx_1
%format fx_2

%% Intersection of effects
%format andeffects (fx1) (fx2) = fx1 "\cap" fx2


%format succeeds = "\textbf{succeeds}"
%format succeedsE (e) = "\textbf{succeeds}\{" e "\}"
%format decides = "\textbf{decides}"
%format decidesE (e) = "\textbf{decides}\{" e "\}"
%format iterates = "\textbf{iterates}"
%format iteratesE (e) = "\textbf{iterates}\{" e "\}"
%format resolves = "\textbf{resolves}"
%format fails = "\textbf{fails}"
%format nofail = "\textbf{nofail}"
%format abstracts = "\textbf{abstracts}"
%format contradicts = "\textbf{contradicts}"
%format closed = "\textbf{closed}"
%format open = "\textbf{open}"
%format openeff = "\textbf{open}"
%format closedeff = "\textbf{closed}"
%format diverges = "\textbf{diverges}"
%format transacts = "\textbf{transacts}"
%format interacts = "\textbf{interacts}"
%format chooses = "\textbf{chooses}"
%format reads = "\textbf{reads}"
%format writes = "\textbf{writes}"
%format allocs = "\textbf{allocs}"

%format cons (x) (y) = consKW "[" x "," y "]"
%format applyx a b = a "(" b ")"
%format snoc = "\textbf{snoc}"
%format len = "\textbf{length}"

%% ----------------------
%format ^ = " "
%format ^^ = "\hspace{0.1em}"

%format subst (e) (x) (v)  = e "[" v "/" x "]"
%format substw (e) (x) (v) = e "\{\!\{" v "/" x "\}\!\}"

%% --------------------------
%%        Desugaring rules
%% --------------------------

%format (Ane (x)) = "\Ane{" ^ x "}"
%format (Fne (x)) = "\Fne{" ^ x "}"
%format (De (x)) = "\De{" ^ x "}"
%format (Ve (x)) = "\Ve{" ^ x "}"
%format (Ie (x)) = "\Ie{" ^ x "}"
%format (Fe (i) (e)) = "\Fe{" ^ i "}{" ^e "}"
%format (Me  (i) (e)) = "\Me{"  ^ i "}{" ^e "}"
%format (DMe (i) (e))  = "{\mathcal M}\llbracket" e "\rrbracket{}" i
%format (DMe2 (m) (i) (e)) = "{\mathcal M}_{" m "}\llbracket" e "\rrbracket{}" i
%format (DMe3 (m) (pi) (e)) = "{\mathcal V}_{" m "}\llbracket" e "\rrbracket{}"pi
%format (MMe (m) (i) (e)) = "\MMe{" ^ i "}{" ^e "}{" ^m "}"

%format (XMe (i) (u) (m)) = "{\mathcal M}\llbracket{}" m "\rrbracket{}" i "^{" u "}"
%format (DB (m) (j) (pi) (t)) = "{\mathcal B}_{" m "}\llbracket{}" t "\rrbracket{}" pi "\," j
%format (De2 md (x))      = "{\mathcal D}_{" md "}\llbracket" x "\rrbracket"

%% "Mcirc" is a meta function for matching
%% Mcirc w t  =  exists x. x ~>circ t
%format (Mcirc w t)  = "{\mathcal D}_{" w "}\llbracket" t "\rrbracket"

% ----------------------------------------------------
% New desugaring, just does the wrapping part:
% ----------------------------------------------------
%format (SS u (e))    = "{\mathcal W}\llbracket" e "\rrbracket" u
%format (checkfun q x e)  = "{\mathcal K}_{" q "}\llbracket" e "\rrbracket" x
%format `ueq`         = "\;\mathring{=}\;"
%format underscore    = "{\_}"
%   Input for wrapping
%format wu            = "\kappa"
%format mkwu (dr) (inp) = dr ",\!" inp
%format drdom         = "D"
%format (drrng x)     = "R\langle" x "\rangle"
%format wrapemp       = "\bullet"
%format wrape (e)     = e
%format wuinit        = "(" drdom "," wrapemp ")"

%format FunCheck (pi) = "{\mathcal F}(" pi ")"

%%format Hide (e) = "{\mathcal H}\llbracket{}" e "\rrbracket{}"
%format Hide (v) = "{\bf some}(" v ")"

%% 'si' is short for "solve or infer" or "unification variable or not" resp
%format si = "\pi"
%format sipat (x) = "\mathsf{P}(\!" x ")"
%format sibody    = "\mathsf{E}"
%format siupd (pi) x = pi ^ "\langle" x "\rangle"
%format sip = si "\rq"
%format solve = "\circ"
%format infer = "\bullet"
%format solvex = "\diamond"
%format inpw  = "w"
%format inp (x) (u) = x "^{" u "}"
%format inp2 (x) (u) (md) = x "^{" u "}_{" md "}"

%% 'md' is short for "mode" or "unification variable or not" resp
%format md = "\sigma"
%format mdx   = "\textbf{x}"
%format mdpos = "+"
%format mdneg = "-"

%% flipsi is a no-op for now
%format flipsi (si) = "\bullet"

%format (Ae (i) (e)) = "\Ae{" ^ i "}{" ^e "}"
%format (An (x)) = "\An{" ^ x "}"
%format (Cr (x)) = "\Cr{" ^ x "}"
%format (Bi (x)) = "\Bi{" ^ x "}"
%format (Vr (x)) = "\Vr{" ^ x "}"
%format (Vl (x)) = "\Vl{" ^ x "}"
%format (Th (x)) = "\Th{" ^ x "}"
%format (Pd (x)(y)) = "\Pd{" ^ x "}{" ^ y "}"
%format (Ld (x)(y)) = "\Ld{" ^ x "}{" ^ y "}"
%format PX (x) = "P\{" x "\}"

%% EXX is just EX, but with no argument
%format EX (x) = "C\{" x "\}"
%format EXX (x) = "C"

%format suspx (x) = "susp\{" x "\}"
%format suspx1 (x) = "susp\{" x "\}_1"
%format suspx2 (x) = "susp\{" x "\}_2"

%format validc x xs (y) = "\mathsf{valid}("  x "," xs "," y ")"
%format blockedc xs (y) = "\mathsf{blkd}_{\small c}("  xs "," y ")"
%format blockede xs (y) = "\mathsf{blkd}_{\small e}("  xs "," y ")"
%format choicefreec (y) = "\mathsf{choicefree}_{\small c}(" y ")"
%format choicefreee (y) = "\mathsf{choicefree}_{\small e}(" y ")"
%format skolval (xs) v = "\mathsf{skol}(" xs "," v ")"
%format freevars (e) = "\mathsf{fvs}(" e ")"
%format boundvars (e) = "\mathsf{bvs}(" e ")"
%format `delete` = "\setminus"
%format (singleton (x)) = "\{" x "\}"

%format match (e) (b) = e "\blacktriangleright" b
%format `match`       = "\blacktriangleright"

%% ----------- Applications --------------
%% %format applyx a b = a "@" b
%% %format applyx a b = a "\," b

%% Function application with no arguments
%format apply0 a = a "[]"

%% Function application with 1 argument
%format apply1 a (b) = a "(" b ")"

%% Function application with 1 argument, no parens
%format apply1np (a) (b) = a "(" b ")"

%% Function application with 1 argument, without parenthesis
%format apply1N a (b) = a^ "[\hspace{-0.2mm}" b "]"
%format apply1Np (a) b = a^ "[\hspace{-0.2mm}" b "]"

%% Function application with many arguments
%format applyN a (b) = a "[" b "]"

%% ----------- End of Applications --------------

%format space = "\hspace{0.3em}"
%format olam (x) (y) = olamKW "(" x "," y ")"
%format olamKW = "\textbf{olam}"
%format inapplic (x) (y) = "\textbf{inapplic}(" x "," y ")"

%format lam (x) (e) = "\lambda" x" .\," e
%format lam2 x r e = "\lambda"x"\!\shortrightarrow{}\!"r".\," e
%format lamhdr (x) = "\lambda" x".\,"
%format mlam (e1) (e2) = "\mu\hspace{0.03em}" e1 ".\," e2
%format thunk (e) = "\lambda \_.\," e
%format force (e) = e "[]"
%format lambda = "\lambda\!"
%format BigLambda = "\Lambda\!"
%format tlamx  (fx) (x) (y) (e1) (e2) = "\tlamFX{" fx "}" "(" x ")[" y "]\{" e1 "\}\{" e2 "\}"
%format tlamxt (fx) (x) (y) (e1) (e2) (e3) = "\tlamFX{" fx "}" "(" x ")[" y "]\{" e1 "\}\{" e2 "\}\{" e3 "\}"
%format tlam (x) (e1) (e2) = tlamKW "(" x ")\{" e1 "\}\{" e2 "\}"
%format tlamt (x) (e1) (e2) (e3) = tlamKW "(" x ")\{" e1 "\}\{" e2 "\}\{" e3 "\}"
%format tlamKW = "\textbf{tlam}"
%format oftype (e) (t) = e "\vartriangleright" t
%format voftype (e) (t) = e "\vartriangleright_V" t
%format ioftype (e) (t) = e "\vartriangleright_I" t
%format oftypeKW = "\vartriangleright"
%format oftypefx (e) (fx) (t) = e "\vartriangleright\hspace{-1.3mm} \langle" fx "\rangle\," t
%format colonfx fx t = :t "\hspace{-0.2mm} \langle" fx "\rangle"
%% %format at = "\, @\!\!"
%format dot = "\! ."
%format alpha = "\alpha"
%format beta = "\beta"
%format gamma = "\gamma"
%format tau = "\tau"
%format sigma = "\sigma"
%format varsigma = "\varsigma"
%format upsilon = "\upsilon"
%format colonequals = "\colonequals"
%format dollar = "\$"
%format fordo (a) b = "\textbf{for}(" a ")\,\textbf{do}\{" b "\}"
%format forb (a) b = "\textbf{for}(" a ")\{" b "\}"
%format for1 (a) = "\textbf{for}(" a ")"

%format blam (x) (fx) (e) = "\lambda_{" fx "}" x".\," e


%% Sequences e1; ...; en; v
%format se = "es"
%format xs = "\overline{x}"
%format cs = "\overline{c}"
%format rs = "\overline{r}"
%format vs = "\overline{v}"
%format es = "\overline{e}"
%format ys = "\overline{y}"
%format zs = "\overline{z}"
%format es_1
%format es_2
%format hnf = "\mathit{hnf}"
%format q_1
%format q_2
%format qc_1
%format qc_2

%% xs etc stole syntax used in examples.
%format xsl = " xs "
%format ysl = " ys "
%format zsl = " zs "

%% Old version: | for BNF, [] for choice
%format vbar = "\mathop{\mid}"
%format choice = "\rule[-0.1em]{0.15em}{0.75em}"
%% 1mm is about 0.3em with the current font
%format `choice` = "\hspace{0.19em}\mathop{\rule[-0.1em]{0.15em}{0.75em}}\hspace{0.2em}"
%format `uchoice` = "|\!|\!|"

%format hastype (x) (y) = x "\," hastypeKW "\," y
%format hastypeKW = "{\bf hastype}"

%format srcand = "\textbf{and}"
%format srcor = "\textbf{or}"
%format hat = "\hat{\hspace{0.8em}}"
%format amp = "\!\textbf{\&}\!"

%format hchoice = "\|"
%format he = "he"
%format none = "\textbf{none}"
%format fail = "\textbf{fail}"

%% %format ok = "\textbf{ok}"
%format ok = "\langle\rangle"

%format `wherekw` = "\;\textbf{where}\;"
%format succeed = "\textbf{succeed}"
%format wront = "\wrong"
%format do = "\textbf{do}"
%format if = "\textbf{if}"
%format collect = "\textbf{collect}"
%format orElse = "\textbf{orElse}"
%format append = "\textbf{append}"
%format `plusplus` = "+ \! + \,"
%format app = "\textbf{app}"
%% %format `eqsemi` = "\hspace{-0.5mm}\fatsemi{}"
%% %format eqsemiKW = "\fatsemi"
%format `eqsemi` = ";"
%format eqsemiKW = ";"

%% Arrays and tuples
%format array (x) = "\textbf{array}\{" x "\}"
%format ar (x) = "\textbf{ar}\{" x "\}"
%format arr (x) = "\langle" x "\rangle"
%format arrsp (x) = "\langle\;" x "\;\rangle"
%format (tup (x)) = "\langle{}" x "\rangle"
%format emptytup = "\langle" "\rangle"
%format emptyset = "\emptyset"
%format arropen = "\langle"
%format arrclose = "\rangle"

%format amap (x) = "\textbf{map}\{" x "\}"
%format mkMap = "\textbf{mkMap}"
%format vmap (x) = "\langle\hspace{-0.25em}\langle" x "\rangle\hspace{-0.25em}\rangle"
%% %format vmap (x) = "\llangle" x "\rrangle"

%format left (x)  = "L \triangleright" x
%format right (x)  = "R \triangleright" x

%format ifKW = "\textbf{if}"
%format forKW = "\textbf{for}"
%format countKW = "\textbf{count}"
%format typeKW (x) = "\textbf{type}"
%format oneKW = "\textbf{one}"
%format allKW = "\textbf{all}"
%format iterKW = "\textbf{iter}"

%format tuple = "\textbf{tup}"
%format (typex (x)) = typeKW "\{" x "\}"
%format (truth t) = "\textbf{truth}\{" t "\}"
%format (all (x)) = allKW "\{" x "\}"
%format all2 (r) (x) = allKW "("r")\{" x "\}"
%format (one (x)) = "\textbf{one}\{" x "\}"
%format one2 (r) (x) = oneKW "("r")\{" x "\}"
%format if3 (e1) (e2) (e3) = ifKW "(" e1 ")\{" e2 "\}\!" else "\!\{" e3 "\}"

%format iter (e) (a) (f) (g) = iterKW "(" e ")\{" a ";" f ";" g "\}"
%format iter2 (k) (e) (z) = iterKW "(" k ")\{"e "\}\{" z "\}"
%format block (e) = blockKW "\{" e "\}"
%format blk (x) (hp) (e) = "\exists{}" x "\{" hp "\}.\," e
%format emptyheap = "\{\}"
%format `without` = "\! \bbslash \!"
%format delay (e) = delayKW "\{" e "\}"
%format twiddle x w (t) = x  "\leadsto_{" w "}" t
%format hbind x e = x "\!\shortleftarrow\!" e
%format verifyflag = "\textsc{\bf \small v}"
%format execflag = "\textsc{\bf \small x}"
%format bbcirc = "\circ"
%format bbblob = "\bullet"
%format applyiter k (v) (e) = k "[" v "," e "]"
%format leftchoicefree (c) = "\mathsf{leftChoiceFree}(" c ")"
%format choicefree (e) = "\mathsf{choiceFree}(" e ")"

%format splitKW = "\textbf{split}"
%%  OLD SYNTAX   %format split (x) (y) (z) = "\textbf{split}(" x ")\{" y "," z "\}"
%format split (x) (y) (z) = "\textbf{split}\{" x "\}\langle" y "," z "\rangle"
%% %format defKW = "\textbf{def}"
%format defKW = "\exists{}"
%format defintro (x) = "\exists" x
%format defhdr (x) = "\exists" x ".\,"
%format def (x) (y) = "\exists" x ".\," y
%format dlet (x) (r) (b) = "\textbf{let}\;" x "=" r "\;\textbf{in}\,\{" b "\}"
%format llet (x) (r) (b) = "\textbf{let}\;" x "=" r "\;\textbf{in}\," b
%format defTwoLines (x) (y) = "\textbf{def}\;" x "\;\textbf{in}\\\{" y "\}"
%format storeKW = "\textbf{store}"
%format store (x) (y) = "\textbf{store}\;" x "\;\textbf{in}\,\{" y "\}"
%format storeTwoLines (x) (y) = "\textbf{store}\;" x "\;\textbf{in}\\\{" y "\}"
%format cell (k) (v) = k "\mapsto\!" v
%format rangeKW = "\textbf{range}"
%format range = "\textbf{range}"
%format square(x) = x "^2"
%format univ (x) (y) = "\nu" x ".\," y
%format myite (x) (y) (z) = ifKW ";" x "\;\{" y "\}\;\{" z "\}"
%format vif (x) (y) (z) = ifKW "(" x ")\{" y "\}\textbf{else}\{" z "\}"
%format in = "\textbf{in}"
%format then = "\textbf{then}"
%format else = "\textbf{else}"
%format for = "\textbf{for}"
%format blockKW = "\textbf{block}"
%format delayKW = "\textbf{delay}"
%format orElse = "\textbf{orElse}"
%format collect = "\textbf{collect}"
%format apply = "\textbf{apply}"
%format arrow = "\textbf{arrow}"
% only used in comments, but still prettier this way:
%format true = "\textbf{true}"
%format false = "\textbf{false}"
%format fix = "\textbf{fix}"
%format unify = "\textbf{unify}"
%format consKW = "\textbf{cons}"
%format add = "\textbf{add}"
%format dotdot = "\textbf{dotdot}"
%format pfun = "\mathit{pf}"
%format ppred = "\mathit{pp}"
%%%%format map = "\textbf{map}"
%format sub = "\textbf{sub}"
%format semi = "\textbf{seq}"
%format gt = "\textbf{gt}"
%format rec = "\textbf{rec}"
%format wrong = "\textbf{wrong}"
%format int = "\textbf{int}"
%format rat = "\textbf{rat}"
%format str = "\textbf{str}"
%format char = "\textbf{char}"
%format path = "\textbf{path}"
%format nat = "\textbf{nat}"
%format abs = "\textbf{abs}"
%format isInt = "\textbf{isInt}"
%format isString = "\textbf{isString}"
%format isFun = "\textbf{isFun}"
%format string = "\textbf{string}"

%% -------Functions ---------------
%format functionKW = "\textbf{fun}"
%format relationKW = "\textbf{rel}"
%format choiceindex (t) = "\textbf{choiceIndex}\{t\}"

%format fndef (x) (a) (out) (rhs) = functionKW "(" x : a ")" out "\{" rhs "\}"
%format function (x) (rhs) = functionKW "(" x ")\{" rhs "\}"
%format relation (x) (rhs) = relationKW "(" x ")\{" rhs "\}"
%format functionP (x) (rhs) = functionKW "(" x ")\{" rhs "\}"
%format functionX (x) (fx) (rhs) = functionKW "(" x ")" fx "\{" rhs "\}"
%format funk k (e) (rhs) = functionKW "_"k"(" e ")\{" rhs "\}"

%% functionOC has open/closed subscript
%format functionOC (oc) (x) (rhs) = functionKW "(" x ")\langle" oc "\rangle \{" rhs "\}"
%format functionOCX (oc) (x) (fx) (rhs) = functionKW "(" x ")\langle" oc "\rangle\langle" fx "\rangle\{" rhs "\}"
%format lamOC (oc) (x) (t1) (t2) = "\lambda_{" oc "}" x ".(" t1 ")\{" t2 "\}"
%format lamOCv (oc) (x) (t1) (t2) = "\lambda_{" oc "}" x ".\begin{array}[t]{@{}l} (" t1 ") \\ \{" t2 "\} \end{array}"

%   \_q<fx>i.(e1)(y:=f[x]){e2}
%format lamH q (fx)(i)(e1)(hw)(e2) = "\lambda_{" q "}\langle" fx "\rangle" i ".(" e1 ")(" hw ")\{" e2 "\}"
%format lamHv q (fx)(i)(e1)(hw)(e2) = "\lambda_{" q "}\langle" fx "\rangle" i ".\begin{array}[t]{@{}l} (" e1 ") \\ (" hw ")\{" e2 "\} \end{array}"

%% -------End of functions ---------------

%format prefix op = "\textbf{prefix}\textquote " op "\textquote"
