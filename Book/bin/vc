#!/usr/bin/env node
const { spawn } = require('child_process')
const path = require('path')
const defaultPath = "../../fortniteMain/Engine/Restricted/NotForLicensees/Binaries/Win64/VerseCLRVM-Win64-Shipping.exe"
function printUsage() {
  console.log('Usage: vc <compiler-path> <verse-file>'); console.log('')
  console.log('Runs the Verse compiler and formats error messages.')
  process.exit(1)
}
function parseArgs() {
    const args = process.argv.slice(2)
    if (args.length < 1) printUsage()
    if (args.length == 2) {
        const compilerPath = args[0]
        const verseFile = args[1]
        return { compilerPath, verseFile }
    } else  if (args.length == 1) {
        const compilerPath = defaultPath
        const verseFile = args[0]
        return { compilerPath, verseFile }
    } else {
        console.log("Not expected")
    }
}
function parseErrorMessages(output) {
    const lines = output.split('\n')
    const errors = []
    let i = 0
    // Skip first line (vproject opened message)
    if (lines.length > 0 && lines[0].includes('vproject has opened')) {  i = 1 }
    // Process lines until we hit the final error messages
    while (i < lines.length) {
        const line = lines[i]
        // Stop if we hit the final error/command lines
        if (line.startsWith('ERROR:') || line.startsWith('Command:')) { break; }
        // Check if this is a "Build Failure:" line
        if (line.startsWith('Build Failure:')) {
            // Extract the error message
            const re = /^Build Failure:\s+(.+?)\((\d+),\s*(\d+),\s*(\d+),\s*(\d+)\):\s*([^\r\n]+)/
            const m = re.exec(line)
            if (!m) { console.log("No match")
            } else {
                const [_, file, lineNumber, startCol, endLine, endCol, message] = m
                errors.push({ lineNumber, message })
            }
        }
        i++
    }
    return errors
}
function isSuccess(output) { return !output.includes('Build Failure:') }
function main() {
  const { compilerPath, verseFile } = parseArgs();
  const compiler = spawn(compilerPath, ['--open=' + verseFile], { stdio: ['pipe', 'pipe', 'pipe'] });
  let stdout = '';
  let stderr = '';
  compiler.stdout.on('data', (data) => { stdout += data.toString(); });
  compiler.stderr.on('data', (data) => { stderr += data.toString(); });
  compiler.on('close', (code) => {
    const output = stdout + stderr;
      if (isSuccess(output)) { console.log("Success"); process.exit(0)
      } else { // Failure - parse and print error messages
          const errors = parseErrorMessages(output)
          if (errors.length==0) console.log(output)
          errors.forEach(error => { console.log(${error.lineNumber}: ${error.message}) })
          process.exit(1)
      }
  });
    compiler.on('error', (err) => {  console.error(Failed to run compiler: ${err.message});  process.exit(1) })
}
main();
