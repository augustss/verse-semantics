#!/usr/bin/env bash

# Script to run .versetest files using VerseTestScriptCmdVM.exe from WSL

# Configuration
VERSE_TEST_VM="/mnt/c/fortniteMain/Engine/Restricted/NotForLicensees/Binaries/Win64/VerseTestScriptCmdVM.exe"
VERSE_DIR="$(pwd)/verse"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if VerseTestScriptCmdVM.exe exists
if [ ! -f "$VERSE_TEST_VM" ]; then
  echo -e "${RED}Error: VerseTestScriptCmdVM.exe not found at: $VERSE_TEST_VM${NC}"
  echo "Please update the VERSE_TEST_VM path in this script"
  exit 1
fi

# Check if verse directory exists
if [ ! -d "$VERSE_DIR" ]; then
  echo -e "${RED}Error: verse directory not found at: $VERSE_DIR${NC}"
  exit 1
fi

# Convert WSL path to Windows path
wsl_to_windows() {
  wslpath -w "$1"
}

# Find all .versetest files
echo "Finding .versetest files..."
mapfile -t versetest_files < <(find "$VERSE_DIR" -name "*.versetest" | sort)

if [ ${#versetest_files[@]} -eq 0 ]; then
  echo -e "${YELLOW}No .versetest files found${NC}"
  exit 0
fi

echo -e "Found ${GREEN}${#versetest_files[@]}${NC} .versetest file(s)\n"

# Counters
total=0
passed=0
failed=0

# Run each test
for test_file in "${versetest_files[@]}"; do
  total=$((total + 1))

  # Convert to Windows path - must be absolute
  abs_path=$(realpath "$test_file")
  windows_path=$(wsl_to_windows "$abs_path")
  windows_vm=$(wsl_to_windows "$VERSE_TEST_VM")

  # Get relative path for display
  rel_path="${test_file#$VERSE_DIR/}"

  echo -e "${YELLOW}Testing:${NC} $rel_path"

  # Run the test using cmd.exe
  if cmd.exe /c "$windows_vm" "$windows_path" 2>&1; then
    echo -e "${GREEN}✓ PASS${NC}\n"
    passed=$((passed + 1))
  else
    echo -e "${RED}✗ FAIL${NC}\n"
    failed=$((failed + 1))
  fi
done

# Summary
echo "=========================================="
echo -e "Total tests: $total"
echo -e "${GREEN}Passed: $passed${NC}"
echo -e "${RED}Failed: $failed${NC}"
echo "=========================================="

if [ $failed -gt 0 ]; then
  exit 1
fi
