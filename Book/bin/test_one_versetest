#!/usr/bin/env bash

# Script to run a single .versetest file using VerseTestScriptCmdVM.exe from WSL

VERSE_TEST_VM="/mnt/c/fortniteMain/Engine/Restricted/NotForLicensees/Binaries/Win64/VerseTestScriptCmdVM.exe"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check arguments
if [ $# -eq 0 ]; then
  echo "Usage: $0 <path-to-versetest-file>"
  echo "Example: $0 verse/12_live_variables/01.versetest"
  exit 1
fi

TEST_FILE="$1"

# Check if file exists
if [ ! -f "$TEST_FILE" ]; then
  echo -e "${RED}Error: File not found: $TEST_FILE${NC}"
  exit 1
fi

# Check if it's a .versetest file
if [[ ! "$TEST_FILE" =~ \.versetest$ ]]; then
  echo -e "${YELLOW}Warning: File doesn't have .versetest extension${NC}"
fi

# Check if VerseTestScriptCmdVM.exe exists
if [ ! -f "$VERSE_TEST_VM" ]; then
  echo -e "${RED}Error: VerseTestScriptCmdVM.exe not found at: $VERSE_TEST_VM${NC}"
  exit 1
fi

# Convert to Windows path - must be absolute path
abs_path=$(realpath "$TEST_FILE")
windows_path=$(wslpath -w "$abs_path")
windows_vm=$(wslpath -w "$VERSE_TEST_VM")

echo -e "${YELLOW}Testing:${NC} $TEST_FILE"
echo ""

# Run the test
if cmd.exe /c "$windows_vm" "$windows_path"; then
  echo ""
  echo -e "${GREEN}✓ TEST PASSED${NC}"
  exit 0
else
  echo ""
  echo -e "${RED}✗ TEST FAILED${NC}"
  exit 1
fi
