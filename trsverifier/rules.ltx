\begin{figure}
$\begin{array}{lcl}
\toprule
\proves{P}{e}                & \doteq & \UnAssume{e} \in \FEnv{P}       \\
\midrule
%
\UnAssume{|e_1 = e_2|}       & \doteq & \UnAssume{e_1} = \UnAssume{e_2} \\
\UnAssume{|e_1 ; e_2|}       & \doteq & \UnAssume{e_1} ; \UnAssume{e_2} \\
\UnAssume{|e_1 choice e_2|}  & \doteq & \UnAssume{e_1} |choice| \UnAssume{e_2} \\
\UnAssume{|apply1N e_1 e_2|} & \doteq & \UnAssume{e_1} \ \UnAssume{e_2} \\
\UnAssume{|assume e|}        & \doteq & \UnAssume{e}                    \\
\UnAssume{|e|}               & \doteq & e                               \\
\midrule
%
\FEnv{|P; e|}                & \doteq & \FEnv{P} \cup \Facts{e}         \\
\FEnv{|e; P|}                & \doteq & \FEnv{P} \cup \Facts{e}         \\
\FEnv{|lam x P|}             & \doteq & \FEnv{P} \cup \{ x \}           \\
\FEnv{|xdots P xdots|}       & \doteq & \FEnv{P}                        \\
\midrule
%
\Facts{|assume e |} & \doteq & \{\UnAssume{e}\}                         \\
\Facts{|e_1; e_2|}  & \doteq & \Facts{e_1} \cup \Facts{e_2}             \\
\Facts{|e_1 choice e_2|} & \doteq & \Facts{e_1} \cap \Facts{e_2}             \\
\Facts{|def x e|}   & \doteq & \Facts{\subst{e}{x}{x'}} \quad \text{where}\ $|x'|$\ \text{is fresh} \\
\Facts{|e|}         & \doteq & \emptyset \\
\bottomrule
\end{array}$
\caption{Definitions for the \rulename{prove} rule in \cref{fig:verifier-rewrite-rules}.}
\end{figure}