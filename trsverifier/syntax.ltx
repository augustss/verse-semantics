   &   & \vb & |def x t| \vb |t = t| \vb |t; t| \vb |t choice t| \vb |one t| \vb |all t| \\
   &   & \vb & |t^[t]| \\
   &   & \vb & |t^(t)| \\
   &   & \vb & |fndef x t (tup (fx)) t| \\
