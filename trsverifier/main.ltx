\section{Syntax}\label{sec:syntax}

% \figureSyntax

\begin{figure}
$$\begin{array}{lr@@{\;}c@@{\;}l}
\text{Expressions} & e & ::= & \ldots \\
                   &   & \vb & |myite e e e| \\
                   &   & \vb & |succeed e| \vb |decide e| \\
                   &   & \vb & |assume e| \vb |verify e| \\
\end{array}$$
\caption{Syntax of the extensions needed by the TRS Verifier.}
\label{fig:verifier-syntax}
\end{figure}

The verifier's language is an extension of Core Verse
-- as described in \cref{fig:syntax} -- with a few constructs
that record the verification goals and the assumptions under which
they must be proved.
%
These extensions are summarized in \cref{fig:verifier-syntax}.
%
The |myite e_1 e_2 e_3| construct makes it easier to use
the information established by the branch (|e_1|) in the |then|
expression |e_2|.
%
The |assume e| construct records an \emph{assumption} that
the evaluation of |e| always produces a value \ie does not
get stuck or |fail|.
%
Dually, the |succeed e| construct (perhaps better named |succeeds|)
denotes an \emph{obligation} that the evaluation of |e| always
produces a value \ie does not get stuck or fail.
%
The |decide e| construct denotes an \emph{obligation} that
the evaluation of |e| does not get \emph{stuck} \ie either
produces values or fails.

\section{Rewrite Rules}


\newcommand{\mustSucceedKW}{\mathsf{Suc}}
\newcommand{\mustSucceed}[1]{\ensuremath{\mustSucceedKW(#1)}}

\newcommand{\mustDecideKW}{\mathsf{Dec}}
\newcommand{\mustDecide}[2]{\ensuremath{\mustDecideKW(#1, #2)}}

\newcommand{\mustVerifyKW}{\mathsf{Prove}}
\newcommand{\mustVerify}[1]{\ensuremath{\mustVerifyKW(#1)}}
\newcommand{\proves}[2]{\ensuremath{#1 \vdash #2}}
\newcommand{\lamvars}[1]{\mathsf{lams}(#1)}
\newcommand{\UnAssume}[1]{\ensuremath{\lfloor #1 \rfloor}}
\newcommand{\FEnv}[1]{\ensuremath{\Gamma(#1)}}
\newcommand{\Facts}[1]{\ensuremath{\mathsf{Facts}(#1)}}


\begin{figure}[t]
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l @@{} r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Assume:}
  \rulename{asm-hnf} & |assume hnf|         & \movesto & |hnf|                    & \\
  \rulename{asm-seq} & |assume (e_1; e_2)|  & \movesto & |assume e_1; assume e_2| & \\
  \rulename{asm-exi} & |assume (def x e)|   & \movesto & |def x (assume e)|       & \\
  % \rulename{asm-cas} & |verify (E^[assume (e_1 choice e_2)])| & \movesto & \multicolumn{2}{@@{}l}{|verify (E^[assume e_1]) ; verify (E^[assume e_2])|}  \\
  \rulename{asm-cas} & |verify (E^[assume (e_1 choice e_2)])| & \movesto & |verify (E^[assume e_1]);| & \\
                     &                                        &          & |verify (E^[assume e_2])|  \\
  \rulename{asm-id}  & |assume (assume e)|  & \movesto & |assume e|               & \\
  \rulename{asm-suc} & |assume (succeed e)| & \movesto & |assume e|               & \\
  \rulename{asm-dec} & |assume (decide e)|  & \movesto & |assume e|               & \\
  \rulename{asm-ver} & |assume (verify e)|  & \movesto & |tup ()|                 & \\
\\[-0.6em]

\rulegroupname{Succeed/Decide:}
  \rulename{suc-elim}   & |succeed e|     & \movesto & |e|      & \text{if}\ $\mustSucceed{e}$ \\
  \rulename{dec-elim}   & |P^[decide e]|  & \movesto & |P^[e]|  & \text{if}\ $\mustDecide{P}{e}$ \\
  \rulename{prove-elim} & |verify e|      & \movesto & e        & \text{if}\ $e$\ \text{has no}\ |succeedKW|, |decideKW| \\
\\[-0.6em]

\rulegroupname{Prove:}
  \rulename{asm-intro}  & |P^[e]|                          & \movesto & |P^[assume e]|                  & \text{if}\ \proves{P}{e} \\ %\ \text{and}\ $e \not \equiv$ |assume e'|\\
  \rulename{asm-if}     & |verify (P^[myite e_1 e_2 e_3])| & \movesto & |verify (P^[assume e_1; e_2]);| & \text{if}\ \mustDecide{P}{e_1} \\
                        &                                  &          & |verify (P^[e_3])|              & \\
\end{array}\\
\end{array}$
\\[0.1in]
$\begin{array}{l}
  \begin{array}{lr@@{\;}c@@{\;}l}
  \text{Prove contexts} & P & ::= & \hole \vb |v == P| \vb |P ; e| \vb |e; P| \vb |def x P| \vb |lam x P| \vb |apply1N P e| \vb |apply1N e P| \\
                        &   & \vb & |one P| \vb |all P| \vb |P choice e| \vb |e choice P| \\
                        &   & \vb & |myite P e e| \vb |succeed P| \vb |verify P| \\
  \end{array}\\
\end{array}$
\\[0.1in]
\caption{TRS Verifier Rewrite Rules}
\label{fig:verifier-rewrite-rules}
\end{figure}

\begin{figure}
$\begin{array}{lcl}
  \toprule
  \mustSucceedKW & :: & e \rightarrow \{ \mathit{true}, \mathit{false} \} \\
  \midrule
   \mustSucceed{n}              & \doteq & \mathit{true} \\
   \mustSucceed{|lam x e|}      & \doteq & \mathit{true} \\
   \mustSucceed{|assume e|}     & \doteq & \mathit{true} \\
   \mustSucceed{|arr (v_1, xdots, v_n) |} & \doteq & \mustSucceed{|v_1|} \wedge \dots \wedge \mustSucceed{|v_n|} \\
   \mustSucceed{|def x e|}         & \doteq & \mustSucceed{e} \\
   \mustSucceed{|e_1; e_2|}        & \doteq & \mustSucceed{e_1} \wedge \mustSucceed{e_2} \\
   \mustSucceed{|one e|}           & \doteq & \mustSucceed{e} \\
   \mustSucceed{|all e|}           & \doteq & \mustSucceed{e} \\
   \mustSucceed{|e_1 choice e_2|}  & \doteq & \mustSucceed{e_1} \vee \mustSucceed{e_2} \\
   \mustSucceed{|e|}               & \doteq & \mathit{false} \\
   \bottomrule
\end{array}$
\caption{Definitions of the $\mustSucceedKW$ predicate used in \cref{fig:verifier-rewrite-rules}.}
\end{figure}

\begin{figure}
$\begin{array}{lcl}
  \toprule
  \mustDecideKW & :: & (P, e) \rightarrow \{ \mathit{true}, \mathit{false} \} \\
  \midrule
  \mustDecide{P}{n}                 & \doteq & \mathit{true} \\
  \mustDecide{P}{|op|}              & \doteq & \mathit{true} \\
  \mustDecide{P}{|assume e|}        & \doteq & \mathit{true} \\
  \mustDecide{P}{|arr (v_1, xdots, v_n) |} & \doteq & \mustDecide{P}{|v_1|} \wedge \dots \wedge \mustDecide{P}{|v_n|} \\
  \mustDecide{P}{x}                 & \doteq & x \in \lamvars{P} \\
  \mustDecide{P}{|one e|}           & \doteq & \mustDecide{P}{e} \\
  \mustDecide{P}{|all e|}           & \doteq & \mustDecide{P}{e} \\
  \mustDecide{P}{|e_1 = e_2|}       & \doteq & \mustDecide{P}{e_1} \wedge \mustDecide{P}{e_2} \\
  \mustDecide{P}{|e_1; e_2|}        & \doteq & \mustDecide{P}{e_1} \wedge \mustDecide{P}{e_2} \\
  \mustDecide{P}{|e_1 choice e_2|}  & \doteq & \mustDecide{P}{e_1} \wedge \mustDecide{P}{e_2} \\
  \mustDecide{P}{|apply1N op e|}    & \doteq & \mustDecide{P}{e} \\
  \mustDecide{P}{|e|}               & \doteq & \mathit{false} \\
  \bottomrule
\end{array}$
\caption{Definitions of the $\mustDecideKW$ predicates used in \cref{fig:verifier-rewrite-rules}.}
\end{figure}

