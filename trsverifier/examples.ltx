\section{Examples}


$$\begin{array}{ll}
|f^(x:int) :== x+1|                                                           & \text{\# pass} \\
|f^(x:int) :== x+1; apply1 f 42|                                              & \text{\# pass} \\
|f^(x:int) :== x+1; apply1 f (arr ())|                                        & \text{\# fail} \\
|f^(x):int :== myite ((apply1 int x)) (x + 1) 0|                              & \text{\# pass} \\
|f^(n):int :== myite (0 < n) (n + (apply1 f (n-1))) 0|                        & \text{\# pass} \\
|f^(x:int) :== {x + 1}; g^(h^(z:int):int):int :== {h^(3)}; g^(f)|             & \text{\# pass} \\
|t^(x:int)(eff decides) :== {x = 666 choice x = 42}; f^(z:t):t :== {708 - z}| & \text{\# pass} \\
\end{array}$$

\mypara{Example 0} Consider |f^(x:int):int :== x|, represented as the surface term
\begin{align*}
& |def f (f = (fndef x int (tup (succeedKW) : int) x))| \\
\intertext{Desugaring turns the definition of |f| into the verification goal}
& |def f (verify (lam y (def x (assume (apply1 int y; x = y; x); succeed (apply1 int x)))); f = v_f)| \\
\intertext{where $v_f \doteq |lam x (apply1 int x; assume (apply1 int x))|$. The above rewrites as}
& \movestoR{subst}\ \text{with}\ |x = y| \\
& |def f (verify (lam y (def x (assume (apply1 int y; x = y; y); succeed (apply1 int y)))); f = v_f)| \\
& \movestoR{asm-seq}\\
& |def f (verify (lam y (def x (assume (apply1 int y); assume(x = y); assume (y); succeed (apply1 int y)))); f = v_f)| \\
& \movestoR{asm-intro}\\
& |def f (verify (lam y (def x (assume (apply1 int y); assume(x = y); assume (y); succeed (assume (apply1 int y))))); f = v_f)| \\
& \movestoR{suc-elim}\\
& |def f (verify (lam y (def x (assume (apply1 int y); assume(x = y); assume (y); assume (apply1 int y)))); f = v_f)| \\
& \movestoR{prove-elim}\\
& |def f (arr (); f = v_f)| \\
\intertext{at which point the verifier is done and accepts the program.}
\end{align*}

\mypara{Example 1: Unification} Consider the following surface term
$$ |def f (f = (functionKW (x:int,y:int,z:int where x=y)(tup (succeedKW)) { def (a, b) (a = x; b = a; b = y) }))| $$
which desugars to the core expression
$$ |def f (verify (lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (def (a, b) (a = x; b = a; b = y) ))); f = xdots)| $$
where we elide the actual $\lambda$-term defining |f| for brevity. The |verify ()| block corresponds to checking the
body of |f| under the input types and rewrites as
\begin{align*}
& |verify(lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (def (a, b) (a = x; b = a; b = y))))| \\
& \movestoR{subst}\ \text{with}\ |x = y| \\
& |verify(lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (def (a, b) (a = y; b = a; b = y))))| \\
& \movestoR{subst}\ \text{with}\ |a = y| \\
& |verify(lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (def (a, b) (a = y; b = y; b = y))))| \\
& \movestoR{exi-elim}\ \text{the variable}\ |a| \\
& |verify(lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (def b (b = y; b = y))))| \\
& \movestoR{subst}\ \text{with}\ |b = y| \\
& |verify(lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (def b (b = y; y = y))))| \\
& \movestoR{exi-elim}\ \text{the variable}\ |b| \\
& |verify(lam (x,y,z) (assume (apply1 int x; apply1 int y; apply1 int z; x=y) ; succeed (y = y)))| \\
& \movestoR{asm-seq}\\
& |verify(lam (x,y,z) (assume (apply1 int x); assume(apply1 int y); assume(apply1 int z); assume(x=y) ; succeed (y = y)))| \\
& \movestoR{asm-intro}\ \text{using}\ |assume (apply1 int y)| \\
& |verify(lam (x,y,z) (assume (apply1 int x); assume(apply1 int y); assume(apply1 int z); assume(x=y) ; succeed (assume(y = y))))| \\
& \movestoR{suc-elim} \\
& |verify(lam (x,y,z) (assume (apply1 int x); assume(apply1 int y); assume(apply1 int z); assume(x=y) ; assume(y = y)))| \\
& \movestoR{prove-elim} \\
& |arr ()|
\end{align*}

\mypara{Primitive Operators}
%
In the sequel, we assume that the infix names |+| and |-| are bound to the following core expressions,
which test that that the inputs are |int| before invoking the respective primitive arithmetic operations
|plus| and |minus|.
%
\begin{align*}
|(+)| & \doteq\ |(lam p (def (a, b) ( p = tup (a, b); apply1 int a; apply1 int b; assume (def r (r = a plus b; apply1 int r)))))| \\
|(-)| & \doteq\ |(lam p (def (a, b) ( p = tup (a, b); apply1 int a; apply1 int b; assume (def r (r = a minus b; apply1 int r)))))| \\
\end{align*}

\mypara{Example 2: Primitive Operations} Consider |f^(x:int) :== x + 1|, represented as the surface term
%
\begin{align*}
& |def f (f = (fndef x int (tup (succeedKW)) (x + 1)))|
\intertext{Desugaring turns the definition of |f| into the verification goal}
& |def f (verify (lam y (def x (assume (apply1 int y; x = y; x); succeed (x + 1)))); f = v_f)| \\
\intertext{where $v_f \doteq |lam x (apply1 int x; x + 1)|$. The above rewrites as}
& |def f (verify (lam y (def x (assume (apply1 int y; x = y; x); succeed (apply1 int x; apply1 int 1; assume (def r (xdots; apply1 int r)))))); f = v_f)| \\
& \movestoR{subst}    \\
& |def f (verify (lam y (def x (assume (apply1 int y; x = y; y); succeed (apply1 int y; apply1 int 1; assume (def r (xdots; apply1 int r)))))); f = v_f)| \\
& \movestoR{eqn-elim} \\
& |def f (verify (lam y (assume (apply1 int y; y); succeed (apply1 int y; apply1 int 1; assume (def r (xdots; apply1 int r))))); f = v_f)| \\
& \movestoR{asm-seq + seq-assoc} \\
& |def f (verify (lam y (assume (apply1 int y; assume y; succeed (apply1 int y; apply1 int 1; assume (def r (xdots; apply1 int r)))))); f = v_f)| \\
& \movestoR{asm-intro} \\
& |def f (verify (lam y (assume (apply1 int y; assume y; succeed (assume (apply1 int y); apply1 int 1; assume (def r (xdots; apply1 int r)))))); f = v_f)| \\
& \movestoR{app-int} \\
& |def f (verify (lam y (assume (apply1 int y; assume y; succeed (assume (apply1 int y); 1; assume (def r (xdots; apply1 int r)))))); f = v_f)| \\
& \movestoR{suc-elim} \\
& |def f (verify (lam y (assume (apply1 int y; assume y; assume (apply1 int y); 1; assume (def r (xdots; apply1 int r))))); f = v_f)| \\
& \movestoR{prove-elim} \\
& |def f (arr (); f = v_f)|
\end{align*}

\mypara{Example 3: Verifying Applications} Next, consider |f^(x:int) :== {x + 1}; f^(42)|. This is represented as the surface term
%
\begin{align*}
& |def f (f = (fndef x int (tup (succeedKW)) (x + 1)); apply1 f 42)| \\
\intertext{which desugars into the below where the |verify (xdots)| is the same as above}
& |def f (verify (xdots); f = (lam x (apply1 int x; (x + 1))); succeed (apply1 f 42))| \\
& \movesto^{*} \text{many steps as in the previous example} \\
& |def f (arr(); f = (lam x (apply1 int x; (x + 1))); succeed (apply1 f 42))| \\
& \movestoR{val-elim} \\
& |def f (f = (lam x (apply1 int x; x + 1)); succeed (apply1 f 42))| \\
& \movestoR{app-beta + subst + eqn-elim} \\
& |succeed (apply1 int 42; 42 + 1)| \\
& \movestoR{app-beta} \\
& |succeed (apply1 int 42; apply1 int 42; apply1 int 1; 42 plus 1)| \\
& \movestoR{app-int} \\
& |succeed (42; 42; 1; 42 plus 1)| \\
& \movestoR{val-elim} \\
& |succeed (42 plus 1)| \\
& \movestoR{app-plus} \\
& |succeed (43)| \\
& \movestoR{suc-elim}\\
& |43|
\end{align*}

\mypara{Example 3: Ill-typed application} Consider |f^(x:int) :== {x + 1}; f^(arr ())|, with the surface representation
%
\begin{align*}
& |def f (f = (fndef x int (tup (succeedKW)) (x+1)); f^(arr ()))| \\
\intertext{which desugars into the below where the |verify (xdots)| is the same as above}
& |def f (verify (xdots); f = (lam x (apply1 int x; x + 1)); succeed (apply1 f (arr())))| \\
& \movesto^{*} \text{as before} \\
& |succeed (apply1 int (arr()); arr() + 1)| \\
& \movestoR{app-int} \\
& |succeed (fail; xdots)| \\
& \movestoR{fail-elim} \\
& |succeed (fail)|
\end{align*}
%
The (final) normal form has a \emph{residual} obligation |succeed (xdots)|,
so the verifier rejects the ill-typed program.

\mypara{Example 4: HOFs and residual checks} see
%
% https://epicgames.slack.com/archives/C045HLE7T2N/p1690548481495029?thread_ts=1689879022.328029&cid=C045HLE7T2N
%
Consider |f(g(x:int):int) := g(10)|. Let
\begin{align}
e \doteq\ & |verify(lam x (assume(int[x]); succeed (def y (y = g'[x]; int[y]; y))));| \notag \\
          & |g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y)))| \notag \\
\intertext{the surface representation for |f| desugars to the core}
& |def f (verify (lam g' (def g (assume e; succeed (g[10])))); f = lam g' (def g (e; assume (g[10]))); f)| \label{eq:hof:1} \\
\end{align}
%
The |verify| block |lam g' (def g (assume e; succeed (g[10])))|, after expanding the definition of |e|
and using \rulename{asm-seq} rewrites as
%
$$\begin{array}{ll}
           & |lam g' (def g ())| \\
           & \quad |assume(verify(lam x (assume(int[x]); succeed (def y (y = g'[x]; int[y]; y)))));| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |succeed(g[10])| \\
%
& \movestoR{asm-ver} \\
%
           & |lam g' (def g ())| \\
           & \quad |arr();| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |succeed(g[10])| \\
%
& \movestoR{elim-val} \\
%
           & |lam g' (def g ())| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |succeed(g[10])| \\
&{\movestoR{subst + app-beta}} \\
%
           & |lam g' (def g ())| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |succeed(int[10]; assume (def y (y = g'[10]; int[y]; y)))| \\
%
& \movestoR{app-int} \\
%
           & |lam g' (def g ())| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |succeed(10; assume (def y (y = g'[10]; int[y]; y)))| \\
%
& \movestoR{elim-val} \\
%
           & |lam g' (def g ())| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |succeed(assume (def y (y = g'[10]; int[y]; y)))| \\
%
& \movestoR{suc-elim} \\
%
           & |lam g' (def g ())| \\
           & \quad |assume(g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y))));| \\
           & \quad |assume (def y (y = g'[10]; int[y]; y))| \\
%
& \movestoR{prove-elim} \\
%
           & |arr()| \\
%
\end{array}$$
Thus, via the above steps, (\ref{eq:hof:1}) rewrites to
%
\begin{align*}
%
& |def f (arr(); f = lam g' (def g (e; assume (g[10]))); f)| \\
%
& \movestoR{elim-val} \\
%
& |def f (f = lam g' (def g (e; assume (g[10]))); f)| \\
%
& \movestoR{subst + exi-elim}  \\
%
& |lam g' (def g (e; assume (g[10])))| \\
%
\intertext{expanding the definition of |e|} \\
%
& |lam g' (def g ())| \\
& \quad |verify(lam x (assume(int[x]); succeed (def y (y = g'[x]; int[y]; y))));| \\
& \quad |g = lam x (int[x]; assume(def y (y = g'[x]; int[y]; y)));| \\
& \quad |assume(g[10])|
\intertext{which contains a |succeedKW| but in a  |verify| that
is under a $\lambda$, so the verifier accepts the program.}
\end{align*}
%

