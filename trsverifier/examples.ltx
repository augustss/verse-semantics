\section{Examples}

$$\begin{array}{ll}
|f^(x:int) :== x+1|                           & \text{\# pass} \\
|f^(x:int) :== x+1; f^(42)|                   & \text{\# pass} \\
|f^(x:int) :== x+1; f^(arr (4,2))|            & \text{\# fail} \\
|f^(x):int :== myite (int^[x]) (x + 1) 0|     & \text{\# pass} \\
|f^(n):int :== myite (0 < n) (n + f^(n-1)) 0| & \text{\# pass} \\
|f^(x:int) :== {x + 1}; g^(h^(z:int):int):int :== {h^(3)}; g^(f)| & \text{\# pass} \\
|t^(x:int)(eff decides) :== {x = 666 choice x = 42}; f^(z:t):t :== {708 - z}| & \text{\# pass} \\
\end{array}$$

\mypara{Example 1} Consider the surface level function definition
%
\begin{align*}
& |f^(x:int) :== x+1|
\intertext{Desugaring turns the definition of |f| into the verification goal}
& |verify (lam y (def x (assume (int^(y); x = y; x); succeed (int^(x); int^(1); assume (def r (int^(r)))))))| \\
% \intertext{which now rewrites via the sequence of steps}
& \movestoR{subst}    \\
& |verify (lam y (def x (assume (int^(y); x = y; y); succeed (int^(y); int^(1); assume (def r (int^(r)))))))| \\
& \movestoR{eqn-elim} \\
& |verify (lam y (assume (int^(y); y); succeed (int^(y); int^(1); assume (def r (int^(r))))))| \\
& \movestoR{asm-seq + seq-assoc} \\
& |verify (lam y (assume (int^(y); assume y; succeed (int^(y); int^(1); assume (def r (int^(r)))))))| \\
& \movestoR{asm-intro} \\
& |verify (lam y (assume (int^(y); assume y; succeed (assume (int^(y)); int^(1); assume (def r (int^(r)))))))| \\
& \movestoR{app-int} \\
& |verify (lam y (assume (int^(y); assume y; succeed (assume (int^(y)); 1; assume (def r (int^(r)))))))| \\
& \movestoR{suc-elim} \\
& |verify (lam y (assume (int^(y); assume y; assume (int^(y)); 1; assume (def r (int^(r))))))| \\
& \movestoR{prove-elim} \\
& |arr ()|
\end{align*}


