\begin{figure}
$$
\begin{array}{l}
\textbf{Sequences} \\
\begin{array}{r@@{\;}c@@{\;}ll}
  |[e_1,xdots,e_n]| & : & \seq{A} & \text{Sequence of items} \\
  |[e || x_1 <- e_1, x_2 <- e_2, xdots]| & : & \seq{A} & \text{Sequence comprehension} \\
  |++| & : & \seq{A} \rightarrow \seq{A} \rightarrow \seq{A} & \text{Sequence concatenation} \\
  \concat & : & \seq{\seq{A}} \rightarrow \seq{A} & \text{Sequence concatenation} \\
\end{array}\\
\\

\textbf{Sets} \\
\begin{array}{r@@{\;}c@@{\;}ll}
  \unionListE & : & \seq{\powerset{A}} \rightarrow \powerset{A} \\
  \unionListE(ss) & = & \text{set-union of elements of $ss$} \\
  \squashE & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  \squashE(ss) & = & [ s \vb s |<-| ss, s \not= \{ \} ] \\
  \squashTailE & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  \squashTailE(xs) & = & xs \text{ with trailing \{\} removed} \\[1mm]
  \pickE & : & \seq{\powerset{A}} \rightarrow \powersetnp{\seq{A}} & \text{Pick one from each set} \\
  \pickE[s_0, \mydots, s_n] & = & [ [v_0, \mydots, v_n]  \vb \forall 0 \leq i \leq n.\; v_i \in s_i ] \\
\text{or} \\
  \pickE( [] ) & = & \{ [] \} \\
  \pickE(s:ss) & = & \{\; x:xs \vb x \in s, xs \in \flatten(ss)\; \} \\[1mm]

\\[1mm]
  \headE & : & [\powerset{A}] \rightarrow \powerset{A} \\
  \headE[] & = & \{ \} \\
  \headE(s:\_) & = & s \\[1mm]
  \seqE & : & \powerset{A} \rightarrow \powerset{A} \rightarrow \powerset{A} \\
  s_1 \seqE s_2 & = & \{ a_2 \vb a_1 \in s_1, a_2 \in s_2 \} \\
    & = & \textbf{if} \, (s_1 = \{\}) \, \textbf{then} \, \{\} \, \textbf{else} \, s_2 \\[1mm]
  \prodsingleE & : & \powerset{A} \rightarrow \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  \EV \prodsingleE s_2 & = & [\; \EV \cap \EV_2 \vb \EV_2 |<-| s_2 \; ] \\[1mm]
  \prodE & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  s_1 \prodE s_2 & = & [\; \EV_1 \cap \EV_2 \vb \EV_1 |<-| s_1, \EV_2 |<-| s_2 \; ] \\[1mm]
  \dodgyunion & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \rightarrow \seq{\powerset{A}}
            & \text{``Dodgy union''} \\
  |[x_1,xdots,x_n]| \hat{\cup} |[y_1,xdots,y_n]| & = & |[x_1 `cup` y_1,xdots,x_n `cup` y_n]|
            & \text{Right-padding shorter sequence with \mempty} \\[2mm]

  \hat{\bigcup} & : & \powersetnp{\seq{\powerset{A}}} \rightarrow \seq{\powerset{A}}
                          & \hat{\cup} \text{ extended to sets}\\
  \hat{\bigcup} & = & \cdots \\[2mm]
\end{array}
\end{array}
$$
\caption{Sets and sequences}\label{fig:densem-sets-and-seqs}
\end{figure}


% --------------------- ENV and functions over ENV -----------------

\begin{figure}
$$
\begin{array}{l}

\textbf{Domains}\\
\begin{array}{rl@@{\;\;}c@@{\;\;}ll}
  v \in & \Value & = & \Z + \Fun \\\
  Fun(|fs|) \in & \Fun & = & \seq{\semfcn}  & \text{A \emph{finite} sequence of partial functions} \\
  &&&& \hspace{3mm} \text{with disjoint domains} \\
  \rho \in & \Env & = & \Ident \rightarrow \Value  & \text{Gives a value all identifiers} \\
  \EV \in &\ENV & = & \powerset{ \Env } \\
  \{ \fpr{x_1}{y_1}, \mydots, \fpr{x_n}{y_n} \} \in & \semfcn & = & \powerset{ \Val \times \Val }
  & \text{Partial functions} \\
\end{array} \\
\\
\textbf{The constraint language}\\
\begin{array}{l@@{\;\;}rc@@{\;\;}ll}
  \text{Simple values}    & a & ::= & |k| \vb |x| \vb |o| \vb |arr (a_0, xdots, a_n)| \vb |truth a|
    & \text{Can add strings, floats...} \\
  \text{Constraints} &  \EV & ::= & \conBrack{a_1 = a_2} \\
  & & \vb & \conBrack{op[a_1,\mydots,a_n]} \\
  &  & \vb & \conBrack{ \conFun{a_{arg}}{a_{res}}{a_{fun}}{i}{n}}  \\
  &  & \vb & \conEmpty \vb \conUniv \vb \EV_1 \cup \EV_2 \vb \EV_1 \cap \EV_2 \\
  &  & \vb & \conCompl(\EV)  & \text{Complement} \\
  &  & \vb & \HIDE{\EV}{xs} & \text{Hiding} \\
\text{Operators}&  op & ::= & < \vb \leq \vb \geq \vb > \vb + \vb - \vb * \vb / \vb
\end{array}\\
\\[-1mm]
\textbf{Interpretation of simple values and constraints}\\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
  \sembrack{\EV} & : & \ENV \\
  \sembrack{\conEmpty} & = & \{\} \\
  \sembrack{\conUniv} & = & \Env   & \text{Set of all environments} \\
  \sembrack{\conCompl(\EV)} & = & \complE( \sembrack{\EV} )\\
  \sembrack{\HIDE{\EV}{xs}} & = & \{ \rho \in \Env \vb \exists \rho' \in \sembrack{\EV} .\, \forall x \not\in xs.\, \rho(x) =  \rho'(x) \} \\
  \sembrack{\EV_1 \cup \EV_2} & = & \sembrack{\EV_1} \cup \sembrack{\EV_2} \\
  \sembrack{\EV_1 \cap \EV_2} & = & \sembrack{\EV_1} \cap \sembrack{\EV_2} \\
  \sembrack{\conBrack{a_1=a_2}} & = & \{ \rho \in \Env \vb \semapp{A}{a_1}\rho = \semapp{A}{a_2}\rho \} \\
  \sembrack{\conBrack{a_1>a_2}} & = & \{ \rho \in \Env \vb \semapp{A}{a_1}\rho > \semapp{A}{a_2}\rho \} \\
  \sembrack{\conBrack{\conFun{a_a}{a_r}{a_f}{i}{n}}}
  & = & \multicolumn{2}{@@{}l}
           {\{ \rho \in \Env \vb \semapp{A}{a_f}{\rho} = Fun[h_1,\mydots,h_n],
                \fpr{\semapp{A}{a_a}\rho}{\semapp{A}{a_r}\rho} \in h_i \}}\\[1mm]
\semapp{A}{|a|} & : & \Env \rightarrow \Val \\
\semapp{A}{|x|}\rho & = & \rho(x) \\
\semapp{A}{|k|}\rho & = & k \\
\semapp{A}{|o|}\rho & = & \semap{O}{o} \\
\semapp{A}{|truth a|}\rho & = &  FUN [ \fpr{v}{v} ] \hspace{5mm} \text{where $v = \semapp{A}{a}\rho$} \\
\semapp{A}{|arr (a_0, xdots, a_n)|}\rho & = & \tupE [ \semapp{A}{a_0}\rho, \mydots, \semapp{A}{a_n}\rho ] \\[1mm]
\semap{O}{|o|} & : & \Val \\
 \semap{O}{|<=|} & = & \Fun[\,\{ \fpr{\tupE(x,y)}{x} \vb x \in \Z, y \in \Z, x \leq y \}\,] \\[1mm]
\end{array}\\
\\[-1mm]
\textbf{Semantic functions} \\

\begin{array}{lr@@{\;\;}c@@{\;\;}l}
\text{Binders of block} & \semap{I}{|t|} & : & \powerset{\Ident} \\
&  \semap{I}{|t|} & = & \text{the outer $\exists$-bound variables in |t|} \\[1mm]

\text{Tuple values} &  \tupE & : & [\Val] \rightarrow \Val \\
&  \tupE [v_0,\mydots,v_n] & = & Fun [\{ \fpr{i}{v_i} \} \vb i \in 0 \mycdots n ] \\[1mm]
% \text{Extract result} & \extractE & : & \Ident \rightarrow \ENV \rightarrow \powerset{\Val, \ENV} \\
% & \extractE(r,\EV) & = & \{ (v, \hideE(r, \EV'))
%                      \vb v \in \Val, \EV' = \{ \rho \in \EV \vb \rho(r)=v \} \} \\[1mm]
\end{array} \\

\end{array}
$$
\caption{Semantic domains and associated functions}\label{fig:densem-notation}
\end{figure}

