\begin{figure}
$$
\begin{array}{l}
\textbf{Sequences} \\
\begin{array}{r@@{\;}c@@{\;}ll}
  |[e_1,xdots,e_n]| & : & \seq{A} & \text{Sequence of items} \\
  |[e || x_1 <- e_1, x_2 <- e_2, xdots]| & : & \seq{A} & \text{Sequence comprehension} \\
  |++| & : & \seq{A} \rightarrow \seq{A} \rightarrow \seq{A} & \text{Sequence concatenation} \\[2mm]
\end{array}\\
\\

\textbf{Sets} \\
\begin{array}{r@@{\;}c@@{\;}ll}
  \unionListE & : & \seq{\powerset{A}} \rightarrow \powerset{A} \\
  \unionListE(ss) & = & \text{set-union of elements of $ss$} \\
  \squashE & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  \squashE(ss) & = & [ s \vb s |<-| ss, s \not= \{ \} ] \\
  \squashTailE & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  \squashTailE(xs) & = & xs \text{ with trailing \{\} removed} \\[1mm]
  \pickE & : & [\powerset{A}] \rightarrow \powersetnp{[A]} \\
  \pickE[s_0, \mydots, s_n] & = & [ [v_0, \mydots, v_n]  \vb \forall 0 \leq i \leq n.\; v_i \in s_i ] \\[1mm]
  \headE & : & [\powerset{A}] \rightarrow \powerset{A} \\
  \headE[] & = & \{ \} \\
  \headE(s:\_) & = & s \\[1mm]

  \seqE & : & \powerset{A} \rightarrow \powerset{A} \rightarrow \powerset{A} \\
  s_1 \seqE s_2 & = & \{ a_2 \vb a_1 \in s_1, a_2 \in s_2 \} \\
    & = & \textbf{if} \, (s_1 = \{\}) \, \textbf{then} \, \{\} \, \textbf{else} \, s_2 \\[1mm]
  \prodE & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \\
  s_1 \prodE s_2 & = & [\; \EV_1 \cap \EV_2 \vb \EV_1 |<-| s_1, \EV_2 |<-| s_2 \; ] \\[1mm]
  \dodgyunion & : & \seq{\powerset{A}} \rightarrow \seq{\powerset{A}} \rightarrow \seq{\powerset{A}}
            & \text{``Dodgy union''} \\
  |[x_1,xdots,x_n]| \hat{\cup} |[y_1,xdots,y_n]| & = & |[x_1 `cup` y_1,xdots,x_n `cup` y_n]|
            & \text{Right-padding shorter sequence with \mempty} \\[2mm]

  \hat{\bigcup} & : & \powersetnp{\seq{\powerset{A}}} \rightarrow \seq{\powerset{A}}
                          & \hat{\cup} \text{ extended to sets}\\
  \hat{\bigcup} & = & \cdots \\[2mm]
\end{array}
\end{array}
$$
\caption{Sets and sequences}\label{fig:densem-sets-and-seqs}
\end{figure}


% --------------------- ENV and functions over ENV -----------------

\begin{figure}
$$
\begin{array}{l}

\textbf{Domains}\\
\begin{array}{rl@@{\;\;}c@@{\;\;}ll}
  v \in & \Value & = & \Z + \Fun \\\
  s \in & \VAL & = & \powerset{\Value} \\
  Fun(|fs|) \in & \Fun & = & \seq{\semfcn}  & \text{A sequence of partial functions} \\
  &&&& \hspace{3mm} \text{with disjoint domains} \\
  \rho \in & \Env & = & \parfun{\Ident}{\Value}  & \text{Gives a value for \emph{in-scope} identifiers} \\
  \EV \in &\ENV & = & \powerset{ \Env } \\
  \{ \fpr{x_1}{y_1}, \ldots, \fpr{x_n}{y_n} \} \in & \semfcn & = & \powerset{ \Val \times \Val }
  & \text{Partial functions} \\
\end{array} \\
\\
\textbf{Semantic functions} \\

\begin{array}{lr@@{\;\;}c@@{\;\;}l}
\text{Simple values} &  \semapp{A}{|a|} & : & \Env \rightarrow \Val \\
&  \semapp{A}{|x|}\rho & = & \rho(x) \\
&  \semapp{A}{|k|}\rho & = & k \\
&  \semapp{A}{|o|}\rho & = & \semap{O}{o} \\
&  \semapp{A}{|truth a|}\rho & = &  FUN [ \fpr{v}{v} ] \hspace{5mm} \text{where $v = \semapp{A}{a}\rho$} \\
&  \semapp{A}{|arr (a_0, xdots, a_n)|}\rho & = & \tupE [ \semapp{A}{a_0}\rho, \mydots, \semapp{A}{a_n}\rho ] \\
\\
\text{Primitive ops} &   \semap{O}{|o|} & : & \Val \\
&   \semap{O}{|<=|} & = & \Fun[\,\{ \fpr{\tupE(x,y)}{x} \vb x \in \Z, y \in \Z, x \leq y \}\,] \\[1mm]

\text{Binders of block} & \semap{I}{|e|} & : & \powerset{\Ident} \\
&  \semap{I}{|e|} & = & \text{the outer $\exists$-bound variables in |e|} \\[1mm]

\text{Tuple values} &  \tupE & : & [\Val] \rightarrow \Val \\
&  \tupE [v_0,\mydots,v_n] & = & Fun [\{ \fpr{i}{v_i} \} \vb i \in 0 \mycdots n ] \\[1mm]
\text{Hiding} & \hideE & : & \powerset{\Ident + \RES} \rightarrow \ENV \rightarrow \ENV \\
& \hideE(xs, \EV) & = & \{ \rho \in \Env \vb \exists \rho' \in \Delta .\, \forall x \not\in xs.\, \rho(x) =  \rho'(x) \} \\
 & \hideEs & : & \powerset{\Ident + \RES} \rightarrow \seq{\ENV} \rightarrow \seq{\ENV} \\
& \hideEs(xs, s) & = & [\; \hideE(xs,\EV) \vb \EV \in s \; ]\\[1mm]

\text{Extract result} & \extractE & : & \ENV \rightarrow \powerset{\Val, \ENV} \\
& \extractE(\EV) & = & \{ (v, \hideE(\RES, \EV'))
                      \vb v \in \Val, \EV' = \{ \rho \in \EV \vb \rho(\RES)=v \} \} \\[1mm]
\end{array} \\
\\
\textbf{The constraint language}\\
\begin{array}{l@@{\;\;}c@@{\;\;}ll}
  \EV & ::= & \conBrack{\conEq{x}{a}} \\
  & \vb & \conBrack{ \conFun{a_{arg}}{a_{res}}{a_{fun}}{i}}  \\
  & \vb & \conEmpty \vb \conUniv \\
  & \vb & \EV_1 \cup \EV_2 \vb \EV_1 \cap \EV_2 \vb \conCompl(\EV)
\end{array}\\
\\
\textbf{Interpretation of constraints}\\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
  \sembrack{\EV} & : & \ENV \\
  \sembrack{\conEmpty} & = & \{\} \\
  \sembrack{\conUniv} & = & \Env   & \text{Set of all environments} \\
  \sembrack{\conCompl(\EV)} & = & \{ \rho \in \Env \vb \rho \not\in \EV \} \\
  \sembrack{\EV_1 \cup \EV_2} & = & \sembrack{\EV_1} \cup \sembrack{\EV_2} \\
  \sembrack{\EV_1 \cap \EV_2} & = & \sembrack{\EV_1} \cap \sembrack{\EV_2} \\
  \sembrack{\conBrack{\conEq{x}{a}}} & = & \{ \rho \in \Env \vb \rho(x) = \semapp{A}{a}\rho \} \\
  \sembrack{\conBrack{\conFun{a_a}{a_r}{a_f}{i}}}
  & = & \multicolumn{2}{@@{}l}
           {\{ \rho \in \Env \vb \semapp{A}{a_f}{\rho} = Fun(hs),
                \fpr{\semapp{A}{a_a}\rho}{\semapp{A}{a_r}\rho} \in hs[i] \}}
\end{array}\\

\end{array}
$$
\caption{Domains and their function}\label{fig:env}
\end{figure}

