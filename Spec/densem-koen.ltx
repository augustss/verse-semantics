$$
% ------------- Syntax of DPS Verse ---------------
\begin{array}{l}
\textbf{Syntax of DPS Verse} \\
\begin{array}{lr@@{\;\;}c@@{\;\;}l}
  \text{Ops} & op & ::= & |x == y| \vb |x == k| \vb |x == arr (x_1, xdots, x_n)| \vb |x = truth y|
               \\
  && \vb & |op_1; op_2| \vb |op_1 `choice` op_2| \vb |fail| \vb |defintro x| \vb |scope op| \\
  && \vb & |x == dpslam x op_1 op_2 y|  \vb |x == apply1N f y|
           \vb |x == apply1N op_1 y| \vb |x == apply1N op_2 (y_1,y_2)| \\
  && \vb & |if3 op_1 op_2 op_3| \vb |x == dpsall x op y|
\end{array} \\
\\

\textbf{Translating Mini Verse to DPS Verse} \\
\text{In all these equations, a ``|defintro x|'' on the RHS implies ``fresh x''.} \\
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}
\rulename{dpsv} & |DpsT x r| & = & |r = x| \\
\rulename{dpsk} & |DpsT k r| & = & |r = k| \\
\rulename{dpsop1} & |DpsT (apply1N o_1 e) r|
  & = & |defintro x; DpsT e x; r = apply1N o_1 x| \\
\rulename{dpsop2} & |DpsT (apply1N o_2 (e_1, e_2)) r|
  & = & |defintro (x,y); DpsT e_1 x; DpsT e_2 y; r = apply1N o_2 (x,y)| \\
\rulename{dpsapp} & |DpsT (apply1N e_1 e_2) r| & = & |defintro (f,x); DpsT e_1 f; DpsT e_2 x; r = apply1N f x| \\
\rulename{dpsseq} & |DpsT (e_1 ; e_2) r| & = & |defintro s; DpsT e_1 s; DpsT e_2 r| & \text{Discards s}\\
\rulename{dpsseq} & |DpsT (e_1 == e_2) r| & = & |DpsT e_1 r; DpsT e_2 r| & \text{Push r into both} \\
\rulename{dpschoice} & |DpsT (e_1 `choice` e_2) r| & = & |DpsT e_1 r `choice` DpsT e_2 r| & \text{Push r into both} \\
\rulename{dpsfail} & |DpsT fail r| & = & |fail| & \text{What about r?} \\
\rulename{dpsexists} & |DpsT (defintro x) r| & = & |defintro x|  & \text{What about r?}  \\
\rulename{dpslam} & |DpsT (lamOC q x e_1 e_2) r| & = & |r = dpslam x (defintro y; DpsT e_1 y) (DpsT e_2 z) z| \\
\rulename{dpsarr} & |DpsT (arr (e_1, xdots, e_n)) r| & = & |defintro (r_1 xdots r_n); DpsT e_1 r_1; xdots; DpsT e_n r_n; r = arr (r_1,xdots, x_n)| \\
\rulename{dpstru} & |DpsT (truth e) r| & = & |defintro y; DpsT e y; r = truth y| \\
\rulename{dpsopq} & |DpsT (oftypefx t_1 fx t_2) r| & = & ??? \\
\rulename{dpschk} & |DpsT (check fx e) r| & = & ??? \\
\multicolumn{2}{@@{}l}{\rulename{dpsif} \;\; \hfill |DpsT (vif e_1 e_2 e_3) r|}
     & = & |if3 (defintro x; DpsT e_1 x) (DpsT e_2 r) (DpsT e_3 r)| & \text{Push r into branches}\\
\rulename{dpsall} & |DpsT (all e) r| & = & |dpsall (DpsT e y) y|  \\
\rulename{dpsfor} & |DpsT (fordo e_1 e_2) r| & = & ??? \\
\end{array}

\end{array}
$$
\caption{Translating Mini Verse to DPS Verse} \label{fig:dps-verse}
\end{figure}


\begin{figure}
$$
% ------------- Denotationals semantics of DPS Verse ---------------
\begin{array}{l}
\textbf{Domains} \\
\begin{array}{rl@@{\;\;}c@@{\;\;}ll}
  & \Val & = & \Z + \Fun \\\
  Fun(|fs|) \in & \Fun & = & \seq{\semfcn}  & \text{A sequence of partial functions} \\
  \rho \in & \Env & = & \Ident \rightarrow \Value  & \text{Gives a value for \emph{every} identifier} \\
  \EV \in &\ENV & = & \powerset{ \Env } \\
  \{ \fpr{x_1}{y_1}, \ldots, \fpr{x_n}{y_n} \} \in & \semfcn & = & \powerset{ \Val \times \Val }
        & \text{Partial functions}
\end{array} \\
\\
\textbf{Operations over ENV} \\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
  \univE & : & \ENV \\
  \univE & = & \{ \rho \in \Env \} \\[1mm]
%  (\equalsE) & : & \Ident \rightarrow \Value \rightarrow \ENV  & \text{NB: $\equalsE$ is overloaded}\\
%   x \equalsE v & = & \{ \rho \in \Env \vb \rho(x) = v \} \\[1mm]
%  (\equalsE) & : & \Ident \rightarrow \Ident \rightarrow \ENV & \text{NB: $\equalsE$ is overloaded}\\
%   x \equalsE y & = & \{ \rho \in \Env \vb \rho(x) = \rho(y) \} \\[1mm]
  \cleanE & : & [ \ENV ] \rightarrow [ \ENV ] \\
  \cleanE(es) & = & [ \EV \vb \EV \in es, \EV \not= \{\} ] \\[1mm]
  \hideE & : & [\Ident] \rightarrow \ENV \rightarrow \ENV \\
  \hideE(xs, \EV) & = & \{ \rho \in \Env \vb \exists \rho' \in \Delta .\, \forall x \not\in xs.\, \rho(x) =  \rho'(x) \} \\
\end{array} \\
\\

\textbf{Denotational semantics} \\
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}
& \semapp{E}{|e|} & : & \seq{ \ENV } \\
\rulename{edef} & \semapp{E}{|defintro x|} & = & [ \univE ] \\
\rulename{econst} &  \semapp{E}{|x=k|} & = & [  \{ \rho \in \Env \vb \rho(x) = v \} ] \\
\rulename{eeq} &  \semapp{E}{|x=y|} & = & [  \{ \rho \in \Env \vb \rho(x) = \rho(y) \} ] \\
\rulename{eop2} &  \semapp{E}{|r = apply1N o_2 (x,y)|}
   & = & [ \{ \rho \in \Env \vb \rho(x) \in \Z, \rho(y) \in \Z, r = o_2( \rho(x), \rho(y)) \} ] \\
\rulename{earr} &  \semapp{E}{|x = arr (x_0, xdots, x_n)|$$}
 & = & [ \{ \rho \in \Env \vb
     \rho(x) = Fun [\{ \fpr{i}{\rho(x_i)} \vb i \in 0 \mycdots n \}]  \\
\rulename{echoice} &  \semapp{E}{|op_1 `choice` op_2|} & = & \semapp{E}{op_1} \append \semapp{E}{op_2}  \\
\rulename{efail} &  \semapp{E}{|fail|} & = & [ ] \\
\rulename{eseq} &  \semapp{E}{|op_1 ; op_2|}
   & = &  [ \EV_1 \intersectE \EV_2 \vb \EV_1 \in \semapp{E}{op_1}, \EV_2 \in \semapp{E}{op_2} ] \\
\rulename{elam} &  \semapp{E}{|x = dpslam x op_1 op2 y|} & = & ??? \\
\rulename{eapp} & \semapp{E}{|x = apply1N f y|}
 & = & [ \{ \rho \in \Env \vb \rho(f)=Fun(hs), (\fpr{\rho(x)}{\rho(y)}) \in hs[i] \} \vb i \in 0\mydots ] \\
\multicolumn{2}{@@{}l}{\rulename{eif} \; \hfill
  \semapp{E}{|x = if3 op_1 op_2 op_3|} } & = & ??? \\
\rulename{eall} & \semapp{E}{|x = dpsall x op y|} & = & ??? \\
\\
& \semapp{B}{|op|} & : & \seq{ \ENV } \\
& \semapp{B}{|op|} & = & [ \hideE(\semapp{I}{|op|}, \EV) \vb \EV \in \semapp{E}{op} ] \\
\\
& \semap{I}{|op|} & : & [\Ident] \\
& \semap{I}{|op|} & = & \text{the outer $\exists$-bound variables in |op|} \\[1mm]

\end{array} \\

\end{array}
$$
\caption{Denotational semantics of DPS Verse} \label{fig:dps-verse-densem}
\end{figure}

