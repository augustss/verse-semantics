\begin{figure}
$$
% ------------- Syntax of DPS Verse ---------------
\begin{array}{l}
\textbf{Syntax of DPS Verse} \\
\begin{array}{lr@@{\;\;}c@@{\;\;}l}
  \text{Simple values}    & a & ::= & |x| \vb |o| \vb |k| \vb  |arr (a_0, xdots, a_n)| \vb |truth a| \hspace{5mm} \text{Can add strings, floats...} \\
  \text{Wrappings}   & |hw| & ::= & |wrapemp| \vb |y:== apply1N h x| \\
  \text{Ops} & op & ::= & |r == a| \\
  && \vb & |op_1; op_2| \vb |op_1 `choice` op_2| \vb |fail| \vb |defintro x| \vb |scope op| \\
  && \vb & |r == dpslam q fx i op_1 hw op_2 y|  \vb |r == apply1N a_1 a_2| \\
  && \vb & |if3 op_1 op_2 op_3| \vb | r == dpsone op y| \\
  && \vb & |r = dpsfor op_1 op_2 y| \vb |r == dpsall op y|
\end{array} \\
\\

\textbf{Translating Mini Verse to DPS Verse} \\
\text{In all these equations, a ``|defintro x|'' on the RHS implies ``fresh x''.} \\
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}
\rulename{dpssv} & |DpsT a r| & = & |r = a| \\
% \rulename{dpsop1} & |DpsT (apply1N o_1 e) r|
%   & = & |defintro x; DpsT e x; r = apply1N o_1 x| \\
% \rulename{dpsop2} & |DpsT (apply1N o_2 (e_1, e_2)) r|
%  & = & |defintro (x,y); DpsT e_1 x; DpsT e_2 y; r = apply1N o_2 (x,y)| \\
\rulename{dpsapp} & |DpsT (apply1N a_1 a_2) r| & = & |r = apply1N a_1 a_2| \\
\rulename{dpsseq} & |DpsT (e_1 ; e_2) r| & = & |defintro s; DpsT e_1 s; DpsT e_2 r| & \text{Discards s}\\
\rulename{dpsseq} & |DpsT (e_1 == e_2) r| & = & |DpsT e_1 r; DpsT e_2 r| & \text{Push r into both} \\
\rulename{dpschoice} & |DpsT (e_1 `choice` e_2) r| & = & |DpsT e_1 r `choice` DpsT e_2 r| & \text{Push r into both} \\
\rulename{dpsfail} & |DpsT fail r| & = & |fail| & \text{What about r?} \\
\rulename{dpsexists} & |DpsT (defintro x) r| & = & |defintro x|  & \text{What about r?}  \\
\rulename{dpslam} & |DpsT (lamH q fx i e_1 (h:== apply1N h x) e_2) r|
   & = & \multicolumn{2}{l}{|r = dpslam q fx i (DpsT e_1 y)  (y:== apply1N h x) (DpsT e_2 z) z|} \\
\multicolumn{2}{@@{}l}{\rulename{dpsif} \;\; \hfill |DpsT (vif e_1 e_2 e_3) r|}
     & = & |if3 (defintro x; DpsT e_1 x) (DpsT e_2 r) (DpsT e_3 r)| & \text{Push r into both}\\
\rulename{dpsfor} & |DpsT (fordo e_1 e_2) r| & = & |r == dpsfor (DpsT e_1 s) (DpsT e_2 y) y|  \\
\rulename{dpsall} & |DpsT (all e) r| & = & |r == dpsall (DpsT e y) y|  \\
\rulename{dpsone} & |DpsT (one e) r| & = & |r == dpsone (DpsT e y) y|  \\
\end{array}

\end{array}
$$
\caption{Translating Mini Verse to DPS Verse} \label{fig:dps-verse}
\end{figure}


