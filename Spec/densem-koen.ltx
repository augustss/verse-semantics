             \begin{array}[t]{@@{}l@@{\;}l}
               [ & \{ v \vb (v,\EV') \in \extractE(\RES,\EV), \rho \in \EV' \} \\
               \vb & \EV \in \semapsub{E}{d}{|e|} \; ])
               \end{array} \\
           , & \rho(\RES) = v \} \, ]
           \end{array} \\
\\

& \semapp{B}{|e|} & : & \seq{ \ENV } \\
& \semapp{B}{|e|} & = & [ \hideE(\semapp{I}{|e|}, \EV) \vb \EV \in \semapsub{E}{d}{e} ]
