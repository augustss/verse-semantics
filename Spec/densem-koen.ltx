% ------------- Denotational semantics of DPS Verse ---------------
\begin{array}{l}
\textbf{Domains} \\
\begin{array}{r@@{\;}l@@{\;\;}c@@{\;\;}ll}
  \rho \in & \Env & = & (\Ident + \RES) \rightarrow \Value  & \text{Gives a value for \emph{every} identifier} \\
  &&&& \hspace{3mm} \text{plus result token $\RES$}
\end{array} \\
\\
\textbf{Denotational semantics} \\
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
& \semapsub{E}{d}{|e|} & : & \seq{ \ENV } \\
\rulename{ddef} & \semapsub{E}{d}{|defintro x|} & = & [ \Env ]  \hspace{8mm} \text{All environments} \\
\rulename{datom} &  \semapsub{E}{d}{|a|} & = & [ \{ \rho \in \Env \vb \rho(\RES) = \semapp{A}{a}{\rho} \} ] \\
\rulename{dfail} &  \semapsub{E}{d}{|fail|} & = & [ ] \\
\rulename{dchoice} &  \semapsub{E}{d}{|e_1 `choice` e_2|}
 & = & \semap{B}{e_1} \append \semap{B}{e_2}  \\
\rulename{dunify} &  \semapsub{E}{d}{|e_1 == e_2|}
& = &  [ \EV_1 \intersectE \EV_2 \vb \EV_1 |<-| \semapsub{E}{d}{e_1},
          \EV_2 |<-| \semapsub{E}{d}{e_2} ] \\
\rulename{dseq} &  \semapsub{E}{d}{|e_1 ; e_2|}
& = &  [ \hideE(\RES,\EV_1) \intersectE \EV_2
       \vb \EV_1 |<-| \semapsub{E}{d}{e_1},
           \EV_2 |<-| \semapsub{E}{d}{e_2} ] \\
\rulename{dlam} &  \semapsub{E}{d}{|dpslam x e_1 e_2 y|} & = & ??? \\
\rulename{dapp} & \semapsub{E}{d}{|apply1N a_1 a_2|}
 & = & \begin{array}[t]{@@{}l@@{\;}l}
  [ & \{ \rho \in \Env \vb \semapp{A}{a_1}{\rho}=Fun(hs), (\fpr{\semapp{A}{a_2}{\rho}}{\rho(\RES)}) \in hs[i] \} \\
    |vbar| &  i |<-| 0\mydots \; ]
  \end{array} \\

%  ------ IF --------------
\multicolumn{2}{@@{}l}{\rulename{dif} \; \hfill
  \semapsub{E}{d}{|if3 e_1 e_2 e_3|} } & = & ???? \\

