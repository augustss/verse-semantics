% &&&  [ \EV_3 \setminus (\hideE(Y, \EV_1)
%       \vb \EV_3 |<-| \semapsub{E}{d}{|e_3|}] \\
% &&& |where| \begin{array}[t]{ll}
%  Y = \semap{I}{|e_1|} \\
%  \EV_1 = \firstE(Y, \semapsub{E}{d}{|e_3|}) 
%  \end{array} \\

%  ------ ALL --------------
% \rulename{dall} & \semapsub{E}{d}{|all e|}
%  & = & [ \, \{ \rho \vb  (vs,\EV) \in \combineE(\semap{B}{e}), \rho \in \EV, \rho(\RES)=\tupE(vs) \}\, ]
\rulename{dall} & \semapsub{E}{d}{|all e|}
 & = & [ \, \{ \rho \in \Env \;
           \begin{array}[t]{@@{}l@@{\;}l}
             \vb & vs \in \pickE (\squashE
             \begin{array}[t]{@@{}l@@{\;}l}
               [ & \{ v \vb (v,\EV') \in \extractE(\RES,\EV), \rho \in \EV' \} \\
               \vb & \EV \in \semapsub{E}{d}{|e|} \; ])
               \end{array} \\
           , & \rho(\RES) = \tupE(vs) \} \, ]
           \end{array} \\

%  ------ ONE --------------
\rulename{done} & \semapsub{E}{d}{|one e|}
 & = & [ \, \{ \rho \in \Env \;
           \begin{array}[t]{@@{}l@@{\;}l}
