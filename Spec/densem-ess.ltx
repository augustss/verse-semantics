    \letvar \dsplural{\EV_{0}} =
      \semapppp{Q}{t_0}{\rho}{p}{w} \\
    \letvar n = \lengthseq{\dsplural{\EV_{0}}},
    \lengthseq{H} = n,
    \lengthseq{F} = n, \\
    \forall k \inb \{0,\mydots,n-1\}.\, \forall \rho_0 \inb \dsplural{\EV_{0}}[k] . \\
    \quad \letvar \dsplural{\EV_{1}} =
      \semapppp{Q}{t_1}{\rho_0}{j}{z} \\
    \quad \lengthseq{\dsplural{\EV_{1}}} = 1 \, \land \\
    \quad \exists J \inb \Val\, . (\fpr{\rho_0(w)}{J}) \in H[k], \\
    \forall k \inb \{0,\mydots,n-1\}.\, \forall I,Z \inb \Val. \\
    \quad (\fpr{I}{Z}) \in F[k] \\
    \quad\quad \Leftrightarrow \\
    \quad ( (\exists i. \exists \rho_0 \inb \dsplural{\EV_{0}}[i]. \rho_0(p) = I) \, \land \\
    \quad \quad \forall \rho_0 \inb \dsplural{\EV_{0}}[k].\, \rho_0(p) = I \\
    \quad \quad \quad \Rightarrow \\
    \quad \quad \exists \rho_1 \inb
       % \squashE(\hideEs(\semapp{I}{|t_1|} \cup \{j,z\}, \{\rho_0\}) \prodsingleE \semess{S}{j}{z}{|t_1|})
       (\semapppp{Q}{t_1}{\rho_0}{j}{z})
            [0]. \\
    \quad \quad \quad (\fpr{\rho_1(w)}{\rho_1(j)} \in H[k] \land \rho_1(z)=Z \\
    \quad ) \\
 \} ]
  \end{array} \\
  & & & \text{where } p,w,j,z \not\in \semapp{I}{|t_0,t_1|} \\
  \\
  \\
 & \semapp{Q}{t} & : & \Env \rightarrow \Ident \rightarrow \Ident \rightarrow \seq{\ENV} \\
 & \semappppp{Q}{t}{\rho}{x}{y} & = &
 \squashE(\hideEs(\semapp{I}{|t|} \cup \{x,y\}, \{\rho\}) \prodsingleE \semess{S}{x}{y}{|t|}) \\

\end{array}
\end{array}
