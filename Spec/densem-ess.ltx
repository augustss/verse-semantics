\begin{array}{l}
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}l}
\multicolumn{3}{@@{}l}{\textbf{SL is an applicative functor}} \\
\SL{A} & = & \powersetnp{ \seq{A} } \\
\liftATwo & : & (A \rightarrow B \rightarrow C) \rightarrow \SL{A} \rightarrow \SL{B} \rightarrow\SL{C} \\
\liftATwo(OP,E_1,E_2) & = &
  \{ \; \concat(ss)
     \begin{array}[t]{@@{}l@@{\;}l}
     \vb & s_1 : \seq{A} \in E_1 \\
     , & \letvar t : \seq{\powersetnp{\seq{C}}} = [\; \mapE(OP(\EV,\_), E_2) \vb \EV |<-| s_1 \; ] \\
     , & \letvar r : \powersetnp{\seq{\seq{C}}} = \flatten(t) \\
     , & ss : \seq{\seq{C}} \in r \; \}
     \end{array} \\
     \\
 (\seqSL) & : & \SL{\ENV} \rightarrow \SL{\ENV} \rightarrow \SL{\ENV} \\
 E_1 \seqSL E_2 & = & \liftATwo(\, \cap, \, E_1, \, E_2 \, ) \\
\end{array}
\end{array}
$$
