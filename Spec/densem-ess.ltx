\begin{figure}
$$
% ------------- Denotational semantics of Essential Verse ---------------
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}

% -------- LAMBDA ------------
\multicolumn{4}{l}{\rulename{dlam}\quad \semess{S}{h}{f}{|functionOCX q t_0 fx t_1|}} \\
& & = & [
  \begin{array}[t]{ll}
    \hideE(AllowFails, \\
    \{ \rho \, \vb \rho \inb \ENV, \\
    \letvar \fx = \semapp{X}{|fx|}, \, \fx \subseteq \{0,1\}, \\
    \exists H \inb Fun.\, \rho(h)=H, \\
    \exists F \inb Fun.\, \rho(f)=F, \\
    \letvar \dsplural{\EV_{0}} =
      \semapppp{Q}{t_0}{\rho}{p}{w} \\
    \letvar n = \lengthseq{H} = \lengthseq{F}, \\
    \letvar m = \lengthseq{\dsplural{\EV_{0}}}, \\
    q=c \Rightarrow m=n, \\
    q=o \Rightarrow m<=n, \\
    \exists is \inb \seq{\mathbb{N}} .\,
    is=\subseq{[0,\mydots,n-1]}, \lengthseq{is}=m, \\
    \forall k \inb \{0,\mydots,m-1\}. \\
    \quad \letvar i = is[k], \\
    \quad \forall \rho_0 \inb \dsplural{\EV_{0}}[k] . \\
    \quad \quad \letvar \dsplural{\EV_{1}} = \semapppp{Q}{t_1}{\rho_0}{j}{z}, \\
    \quad \quad \lengthseq{\dsplural{\EV_{1}}} <= 1, \\
    \quad \quad \DSifthenelse{\exists J \inb \Val .\, (\fpr{\rho_0(w)}{J}) \in H[i]}{1 \in \fx}{0 \in \fx \land \allowfails{\{ \rho_1\, ||\, \EV_1 |<-| \dsplural{\EV_1}, \rho_1 \inb \EV_1 \} },} \\

    \forall k \inb \{0,\mydots,n-1\}.\, \forall I,Z \inb \Val. \\
    \quad\quad (\fpr{I}{Z}) \in F[k] \\
      \quad \Leftrightarrow \\
      \quad\quad\quad \lnot (\exists i \inb \mathbb{N}. \exists \rho_0 \inb \dsplural{\EV_{0}}[i].\rho_0(p)=I) \land q=o \land (\fpr{I}{Z}) \in H[k] & \text{argument outside domain}\\
      \quad\quad \lor \\
      \quad\quad\quad (\exists i \inb \mathbb{N}. \exists \rho_0 \inb \dsplural{\EV_{0}}[i].\rho_0(p)=I) \land
      \\ \quad\quad\quad\quad
      \begin{array}[t]{l}
        \forall \rho_0 \inb \dsplural{\EV_0}[k]. \\
        \rho_0(p)=I, \\
        \exists \rho_1 \inb (\hideEs(\{j,z\} \cup \semapp{I}{t_1},\{\rho_0\}) \prodsingleE \semapppp{Q}{t_1}{\rho_0}{j}{z})[0].\\
        (\fpr{\rho_1(w)}{\rho_1(j)}) \in H[k] \land \rho_1(z)=Z
        \\
      \end{array} & \text{\hspace{-6em}argument inside domain} \\
      \quad\quad\quad ) \\
 \})\; ]
  \end{array} \\
  & & & \text{where } p,w,j,z \not\in \semapp{I}{|t_0,t_1|} \\
  \\
  \\
 & \semapp{X}{\fx} & : & \powerset{\mathbb{N}} \\
 & \semapp{X}{|fails|} & = & \{0\} \\
 & \semapp{X}{|succeeds|} & = & \{1\} \\
 & \semapp{X}{|decides|} & = & \{0,1\} \\
  \\
  & \allowfails{\EV} & = & \forall \rho \inb \EV.\, \rho(AllowFails)=1 \land \rho[AllowFails\mapsto0/ AllowFails\mapsto1] \not\in \EV \\
\end{array}
\end{array}
$$
