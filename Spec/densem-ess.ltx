$$
% ------------- Denotational semantics of Essential Verse ---------------
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}

% -------- LAMBDA ------------
\rulename{dlam} &
\multicolumn{3}{l}{\semess{S}{h}{f}{|functionOCX c t_0 succeeds t_1|}} \\
& & = & [
  \begin{array}[t]{ll}
 \{ \rho \, \vb \rho \inb \ENV, \\
    \exists H \inb Fun.\, \rho(h)=H, \\
    \exists F \inb Fun.\, \rho(f)=F, \\
    \letvar \EV_{0}s = % \squashE( \hideEs(\semapp{I}{|t_0|} \cup \{p,w\}, \{\rho\}) \prodsingleE \semess{S}{p}{w}{|t_0|}) \\
      \semapppp{Q}{t_0}{\rho}{pw} \\
    \letvar n = \lengthseq{\EV_{0}s},
    \lengthseq{H} = n,
    \lengthseq{F} = n, \\
    \forall k \inb \{0,\mydots,n-1\}.\, \forall \rho_0 \inb \EV_{0}s[k] . \\
    \quad \letvar \EV_{1}s = % \squashE(\hideEs(\semapp{I}{|t_1|} \cup \{j,z\}, \{\rho_0\}) \prodsingleE \semess{S}{j}{z}{|t_1|}) \\
      \semapppp{Q}{t_1}{\rho_0}{jz} \\
    \quad \lengthseq{\EV_{1}s} = 1 \, \land \\
    \quad \exists J \inb \Val\, . (\fpr{\rho_0(w)}{J}) \in H[k], \\
    \forall k \inb \{0,\mydots,n-1\}.\, \forall I,Z \inb \Val. \\
    \quad (\fpr{I}{Z}) \in F[k] \\
    \quad\quad \Leftrightarrow \\
    \quad ( (\exists i. \exists \rho_0 \inb \EV_{0}s[i]. \rho_0(p) = I) \, \land \\
    \quad \quad \forall \rho_0 \inb \EV_{0}s[k].\, \rho_0(p) = I \\
    \quad \quad \quad \Rightarrow \\
    \quad \quad \exists \rho_1 \inb
       % \squashE(\hideEs(\semapp{I}{|t_1|} \cup \{j,z\}, \{\rho_0\}) \prodsingleE \semess{S}{j}{z}{|t_1|})
       (\semapppp{Q}{t_1}{\rho_0}{jz})
            [0]. \\
    \quad \quad \quad (\fpr{\rho_1(w)}{\rho_1(j)} \in H[k] \land \rho_1(z)=Z \\
    \quad ) \\
 \} ]
 \end{array}
  \\
  \\
 & \semapp{Q}{t} & : & \Env \rightarrow \Ident \rightarrow \Ident \rightarrow \seq{\ENV} \\
 & \semapppp{Q}{t}{\rho}{x\,y} & = & 
 \squashE(\hideEs(\semapp{I}{|t|} \cup \{x,y\}, \{\rho\}) \prodsingleE \semess{S}{x}{y}{|t|}) \\

\end{array}
\end{array}
$$
\caption{Denotational semantics of Essential Verse: plan (S-LS), cont.} \label{fig:s-ls-cont}
\end{figure}


