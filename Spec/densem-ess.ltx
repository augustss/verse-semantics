\begin{array}{r@@{\;\;}c@@{\;\;}ll}
 \singleE & : & \ENV \rightarrow \powersetnp{\seq{\ENV}} \\
 \singleE( \EV ) & = & \{ [ \EV ] \} \\[1mm]

\unionEL & : & \seq{ \ENV } \rightarrow \ENV \\
   \unionEL( [] ) & = & \{ \} \\
   \unionEL( \EV : S ) & = & \EV \cup \unionEL(S) \\ [1mm]

 \mapEs & : & (\ENV \rightarrow \ENV) \rightarrow \powersetnp {\seq{ \ENV }} \rightarrow \powersetnp {\seq{ \ENV }} \\
   \mapEs(f, S) & = & \{ \; [ f( \EV) \vb \EV |<-| s ] \vb s \in S \; \} \\[1mm]

\end{array}
$$
