\begin{figure}
$$
% ------------- Denotational semantics of DPS Verse ---------------
\begin{array}{l}
\textbf{Domains} \\
\begin{array}{r@@{\;}l@@{\;\;}c@@{\;\;}ll}
  \rho \in & \Env & = & (\Ident + \RES) \rightarrow \Value  & \text{Gives a value for \emph{every} identifier} \\
  &&&& \hspace{3mm} \text{plus result token $\RES$}
\end{array} \\
\\
\textbf{Denotational semantics} \\
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
& \semapsub{E}{c}{|e|} & : & \powersetnp{\seq{ \ENV }} \\
\rulename{edef} & \semapsub{E}{c}{|defintro x|} & = & \singleE(\Env)  \hspace{8mm} \text{All environments} \\
\rulename{eatom} &  \semapsub{E}{c}{|a|} & = & \singleE( \{ \rho \in \Env \vb \rho(\RES) = \semapp{A}{a}{\rho} \}) \\
\rulename{efail} &  \semapsub{E}{c}{|fail|} & = & \{ [ ]  \} \\
\rulename{echoice} &  \semapsub{E}{c}{|e_1 `choice` e_2|}
 & = & \{ s_1 \append s_2 \vb s_1 \in \semap{B}{e_1}, s_2 \in \semap{B}{e_2}\}  \\
\rulename{eunify} &  \semapsub{E}{c}{|e_1 == e_2|}
 & = & \begin{array}[t]{@@{}l@@{\,}l}
          \{     & [ \EV_1 \intersectE \EV_2 \vb \EV_1 |<-| s_1, \EV_2 |<-| s_2 ] \\
          |vbar| & s_1 \in \semapsub{E}{c}{e_1}, s_2 \in \semapsub{E}{c}{e_2} \; \} 
  \end{array} \\
\rulename{eseq} &  \semapsub{E}{c}{|e_1 ; e_2|}
& = &  \begin{array}[t]{@@{}l@@{\,}l}
          \{     & [ \hideE(\RES, \EV_1) \intersectE \EV_2 \vb \EV_1 |<-| s_1, \EV_2 |<-| s_2 ] \\
          |vbar| & s_1 \in \semapsub{E}{c}{e_1}, s_2 \in \semapsub{E}{c}{e_2} \; \}
  \end{array} \\
\rulename{elam} &  \semapsub{E}{c}{|dpslam x e_1 e2 y|} & = & ??? \\
\rulename{eapp} & \semapsub{E}{c}{|apply1N a_1 a_2|}
& = & \{ \; \begin{array}[t]{@@{}l}
         [ \{ \rho \in \Env \vb \semapp{A}{a_1}{\rho}=Fun(hs), (\fpr{\semapp{A}{a_2}{\rho}}{\rho(\RES)}) \in hs[i] \} \\
         |vbar| i |<-| 0\mydots\, ] \; \}
         \end{array} \\
\multicolumn{2}{@@{}l}{\rulename{eif} \; \hfill
  \semapsub{E}{c}{|if3 e_1 e_2 e_3|} }r
& = & \bigcup \begin{array}[t]{@@{}l@@{\,}l}
  \{      & \begin{array}[t]{@@{}l}
               \mapE(\lambda \EV.\, \hideE(Y,\EV \cap \EV_1),  \; \semapsub{E}{c}{e_2})
                  \; \cup \\
                  \mapE(\lambda \EV.\, \EV \setminus (\hideE(Y,\EV_1)), \; \semapsub{E}{c}{e_3} )
           \end{array}
  \\
      |vbar|  & s_1 \in \semapsub{E}{c}{e_1}, \EV \in \unionEL( s_1 ) \; \}
    \end{array} \\
&&& |where|\; Y = \semap{I}{|e_1|} \\
\rulename{eall} & \semapsub{E}{c}{|all e|}
& = & \begin{array}[t]{@@{}l@@{\,}l}
       \{ & [ \, \{ \rho \vb  (vs,\EV) \in \combineE(s), \rho \in \EV, \rho(\RES)=\tupE(vs) \}\, ] \\
       |vbar| & s \in \semapsub{B}{c}{e} \; \}
      \end{array}
\\
\\

& \semapp{B}{|e|} & : & \powersetnp{\seq{ \ENV }} \\
& \semapp{B}{|e|} & = & \mapE( \lambda \EV. \, \hideE(\semapp{I}{|e|}, \EV),\; \semapsub{E}{c}{e})
\end{array}
\end{array}
$$
\caption{Denotational semantics: plan (D-SLS)}
\label{fig:d-sls1}
\end{figure}

\begin{figure}
$$
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
 \singleE & : & \ENV \rightarrow \powersetnp{\seq{\ENV}} \\
 \singleE( \EV ) & = & \{ [ \EV ] \} \\[1mm]

\unionEL & : & \seq{ \ENV } \rightarrow \ENV \\
   \unionEL( [] ) & = & \{ \} \\
   \unionEL( \EV : S ) & = & \EV \cup \unionEL(S) \\ [1mm]

 \mapE & : & (\ENV \rightarrow \ENV) \rightarrow \powersetnp {\seq{ \ENV }} \rightarrow \powersetnp {\seq{ \ENV }} \\
   \mapE(f, S) & = & \{ \; [ f( \EV) \vb \EV |<-| s ] \vb s \in S \; \} \\[1mm]

\end{array}
$$
\caption{Auxiliary functions for plan (D-SLS)}
\label{fig:d-sls2}
\end{figure}
