\begin{figure}
$$
\begin{array}{@@{}l}

\textbf{Syntax of Core Verse} \\
\begin{array}{lr@@{\;\;}c@@{\;\;}l}
 \text{Expressions} & e & ::= & |x| \vb |k| \vb |o| \vb |apply1N e_1 e_2| \vb |e_1; e_2|
     \vb |e_1 == e_2| \vb |defKW x| \vb |e_1 `choice` e_2|  \\
  && \vb &  |arr (e_1, dots, e_n)| \vb |truth e| \vb |lam x e| \vb |iter2 ic e e_0|\\
  && \vb & |choose v e| \vb |varr v e| \\
  && \vb & |some e| \vb |v guard e| \vb |check fx e| \vb |verify2 rs as e| \\
  \text{Iter combinators} & ic & ::=
     & |allKW| \vb |oneKW| \vb |ifKW| \vb |forKW| \vb  |countKW|  \\
\end{array}
\\[1mm]
\hspace{3mm}\text{Note: ordinary |lam x e|; no |oftype e_1 e_2|; add |verifyKW| and |someKW|, |chooseKW|, |varrKW| } \\[2mm]

\textbf{Iteration macros} \\
\begin{array}{rcl}
  |applyiter ifKW v e_0| & = & |force v| \\
  |applyiter oneKW v e_0| & = & |v| \\
  |applyiter countKW v e_0| & = & |1 + e_0| \\
  |applyiter forKW v e_0| & = & |def x (x == force v; applyiter allKW x e_0)| \\
  |applyiter allKW v e_0| & = & |tup v `plusplus` e_0|
\end{array}

\end{array}
$$
\caption{Syntax of Core Verse} \label{fig:core-verse}
\end{figure}

\begin{figure}
$$
\begin{array}{@@{}l}
\mbox{{\bf Desugaring Mini Verse into Core Verse:} $|DMe3 md si t| = |e|$} \\

% -------------- Syntax ----------------
\multicolumn{1}{c}{\begin{array}{rcll}
  |md| & ::= & |mdx| \vb |mdpos| \vb |mdneg|  & \text{``Mode'': execution, verify, check} \\
  |si| & ::= & \text{Set of in-scope lambda-bound variables} \\[1mm]
\end{array}} \\


% -------------- Basic rules ----------------
\begin{array}{lr@@{\;\;}c@@{\;\;}ll}
\rulename{vatom}  & |DMe3 md si a|                  & = & |a| \\
\rulename{vapp}    & |DMe3 md si (apply1N f a)|     & = & |apply1N f a| \\
\rulename{vtup}    & |DMe3 md si (arr(a_1, xdots, a_n))| & = & |arr(a_1, xdots, a_n)| \\
\rulename{vtruth}  & |DMe3 md si (truth a)|        & = & |truth a| \\
\rulename{vbind}   & |DMe3 md si (defKW x)|          & = & |defKW x| \\
\rulename{veq}     & |DMe3 md si (e_1=e_2)|          & = & |(DMe3 md si e_1) = (DMe3 md si e_2)| \\
\rulename{vsemi}   & |DMe3 md si (e_1 ; e_2)|        & = & |DMe3 md si e_1 ; DMe3 md si e_2| \\
\rulename{vfail}   & |DMe3 md si fail|                  & = & |fail| \\
\rulename{vchoice} & |DMe3 md si (e_1 `choice` e_2)| & = & |(DMe3 md si e_1) `choice` (DMe3 md si e_2)| \\
\rulename{vfor}    & |DMe3 md si (fordo e_1 e_2)|
   & = & |iter2 forKW (DMe3 md si e_1; lam underscore (DMe3 md si e_2)) emptytup| \\
\rulename{vall}    & |DMe3 md si (all e)| & = & |iter2 allKW (DMe3 md si e) emptytup| \\
\rulename{vone}    & |DMe3 md si (one e)| & = & |iter2 oneKW (DMe3 md si e) fail| \\
\multicolumn{2}{l}{\rulename{vif} \;\; \hfill |DMe3 md si (if e_1 then e_2 else e_3|}
& = & \multicolumn{2}{@@{}l}{|iter2 ifKW
        (DMe3 md si e_1; lam underscore (DMe3 md si e_2))
        (DMe3 md si e_3)|}  \\
\rulename{vcheck+} & |DMe3 mdpos    si (check fx e)| & = & |check fx (DMe3 mdpos si e)| \\
\rulename{vcheck-} & |DMe3 mdneg si (check fx e)| & = & |DMe3 mdneg si e| \\
\rulename{vcheckx} & |DMe3 mdx    si (check fx e)| & = & |check fx (DMe3 mdx si e)| \\
\end{array}
\\

%--------- (e1 |> e2) and check<fx>{e}----------------
\begin{array}{lr@@{\;\;}c@@{\;\;}ll}
\multicolumn{4}{l}{\mbox{\it Type rules}} \\
\rulename{voftype+} & |DMe3 mdpos si (oftypefx e_1 fx e_2)|
& = & \begin{array}[t]{@@{}l}
  |verifyKW| (;) \left\{ \begin{array}{@@{}l}
       |defintro r; r == check fx (DMe3 mdpos si e_1);| \\
       |check succeeds (DMe3 mdpos si (apply1N e_2 r))|
  \end{array} \right\} ; \\
  |DMe3 mdneg si (oftypefx e_1 fx e_2|
  \end{array} \\
\rulename{voftype-} & |DMe3 mdneg si (oftypefx e_1 fx e_2)|
 & = & |si guard (havoc fx; some (DMe3 mdneg emp e_2))| \\
\rulename{voftypex} & |DMe3 mdx si (oftypefx e_1 fx e_2)|
& = & \begin{array}[t]{@@{}l}
    |defintro r; r == check fx (DMe3 mdx si e_1);| \\
    |check succeeds (apply1N ((DMe3 mdx si e_2)) r))|
  \end{array}
\end{array}
\\
% -------------- Function rules ----------------
\begin{array}{lr@@{\;\;}c@@{\;\;}ll}
  \multicolumn{4}{l}{\mbox{\it Closed functions}} \\
 \rulename{vfun+} &  |DMe3 mdpos si (lamOC closed x e_1 e_2)|
 & = & \multicolumn{2}{@@{}l}{|verify2 x () (DMe3 mdneg ((si + x)) e_1; DMe3 mdpos ((si +x)) e_2);|} \\
 & & &       |DMe3 mdneg si (lamOC closed x e_1 e_2)| \\[1mm]
\rulename{vfun-} &  |DMe3 mdneg si (lamOC closed x e_1 e_2)|
& = & |lam x (DMe3 mdpos ((si + x)) e_1; DMe3 mdneg ((si + x)) e_2)| \\[1mm]
\rulename{vfunx}& |DMe3 mdx si (lamOC closed x e_1 e_2)|
& = & |lam x (DMe3 mdx ((si + x)) e_1; DMe3 mdx ((si + x)) e_2)| \\[2mm]
\end{array} \\
% -------------- Auxiliary functions ----------------
\begin{array}{lr@@{\;\;}c@@{\;\;}ll}
\multicolumn{5}{l}{\mbox{{\bf Auxiliary functions:} $|havoc fx = e|$}} \\[0.02in]
\rulename{havoc-succ}     & |havoc2 succeeds e|  & = & |e| \\
\rulename{havoc-fail}     & |havoc2 fails e|  & = & |fail| \\
\rulename{havoc-dec}     & |havoc2 decides e|  & = & |some (lam x x) == tup(); e| \\[1mm]
\end{array}

\end{array}$$
\caption{Desugaring Mini Verse into ICFP Verse} \label{fig:ds12}
\end{figure}


