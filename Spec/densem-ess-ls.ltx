\newcommand{\fx}{\mathrm{fx}}
\newcommand{\allowfails}[1]{\mathbf{allowfails}(#1)}
%% \newcommand{\dsplural}[1]{#1s}
\newcommand{\dsplural}[1]{\overline{#1}}
%\newcommand{\mhideEs}[2]{\hideEs(#1,#2)}
\newcommand{\mhideEs}[2]{#2 \;\hat{-}\; #1}
%\newcommand{\mhideEsNL}[2]{\hideEs(#1,\\ & & & #2)}
\newcommand{\mhideEsNL}[2]{#2 \;\hat{-}\\ & & & #1}

\begin{figure}
$$
% ------------- Denotational semantics of Essential Verse ---------------
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
 & \semess{E}{u}{v}{t} & : & [ \ENV ] \\
\rulename{swild} &  \semess{E}{u}{v}{|_|} & = & [ \conBrack{u =v} ] \\
\rulename{satom} &  \semess{E}{u}{v}{|a|} & = & [ \conBrack{u=v, v=a} ] \\
\rulename{stuple} & \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}
& = & \mhideEsNL{ %%%\begin{array}[t]{@@{}l@@{\,}l}
             \{u_1,\mydots u_n,v_1 \mydots v_n\} \hspace{5mm} u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v}
           }{  %%%\begin{array}[t]{@@{}l}
                 \conBrack{ u=|arr (u_1, xdots, u_n)|,
                            v=|arr (v_1, xdots, v_n)|} 
                   \prodsingleE \semess{E}{u_1}{v_1}{t_1} \prodE \mydots \prodE \semess{E}{u_n}{v_n}{t_n}\; 
                   }
%%      \end{array}
%%      \end{array}
      \\
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &  \conBrack{x=v} \prodsingleE \semess{E}{u}{v}{t} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
   \conBrack{x=u} \prodsingleE \semess{E}{u}{v}{t} \\
\rulename{stype} &  \semess{E}{u}{v}{|:a|} & = & \semess{F}{u}{v}{a}  \\
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & [ ] \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
 & = & \semess{B}{u}{v}{t_1} \append \semess{B}{u}{v}{t_2}  \\
\rulename{sdotdot} &  \semess{E}{u}{v}{|a_1 .. a_2|}
& = & [ \conBrack{u=v, v=i, i \geq a_1, i \leq a_2}
      \vb i |<-| 0.. ] \\
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|}
& = &  \semess{E}{u}{v}{t_1} \prodE \semess{E}{u}{v}{t_2}  \\
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|}
& = &  \semapp{C}{t_1}\; \prodE \;\semess{E}{u}{v}{t_2}\\
\rulename{sapp} & \semess{E}{u}{v}{|apply1N a_1 a_2|}
 & = &  \conBrack{u=v} \prodsingleE \semess{F}{a_2}{v}{a_1} \\[1mm]

%  ------ IF --------------
\multicolumn{2}{@@{}l}{\rulename{dif} \; \hfill
  \semess{E}{u}{v}{|if3 t_1 t_2 t_3|} }
& = & \mhideEs{ xs} { \EV_1  \prodsingleE \semess{B}{u}{v}{t_2}} |++| \\
& & & \complE( \mhideEs{xs}{ \EV_1 }) \prodsingleE \semess{B}{u}{v}{t_3} \\
&&& \text{where} \begin{array}[t]{l}
  xs = \semapp{I}{|t_1|} \\
  \EV_1 : \ENV = \firstE(xs, \semapp{C}{t_1}) \\
  \end{array}
  \\ \\[-2mm]

%  ------ FOR --------------
\rulename{sfor} & \semess{E}{u}{v}{|fordo t_1 t_2|}
& = & \conBrack{ u=v } \prodsingleE [ \, \allE(s, E, v)) \vb E |<-| SS \,] \\
& & & \text{where} \begin{array}[t]{l}
      xs = \semapp{I}{t_1} \hspace{5mm} r,s \not\in \freevars{t_1,t_2} \\
      SS :: \seq{\seq{\ENV}}
      = \pickL \begin{array}[t]{@@{\;}l@@{\;}l}
                     [ & \mhideEs{xs \cup \{r\}}{ \EV \prodsingleE \semess{B}{r}{s}{t_2} } \\
                       \vb & \EV |<-| \squashE(\semapp{C}{t_1}) \; ])
                  \end{array}
\end{array}
\\ \\[-2mm]

%  ------ ONE,ALL --------------
\rulename{sone} & \semess{E}{u}{v}{|one t|}
 & = & \conBrack{ u=v } \prodsingleE [\,\mhideEs{xs}{ \firstE(xs, \mhideEs{p}{ \semess{E}{p}{v}{|t|})}} \, ] \\
 & & & \text{where}\; xs = \semapp{I}{|t|}, \; p \not\in \freevars{t} \\
\rulename{sall} & \semess{E}{u}{v}{|all t|}
 & = & \conBrack{ u=v } \prodsingleE [\, \allE(q,\mhideEs{p}{ \semess{B}{p}{q}{t}},v) \, ] \hspace{5mm} p,q \not\in \freevars{t} \\[2mm]

\\
%% \rulename{dlam} &
%% \multicolumn{3}{l}{\semess{E}{u}{v}{|functionOCX q t_1 fx t_2|}} \\
%%  & & = & ??? \\
%% \\
& \semess{B}{u}{v}{|t|} & : & \seq{ \ENV } \\
& \semess{B}{u}{v}{|t|} & = & \mhideEs{\semapp{I}{|t|}}{ \semess{E}{u}{v}{t}} \\[1mm]
& \semapp{C}{|t|} & : & \seq{ \ENV } \\
& \semapp{C}{|t|} & = & \mhideEs{\{p,q\}}{\semess{E}{p}{q}{|t|}} \hspace{5mm} p,q \not\in \freevars{t}\\[1mm]
\\
& \semess{F}{a_a}{r}{a_f} & : & \seq{\ENV} \\
& \semess{F}{a_a}{r}{a_f} & = & [ \; \conBrack{\conFun{a_a}{r}{a_f}{i}{\_}} \vb N |<-| 0.. \; ] \\
\\
& \allE & : & \Ident  \rightarrow [\ENV] \rightarrow \Ident \rightarrow \ENV \\
& \allE(q,E,r) & = & \begin{array}[t]{@@{}l@@{\;}l}
           \{ & \rho \in \Env \\
             \vb & ws \in \pickE (\squashE
               [ \; \{ w \in \Value \vb \rho[ \fpr{q}{w}] \in \EV \} \vb \EV \in E \; ]) \\
           , & \rho(r) = \tupE(ws) \; \} \\
\end{array} \\
\\[-2mm]
& \firstE & : & \powerset{\Ident} \rightarrow [\ENV] \rightarrow \ENV \\
& \firstE(xs,\; []) & = & \{\} \\
& \firstE(xs,\; \EV : \EV{}s)  & = & \EV \cup (\firstE(xs, \EV{}s) \setminus \mhideEs{xs}{\EV}) \\

\end{array}
\end{array}
$$
\caption{E-LS: denotational semantics of Essential Verse, LS style} \label{fig:s-ls}
\end{figure}


