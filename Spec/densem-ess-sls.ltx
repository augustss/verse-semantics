\begin{figure}
$$
\begin{array}{l}
  \multicolumn{1}{c}{\fbox{
  \begin{minipage}{10cm}
  $$\begin{array}{rcll}
  \multicolumn{4}{c}{{\bf type} \; \pom{A}} \\[1mm]
  \pomempty & : & \pom{A} \\
  \pomunit{\_}  & : & A \rightarrow \pom{A} \\
  \pomcat   & : & \pom{A} \rightarrow \pom{A} \rightarrow \pom{A} \\
  \pomunion & : & \pom{A} \rightarrow \pom{A} \rightarrow \pom{A} \\
  \pomunions & : & \powerset{\pom{A}} \rightarrow \pom{A} & \text{Infinite union} \\
  \pomcats & : & \seq{\pom{A}} \rightarrow \pom{A} & \text{Finite concatenation}
  \end{array}$$
  \end{minipage}
 }} \\

\textbf{Axioms} \\
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}
\rulename{ax1} & \pomempty \pomcat S      & = & S \\
\rulename{ax2} & S \pomcat \pomempty      & = & S \\
\rulename{ax3} & (S \pomcat T) \pomcat R	 & = & S \pomcat (T \pomcat R) \\[1mm]
\rulename{ax4} & \pomempty \pomunion S	 & = & S \\
\rulename{ax5} & S \pomunion \pomempty	 & = & S \\
\rulename{ax6} & S \pomunion T		 & = & T \pomunion S \\
\rulename{ax7} & (S \pomunion T) \pomunion R & = & S \pomunion (T \pomunion R) \\[1mm]
\rulename{ax8} & (S \pomunion T) \pomcat R   & = & (S \pomcat R) \pomunion (T \pomcat R) \\
\rulename{ax9} & S \pomcat (T \pomunion R)  & = & (S \pomcat T) \pomunion (S \pomcat R) \\[2mm]
\end{array}
\\
\text{\textbf{$\pom{A}$ is a monad.}  Theorem: $\pombind$ satisfies axioms} \\
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}ll}
  (\pombind) & : & \pom{A} \rightarrow (A \rightarrow \pom{B}) \rightarrow \pom{B} \\
  \pomempty \pombind h		& = & \pomempty \\
  \pomunit{a} \pombind h  	& = & h(a) \\
  (S \pomcat T) \pombind h      & = & (S \pombind h) \pomcat (T \pombind h) \\
  (S \pomunion T) \pombind h    & = & (S \pombind h) \pomunion (T \pombind h) \\
%   \\
%   \pommap & : & (A \rightarrow B) \rightarrow \pom{A} \rightarrow \pom{B} \\
%  \pommap(f,S) & = & S \pombind \lambda a.\, \pomunit{ f(a) } 
\end{array} \\
\\[-2mm]
\begin{minipage}{10cm}
  \textbf{Pomset comprehensions}
  $$\begin{array}{rcl}
    \mathit{comp} & ::= & \pomcompL e \vb qual_1, \ldots, qual_n \pomcompR \\
    qual & ::= & e \pomelem P \vb a \in S \vb a |<-| xs \vb e \\
   \end{array}$$
  \begin{itemize}
  \item Uses $a \pomelem S$ to mean ``$a$ is drawn from pomset $S$''
  \item Example: $\pommap(f,S)  = \pomcompL f(a) \vb a \pomelem S \pomcompR $
  \item Desugars to $(\pombind)$ and $\pomunit{\_}$ in the usual way
    \begin{itemize}
      \item e.g. $\pommap(f,S)  \; = \; \pomcompL f(a) \vb a \pomelem S \pomcompR \; = \; S \pombind \lambda a.\, \pomunit{ f(a) }$
    \end{itemize}
  \item $a \in S$ means $a \pomelem \pomfromset(S)$, where $\pomfromset :: \powerset{A} \rightarrow \pom{A}$
  \item $a |<-| xs$ means $a \pomelem \pomfromlist(xs)$, where $\pomfromlist :: \seq{A} \rightarrow \pom{A}$
  \end{itemize}
\end{minipage}
\\ \\[-2mm]

\mathbf{Canonicalisation.} \text{Theorem: $\pomcanon$ satisfies axioms.} \\
%    \text{Theorem: $\forall s \in \pomcanon(S).\; s \not=[] \; \text{and}\; \forall \EV \in s. \; \EV \not= \{\}$}
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}ll}
\pomcanon & : & \pom{A} \rightarrow \powersetnp{\seq{A}} \\
\pomcanon( \pomempty ) & = & \{ \} \\
\pomcanon( \pomunit{\EV} ) & = & \{ [ \EV ] \} \\
\pomcanon( S \pomunion T ) & = & \pomcanon(S) \cup \pomcanon(T) \\
\pomcanon( \pomempty \pomcat S ) & = & \pomcanon(S) \\
\pomcanon( (S \pomunion T) \pomcat R ) & = & \pomcanon(S \pomcat R) \cup \pomcanon(T \pomcat R) \\
\pomcanon( (S \pomcat T) \pomcat R ) & = & \pomcanon(S \pomcat (T \pomcat R)) \\
\pomcanon( \pomunit{\EV} \pomcat S ) & = & \{ a:as \vb as \in \pomcanon(S) \} \\
\end{array}
\\ \\
\text{\textbf{Theorems} \hspace{3mm} ``You can remove any sub-sequence''.}\\
\begin{array}{lrcl}
  \rulename{T1} & (S \pomcat T) \pomunion T & = & S \pomcat T \\
  \rulename{T2} & S \pomunion (S \pomcat T) & = & S \pomcat T \\
  \rulename{T3} & (S \pomcat T \pomcat R) \pomunion T & = & S \pomcat T \pomcat R \\
\end{array}
\end{array}
$$
\caption{Pomsets $\pom{A}$}
\end{figure}


\begin{figure}
$$
\begin{array}{l}

\mathbf{type}\; \pomENV = \pom{\ENV} \\
\text{{\bf Invariant:} $\pomENV$ has no nested $\pomempty$ and no $\pomunit{\{\}}$ anywhere}
\\ \\
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}ll}
\multicolumn{3}{l}{\text{\textbf{Conjunction (sequencing, intersection).}  Theorem: $\pomseq$ satisfies axioms.}} \\
(\pomseq) & : & \pomENV \rightarrow \pomENV \rightarrow \pomENV \\
  \pomempty \pomseq S                     & = & \pomempty \\
  S \pomseq \pomempty                     & = & \pomempty \\
  (S \pomunion T) \pomseq R               & = & (S \pomseq R) \pomunion (T \pomseq R) \\
  (S \pomcat T) \pomseq R                 & = & (S \pomseq R) \pomcat (T \pomseq R) \\
  \pomunit{\EV} \pomseq (S \pomunion T)  & = & (\pomunit{\EV} \pomseq S) \pomunion (\pomunit{\EV} \pomseq T) \\
  \pomunit{\EV} \pomseq (S \pomcat T)    & = & (\pomunit{\EV} \pomseq S) \pomcat (\pomunit{\EV} \pomseq T) \\
  \pomunit{\EV_1} \pomseq \pomunit{\EV_2}
  & = & \left\{ \begin{array}{@@{}ll}
           \pomempty & \text{if $\EV_1 \cap \EV_2 = \{\}$ } \\
           \pomunit{\EV_1 \cap \EV_2} & \text{otherwise}
           \end{array}\right. \\
  \\
\multicolumn{3}{l}{\text{\textbf{Alternative definitions of sequencing}}} \\
    S \pomseq T & = & S \pombind (\lambda \EV_1.\, T \pombind (\lambda \EV_2. \,
        \text{if}\,\EV_1 \cap \EV_2 = \{\} \, \text{then}\,  \pomempty \, \text{else} \, \pomunit{\EV_1 \cap \EV_2})) \\
        & = & \pomcompL \EV_1 \cap \EV_2 \vb \EV_1 \pomelem S, \; \EV_2 \pomelem T, \; \EV_1 \cap \EV_2 \not= \{\} \pomcompR \\[1mm]

\multicolumn{3}{l}{\text{\textbf{Disjunction (or, union)}}} \\
(\pomor) & : & \pomENV \rightarrow \pomENV \rightarrow \pomENV \\
 \pomempty \pomor S & = & S \\
 S \pomor \pomempty & = & S \\
 S \pomor T & = & \pomcompL \EV_1 \cup \EV_2 \vb \EV_1 \pomelem S,\; \EV_2 \pomelem T \pomcompR \\[1mm]

\multicolumn{3}{l}{\text{\textbf{Negation (or, complement)}}} \\
\pomNOT & : & \pomENV \rightarrow \pomENV \\
\pomNOT(\pomempty) & = & \pomunit{ \conUniv } \hfill \text{(|if3 fail t_1 t_2| = |t_2|)} \\
\pomNOT(S) & = & \pomcompL \conCompl(\EV) \vb \EV \in S, \conCompl(\EV) \not= \{\} \pomcompR
\end{array} \\
\\
\hline
\\
\mathbf{type}\; \pomFUN = \pom{\parfun{\Val}{\Val}}\\
\text{{\bf Invariant:} $\pomFUN$ has no nested $\pomempty$, no $\pomunit{\{\}}$ (empty partial function),
  and no domain overlap}
\\
\\
\text{ToDo: define tuple concatenation $\pomtupcat$.}
\end{array}
