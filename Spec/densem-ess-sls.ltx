%           Denotational semantics of Essential Verse in SLS style
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
  & \semess{E}{u}{v}{|t|} & : & \pomENV  \\

% Wildcards and atoms
\rulename{swild}  &  \semess{E}{u}{v}{|_|} & = & \pomunit{ \conBrack{u =v} } \\
\rulename{svar}   &  \semess{E}{u}{v}{|x|} & = & \pomunit{ \conBrack{u=v=x} } \\
\rulename{sconst} &  \semess{E}{u}{v}{|k|} & = & \pomunit{ \conBrack{u=v=k} }\\
\rulename{sprim}  &  \semess{E}{u}{v}{|o|} & = & \pomunit{ \conBrack{u=v=o} } \\

% Capture input and output
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &  \pomunit{\conBrack{x=v}} \pomseq \semess{E}{u}{v}{t} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
   \pomunit{\conBrack{x=u}} \pomseq \semess{E}{u}{v}{t} \\

% Tuples
\multicolumn{2}{@@{}l}{\rulename{stup} \; \hfill \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}}
& = & 
         \pomunit{\conBrack{ u=|arr (u_1, xdots, u_n)|,
                            v=|arr (v_1, xdots, v_n)|}}
         \pomseq \semess{E}{u_1}{v_1}{t_1}
         \pomseq \mydots
         \pomseq \semess{E}{u_n}{v_n}{t_n} \\
&&&         \pomHIDE { \{u_1,\mydots u_n,v_1 \mydots v_n\} }
         \hfill u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v} \\

% Choice and failure
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & \pomempty \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
  & = & \semess{B}{u}{v}{t_1} \pomcat \semess{B}{u}{v}{t_2} \\
\rulename{suchoice} &  \semess{E}{u}{v}{|t_1 `uchoice` t_2|}
  & = & \semess{B}{u}{v}{t_1} \pomunion \semess{B}{u}{v}{t_2} \\

% Unification
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|} & = &   \semess{E}{u}{v} {t_1} \pomseq \semess{E}{u}{v}{t_2} \\

% Sequencing
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|} & = &  \semapp{C}{t_1} \pomseq \semess{E}{u}{v}{t_2} \\
% Dot-dot
\rulename{sdotdot} &  \semess{E}{u}{v}{|t_1 ..  t_2|}
  & = & \pomunit{\conBrack{u=v}} \pomseq \semess{E}{p_1}{q_1}{t_1} \pomseq \semess{E}{p_2}{q_2}{t_2} \pomseq \\
  & & & \pomunions \{\;  \pomcats [ \conBrack{v=q_1+i, i \leq q_2 - q_1}  \vb i \leftarrow [0..n] ]  \vb n \in \N \; \} \\
  & & & \pomHIDE \{p_1,q_1,p_2,q_2\} \hfill  p_1,q_1,p_2,q_2 \not\in \freevars{t_1,t_2,u,v} \\[1mm]

% Application and type
\rulename{sapp} & \semess{E}{u}{v}{|apply1N t_1 t_2|}
& = &  \pomunit{\conBrack{u=v}} \pomseq \semess{E}{f}{g}{t_1} \pomseq \semess{E}{p}{q}{t_2}
\pomseq \semap{F}{|apply1N g q|}v  \\
& & & \pomHIDE \{f,g,p,q\} \hfill f,g,p,q \not\in \freevars{t_1,t_2,u,v} \\[1mm]
\rulename{stype} &  \semess{E}{u}{v}{|:t|} & = & \semess{E}{p}{q}{t} \pomseq \semap{F}{|apply1N q u|}v
  \pomHIDE \{p,q\} \hfill p,q \not\in \freevars{t,u,v} \\[1mm]

% IF
\multicolumn{2}{@@{}l}{\rulename{sif} \; \hfill
  \semess{E}{u}{v}{|if3 t_0 t_1 t_2|} }
& = & \begin{array}[t]{@@{\;}l@@{\,}l}
        (S0 \pomseq \semess{B}{u}{v}{t_1} \pomHIDE xs)
            \pomunion
          (\pomNOT(S0 \pomHIDE xs) \pomseq \semess{B}{u}{v}{t_2}) \\
        \textbf{where} \; \xs = \semap{I}{|t_0|}, \; S0 = \pomONE( xs, \semap{C}{|t_0|} )
      \end{array}
\\[5mm]
\multicolumn{2}{@@{}l}{\rulename{sfor} \; \hfill \semess{E}{u}{v}{|fordo t_0 t_1|}}
& = &  \semFOR{\semapp{C}{t_0}}{\semap{I}{t_0}}{u}{v}{t_1} \\[2mm]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%       B, C, and F
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
& \semess{B}{u}{v}{|t|} & : & \pomENV \\
& \semess{B}{u}{v}{|t|} & = & \semess{E}{u}{v}{e} \pomHIDE \semapp{I}{|t|} \\[1mm]
& \semapp{C}{|t|} & : & \pomENV \\
& \semapp{C}{|t|} & = & \semess{E}{p}{q}{|t|} \pomHIDE \{p,q\} \hfill p,q \not\in \freevars{t}\\[1mm]
& \semap{F}{|apply1N f x|}r & : & \pomENV \\
& \semap{F}{|apply1N f x|}r  & = &
\pomcompL \EV \begin{array}[t]{@@{}l@@{\,}l}
  \vb & Fun(F) \in \Val, \; h \pomelem F  \\
  \; ,   & \EV = \conBrack{ f = Fun(F) } \cap \conBrack{ \fpr{x}{r} \in h }, \EV \not= \emptyset \pomcompR
  \end{array}
%    \pomunions \{ \ \pomcats [ \; \conBrack{\conFun{x}{r}{f}{i}{n}} \vb i |<-| [0..n] \; ] \vb n \in \N
%      \; \}
\end{array} \\
\\

\begin{array}{r@@{\;\;}c@@{\;\;}l}
  \pomONE & : & \powerset{\Ident} \rightarrow \pomENV \rightarrow \pomENV
       \hspace{5mm} \text{Result has no $(\pomcat)$}\\

  \pomONE( xs, \pomempty )  & = & \pomempty \\
  \pomONE( xs, \pomunit{\EV} )  &  = & \pomunit{\EV} \\
  \pomONE( xs, S \pomunion T) & = & \pomONE(xs,S) \pomunion \pomONE(xs,T) \\
  \pomONE( xs, S \pomcat T )  & = & S1 \pomor ( \pomNOT(S1 \pomHIDE xs) \pomseq \pomONE(xs, T)) \\
                              & \multicolumn{2}{l}{\textbf{where}\; S1 = \pomONE(xs, S)} \\[1mm]

  \semFOR{\_}{xs}{u}{v}{t_1} & : & \powerset{\Ident} \rightarrow \pomENV \rightarrow \pomENV \\
\semFOR{\pomempty}{xs}{u}{v}{t_1} & = & \pomunit{\conBrack{u=v=|emptytup|}}
                   \hfill \text{(NB: |for1 fail| returns empty tuple)} \\[1mm]
\semFOR{S \pomunion T}{xs}{u}{v}{t_1}
                   & = & \pomunit{\conBrack{u=u_1 \fununion u_2, v=v_1 \fununion v_2}}
                   \hfill u_1,v_1,u_2,v_2 \not\in \freevars{t_1,u,v,xs} \\
    &&  \pomseq \semFOR{S}{xs}{u_1}{v_1}{t_1} \pomseq \semFOR{T}{xs}{u_2}{v_2}{t_1} \\
    && \pomHIDE \{u_1,v_1,u_2,v_2\} \\[1mm]
\semFOR{S \pomcat T}{xs}{u}{v}{t_1}
                   & = & \pomunit{\conBrack{u=u_1 \tupcat u_2, v=v_1 \tupcat v_2}}
                   \hfill u_1,v_1,u_2,v_2 \not\in \freevars{t_1,u,v,xs} \\
    &&  \pomseq \semFOR{S}{xs}{u_1}{v_1}{t_1} \pomseq \semFOR{T}{xs}{u_2}{v_2}{t_1} \\
    && \pomHIDE \{u_1,v_1,u_2,v_2\} \\[1mm]
\semFOR{\pomunit{\EV}}{xs}{u}{v}{t_1}
       &  = &  (\pomunit{\EV} \pomseq \pomunit{\conBrack{u=|arr p|,v=|arr q|}}
                  \pomseq \semess{B}{p}{q}{t_1}) \pomHIDE \{p,q,xs\}   \\
 &&  \pomunion \; \pomNOT(\pomunit{\EV} \pomHIDE xs) \pomseq \pomunit{\conBrack{u=v=|emptytup|}}  \hspace{6mm}  p,q \not\in \freevars{t_1,u,v,xs} \\
\end{array}
\end{array}
$$
\caption{E-POM: denotational semantics of Essential Verse, using pomsets}
\label{fig:E-sls1}
\end{figure}


