% ------------------------------------------------------------------------------------
%
%           Pomsets
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}

  \multicolumn{1}{c}{\fbox{
  \begin{minipage}{5cm}
  $$\begin{array}{rcl}
  \multicolumn{3}{c}{{\bf type} \; \pom{A}} \\[1mm]
  \pomempty & : & \pom{A} \\
  \pomunit{\_}  & : & A \rightarrow \pom{A} \\
  \pomcat   & : & \pom{A} \rightarrow \pom{A} \rightarrow \pom{A} \\
  \pomunion & : & \pom{A} \rightarrow \pom{A} \rightarrow \pom{A} \\
  \end{array}$$
  \end{minipage}
 }} \\ \\

\begin{array}{@@{}r@@{\;\;}c@@{\;\;}ll}

\multicolumn{3}{l}{\textbf{Axioms}} \\
\pomempty \pomcat S      & = & S \\
S \pomcat \pomempty      & = & S \\
(S \pomcat T) \pomcat R	 & = & S \pomcat (T \pomcat R) \\[1mm]
\pomempty \pomunion S	 & = & S \\
S \pomunion \pomempty	 & = & S \\
S \pomunion T		 & = & T \pomunion S \\
(S \pomunion T) \pomunion R & = & S \pomunion (T \pomunion R) \\[1mm]
(S \pomunion T) \pomcat R   & = & (S \pomcat R) \pomunion (T \pomcat R) \\
S \pomcat (T \pomunion R)  & = & (S \pomcat T) \pomunion (S \pomcat R) \\[2mm]

\multicolumn{3}{l}{\mathbf{Canonicalisation.}
  \begin{array}[t]{l}
    \text{Theorem: $\pomcanon$ satisfies axioms.} \\
    \text{Theorem: $\forall s \in \pomcanon(S).\; s \not=[] \text{and}\; \forall \EV \in s. \; \EV \not= \{\}$}
      \end{array}} \\
\pomcanon & : & \pom{\ENV} \rightarrow \powerset{\seq{\ENV}} \\
\pomcanon( \pomempty ) & = & \{ \} \\
\pomcanon( \pomunit{\EV} ) & = & \left\{\begin{array}{ll}
\{ \} & \text{if $\EV = \{\}$} \\
\{ [ \EV ] \} & \text{otherwise}
\end{array}
\right. \\
\pomcanon( S \pomunion T ) & = & \pomcanon(S) \cup \pomcanon(T) \\
\pomcanon( \pomempty \pomcat S ) & = & \pomcanon(S) \\
\pomcanon( (S \pomunion T) \pomcat R ) & = & \pomcanon(S \pomcat R) \cup \pomcanon(S \pomcat R) \\
\pomcanon( (S \pomcat T) \pomcat R ) & = & \pomcanon(S \pomcat (T \pomcat R)) \\
\pomcanon( \pomunit{\EV} \pomcat S ) & = &
\left\{ \begin{array}{ll}
    \pomcanon(S) & \text{if $\EV = \{\}$} \\
    \pomunit{\EV} & \text{if $S = \{\}$} \\
    \{ a:as \vb as \in \pomcanon(S) \} & \text{otherwise}
 \end{array} \right.
\\[2mm]

\multicolumn{3}{l}{\text{\textbf{Sequencing.}  Theorem: $\pomseq$ satisfies axioms.}} \\
(\pomseq) & : & \pom{\ENV} \rightarrow \pom{\ENV} \rightarrow \pom{\ENV} \\
  \pomempty \pomseq S                     & = & \pomempty \\
  S \pomseq \pomempty                     & = & \pomempty \\
  (S \pomunion T) \pomseq R               & = & (S \pomseq R) \pomunion (T \pomseq R) \\
  (S \pomcat T) \pomseq R                 & = & (S \pomseq R) \pomcat (T \pomseq R) \\
  \pomunit{\EV_1} \pomseq \pomunit{\EV_2} & = & \pomunit{\EV_1 \cap \EV_2} \\
  \pomunit{\EV} \pomseq (S \pomunion T)  & = & (\pomunit{\EV} \pomseq S) \pomunion (\pomunit{\EV} \pomseq T) \\
  \pomunit{\EV} \pomseq (S \pomcat T)    & = & (\pomunit{\EV} \pomseq S) \pomcat (\pomunit{\EV} \pomseq T) \\[2mm]

  \multicolumn{3}{l}{\text{\textbf{$\pom{A}$ is a monad.}  Theorem: $\pombind$ satisfies axioms}} \\
  (\pombind) & : & \pom{A} \rightarrow (A \rightarrow \pom{B}) \rightarrow \pom{B} \\
  \pomempty \pombind h		& = & \pomempty \\
  \pomunit{a} \pombind h  	& = & h(x) \\
  (S \pomcat T) \pombind h      & = & (S \pombind h) \pomcat (T \pombind h) \\
  (S \pomunion T) \pombind h    & = & (S \pombind h) \pomunion (T \pombind h) \\
  \\
  S \pomseq T & = & S \pombind (\lambda \EV_1.\, T \pombind (\lambda \EV_2. \, \pomunit{\EV_1 \cap \EV_2})) \\
              & = & [ \EV_1 \cap \EV_2 \vb \EV_1 |<-| S, \EV_2 |<-| T ]  \hspace{6mm} \text{Using pomset-comprehensions}\\
  \pommap & : & (A \rightarrow)
\end{array} \\

\end{array}
$$
\caption{Pomsets $\pom{A}$}
\end{figure}



% ------------------------------------------------------------------------------------
%
%           Denotational semantics of Essential Verse in SLS style
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
    & \semess{E}{u}{v}{|t|} & : & \pom{\ENV} \\

% Wildcards and atoms
\rulename{swild}  &  \semess{E}{u}{v}{|_|} & = & \pomunit{ \conBrack{u =v} } \\
\rulename{svar}   &  \semess{E}{u}{v}{|x|} & = & \pomunit{ \conBrack{u=v=x} } \\
\rulename{sconst} &  \semess{E}{u}{v}{|k|} & = & \pomunit{ \conBrack{u=v=k} }\\
\rulename{sprim}  &  \semess{E}{u}{v}{|o|} & = & \pomunit{ \conBrack{u=v=o} } \\

% Capture input and output
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &  \pomunit{\conBrack{x=v}} \pomseq \semess{E}{u}{v}{t} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
   \pomunit{\conBrack{x=u}} \pomseq \semess{E}{u}{v}{t} \\

% Tuples
\multicolumn{2}{@@{}l}{\rulename{stup} \; \hfill \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}}
& = & \begin{array}[t]{@@{}l}
         \pomunit{\conBrack{ u=|arr (u_1, xdots, u_n)|,
                            v=|arr (v_1, xdots, v_n)|}}
         \pomseq \semess{E}{u_1}{v_1}{t_1}
         \pomseq \mydots
         \pomseq \semess{E}{u_n}{v_n}{t_n} \\
         \HIDESkw { \{u_1,\mydots u_n,v_1 \mydots v_n\} }
         \hspace{5mm} u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v}
      \end{array} \\

% Choice and failure
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & \pomempty \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
  & = & \semess{B}{u}{v}{t_1} \pomcat \semess{B}{u}{v}{t_2} \\

% Unification
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|} & = &   \semess{E}{u}{v} {t_1} \pomseq \semess{E}{u}{v}{t_2} \\

% Sequencing
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|} & = &  \semapp{C}{t_1} \pomseq \semess{E}{u}{v}{t_2} \\
% Dot-dot
\rulename{sdotdot} &  \semess{E}{u}{v}{|a_1 ..  a_2|}
& = & \pomunions \{\;  \pomcats [ \conBrack{u=v=a_1+i, i \leq a_2 - a_1}  \vb i \leftarrow [0..n] ]  \vb n \in \N \; \} \\

% Application and type
\rulename{sapp} & \semess{E}{u}{v}{|apply1N a_1 a_2|}
 & = &  \conBrack{u=v} \seqSLOne \semap{F}{|apply1N a_1 a_2|}v \\
\rulename{stype} &  \semess{E}{u}{v}{|:a|} & = & \semap{F}{|apply1N a u|}v  \\
\\

% IF
\multicolumn{2}{@@{}l}{\rulename{sif} \; \hfill
  \semess{E}{u}{v}{|if3 t_0 t_1 t_2|} }
& = & \begin{array}[t]{@@{\;}l@@{\,}l}
        (S0 \pomseq \semess{B}{u}{v}{t_2}) \pomHIDE xs)
            \cup
          (\pomNOT(xs,S0) \pomseq \semess{B}{u}{v}{t_3} \\
        \textbf{where} \; \xs = \semap{I}{|t_0|}, \; S0 = \pomONE( xs, \semap{C}{|t_0|} )
      \end{array}
\\ \\
\multicolumn{2}{@@{}l}{\rulename{sfor} \; \hfill \semess{E}{u}{v}{|fordo t_1 t_2|}}
& = &  \pomFOR{\semapp{C}{t_1}}{\semap{I}{t_1}}{u}{v}{t_2} \\
\end{array}
\\

\\
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%       B, C, and F
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
& \semess{B}{u}{v}{|t|} & : & \SL{ \ENV } \\
& \semess{B}{u}{v}{|t|} & = & \semess{E}{u}{v}{e} \pomHIDE \semapp{I}{|t|} \\[1mm]
& \semapp{C}{|t|} & : & \SL{ \ENV } \\
& \semapp{C}{|t|} & = & \semess{E}{p}{q}{|t|} \pomHIDE \{p,q\} \hspace{5mm} p,q \not\in \freevars{t}\\[1mm]
& \semap{F}{|apply1N a_1 a_2|}r & : & \SL{\ENV} \\
& \semap{F}{|apply1N a_1 a_2|}r  & = &
    \{ \ [ \; \conBrack{\conFun{a_2}{r}{a_1}{i}{n}} \vb i |<-| [0..n] \; ] \vb n \in \N
      \; \}
 \\[1.5ex]

 & \pomONE & : & \powerset{\Ident} \rightarrow \pom{\ENV} \rightarrow \pom{\ENV}
       \hspace{5mm} \text{Result has no $(\pomcat)$}\\

 & \pomONE( xs, \pomempty )  & = & \pomempty \\
 & \pomONE( xs, \pomunit{\EV} )  &  = & \pomunit{\EV} \\
 & \pomONE( xs, S \pomunion T) & = & \pomONE(xs,S) \pomunion \pomONE(xs,T) \\
 & \pomONE( xs, S \pomcat T )  & = & S1 \pomunion (\pomNOT(xs,S1) \pomseq \pomONE(xs, T)) \\
 &                             & \multicolumn{2}{l}{\textbf{where}\; S1 = \pomONE(xs, S)} \\[1mm]
 & NOT & : & \powerset{\Ident} \rightarrow \pom{\ENV} \rightarrow \pom{\ENV} \\
 & NOT(xs,S) & = & \pommap( \conCompl, S \pomHIDE xs) \hspace{5mm} \text{Hide $xs$, and complement each ENV} \\[1mm]

 & \pomFOR{\_}{xs}{u}{v}{t_2} & : & \pom{\ENV} \rightarrow \pom{\ENV} \\
 & \pomFOR{\pomempty}{xs}{u}{v}{t_2} & = & \pomempty \\
  & \pomFOR{S \pomunion T}{xs}{u}{v}{t_2 } & = & \pomFOR{S}{xs}{u}{v}{t_2} \pomunion \pomFOR{T}{xs}{u}{v}{t_2} \\
 & \pomFOR{\pomunit{\EV}}{xs}{u}{v}{t_2}
       &  = & \begin{array}[t]{@@{}l}
                (\pomunit{\EV} \pomseq \pomunit{\conBrack{u=|arr p|,v=|arr q|}}
                  \pomseq \semess{E}{p}{q}{t_2}) \pomHIDE \{p,q,xs\}   \\
                \pomunion \; \pomNOT(xs, \pomunit{\EV}) \pomseq \pomunit{\conBrack{u=|emptytup|,v=|emptytup|}}
              \end{array} \\
 & \pomFOR{S \pomcat T}{xs}{u}{v}{t_2}
         & = & \begin{array}[t]{@@{}l}
          \pomunit{\conBrack{u=u_1 \oplus u_2, v=v_1 \oplus v_2}} \\
          \pomseq \pomFOR{S}{xs}{u_1}{v_1}{t_2} \pomseq \pomFOR{T}{xs}{u_2}{v_2}{t_2}
          \end{array}
\end{array}
\end{array}
$$
\caption{E-POM: denotational semantics of Essential Verse, using pomsets}
\label{fig:E-sls1}
\end{figure}


% ------------------------------------------------------------------------------------
%
%           The SL monad
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
  \multicolumn{1}{c}{\fbox{\parbox{8cm}{
   \begin{center}
      ${\bf type} \; \SL{A} = \powersetnp{\seq{A}}$ \\
      \text{The set may be infinite, but the list is always finite}
   \end{center}
 }}} \\ \\

\textbf{SL is an applicative functor} \\[1mm]
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}l}
     \pureSL & : & \ENV \rightarrow \SL{\ENV}  \\
     \pureSL( \EV ) & = & \{ [ \EV ] \} \\[1mm]

\liftATwo & : & (A \rightarrow B \rightarrow C) \rightarrow \SL{A} \rightarrow \SL{B} \rightarrow\SL{C} \\
\liftATwo(OP,S_1,S_2) & = &
  \{ \; \concat(ss)
     \begin{array}[t]{@@{}l@@{\;}l}
     \vb & s_1 {:} \seq{A} \in S_1 \\
     , & \letvar t {:} \seq{\SL{C}} = [\; \mapSL(OP(\EV,\_), S_2) \vb \EV |<-| s_1 \; ] \\
     , & \letvar r {:} \SL{\seq{C}} = \pickE(t) \\
     , & ss {:} \seq{\seq{C}} \in r \; \}
     \end{array} \\
     \\[-2mm]

 (\seqSL) & : & \SL{\ENV} \rightarrow \SL{\ENV} \rightarrow \SL{\ENV} \\
 E_1 \seqSL E_2 & = & \liftATwo(\, \cap, \, E_1, \, E_2 \, ) \\[1mm]
 (\seqSLOne) & : & \ENV \rightarrow \SL{\ENV} \rightarrow \SL{\ENV} \\
 \EV_1 \seqSLOne E_2 & = & \pureSL(\EV_1) \seqSL E_2 \\
              & = & \mapSL(\;  \lambda \EV_2.\, \EV_1 \cap \EV_2, E_2 \;) \\[1mm]
  \mapSL & : & (A \rightarrow B) \rightarrow \SL{A} \rightarrow \SL{B} \\
  \mapSL(OP, E) & = & \{ \; [ OP( \EV) \vb \EV |<-| s ] \vb s \in E \; \} \\[1mm]
(\HIDESkw) & : &  \SL{\ENV} \rightarrow \powerset{\Ident} \rightarrow \SL{\ENV} \\
\HIDES{s}{xs} & = & \mapSL( \lambda \EV.\, \HIDE{\EV}{xs}, \; s) \\
\end{array}
\\
\\
\text{ \textbf{SL is also a monad (I think)} and bind is easier to think about than liftA2!} \\[1mm]
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}l}
(\bindSL) & : & \SL{A} \rightarrow (A \rightarrow \SL{B}) \rightarrow \SL{B} \\
S \bindSL K & = & \{ \; \concat(ss)
\begin{array}[t]{@@{}l@@{\;}l}
   \vb & s{:}[A] \in S \\
   , & \letvar t {:} [\SL{C}] = [\, K(\EV) \vb \EV |<-| s\, ] \\
   , & \letvar r {:} \SL{[C]} = \pickE(t) \\
   , & ss{:}[[C]] \in r \; \}
\end{array} \\
& = & \{ \; \concat(ss) \vb s \in S, \; ss \in \pickE[\, K(\EV) \vb \EV |<-| s\, ] \; \} \hspace{3mm} \text{\emph{more compactly}}
  \\[1mm]
\liftATwo(OP,S_1, S_2) & = & \begin{array}[t]{@@{}l}
  S_1 \bindSL (\lambda \EV_1. \\
  S_2 \bindSL (\lambda \EV_2. \\
  \pureSL( OP(\EV_1,\EV_2) )\,))
  \end{array}
\end{array} \\
\\
\parbox{8cm}{NB: this naive version of $\liftATwo$ is wrong:
  $$\liftATwo(OP,S_1,S_2)
  = \{ [ OP(\EV_1,\EV_2) \vb \EV_1 |<-| s_1, \EV_2 |<-| s_2 ] \vb s_1 \in S_1, s_2 \in S_2 \}$$
...but there is no naive $\bindSL$.   True?}

\end{array}
$$
\caption{The $\SL{A}$ applicative functor}
\end{figure}

% ------------------------------------------------------------------------------------
%
%           Denotational semantics of Essential Verse in SLS style
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
    & \semess{E}{u}{v}{|t|} & : & \SL{\ENV} \\

% Wildcards and atoms
\rulename{swild}  &  \semess{E}{u}{v}{|_|} & = & \pureSL \conBrack{u =v} \\
\rulename{svar}   &  \semess{E}{u}{v}{|x|} & = & \pureSL \conBrack{u=v=x} \\
\rulename{sconst} &  \semess{E}{u}{v}{|k|} & = & \pureSL \conBrack{u=v=k} \\
\rulename{sprim}  &  \semess{E}{u}{v}{|o|} & = & \pureSL \conBrack{u=v=o} \\

% Capture input and output
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &  \conBrack{x=v} \seqSLOne \semess{E}{u}{v}{t} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
   \conBrack{x=u} \seqSLOne \semess{E}{u}{v}{t} \\

% Tuples
\multicolumn{2}{@@{}l}{\rulename{stup} \; \hfill \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}}
& = & \begin{array}[t]{@@{}l}
         \conBrack{ u=|arr (u_1, xdots, u_n)|,
                    v=|arr (v_1, xdots, v_n)|}
         \seqSLOne \semess{E}{u_1}{v_1}{t_1}
         \seqSL \mydots
         \seqSL \semess{E}{u_n}{v_n}{t_n} \\
         \HIDESkw { \{u_1,\mydots u_n,v_1 \mydots v_n\} }
         \hspace{5mm} u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v}
      \end{array} \\

% Choice and failure
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & \{ [ ] \} \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
  & = & \{ \; s_1 \append s_2 \vb s_1 \in \semess{B}{u}{v}{t_1}, s_2 \in \semess{B}{u}{v}{t_2} \; \} \\

% Unification
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|} & = &   \semess{E}{u}{v} {t_1} \seqSL \semess{E}{u}{v}{t_2} \\

% Sequencing
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|} & = &  \semapp{C}{t_1} \seqSL \semess{E}{u}{v}{t_2} \\
% Dot-dot
\rulename{sdotdot} &  \semess{E}{u}{v}{|a_1 ..  a_2|}
& = & \conBrack{u=v} \seqSLOne
   \{  \; [\conBrack{v=a_1+i, i \leq a_2 - a_1}  \vb i \leftarrow [0..n] ]  \vb n \in \N \} \\

% Application and type
\rulename{sapp} & \semess{E}{u}{v}{|apply1N a_1 a_2|}
 & = &  \conBrack{u=v} \seqSLOne \semap{F}{|apply1N a_1 a_2|}v \\
\rulename{stype} &  \semess{E}{u}{v}{|:a|} & = & \semap{F}{|apply1N a u|}v  \\
\\

% IF
\multicolumn{2}{@@{}l}{\rulename{sif} \; \hfill
  \semess{E}{u}{v}{|if3 t_0 t_1 t_2|} }
& = &   \bigcup\limits_{s_0 \in \semap{C}{|t_0|}}\left\{
 \begin{array}{@@{\;}l@@{\,}l}
(\HIDES{\EV_1 \seqSLOne \semess{B}{u}{v}{t_2})}{xs} \\
\cup \\
(\HIDE{\conCompl(\EV_1)}{xs}) \seqSLOne \semess{B}{u}{v}{t_3} \\
 \textbf{where} \; \xs = \semap{I}{|t_0|}, \; \EV_1 = \firstE(xs,s_0)
 \end{array}
 \right\}
\\ \\
\multicolumn{2}{@@{}l}{\rulename{sfor} \; \hfill \semess{E}{u}{v}{|fordo t_1 t_2|}}
& = &   \bigcup\limits_{s_0 \in \semap{C}{|t_0|}} \left\{
 \begin{array}{@@{\;}l@@{\,}l}
   \conBrack{ u=(u_1 \oplus \mydots \oplus u_n), v=(v_1 \oplus \mydots \oplus v_n)}
   \seqSLOne D_1 \seqSL \mydots \seqSL D_n \\
\hspace{5mm} \HIDESkw \{u_1, \mydots, u_n, v_1, \mydots, v_n \} \\
\textbf{where} \\
\;  \begin{array}[t]{l}
  \{u_1, \mydots, u_n, v_1, \mydots, v_n \} \not\in \freevars{u,v,t_0,t_1} \\
  {} [\EV_1,\mydots,\EV_n] = s_0 \\
  S1 = \semess{B}{p}{q}{t_1} \\
  C_i = \begin{array}[t]{@@{}l}
      \HIDES{(\EV_i \seqSLOne \conBrack{u_i=|arr p|, v_i=|arr q|} \seqSLOne S1)}{\{p,q\}} \\
      \cup \\
      \conCompl( \EV_i ) \seqSLOne \pureSL \conBrack{u_i=|arr ()|, v_i=|arr ()|}
      \end{array} \\
  D_i = \HIDES{C_i}{xs} \\ 
  \xs = \semap{I}{|t_0|}
 \end{array}
 \end{array}
 \right\}
\end{array}
\\

\\
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%       B, C, and F
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
& \semess{B}{u}{v}{|t|} & : & \SL{ \ENV } \\
& \semess{B}{u}{v}{|t|} & = & \HIDES{\semess{E}{u}{v}{e}}{\semapp{I}{|t|}} \\[1mm]
& \semapp{C}{|t|} & : & \SL{ \ENV } \\
& \semapp{C}{|t|} & = & \HIDES{\semess{E}{p}{q}{|t|}}{\{p,q\}} \hspace{5mm} p,q \not\in \freevars{t}\\[1mm]
& \semap{F}{|apply1N a_1 a_2|}r & : & \SL{\ENV} \\
& \semap{F}{|apply1N a_1 a_2|}r  & = &
    \{ \ [ \; \conBrack{\conFun{a_2}{r}{a_1}{i}{n}} \vb i |<-| [0..n] \; ] \vb n \in \N
      \; \}
 \\[1.5ex]

& \firstE & : & \powerset{\Ident} \rightarrow [\ENV] \rightarrow \ENV \\
& \firstE(xs,\; []) & = & \{\} \\
& \firstE(xs,\; \EV : s)  & = & \EV \cup (\firstE(xs, s) \cap \conCompl(\HIDE{\EV}{xs})) \\
\end{array}
\end{array}
$$
\caption{E-SLS: denotational semantics of Essential Verse, in SLS style}
\label{fig:E-sls1}
\end{figure}
