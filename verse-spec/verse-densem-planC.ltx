%        & \hspace{1em} \implies x \in \dom(f) \land f(x) \in \semapp{D}{e_2}{\rho'}} \}  \\
%    \end{array} \\


\end{array}
\\
\begin{array}{r@@{\;\;\;}c@@{\;\;\;}ll}
\semap{D}{|e|} & : & \Env \rightarrow \mtype \\
\semapp{D}{|e|}{\rho} & = & \hat{\bigcup}_{\rho' \dot{\in} \semapp{X}{|e|}{\rho}} \semapp{E}{|e|}\rho' \\[2mm]
\end{array}
\\
\textbf{Notation}\\
\begin{array}{lcll}
  |[e_1,xdots,e_n]| & : & \mtype & \text{sequence of items} \\
                & & & \text{eliminating (trailing?) empty sets?} \\
  |[e || x_1 <- e_1, x_2 <- e_2, xdots]| & : & \mtype & \text{sequence comprehension (order preserving)}, \\
                & & & \text{eliminating (trailing?) empty sets?} \\
  |++| & : & \mtype \rightarrow \mtype \rightarrow \mtype & \text{sequence concatenation} \\
  |[x_1,xdots,x_n] ++ [y_1,xdots,y_n]| & = & |[x_1,xdots,x_n,y_1,xdots,y_n]| \\
  \hat{\cup} & : & \mtype \rightarrow \mtype \rightarrow \mtype & \text{elementwise union of sequences,} \\
  |[x_1,xdots,x_n]| \hat{\cup} |[y_1,xdots,y_n]| & = & |[x_1 `cup` y_1,xdots,x_n `cup` y_n]| & \text{and pad shorter sequence with \mempty} \\
  \hat{\bigcup} & & & \hat{\cup} \text{ extended to sets} \\
  |re| & : & \mtype \rightarrow \mtype \\
  |re(s)| & = & \text{remove all empty sets from s} \\
\end{array}

