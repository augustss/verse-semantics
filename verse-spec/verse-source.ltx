\subsection{Source Verse}

\begin{figure}
$$
\begin{array}{lrcll}
\textbf{Terms} & |t| & ::= & |x|               & \text{Variable} \\
&      & \vb & |_|               & \text{Wildcard} \\
&      & \vb & |k|               & \text{Constant} \\
&      & \vb & |t_1 ; t_2|       & \text{Sequencing} \\
&      & \vb & |t_1^[t_2]|       & \text{Function application} \\
&      & \vb & |t_1^(t_2)|       & \text{Non-failing function application} \\
&      & \vb & |def x t|         & \text{Existential} \\
&      & \vb & |t_1 `choice` t_2| & \text{Choice} \\
&      & \vb & |t_1 = t_2|       & \text{Unification} \\
&      & \vb & |if(t_1) then t_2 else t_3| & \text{Conditional expression} \\
&      & \vb & |for(t_1) do t_2|     & \text{Finite loop} \\
&      & \vb & |check fx t|     & \text{Effects check} \\
&      & \vb & |array (t_1; xdots; t_n)| & \text{Array}, n \geq 0 \\
&      & \vb & |t_1, xdots, t_n|  & \text{Array}, n \geq 2 \\
&      & \vb & |()|              & \text{Empty array} \\
&      & \vb & |t_1 eqgt t_2|    & \text{Lambda expression} \\
&      & \vb & |p := t|          & \text{General definition} \\
&      & \vb & |p : t|           & \text{Type ascription} \\
&      & \vb & |op_b t|          & \text{Prefix operator} \\
&      & \vb & |t op_a|          & \text{Postfix operator} \\
&      & \vb & |t_1 op_i t_2|    & \text{Infix operator} \\
&      & \vb & |: t|             & \text{Range} \\
&      & \vb & |t_1 where t_2|   & \text{Reverse sequencing} \\
&      & \vb & |functionOC oc (a_1 xdots a_n) t|    & \text{Function}\;(n\geq 1) \\
&      & \vb & |if(t) then t|    & \text{Conditional expression} \\
&      & \vb & |if(t) else t|    & \text{Conditional expression} \\
&      & \vb & |if{t}|           & \text{Conditional expression} \\
&      & \vb & |for{t}|          & \text{Finite loop} \\
&      & \vb & |let(t) in t|     & \text{Local binding} \\
&      & \vb & |block t|         & \text{Scope delimiter} \\
&      & \vb & |case(t) of {t_1; xdots t_n}|    & \text{Case expression} \\
&      & \vb & |case{t_1; xdots t_n}| & \text{Case expression} \\
&      & \vb & |type^{t}|         & \text{Type definition} \\
&      & \vb & |option^{}|        & \text{Create an option} \\
&      & \vb & |option^{t}|       & \text{Create an option} \\
&      & \vb & |truth^{t} |       & \text{Singleton map} \\
&      & \vb & |amap (t_1; xdots; t_n) | & \text{Map}, n \geq 0 \\
\\
\text{\bf Arguments} &
 |a| & ::= & |(t)|  \vb |()| \vb |apeff a fx|
\\[2mm]
\text{\bf Patterns} & |p| & ::= & |_| \vb |xsl| \vb |p a| \vb  |squig p_1 p_2| \\
&     & \vb & |: t| \vb |p : t|  \vb |p_1, xdots, p_n| \vb |..p| \\
& |xsl| & ::= & x \vb  |xsl amp x|
\\[2mm]
\text{\bf Operators} &
 |op_b| & ::= &  ! \vb - \vb + \vb |hat| \vb ? \vb |arrayty| \vb ..  & \text{Prefix}\\
& |op_a| & ::= &  ? \vb |hat| & \text{Postfix}\\
& |op_i| & ::= &  + \vb - \vb * \vb / \vb |srcand| \vb |srcor| \vb : \vb .. & \text{Infix} \\
&        & \vb & < \vb <= \vb > \vb >= \vb <> \vb |minusgt| \\
\end{array}
$$
