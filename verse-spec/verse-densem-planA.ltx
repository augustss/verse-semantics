\begin{array}{l}
\text{\bf Utility functions} \\

\text{\bf Predefined functions} \\
  \begin{array}{rcll}
  \semapp{O}{|op|}{} & : & (\semfcn)^{*} \\
  \semapp{O}{|gt|}{} & = & \{ \fcn \{ (\tuple{x,y},x) \, || \, x \inb \mathbb{Z}, y \inb \mathbb{Z}, x > y \} \} & \text{one function} \\
  \semapp{O}{|int|}{} & = & \{ \fcn \{ (x,x) \, || \, x \inb \mathbb{Z} \} \} & \text{one function} \\
  \semapp{O}{|add|}{} & = & \{ f \, || \, f \inb \semfcn, \; \forall x,y \inb \mathbb{Z}.f(\tuple{x,y})=x+y \} & \text{many functions} \\
  \end{array} \\ \\
  
\text{\bf Defined identifiers} \\
  \begin{array}{rcll}
  \semapp{I}{|e|}{} & : & |[Ident]| \\
  \semapp{I}{|apply1N e_1 e_2|}{} & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|e_1 = e_2|}{}       & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|e_1 ; e_2|}{}       & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|x := e|}{}          & = & |[x]| <> \semapp{I}{|e|}{} \\
  \semapp{I}{|:e|}{}              & = & \semapp{I}{|e|}{} \\
  \semapp{I}{|arr (e_1, e_2)|}{}  & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|e|}                 & = & |[]| & \text{otherwise} \\
  \end{array} \\ \\
    
\begin{array}{rcll}
\apply & : & (\Value \times \Value) \rightarrow \mtype \\
\apply( f, w ) & = & \msing{f(w)} & f \in \semfcn, w \in \dom(f) \\
\textbf{alternative:\hspace{6em}}               & = & \{ y \, || \, (x, y) \inb f, \; x=w \} & f \in \semfcn \\
\apply( f, w ) & = & \emptyset & \text{otherwise} \\
%%\end{array}
\\

