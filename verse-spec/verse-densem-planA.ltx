\dom & : & (\Value \rightharpoonup \Value) \rightarrow \mtype \\
\dom(f) & = & \{ x \, || \, (x,y) \inb f \} \\

\\

\ran & : & (\Value \rightharpoonup \Value) \rightarrow \mtype \\
\ran(f) & = & \{ y \, || \, (x,y) \inb f \} \\

\\

\fcn & : & (\tuple{\Value,\Value})^{*} \rightarrow (\semfcn) \\
\fcn & & \multicolumn{2}{l}{\text{indicates a function made from a set of pairs} } \\

\\

\get{} & : & \mtype \rightarrow \mtype \\
\get{\{x\}} & = & \{ x \} \\
\get{s} & = & \emptyset & \text{if the cardinality of s is not 1} \\

