  \begin{array}{rcll}
%\multicolumn{4}{l}{\text{\bf Match semantics of a scoped expression}} \\
  \semapp{L}{|e|}{} & : & \Value \rightarrow \Env \rightarrow \mtype \\
  \semappp{L}{|e|}{u}{\rho} & = & \{ r \; || \; \rho' \inb \semapp{X}{e}{\rho}, r \inb \semapp{M}{|e|}{u}{\rho'} \} \\
\\
%\multicolumn{4}{l}{\text{\bf Match semantics of an expression}} \\
  \semapp{M}{|e|} & : & \Value \rightarrow \Env \rightarrow \mtype \\
  \semappp{M}{|x|}{u}{\rho} & = & \msing{\rho(x)} \cap \msing{u} \\
  \semappp{M}{|k|}{u}{\rho} & = & \msing{k} \cap \msing{u} \\
  \semappp{M}{|o|}{u}{\rho} & = & \semapp{O}{|o|}{} \cap \msing{u} \\
  \semappp{M}{|apply1N e_1 e_2|}{u}{\rho} & = &
    \{ r \, || \, f \inb \semapp{E}{|e_1|}{\rho}, \; a \inb \semapp{E}{|e_2|}{\rho}, \; r \inb \apply(f, a) \} \cap \msing{u} \\
  \semappp{M}{|e_1 = e_2|}{u}{\rho}      & = & \semappp{M}{|e_1|}{u}{\rho} \; \cap \; \semappp{M}{|e_2|}{u}{\rho} \\
  \semappp{M}{|e_1 ; e_2|}{u}{\rho}      & = &
    \{ y \, || \, x \inb \semapp{E}{|e_1|}{\rho}, \; y \inb \semappp{M}{|e_2|}{u}{\rho}) \} \\
  \semappp{M}{|x := e|}{u}{\rho} & = & \msing{\rho(x)} \;\cap\; \semappp{M}{e}{u}{\rho} \\
  \semappp{M}{|:e|}{u}{\rho} & = &
    \{ r \, || \, f \inb \semapp{E}{|e|}{\rho}, \; r \inb \apply(f, u) \} \\
%FAIL  \semappp{M}{|fail|}{u}{\rho} & = & \emptyset \\
  \semappp{M}{|vif e_1 e_2 e_3|}{u}{\rho} & = &
  \left\{
  \begin{array}{ll}
    \semapp{L}{|e_3|}{u}{\rho} & \text{if}\; \bar{\rho} = \emptyset \\
    \bigcup_{\rho' \dot{\in} \bar{\rho}} \semapp{L}{|e_2|}{u}{\rho'} & \text{otherwise} \\
  \end{array}
  \right. \\
  & &  |where|\; \bar{\rho} = \semappp{C}{e_1}{\rho} \\
  \semappp{M}{|arr (e_0, xdots e_n)|}{u}{\rho} & = &
  \{ \mkfcn{0 \fmapsto w_0,\mydots, n \fmapsto w_n} \, || \, u \in \semfcn, \, \dom(u) = \{0,\mydots,n\}, \\
  & & \hspace{0.5em} w_0 \inb \semappp{M}{|e_1|}{(u(0))}{\rho}, \,\mydots,\, w_n \inb \semappp{M}{e_n}{(u(n))}{\rho} \} \\

  \semappp{M}{|funk q e_1 e_2|}{g}{\rho} & = & \{ f
    \begin{array}[t]{l@@{\;}l}
      || & f \inb \semfcn \\
      ,  & g \in \semfcn  \\
      ,  & \forall x \inb \Value, \forall \rho' \inb \semapp{X}{e_1}{\rho},
           \forall y \inb \semapp{M}{e_1}{x}{\rho'}.  \\
         & \hspace{0.5em} x \in \dom(f) \land y \in \dom(g) \land f(x) \in \semapp{L}{e_2}{(g(y))}{\rho'} \\
      , & q=|closed| \implies \forall x \inb \dom(f). \\
        & \hspace{0.5em} \exists \rho' \inb \semapp{X}{e_1}{\rho}.\, \semappp{M}{e_1}{x}{\rho'} \neq \emptyset \\
     \}
    \end{array}
\\
