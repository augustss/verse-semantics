\apply & : & (\Value \times \Value) \rightarrow \mtypec \\
\apply( \tuple{w_0, \mydots,\, w_n}, k) & = & \msing{(\Rtag^k\Ltag,w_k)} & 0 \leq k \leq n \\
\apply( f, w ) & = & \msing{f(w)} & f \in \semfcnc, w \in \dom(f) \\
\apply( f, w ) & = & \emptyset & \text{otherwise} \\

 \munion & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
  s_1 \munion s_2 & = &
\multicolumn{2}{l}{\scompr{(\lbll{l},w)}{\sbind{(l,w)}{s_1}} \cup
                                              \scompr{(\lblr{l}, w)}{\sbind{(l,w)}{s_2}}} \\[1mm]
 \mintersect & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
  s_1 \mintersect s_2 & = &
\multicolumn{2}{l}{\scompr{(\lblseq{l_1}{l_2},w_1)}{\sbind{(l_1,w_1)}{s_1}, \sbind{(l_2,w_2)}{s_2}, w_1=w_2}} \\[1mm]
 \msemi & : & \mtype \rightarrow \mtype \rightarrow \mtype \\
  s_1 \msemi s_2 & = &
\multicolumn{2}{l}{\scompr{(\lblseq{l_1}{l_2}, w_2)}{\sbind{(l_1,w_1)}{s_1}, \sbind{(l_2,w_2)}{s_2}}} \\[1mm]

