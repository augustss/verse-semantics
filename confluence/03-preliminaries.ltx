\begin{definition}[\halfcommutes]
A reduction relation $R$ \emph{\halfcommutes} with $S$ if
whenever $\rstep{R}{e}{e_1$} and $\rstep{S}{e}{e_2}$
there exists $e'$ such that
$\rsteps{R}{e_2}{e'}$ and
$\rstep{S\epsilon}{e_1}{\rsteps{R}{\cdot}{e'}}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	e && {e_2} \\
	{e_1} & \bullet & {e'}
	\arrow["S", from=1-1, to=1-3]
	\arrow["R"', from=1-1, to=2-1]
	\arrow["{S^\epsilon}"', dotted, from=2-1, to=2-2]
	\arrow["R"', dotted, two heads, from=2-2, to=2-3]
	\arrow["R", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]
\end{definition}

\begin{lemma}\label{lem:half-com}
If $R$ is confluent and $R$ \halfcommutes with $S$ then $R$ commutes with $R \cup S$.
\end{lemma}

