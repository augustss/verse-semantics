\end{proof}

\begin{definition}[Postpones]
	A reduction relation $R$ \emph{strongly postpones} after $S$
	if $\rstep{R}{e}{\rstep{S}{\cdot}{e'}}$
	implies $\rsteps{S}{e}{\rstep{R}{\cdot}{e'}}$.
\end{definition}

\begin{lemma}[\cite{Hindley}] \label{lem:strong-pp}
%% CITATION https://www.irif.fr/~faggian/LMFI_2021/Home1_PP.pdf
If $R$ strongly postpones after $S$ then
if $\rsteps{R \cup S}{e}{e'}$ then
   $\rsteps{S}{e}{\rsteps{R}{\cdot}{e'}}$.
\end{lemma}

\begin{definition}[Hops]
A reduction relation $R$ \emph{hops after} $S$
if $\rstep{R}{e}{\rstep{S}{\cdot}{e'}}$
implies there is an $e''$ such that
$\rsteps{R}{e'}{e''}$ and
$\rstep{S}{e}{\rsteps{R}{\cdot}{e''}}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	e & \bullet & {e'} \\
	\bullet && {e''}
	\arrow["R", from=1-1, to=1-2]
	\arrow["S", from=1-2, to=1-3]
	\arrow["S"', dotted, from=1-1, to=2-1]
	\arrow["R"', dotted, two heads, from=2-1, to=2-3]
	\arrow["R", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]
\end{definition}

\begin{lemma} \label{lem:hops}
If $R$ is confluent and hops after $S$ then
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	e & \bullet & {e'} \\
	\bullet && {e''}
	\arrow["R", two heads, from=1-1, to=1-2]
	\arrow["S", from=1-2, to=1-3]
	\arrow["S"', dotted, from=1-1, to=2-1]
	\arrow["R"', dotted, two heads, from=2-1, to=2-3]
	\arrow["R", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
By induction on size of $\rsteps{R}{}{}$.
\begin{description}
\item[Base case] By definition of \emph{hops after}.
\item[Inductive case] Assume the lemma for reductions of size upto $k$
and complete the proof via the following diagram where
(1)~is from the induction hypothesis,
(2)~is from the definition of hops over, and
(3)~is from the assumption that $R$ is confluent.
%
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	\bullet & \bullet & \bullet & \bullet \\
	\bullet & \bullet && {(1)} \\
	& {(2)} && {(3)}
	\arrow["R", from=1-1, to=1-2]
	\arrow["{R^k}", two heads, from=1-2, to=1-3]
	\arrow["S", from=1-3, to=1-4]
	\arrow["S"', dotted, from=1-1, to=2-1]
	\arrow["S"', dotted, from=1-2, to=2-2]
	\arrow["R"', dotted, two heads, from=2-2, to=2-4]
	\arrow["R", dotted, two heads, from=1-4, to=2-4]
	\arrow["R"', dotted, two heads, from=2-2, to=3-2]
	\arrow["R"', dotted, two heads, from=2-1, to=3-2]
	\arrow["R"', dotted, two heads, from=3-2, to=3-4]
	\arrow["R", dotted, two heads, from=2-4, to=3-4]
\end{tikzcd}\]
\end{description}
\end{proof}

