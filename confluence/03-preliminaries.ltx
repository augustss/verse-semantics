\begin{lemma}[Kernel-Steps] \label{lem:kernel-steps}
If $\kernel{S}{R}$ and $S$ is confluent and $\rsteps{R}{a}{b}$
then $\exists c.\ \rsteps{S}{a,b}{c}$.
\end{lemma}

\begin{proof}
By induction on $\rsteps{R}{a}{b}$.
\begin{description}
\item[Base Case:] $a \equiv b$ so trivially $\rsteps{S}{a,b}{a}$.
\item[Inductive Case:] Assume theorem for $\rstepk{R}{n}{a}{b}$.
	Suppose that $\rstepk{R}{n}{a}{b'}$ via $\rstepk{R}{n}{a}{b}$ and $\rstep{R}{b}{b'}$.
	The proof follows from the diagram below: $c$ is from the IH, $c'$ from $\kernel{S}{R}$
	and $c''$ from the confluence of $S$.
	% https://q.uiver.app/?
\[\begin{tikzcd}
	a \\
	b & c \\
	{b'} & {c'} & {c''}
	\arrow["{R^n}"', two heads, from=1-1, to=2-1]
	\arrow["S", dotted, two heads, from=1-1, to=2-2]
	\arrow["S"', dotted, two heads, from=2-1, to=2-2]
	\arrow["R"', from=2-1, to=3-1]
