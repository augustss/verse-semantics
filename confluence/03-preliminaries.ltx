	\arrow["S"{pos=0.7}, dotted, two heads, from=2-2, to=3-3]
\end{tikzcd}\]
\end{description}
\end{proof}

\begin{theorem}{Kernel Confluence} \label{thm:kernel-confluence}
If $\kernel{S}{R}$ and $S$ is confluent, then $R$ is confluent.
\end{theorem}

\begin{proof}
Suppose that $\rsteps{R}{a}{b_1}$ and $\rsteps{R}{a}{b_2}$.
The following diagram shows how to construct $c$ such that
$\rsteps{R}{b_1}{c}$ and $\rsteps{R}{b_2}{c}$.
$c_1$ (resp. $c_2$) follows from \cref{lem:kernel-steps}
using $a$ and $b_1$ (resp. $b_2$).
%
Recall that $\kernel{S}{R}$ implies every $S$ reduction
is also an $R$ reduction.
% https://q.uiver.app/?
\[\begin{tikzcd}
	&& a \\
