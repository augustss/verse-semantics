\begin{lemma}[$\runi-\rcon$-Comm] \label{lem:u-c-c}
	$\runi$ and $\rcon$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ $*$-commutes with $\rcon$ and hence commutes via \cref{lem:star-comm}.
%
Let $\tx{\runi}$ and $\tx{\rcon}$ denote the reducts for $\runi$ and $\rcon$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rcon}$ or vice versa.


\begin{description}
\item[Case $\rdx{runi} \subset \rdx{\rcon}$:] Split cases on the rule used in $\rcon$.
	\begin{description}
	\item[Case:] \rulename{norm-val} \ie $\tx{\rcon} \equiv |v; e| \movesto |e|$.
		If $\rdx{\runi} \subset |v|$, \ie $\runi : |v| \movesto |v'|$, then join at $|e|$.
		If $\rdx{\runi} \subset |e|$, \ie $\runi : |e| \movesto |e'|$, then join at $|e'|$.
	\item[Case:] \rulename{norm-seq-assoc} \ie $\tx{\rcon} \equiv (e_1; e_2); e_3 \movesto e_1; (e_2 ; e_3)$.
		If $\rdx{\runi} \subset e_1$, \ie $\runi : e_1 \movesto e_1'$, then join at $(e_1'; (e_2; e_3)$.
		If $\rdx{\runi} \subset e_2$, \ie $\runi : e_2 \movesto e_2'$, then join at $(e_1; (e_2'; e_3)$.
		If $\rdx{\runi} \subset e_3$, \ie $\runi : e_3 \movesto e_3'$, then join at $(e_1; (e_2; e_3'))$.
		If $\rdx{\runi} \subset (e_1; e_2)$, \ie $\runi : (e_1; e_2) \movesto (e_1'; e_2')$, then join at $(e_1'; (e_2'; e_3))$.
	\item[Case:] \rulename{norm-seq-swap} \ie $\tx{\rcon} \equiv |e_1; x == v; e_2| \movesto |x == v; e_1; e_2|$.
		If $\rdx{\runi} \subset |e_1|$, \ie $\runi : e_1 \movesto e_1'$, then join at $x = |v|; e_1'; e_2$.
		If $\rdx{\runi} \subset |e_2|$, \ie $\runi : e_2 \movesto e_2'$, then join at $x = |v|; e_1; e_2'$.
		If $\rdx{\runi} \subset |x == v; e_2|$, \ie $\runi : |x == v| \movesto x = |v|; e_2'$, then join at $x = |v|; e_1; e_2'$.
	\item[Case:] \rulename{norm-swap-eq} \ie $\tx{\rcon} \equiv \hnf = x \movesto x = \hnf$.
		Here $\rdx{\runi} \subset \hnf$, \ie $\runi : \hnf \movesto \hnf'$, hence join at $x = \hnf'$.
	\item[Case:] \rulename{norm-seq-def}, \rulename{norm-defr}, \rulename{norm-seqr}, \rulename{norm-unifyr}]
		In this case $\tx{\rcon} \equiv C[e_1, e_2] \movesto C'[e_1, e_2]$.
		If $\rdx{\runi} \subset e_1$, \ie $\runi : e_1 \movesto e_1'$, then join at $C'[e_1', e_2]$.
		If $\rdx{\runi} \subset e_2$, \ie $\runi : e_2 \movesto e_2'$, then join at $C'[e_1, e_2']$.
	\end{description}

\item[Case $\rdx{\rcon} \subset \rdx{\runi}$:] via \cref{lem:under-u}.

\end{description}
\end{proof}

\begin{lemma}[$\runi-\rfail$-Comm] \label{lem:u-f-c}
	$\runi$ and $\rfail$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ strongly commutes wth $\rfail$.
%
Let $\tx{\runi}$ and $\tx{\rfail}$ denote the reducts for $\runi$ and $\rfail$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rfail}$ or vice versa.
%
\begin{description}
	\item[Case] $\rdx{\runi} \subset \rdx{\rfail}$ via \cref{lem:under-f}.
	\item[Case] $\rdx{\rfail} \subset \rdx{\runi}$: via \cref{lem:under-u}.
\end{description}
\end{proof}



\begin{lemma}[$\runi-\rgc$-Comm] \label{lem:u-g-c}
	$\runi$ and $\rgc$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ strongly commutes wth $\rgc$.
%
Let $\tx{\runi}$ and $\tx{\rgc}$ denote the reducts for $\runi$ and $\rgc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rgc}$ or vice versa.
%
\begin{description}
	\item[Case] $\rdx{\runi} \subset \rdx{\rgc}$:
		Suppose that $\tx{\rgc} \equiv \exists x_1,\ldots. x_1=v_1; \ldots; e \movesto e$, where no $x_i \in \freevars{e}$.
		If $\rdx{\runi} \subset e$, \ie $\runi : e \movesto e'$, then as $\freevars{e'} \subset \freevars{e}$ we can join at $e'$.
		If $\rdx{\runi} \subset v_i$, \ie $\runi : v_i \movesto v_i'$, then we can join at $e$.
		If $\rdx{\runi}$ spans some $x_i, v_i$ and $e$, then $\runi$ is via a \rulename{deref-*}, \ie
		$\tx{\runi} \equiv x_i = |v_i|; E[x_i] \movesto x_i = |v_i|; E[|v_i|]$.
		However, this $E[x_i]$ is disjoint from $e$ as $x_i \not \in \freevars{e}$,
		so we can still join at $e$.
	\item[Case] $\rdx{\rgc} \subset \rdx{\runi}$: via \cref{lem:under-u}.
\end{description}
%
\end{proof}

\begin{lemma}[$\runi-\rspc$-Comm] \label{lem:u-s-c}
	$\runi$ and $\rspc$ commute.
