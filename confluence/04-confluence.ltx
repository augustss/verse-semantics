	\arrow["\rconm"{description}, two heads, from=2-1, to=4-1]
	\arrow["\rconm"{description}, two heads, from=2-5, to=4-5]
	\arrow["{\rulename{exi-float}}"{description}, dotted, two heads, from=4-1, to=5-1]
	\arrow["\rconm"', dotted, two heads, from=5-1, to=6-2]
	\arrow["\rconm"{description}, dotted, two heads, from=4-3, to=6-2]
