\text{V-Eq-Ctx}  & C^k   & ::= & \hole^k \vb V^k = |v|; c \vb |v| = V^k; c \vb |v_1 == v_2|; C^k \vb EE^{k} \\
\text{E-Eq-Ctx}  & EE^k  & ::= & \hole^k \vb V^k = d; ee \vb v = D^k; ee  \vb |v = d|; EE^k \vb D^k \\
\text{Delim-Ctx} & D^k   & ::= & \exists x. C^{k+1} \vb V^{k+1}\ |v| \vb |v|\ V^{k+1} \vb C^{k+1}\ |choice|\ c \vb c\ |choice|\ C^{k+1} \vb \textbf{one}\{ C^{k+1} \} \vb \textbf{all}\{ C^{k+1} \}  \\
