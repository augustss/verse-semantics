\subsubsection{Unification}

\begin{lemma}[Under-$\runi$] \label{lem:under-u}
%
Let $\rr' \equiv \rr - \rulename{subst} - \rulename{var-swap}$.
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rr'}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\runi}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} & {E[\rdx{}']} \\
	{\rdx{\runi}'} & {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rr'}", from=1-1, to=1-2]
	\arrow["\runi", dotted, from=1-2, to=2-2]
	\arrow["{\rr'}"', dotted, two heads, from=2-1, to=2-2]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case \rulename{subst}]: Here, $\rdx{\runi} \equiv |X^[x==v]|$. Split cases on the occurrence of $\rdx{}$.
	\begin{description}
	\item[Case] $\rdx{} \occunder X$, \ie $X \equiv X'[\rdx{}]$.
	% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X'[\rdx{}][x=v]} && {X'\{v/x\}[\rdx{}\{v/x\}][x=v]} \\
	{X'[\rdx{}'][x=v]} && {X'\{v/x\}[\rdx{}'\{v/x\}][x=v]}
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=2-1, to=2-3]
	\arrow["{\rr' \ \text{via}\ \cref{lem:subst}}", dotted, from=1-3, to=2-3]
\end{tikzcd}\]

	\item[Case] $\rdx{} \occunder v$, \ie $\rstep{\rr'}{v}{v'}$
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x=v]} && {X\{v/x\}[x=v]} \\
	{X[x=v']} && {X\{v'/x\}[x=v']}
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=2-1, to=2-3]
	\arrow["{\rr' \ (\text{repeat at each}\ v)}", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]


	\end{description}
\item[Case \rulename{hnf-swap}]: $\rdx{\runi} \equiv |hnf == x|$ and $\rstep{\rr'}{h}{h'}$, so join at $\rdx{\runi}'' \equiv |x = hnf'|$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\mathit{hnf} = x} && {x = \mathit{hnf}} \\
	{\mathit{hnf}' = x} && {x = \mathit{hnf}'}
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["{\rr'}", dotted, from=1-3, to=2-3]
	\arrow["\runi", dotted, from=2-1, to=2-3]
\end{tikzcd}\]

\item[Case \rulename{u-occurs}]: $\rdx{\runi} \equiv x = V[x]$ and $\rstep{\rr'}{V[x]}{V'[x]}$, so join at $\rdx{\runi}'' \equiv |fail|$.
% https://q.uiver.app/?q=WzAsMyxbMCwwLCJ4ID0gVlt4XSJdLFsyLDAsIlxcdGV4dGJme2ZhaWx9Il0sWzAsMSwieCA9IFYnW3hdIl0sWzAsMSwiXFxydW5pIl0sWzAsMiwiXFxyciciLDJdLFsyLDEsIlxccnVuaSIsMix7InN0eWxlIjp7ImJvZHkiOnsibmFtZSI6ImRvdHRlZCJ9fX1dXQ==&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{x = V[x]} && {\textbf{fail}} \\
	{x = V'[x]}
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["\runi"', dotted, from=2-1, to=1-3]
\end{tikzcd}\]
\item[Case \rulename{var-swap}]: Impossible, no $\rdx{} \occunder \rdx{\runi}$
\item[Case \rulename{u-lit}]: Impossible, no $\rdx{} \occunder \rdx{\runi}$
\item[Case \rulename{u-fail}]: Join at $\rdx{\runi}'' \equiv |fail|$.
\item[Case \rulename{u-tup}]: $\rdx{\runi} \equiv |(u_1 ... u_n)| == |(v_1 ... v_n)|$.
	\begin{description}
		\item[Case] $\rdx{} \occunder u_i$ \ie $\rstep{\rr'}{u_i}{u_i'}$
			Join at $\rdx{\runi}'' \equiv  u_1 = v_1; \ldots u_i' = v_i; \ldots u_n = v_n$.
		\item[Case] $\rdx{} \occunder v_j$ \ie $\rstep{\rr'}{v_j}{v_j'}$
			Join at $\rdx{\runi}'' \equiv  u_1 = v_1; \ldots u_j = v_j'; \ldots u_n = v_n$.
	\end{description}

\item[Case \rulename{seq-assoc}]: $\rdx{\runi} \equiv \rstep{}{(eu; e_1); e_2}{eu;(e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs, which as we're precluding \rulename{subst} is either in $eu$ or in $e_1$ or in $e_2$.
	\begin{description}
		\item[Case] $\rdx{} \occunder eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1; e_2)$.
		\item[Case] $\rdx{} \occunder e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1; e_2')$.
		\item[Case] $\rdx{}$ spans $(eu; e_1)$ or $(eu; e_1); e_2$ via \rulename{fail-elim}.
			Join at $|fail|$.
	\end{description}

\item[Case \rulename{eqn-float}]: $\rdx{\runi} \equiv \rstep{}{v = (eu; e_1); e_2}{eu;(v = e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs, which as we're precluding \rulename{subst} is either in $v$, $eu$, $e_1$ or in $e_2$.
	\begin{description}
		\item[Case] $\rdx{} \occunder v$ \ie $\rstep{\rr'}{v}{v'}$
			Join at $\rdx{\runi}'' \equiv eu; (v' = e_1; e_2)$.
		\item[Case] $\rdx{} \occunder eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1; e_2)$.
		\item[Case] $\rdx{} \occunder e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1; e_2')$.
		\item[Case] $\rdx{}$ spans $(eu; e_1)$ or $v = (eu; e_1); e_2$ via \rulename{fail-elim}.
			Join at $|fail|$.
	\end{description}

\item[Case \rulename{choose}]: via \cref{lem:under-choose}.

\end{description}
\end{proof}

\begin{lemma}[Under \rulename{choose}] \label{lem:under-choose}
If $\rstep{\rulename{choose}}{\rdx{ch}}{\rdx{ch}'}$ and
	$\rdx{ch} \equiv E[\rdx{}]$ and
	$\rstep{\rr}{\rdx{}}{\rdx{}'}$
 then there exists $\rdx{ch}''$ such that
	$\rsteps{\rr}{\rdx{ch}'}{\rdx{ch}''}$ and
	$\rstep{\rulename{choose}}{E[\rdx{}']}{\rdx{ch}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{ch} \equiv E[\rdx{}]} && {E[\rdx{}']} \\
	{\rdx{ch}'} && {\rdx{ch}''}
	\arrow["{\rulename{choose}}"', from=1-1, to=2-1]
	\arrow["\rr", from=1-1, to=1-3]
	\arrow["{\rulename{choose}}", dotted, from=1-3, to=2-3]
	\arrow["\rr"', dotted, two heads, from=2-1, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
By the definition of \rulename{choose} we have
$$\rdx{ch} \equiv |SX^[CX^[e_1 choice e_2]]| \movesto |SX^[CX^[e_1] choice CX^[e_2]]| \equiv \rdx{ch}'$$
Split cases on where $\rdx{}$ occurs
\begin{description}
\item[Case $\rdx{} \occunder e_1$] \ie \rstep{\rr}{e_1}{e_1'}, so join at $|SX^[CX^[e1'] choice CX^[e_2]]|$.
\item[Case $\rdx{} \occunder e_2$] \ie \rstep{\rr}{e_2}{e_2'}, so join at $|SX^[CX^[e_1 choice e2']]|$.
\item[Case $\rdx{} \occunder |e_1 choice e_2|$] \ie \rstep{\rr}{|e_1 choice e_2|}{|e_i|} where $e_{3-i}$ is $|fail|$
so join at $|SX^[CX^[e_i]]|$.
\item[Case $\rdx{} \occunder CX$] \ie \rstep{\rr}{CX}{CX'} so join (via \emph{two} $\rr$ steps) at $|SX^[CX'^[e_1] choice CX'^[e_2]]|$.
\item[Case $\rdx{} \occunder |CX^[e_1 choice e_2]|$] \ie $\rstep{\rr}{|CX^[e_1 choice e_2]|}{|CX'^[e1' choice e2']|}$,
so join at $|SX^[CX'^[e1'] choice CX'^[e2']]|$.
\end{description}
\end{proof}

\subsubsection{Normalization}

\begin{lemma}[Under-$\rcon$] \label{lem:under-n}
%
Let $\rr' = \rr - \rcon - \runi$.
%
If $\rstep{\rcon}{\rdx{\rcon}}{\rdx{\rcon}'}$ and
   $\rdx{\rcon} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then exists $\rdx{\rcon}''$ such that
   $\rstep{\rr'}{\rdx{\rcon}'}{\rdx{\rcon}''}$ and
   $\rstep{\rcon}{E[\rdx{}']}{\rdx{\rcon}''}$.
\end{lemma}

\begin{proof}
Let $\rcon : \rdx{\rcon} \movesto \rdx{\rcon}'$ be the $\rcon$ redex and split cases
on the reduction rule used in the step.
%
\begin{description}
\item[Case \rulename{exi-swap}]: \ie $\rcon: |def x (def y e)| \movesto |def y (def x e)|$.
Split cases on the position of $\rdx{}$.
	\begin{description}
	\item[Case $\rdx{} \occunder e$]: \ie $\rstep{\rr'}{e}{e'}$; join at $|def x (def y e')|$.
	\item[Case $\rdx{} \occunder |(def y e)|$]: \ie $y$ eliminated via an \rulename{exi-elim} or \rulename{eqn-elim}
		$\rstep{\rr'}{|def y e|}{e'}$; join at $|def x e'|$.
	\item[Case $\rdx{} \occunder |(def x (def y e))|$]: \ie $x$ eliminated via an \rulename{exi-elim} or \rulename{eqn-elim}
		$\rstep{\rr'}{|def x (def y e)|}{|def y e'|}$; join at $|def y e'|$.
	\end{description}

\item[Case \rulename{exi-float}]: \ie $\rcon: |X^[def x e]| \movesto |def x (X^[e])|$.
Split cases on the position of $\rdx{}$.
	\begin{description}
	\item[Case $\rdx{} \occunder e$]: \ie $\rstep{\rr'}{e}{e'}$; join at $|def x (X^[e'])|$.
	\item[Case $\rdx{} \occunder |(def x e)|$]: \ie $x$ eliminated via an \rulename{exi-elim} or \rulename{eqn-elim}
		$\rstep{\rr'}{|def x e|}{e'}$; join at $|X^[e']|$.
	\item[Case $\rdx{} \occunder X$]: \ie $\rstep{\rr'}{|X^[def x e]|}{|X'^[def x e']|}$; join at $|def x (X'^[e'])|$.
	\end{description}

\item[Case \rulename{subst-var}]: \ie $\rcon: |X^[x=y]|  \movesto |(subst X x y)^[x=y]|$.
	The only possible position of $\rdx{}$ is $\rdx{} \occunder X$ \ie
	$\rstep{\rr'}{X^[x=y]}{X'^[x=y]}$; join at $|(subst X' x y)^[x=y]|$.

\item[Case \rulename{var-swap}]: \ie $\rcon:  |x=y| \movesto |y=x|$.
	Impossible to have $\rdx{} \occunder |x=y|$.
\end{description}
\end{proof}

\subsubsection{Garbage Collection}

\begin{lemma}[Under-$\rgc$] \label{lem:under-g}
If $\rstep{\rgc}{\rdx{\rgc}}{\rdx{\rgc}'}$ and
	   $\rdx{\rgc} \equiv E[\rdx{}]$ where $E \not \equiv |hole|$ and
	   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rgc}''$ such that
	   $\rstepo{\rr}{\rdx{\rgc}'}{\rdx{\rgc}''}$ and
	   $\rstep{\rgc}{E[\rdx{}']}{\rdx{\rspc}''}$.
\end{lemma}

\begin{proof}
Let $\rgc : \rdx{\rgc} \movesto \rdx{\rgc}'$ be the $\rgc$ redex and split cases
on the reduction rule used in the step.
%
\begin{description}
\item[Case \rulename{val-elim}]: \ie $\rgc : |v;e| \movesto |e|$.
	Split cases on position of $\rdx{}$
	%
	\begin{description}
	\item[Case $\rdx{} \occunder |v|$]: Join at $|e|$.
	\item[Case $\rdx{} \occunder |e|$]: \ie $\rstep{\rr}{e}{e'}$; join at $|e'|$.
	\item[Case $\rdx{} \occunder |v;e|$]: \ie $\rstep{\rulename{fail-elim}}{v;e}{|fail|}$ as $e \equiv X[|fail|]$; join at $|fail|$.
	\end{description}

\item[Case \rulename{fail-elim}]: \ie $\rgc : |X^[fail]| \movesto |fail|$.
	Then $\rstep{\rr}{|X^[fail]|}{|X'^[fail]|}$ hence join at $|fail|$.

\item[Case \rulename{exi-elim}]: \ie  $\rgc : |def (ys,x,zs) e| \movesto |def (ys,zs) e|$;
	%
	(We can generalize \rulename{exi-elim} to first use a sequence of \rulename{exi-swap} to bring the $|x|$ binder to the end
	before applying \rulename{exi-elim} as this does not change the order of the \emph{remaining} binders.)
	%
	%
	Split cases on position of $\rdx{}$
	%
	\begin{description}
	\item[Case $\rdx{} \occunder |e|$]: \ie $\rstep{\rr}{e}{e'}$; join at $|def (ys,zs) e'|$.
	\item[Case $\rdx{} \occunder |def (ys,x,zs) e|$]: \ie via \rulename{exi-swap}; join at $|def (ys,zs) e|$.
	\end{description}

\item[Case \rulename{eqn-elim}]: \ie $\rgc : |def x (X^[x = v;e])| \movesto |X^[e]|$ where $x \not \in \freevars{|X^[v;e]|}$.
	%
	(We can generalize \rulename{exi-elim} to first use a sequence of \rulename{exi-swap} to bring the $|x|$ binder to the end
	before applying \rulename{eqn-elim} as this does not change the order of the \emph{remaining} binders.)
	%
	Split cases on position of $\rdx{}$
	%
	\begin{description}
	\item[Case $\rdx{} \occunder |v|$]: \ie $\rstep{\rr}{v}{v'}$; join at $|X^[e]|$.
	\item[Case $\rdx{} \occunder |e|$]: \ie $\rstep{\rr}{e}{e'}$ (where $\freevars{e'} = \freevars{e}$); join at $|X^[e']|$.
	\item[Case $\rdx{} \occunder |X|$]: \ie $\rstep{\rr}{|X^[x = v; e]|}{|X'^[x=v;e]|}$ (where $\freevars{X'} = \freevars{X}$); join at $|X'^[e]|$.
	\end{description}
\end{description}
\end{proof}

\subsubsection{Choice}

\begin{lemma}[Under-$\rspc$] \label{lem:under-s}
	If $\rstep{\rspc}{\rdx{\rspc}}{\rdx{\rspc}'}$ and
	   $\rdx{\rspc} \equiv E[\rdx{}]$ where $E \not \equiv |hole|$ and
	   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
	then there exists $\rdx{\rspc}''$ such that
	   $\rstepo{\rr}{\rdx{\rspc}'}{\rdx{\rspc}''}$ and
	   $\rstep{\rspc}{E[\rdx{}']}{\rdx{\rspc}''}$.
\end{lemma}

\begin{proof}
Split cases on the rule used in  $\rstep{\rspc}{\rdx{\rspc}}{\rdx{\rspc}'}$.

\begin{description}
\item[Case] \rulename{one-fail} (symmetric \rulename{all-fail})
	Impossible as $\rdx{} \not \occunder \rdx{\rspc}$.

\item[Case \rulename{one-value}]:
	Here $\tx{\rspc} \equiv |one v| \movesto |v|$.
	Hence $\rdx{} \occunder |v|$ \ie $\rr : |v| \movesto |v'|$, so join at |v'|.
\item[Case \rulename{all-value}]:
	Here $\tx{\rspc} \equiv |all v| \movesto |tup (v)|$.
	Hence $\rdx{} \occunder |v|$ \ie $\rr : |v| \movesto |v'|$, so join at |(v')|.

\item[Case \rulename{one-choice}]:
	Here $\tx{\rspc} \equiv |one (v `choice` e)| \movesto |v|$.
	If $\rdx{} \occunder |v|$, \ie $\rr : |v| \movesto |v'|$ then join at $|v'|$.
	If $\rdx{} \occunder |e|$, \ie $\rr : |e| \movesto |e'|$ then join at $|v|$.

\item[Case \rulename{all-choice}]:
	Here $\tx{\rspc} \equiv |all (v_1 `choice` dots `choice` v_n)| \movesto |tup (v_1,dots,v_n)|$.
	%
	If $\rdx{} \occunder |v_i|$ ie $\rr : |v_i| \movesto |v_i'|$
	then join at $|tup (v_1,dots,v_i',dots, v_n)|$.

\item[Case \rulename{choose-l}]: (symmetric \rulename{choose-r})
	Here $\tx{\rspc} \equiv |fail choice e| \movesto e$.
	Here, $\rdx{} \occunder e$, \ie $\rr : e \movesto e'$ so join at $|e'|$.

\item[Case \rulename{choose-assoc}]: \ie $\tx{\rspc} \equiv (e_1 |choice| e_2) |choice| e_3 \movesto e_1 |choice| (e_2 |choice| e_3)$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
	\item[Case] $\rdx{} \occunder e_1$, \ie $\rr : e_1 \movesto e_1'$ so join at $e_1' |choice| (e_2 |choice| e_3)$.
	\item[Case] $\rdx{} \occunder e_2$, \ie $\rr : e_2 \movesto e_2'$ so join at $e_1 |choice| (e_2' |choice| e_3)$.
	\item[Case] $\rdx{} \occunder e_3$, \ie $\rr : e_3 \movesto e_3'$ so join at $e_1 |choice| (e_2 |choice| e_3')$.
	\item[Case] $\rdx{} \equiv  |e_1 `choice` fail|$, \ie $\rr : |e_1 choice fail| \movesto e_1$ so join at $e_1 |choice| e_3$.
	\item[Case] $\rdx{} \equiv  |fail `choice` e_2|$, \ie $\rr : |fail choice e_2| \movesto e_2$ so join at $e_2 |choice| e_3$.
	\end{description}
\end{description}
\end{proof}


\subsection{Lemmas for Substitution and Unification} \label{sec:unify-lemmas}

\begin{lemma}[Substitution] \label{lem:subst}
	Let $\rr' \equiv \rr - \runi$.
	If $\rstep{\rr'}{\rdx{}}{\rdx{}'}$ then $\rstep{\rr'}{\subst{\rdx{}}{x}{v}}{\subst{\rdx{}'}{x}{v}}$.
\end{lemma}

\begin{proof} By induction on the structure of $\rdx{}$, splitting cases on the reduction rule used
	and using the fact that $|e|, |v|, |X|, |CX|, |SX|$ are all closed under value substitution.
\end{proof}

\begin{lemma}[Subst-Swap] \label{lem:subst-swap-c}
If $\rstep{\rulename{subst}}{e}{e_1}$ and $\rstep{\rulename{swap}}{e}{e_2}$
then exists $e'$ such that $\rsteps{\runi}{e_1, e_2}{e'}$.
\end{lemma}

\begin{proof}
Let $\rstep{\rulename{subst}}{\rdx{1}}{\rdx{1}'}$
and $\rstep{\rulename{swap}}{\rdx{2}}{\rdx{2}'}$
be the respective reducts. Via \cref{lem:disjoint}
it suffices to consider two cases:
\begin{description}
\item[Case \rulename{swap} under \rulename{subst}]: \ie $\rdx{2} \occunder \rdx{1}$
Let $\rdx{1} \equiv |X^[x==v]|$; split cases on $\rdx{2}$ position.
	\begin{description}

	\item[Case $\rdx{2} \equiv |x==v|$]: via rule \rulename{var-swap}:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x=y]} && {X\{y/x\}[x=y]} \\
	&& {X\{y/x\}[y=x]} \\
	{X[y=x]} && {X\{x/y\}[y=x]}
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["{\rr'}", dotted, from=1-3, to=2-3]
	\arrow["{\rr'}"', from=1-1, to=3-1]
	\arrow["\runi", dotted, from=3-1, to=3-3]
	\arrow["\runi", dotted, from=2-3, to=3-3]
\end{tikzcd}\]


	\item[Case $\rdx{2} \occunder v$]: \ie $\rstep{\rulename{swap}}{v}{v'}$.
	% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = v]} && {X\{v/x\}[x = v]} \\
	{X[x=v']} && {X\{v'/x\}[x=v']}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{swap}}"', from=1-1, to=2-1]
	\arrow["{\rulename{subst}}"', dotted, from=2-1, to=2-3]
	\arrow["{\rulename{swap}\ (\text{repeat at each}\ v)}", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]
	\item[Case $\rdx{2} \occunder X$]: \ie $X \equiv X'[\ldots \rdx{2} \ldots]$.
 		Let $u' \equiv \subst{u}{x}{v}$, split cases on \rulename{swap} RHS.
		\begin{description}
		\item[Case same variable]: $\rdx{2} \equiv |u == x|$ where $u$ is HNF or variable.
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X'[\ldots u = x \ldots][x = v]} && {X'\{v/x\}[\ldots u' = v \ldots][x = v]} \\
	& {} & \bullet \\
	{X'[\ldots x = u \ldots][x = v]} && {X'\{v/x\}[\ldots v = u' \ldots][x=v]}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{*-swap}}"', from=1-1, to=3-1]
	\arrow["{\rulename{subst}}"', dotted, from=3-1, to=3-3]
	\arrow[dotted, two heads, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=3-3, to=2-3]
	\arrow["{\cref{lem:eq-join-flip}}"{description, pos=0.7}, draw=none, from=2-2, to=2-3]
\end{tikzcd}\]
		\item[Case different variable]: $\rdx{2} \equiv |u == y|$ where $u$ is HNF or variable.
		\end{description}
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X'[\ldots u = y \ldots][x = v]} && {X'\{v/x\}[\ldots u' = y \ldots][x = v]} \\
	\\
	{X'[\ldots y = u \ldots][x = v]} && {X'\{v/x\}[\ldots y = u' \ldots][x=v]}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{swap}}"', from=1-1, to=3-1]
	\arrow["{\rulename{subst}}"', dotted, from=3-1, to=3-3]
	\arrow["{\rulename{swap}}", dotted, from=1-3, to=3-3]
\end{tikzcd}\]
	\end{description}
\item[Case \rulename{subst} under \rulename{swap}]: \ie $\rdx{1} \occunder \rdx{2}$
   Let $\rdx{2} \equiv |hnf == x|$, so $\rdx{1} \occunder |hnf|$, \ie $\rstep{\rulename{subst}}{|hnf|}{|hnf'|}$,
   so join at $|x = hnf'|$.
   % https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\mathit{hnf} = x} && {\mathit{hnf}' = x} \\
	{x = \mathit{hnf}} && {x = \mathit{hnf}'}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{swap}}"', from=1-1, to=2-1]
	\arrow["{\rulename{swap}}", dotted, from=1-3, to=2-3]
	\arrow["{\rulename{subst}}"', dotted, from=2-1, to=2-3]
\end{tikzcd}\]
\end{description}
\end{proof}

\begin{definition}[Levels]
Let $eu_1 \equiv |x_1 == v_1|$ and $eu_2 \equiv |x_2 == v_2|$ be two equations in a term $e$.
%
We say $eu_2$ \emph{is under} $eu_1$ if $eu_2 \occunder X$ and $|X^[eu_1]| \occunder e$.
\end{definition}

\begin{lemma}[Subst-Subst] \label{lem:subst-subst-c}
If $\rstep{\rulename{subst}}{e}{e_1}$ and $\rstep{\rulename{subst}}{e}{e_2}$
then $\join{\runi}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
Suppose that the redex $\rstep{}{e}{e_i}$ is using the equation $eu_i \equiv |x_i == v_i|$. Split cases on
\begin{description}
\item[Case] $eu_1$ is under $eu_2$ and $eu_2$ is under $eu_1$:
	\cref{lem:subst-same} completes the proof.

\item[Case] $eu_1$ is under $eu_2$ and $eu_2$ is not under $eu_1$:
	\cref{lem:subst-diff} completes the proof.

\item[Case] $eu_1$ is not under $eu_2$ and $eu_2$ is under $eu_1$:
	\cref{lem:subst-diff} completes the proof.

\item[Case] $eu_1$ is not under $eu_2$ and $eu_2$ is not under $eu_1$:
	The substitutions are disjoint, so \cref{lem:disjoint} completes the proof.
\end{description}
\end{proof}


\begin{lemma}[Subst-Same] \label{lem:subst-same}
If $\rstep{\rulename{subst}}{e}{e_1}$ using $eu_1$ and
$\rstep{\rulename{subst}}{e}{e_2}$ using $eu_2$ such that
$eu_1$ is under $eu_2$ and $eu_2$ is under $eu_1$,
then $\join{\runi}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
As $eu_1$ is under $eu_2$ and $eu_2$ is under $eu_1$, we have $e \equiv |X^[x = v_1; y = v_2]|$,
\ie wlog the equations $eu_1$ and $eu_2$ are adjacent. Let us split cases on whether $x \equiv y$
\begin{description}
\item[Case $x \equiv y$]: We join $e_1$ and $e_2$ using \cref{lem:eq-join-flip}
via the context $X' \equiv |subst X x z|^[x = z]$ where $z$ is a fresh variable.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = u; x = v]} && {X\{u/x\}[x=u; u=v]} \\
	{X\{v/x\}[v = u; x = v]} && \bullet
	\arrow["{eu_2}"', from=1-1, to=2-1]
	\arrow["{eu_1}", from=1-1, to=1-3]
	\arrow[dotted, from=1-3, to=2-3]
	\arrow[dotted, from=2-1, to=2-3]
	\arrow["{\cref{lem:eq-join-flip}}"{description, pos=0.8}, draw=none, from=1-1, to=2-3]
\end{tikzcd}\]

\item[Case $x \not \equiv y$]: Let us split cases on whether $x, y$ appear in $\freevars{u}, \freevars{v}$ respectively.
	\begin{description}
	\item[Case $x \not \in \freevars{v}, y \not \in \freevars{u}$]:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = u; y = v]} && {X\{u/x\}[x=u; y=v]} \\
	{X\{v/x\}[x = u; y = v]} && {X\{v/x\}[x = u; y = v]}
	\arrow["{eu_2}"', from=1-1, to=2-1]
	\arrow["{eu_1}", from=1-1, to=1-3]
	\arrow["{eu_2}", dotted, from=1-3, to=2-3]
	\arrow["{eu_1}", dotted, from=2-1, to=2-3]
\end{tikzcd}\]

	\item[Case $x \not \in \freevars{v}, y \in \freevars{u}$]:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = u; y = v]} && {X\{u/x\}[x=u; y=v]} \\
	{X\{v/y\}[x = u\{v/y\}; y = v]} && {X\{u\{v/y\}/x,v/y\}[x = u\{v/y\}; y = v]}
	\arrow["{eu_2}"', from=1-1, to=2-1]
	\arrow["{eu_1}", from=1-1, to=1-3]
	\arrow["{eu_2}", dotted, from=1-3, to=2-3]
	\arrow["{eu_1}", dotted, from=2-1, to=2-3]
\end{tikzcd}\]
	\item[Case $x \in \freevars{v}, y \not \in \freevars{u}$]: Symmetric to previous case.

	\item[Case $x \in \freevars{v}, y \in \freevars{u}$]: Join at |fail| if \rulename{u-occurs}, else
	impossible due to \norecursion.
	\end{description}
\end{description}
\end{proof}

\begin{lemma}[Subst-Diff] \label{lem:subst-diff}
If $\rstep{\rulename{subst}}{e}{e_1}$ using $eu_1$ and
$\rstep{\rulename{subst}}{e}{e_2}$ using $eu_2$ such that
$eu_1$ is not under $eu_2$ and $eu_2$ is under $eu_1$,
then $\join{\runi}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
% As $eu_1$ is \emph{not under} $eu_2$ and $eu_2$ is under $eu_1$,
Here, we have $e \equiv X_1[ ... X_2[x_2 = v_2] ... ][x_1 = v_1]$
where the substitution with $|x_2=v_2|$ does not affect $X_1, x_1, v_1$.
%
Split cases on whether $x_1 \equiv x_2$.

\begin{description}
\item[Case $x_1 \equiv x_2 \equiv x$]: By \norecursion we have $x \not \in \freevars{v_1}, x \not \in \freevars{v_2}$.
Hence, we can join $e_1$ and $e_2$ using \cref{lem:eq-join} on the sub-terms
$\subst{X_2}{x}{v_1}[v_1=v_2]$ and $\subst{X_2}{x}{v_2}[v_1=v_2]$.
%
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x = v_2] \ldots][x = v_1]} & {} & {X_1[\ldots X_2\{v_2/x\}[x = v_2] \ldots][x = v_1]} \\
	{X_1\{v_1/x\}[\ldots X_2\{v_1/x\}[v_1 = v_2] \ldots][x = v_1]} & \bullet & {X_1\{v_1/x\}[\ldots X_2\{v_2/x\}[v_1 = v_2] \ldots][x = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}", from=1-1, to=1-3]
	\arrow["{eu_1}", dotted, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=2-1, to=2-2]
	\arrow[dotted, two heads, from=2-3, to=2-2]
	\arrow["{\cref{lem:eq-join}}"{description, pos=0.9}, draw=none, from=1-2, to=2-2]
\end{tikzcd}\]

\item[Case $x_1 \not \equiv x_2$]:
Let
	$|v_1'| \equiv \subst{v_1}{x_2}{v_2}$ and
	$|v_2'| \equiv \subst{v_2}{x_1}{v_1}$.
Split cases on whether $x_i \in \freevars{v_{3-i}}$.
\begin{description}
	\item[Case $x_2 \not \in \freevars{v_1}$]
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1[\ldots X_2\{v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	{X_1\{v_1/x_1\}[\ldots X_2\{v_1/x\}[x_2 = v_2'] \ldots][x_1 = v_1]} & {X_1\{v_1/x\}[\ldots X_2\{v_2'/x_2, v_1/x_1\}[x_2 = v_2'] \ldots][x_1 = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}"', dotted, from=2-1, to=2-2]
	\arrow["{eu_2}", from=1-1, to=1-2]
	\arrow["{eu_1}", dotted, from=1-2, to=2-2]
\end{tikzcd}\]

	\item[Case $x_2 \in \freevars{v_1}, x_1 \not \in \freevars{v_2}$]
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1[\ldots X_2\{v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	{X_1\{v_1/x_1\}[\ldots X_2\{v_1/x_1\}[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1\{v_1/x_1\}[\ldots X_2\{v_1/x_1, v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	& {X_1\{v_1/x_1\}[\ldots X_2\{v_1'/x_1, v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}", from=1-1, to=1-2]
	\arrow["{eu_1}", dotted, from=1-2, to=2-2]
	\arrow["{eu_2}"', dotted, from=2-1, to=3-2]
	\arrow["{eu_2}", dotted, from=2-2, to=3-2]
\end{tikzcd}\]
	\item[Case $x_2 \in \freevars{v_1}, x_1 \in \freevars{v_2}$] In this case, we get the below diagram
	where, since $x_2 \in \freevars{v_2'}$, the term $x_2 = v_2'$ either steps to |fail| (and so we can
	join at |fail|) or the term violates the \norecursion assumption.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
