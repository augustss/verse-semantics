\begin{proof}
We show that $\rspc$ $*$-commutes with $\runi$, and hence by \cref{lem:star-comm}, $\runi$ commutes wth $\rspc$.
%
Let $\tx{\runi}$ and $\tx{\rspc}$ denote the reducts for $\runi$ and $\rspc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rspc}$ or vice versa.
%
\begin{description}
\item[Case] $\rdx{\runi} \subset \rdx{\rspc}$ via \cref{lem:under-s}.
\item[Case] $\rdx{\rspc} \subset \rdx{\runi}$ via \cref{lem:under-u}.
\end{description}
\end{proof}

