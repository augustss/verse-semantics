\begin{definition}[Recursive Equations] \label{def:norec}
A \emph{recursive equation} is a term of the form
%
$$
% |x == V^[lam y e]| \quad \text{where}\ x \in \freevars{e}
|x == V^[lam y E^[x]]| \quad \text{where}\ x \in \freevars{e}
$$
%
where the LHS is a variable and the RHS is a \emph{value}
that is or contains a $\lambda$ in which $|x|$ occurs free.
%
A term $e$ is \emph{recursive} if it contains a recursive equation.
%
A term $e$ is \emph{transitively recursive} if $\rsteps{\rr}{e}{e'}$ where $e'$ is recursive.
%
A term $e$ has \emph{\norecursion} if it is \emph{not} transitively recursive.
\end{definition}

\begin{theorem}[Confluence] \label{thm:confluence}
%
If $e$ has \norecursion and $\rsteps{\rr}{e}{e_1}$ and $\rsteps{\rr}{e}{e_2}$ then $\join{\rr}{e_1}{e_2}$.
%
% The reduction relation $\rr$ is confluent for all terms with \norecursion.
%
\end{theorem}

\begin{proof}
%
First, we partition $\rr$ into the relations $\runi$, $\rcon$, $\rapp$, $\rgc$ and $\rspc$.
%
Next, we show that each of these relations is confluent and pairwise
commutative (\cref{fig:confluence-summary}).
%
Finally, we use \cref{lem:comm-n} to prove their union $\rr$ is confluent.
\end{proof}

In the rest of the proof:
%
\begin{enumerate}
	\item We assume that we are working with terms with \norecursion.
		  The condition is only need to prove $\runi$ is confluent,
		  but we assume it globally for clarity.
	\item We use the below \cref{lem:disjoint} to focus attention
		  on the cases where one reduct \emph{occurs under} the other
		  and vice versa.
\end{enumerate}

\begin{lemma}[Disjoint] \label{lem:disjoint}
Let $e \equiv \ldots \rdx{1} \ldots \rdx{2} \ldots$
be an expression with two \emph{disjoint} reducts
$\rdx{1}$ and $\rdx{2}$.
%
If $\rstep{}{e}{\ldots \rdx{1}' \ldots \rdx{2} \ldots \equiv e_1}$ and
   $\rstep{}{e}{\ldots \rdx{1} \ldots \rdx{2}' \ldots \equiv e_2}$
then there exists $e'$ such that
		$\rstep{}{e_1}{e'}$ and
		$\rstep{}{e_2}{e'}$.
\end{lemma}

\begin{proof}
Trivial.
\end{proof}

\subsection{Lemmas for Reductions-Under} \label{sec:under-lemmas}

\subsubsection{Application}

\begin{lemma}[Under-$\rapp$] \label{lem:under-a}
If $\rstep{\rapp}{\rdx{\rapp}}{\rdx{\rapp}'}$ and
   $\rdx{\rapp} \equiv E[\rdx{}]$ and
   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rapp}''$ such that
   $\rstep{}{\rdx{\rapp}'}{\rdx{\rapp}''}$ and
   $\rstep{\rapp}{E[\rdx{}']}{\rdx{\rapp}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\rapp} \equiv E[\rdx{}]} & {E[\rdx{}']} \\
	{\rdx{\rapp}'} & {\rdx{\rapp}''}
	\arrow["\rapp"', from=1-1, to=2-1]
	\arrow["\rr", from=1-1, to=1-2]
	\arrow["\rapp", dotted, from=1-2, to=2-2]
	\arrow["\rr"', dotted, from=2-1, to=2-2]
\end{tikzcd}\]
\end{lemma}

\begin{proof} Split cases on the rule used in $\rapp$.
\begin{description}

\item[Case:] \rulename{app-beta} \ie $\tx{\rapp} \equiv (|lam x e|) |v| \movesto |def x (x == v; e)|$.
		If $\rdx{} \subset |e|$, \ie $\rr : e \movesto e'$, then join at $\rdx{\rapp}'' \equiv |def x (x == v; e')|$.
		If $\rdx{} \subset |v|$, \ie $\rr : |v| \movesto |v|'$, then join at $\rdx{\rapp}'' \equiv |def x (x == v'; e)|$.

\item[Case:] \rulename{app-tup} \ie $\tx{\rapp} \equiv |arr (v_0 dots v_n)| |v| \movesto |def x (x == v; (x == 0; v_0 `choice` dots `choice` x == n; v_n))|$.
		If $\rdx{} \subset |v_i|$, \ie $\rr: |v_i| \movesto |v_i|'$,
		then join at $|def x (x == v; (x == 0; v_0 `choice` dots x = i; v_i' dots `choice` x == n; v_n))|$.
		If $\rdx{} \subset |v|$, \ie $\rr: |v| \movesto |v|'$,
		then join at $|def x (x == v'; (x == 0; v_0 `choice` dots `choice` x == n; v_n))|$.

\item[Case:] \rulename{app-tup0} \ie $\tx{\rapp} \equiv |arr ()| |v| \movesto |fail|$.
		Here, $\rdx{} \subset v$, \ie $\rr: |v| \movesto |v|'$, then join at $\rdx{\rapp}'' \equiv |fail|$.

\item[Case:] \rulename{app-add}, \rulename{app-gt-*} In any of the primitive application rules, $\rdx{} \not\subset \rdx{\rapp}$.
\end{description}
\end{proof}

\subsubsection{Unification}

\begin{lemma}[Under-$\runi$] \label{lem:under-u}
%
Let $\rr' \equiv \rr - \rulename{subst} - \rulename{var-swap}$.
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rr'}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\runi}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} & {E[\rdx{}']} \\
	{\rdx{\runi}'} & {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rr'}", from=1-1, to=1-2]
	\arrow["\runi", dotted, from=1-2, to=2-2]
	\arrow["{\rr'}"', dotted, two heads, from=2-1, to=2-2]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case \rulename{subst}]: Here, $\rdx{\runi} \equiv |X^[x==v]|$. Split cases on the occurrence of $\rdx{}$.
	\begin{description}
	\item[Case] $\rdx{} \subset X$, \ie $X \equiv X'[\rdx{}]$.
	% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X'[\rdx{}][x=v]} && {X'\{v/x\}[\rdx{}\{v/x\}][x=v]} \\
	{X'[\rdx{}'][x=v]} && {X'\{v/x\}[\rdx{}'\{v/x\}][x=v]}
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=2-1, to=2-3]
	\arrow["{\rr' \ \text{via}\ \cref{lem:subst}}", dotted, from=1-3, to=2-3]
\end{tikzcd}\]

	\item[Case] $\rdx{} \subset v$, \ie $\rstep{\rr'}{v}{v'}$
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x=v]} && {X\{v/x\}[x=v]} \\
	{X[x=v']} && {X\{v'/x\}[x=v']}
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=2-1, to=2-3]
	\arrow["{\rr' \ (\text{repeat at each}\ v)}", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]


	\end{description}
\item[Case \rulename{hnf-swap}]: $\rdx{\runi} \equiv |hnf == x|$ and $\rstep{\rr'}{h}{h'}$, so join at $\rdx{\runi}'' \equiv |x = hnf'|$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\mathit{hnf} = x} && {x = \mathit{hnf}} \\
	{\mathit{hnf}' = x} && {x = \mathit{hnf}'}
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["{\rr'}", dotted, from=1-3, to=2-3]
	\arrow["\runi", dotted, from=2-1, to=2-3]
\end{tikzcd}\]

\item[Case \rulename{u-occurs}]: $\rdx{\runi} \equiv x = V[x]$ and $\rstep{\rr'}{V[x]}{V'[x]}$, so join at $\rdx{\runi}'' \equiv |fail|$.
% https://q.uiver.app/?q=WzAsMyxbMCwwLCJ4ID0gVlt4XSJdLFsyLDAsIlxcdGV4dGJme2ZhaWx9Il0sWzAsMSwieCA9IFYnW3hdIl0sWzAsMSwiXFxydW5pIl0sWzAsMiwiXFxyciciLDJdLFsyLDEsIlxccnVuaSIsMix7InN0eWxlIjp7ImJvZHkiOnsibmFtZSI6ImRvdHRlZCJ9fX1dXQ==&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{x = V[x]} && {\textbf{fail}} \\
	{x = V'[x]}
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["{\rr'}"', from=1-1, to=2-1]
	\arrow["\runi"', dotted, from=2-1, to=1-3]
\end{tikzcd}\]
\item[Case \rulename{var-swap}]: Impossible, no $\rdx{} \subset \rdx{\runi}$
\item[Case \rulename{u-lit}]: Impossible, no $\rdx{} \subset \rdx{\runi}$
\item[Case \rulename{u-fail}]: Join at $\rdx{\runi}'' \equiv |fail|$.
\item[Case \rulename{u-tup}]: $\rdx{\runi} \equiv |(u_1 ... u_n)| == |(v_1 ... v_n)|$.
	\begin{description}
		\item[Case] $\rdx{} \subset u_i$ \ie $\rstep{\rr'}{u_i}{u_i'}$
			Join at $\rdx{\runi}'' \equiv  u_1 = v_1; \ldots u_i' = v_i; \ldots u_n = v_n$.
		\item[Case] $\rdx{} \subset v_j$ \ie $\rstep{\rr'}{v_j}{v_j'}$
			Join at $\rdx{\runi}'' \equiv  u_1 = v_1; \ldots u_j = v_j'; \ldots u_n = v_n$.
	\end{description}

\item[Case \rulename{seq-assoc}]: $\rdx{\runi} \equiv \rstep{}{(eu; e_1); e_2}{eu;(e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs, which as we're precluding \rulename{subst} is either in $eu$ or in $e_1$ or in $e_2$.
	\begin{description}
		\item[Case] $\rdx{} \subset eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1; e_2)$.
		\item[Case] $\rdx{} \subset e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1'; e_2)$.
		\item[Case] $\rdx{} \subset e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1; e_2')$.
		\item[Case] $\rdx{}$ spans $(eu; e_1)$ or $(eu; e_1); e_2$ via \rulename{fail-elim}.
			Join at $|fail|$.
	\end{description}

\item[Case \rulename{eqn-float}]: $\rdx{\runi} \equiv \rstep{}{v = (eu; e_1); e_2}{eu;(v = e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs, which as we're precluding \rulename{subst} is either in $v$, $eu$, $e_1$ or in $e_2$.
	\begin{description}
		\item[Case] $\rdx{} \subset v$ \ie $\rstep{\rr'}{v}{v'}$
			Join at $\rdx{\runi}'' \equiv eu; (v' = e_1; e_2)$.
		\item[Case] $\rdx{} \subset eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1; e_2)$.
		\item[Case] $\rdx{} \subset e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \subset e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1; e_2')$.
		\item[Case] $\rdx{}$ spans $(eu; e_1)$ or $v = (eu; e_1); e_2$ via \rulename{fail-elim}.
			Join at $|fail|$.
	\end{description}

\item[Case \rulename{choose}]: via \cref{lem:under-choose}.

\end{description}
\end{proof}

\begin{lemma}[Under \rulename{choose}] \label{lem:under-choose}
If $\rstep{\rulename{choose}}{\rdx{ch}}{\rdx{ch}'}$ and
	$\rdx{ch} \equiv E[\rdx{}]$ and
	$\rstep{\rr}{\rdx{}}{\rdx{}'}$
 then there exists $\rdx{ch}''$ such that
	$\rsteps{\rr}{\rdx{ch}'}{\rdx{ch}''}$ and
	$\rstep{\rulename{choose}}{E[\rdx{}']}{\rdx{ch}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{ch} \equiv E[\rdx{}]} && {E[\rdx{}']} \\
	{\rdx{ch}'} && {\rdx{ch}''}
	\arrow["{\rulename{choose}}"', from=1-1, to=2-1]
	\arrow["\rr", from=1-1, to=1-3]
	\arrow["{\rulename{choose}}", dotted, from=1-3, to=2-3]
	\arrow["\rr"', dotted, two heads, from=2-1, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
By the definition of \rulename{choose} we have
$$\rdx{ch} \equiv |SX^[CX^[e_1 choice e_2]]| \movesto |SX^[CX^[e_1] choice CX^[e_2]]| \equiv \rdx{ch}'$$
Split cases on where $\rdx{}$ occurs
\begin{description}
\item[Case $\rdx{} \subset e_1$] \ie \rstep{\rr}{e_1}{e_1'}, so join at $|SX^[CX^[e1'] choice CX^[e_2]]|$.
\item[Case $\rdx{} \subset e_2$] \ie \rstep{\rr}{e_2}{e_2'}, so join at $|SX^[CX^[e_1 choice e2']]|$.
\item[Case $\rdx{} \subset |e_1 choice e_2|$] \ie \rstep{\rr}{|e_1 choice e_2|}{|e_i|} where $e_{3-i}$ is $|fail|$
so join at $|SX^[CX^[e_i]]|$.
\item[Case $\rdx{} \subset CX$] \ie \rstep{\rr}{CX}{CX'} so join (via \emph{two} $\rr$ steps) at $|SX^[CX'^[e_1] choice CX'^[e_2]]|$.
\item[Case $\rdx{} \subset |CX^[e_1 choice e_2]|$] \ie $\rstep{\rr}{|CX^[e_1 choice e_2]|}{|CX'^[e1' choice e2']|}$,
so join at $|SX^[CX'^[e1'] choice CX'^[e2']]|$.
\end{description}
\end{proof}

\subsubsection{Normalization}

\begin{lemma}[Under-$\rcon$] \label{lem:under-n}
%
Let $\rr' = \rr - \rcon - \runi$.
%
If $\rstep{\rcon}{\rdx{\rcon}}{\rdx{\rcon}'}$ and
   $\rdx{\rcon} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then exists $\rdx{\rcon}''$ such that
   $\rstep{\rr'}{\rdx{\rcon}'}{\rdx{\rcon}''}$ and
   $\rstep{\rcon}{E[\rdx{}']}{\rdx{\rcon}''}$.
\end{lemma}

\begin{proof}
Let $\rcon : \rdx{\rcon} \movesto \rdx{\rcon}'$ be the $\rcon$ redex and split cases
on the reduction rule used in the step.
%
\begin{description}
\item[Case \rulename{exi-swap}]: \ie $\rcon: |def x (def y e)| \movesto |def y (def x e)|$.
Split cases on the position of $\rdx{}$.
	\begin{description}
	\item[Case $\rdx{} \subset e$]: \ie $\rstep{\rr'}{e}{e'}$; join at $|def x (def y e')|$.
	\item[Case $\rdx{} \subset |(def y e)|$]: \ie $y$ eliminated via an \rulename{exi-elim} or \rulename{eqn-elim}
		$\rstep{\rr'}{|def y e|}{e'}$; join at $|def x e'|$.
	\item[Case $\rdx{} \subset |(def x (def y e))|$]: \ie $x$ eliminated via an \rulename{exi-elim} or \rulename{eqn-elim}
		$\rstep{\rr'}{|def x (def y e)|}{|def y e'|}$; join at $|def y e'|$.
	\end{description}

\item[Case \rulename{exi-float}]: \ie $\rcon: |X^[def x e]| \movesto |def x (X^[e])|$.
Split cases on the position of $\rdx{}$.
	\begin{description}
	\item[Case $\rdx{} \subset e$]: \ie $\rstep{\rr'}{e}{e'}$; join at $|def x (X^[e'])|$.
	\item[Case $\rdx{} \subset |(def x e)|$]: \ie $x$ eliminated via an \rulename{exi-elim} or \rulename{eqn-elim}
		$\rstep{\rr'}{|def x e|}{e'}$; join at $|X^[e']|$.
	\item[Case $\rdx{} \subset X$]: \ie $\rstep{\rr'}{|X^[def x e]|}{|X'^[def x e']|}$; join at $|def x (X'^[e'])|$.
	\end{description}

\item[Case \rulename{subst-var}]: \ie $\rcon: |X^[x=y]|  \movesto |(subst X x y)^[x=y]|$.
	The only possible position of $\rdx{}$ is $\rdx{} \subset X$ \ie
	$\rstep{\rr'}{X^[x=y]}{X'^[x=y]}$; join at $|(subst X' x y)^[x=y]|$.

\item[Case \rulename{var-swap}]: \ie $\rcon:  |x=y| \movesto |y=x|$.
	Impossible to have $\rdx{} \subset |x=y|$.
\end{description}
\end{proof}

\subsubsection{Garbage Collection}

\begin{lemma}[Under-$\rgc$] \label{lem:under-g}
If $\rstep{\rgc}{\rdx{\rgc}}{\rdx{\rgc}'}$ and
	   $\rdx{\rgc} \equiv E[\rdx{}]$ where $E \not \equiv |hole|$ and
	   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rgc}''$ such that
	   $\rstepo{\rr}{\rdx{\rgc}'}{\rdx{\rgc}''}$ and
	   $\rstep{\rgc}{E[\rdx{}']}{\rdx{\rspc}''}$.
\end{lemma}

\begin{proof}
Let $\rgc : \rdx{\rgc} \movesto \rdx{\rgc}'$ be the $\rgc$ redex and split cases
on the reduction rule used in the step.
%
\begin{description}
\item[Case \rulename{val-elim}]: \ie $\rgc : |v;e| \movesto |e|$.
	Split cases on position of $\rdx{}$
	%
	\begin{description}
	\item[Case $\rdx{} \subset |v|$]: Join at $|e|$.
	\item[Case $\rdx{} \subset |e|$]: \ie $\rstep{\rr}{e}{e'}$; join at $|e'|$.
	\item[Case $\rdx{} \subset |v;e|$]: \ie $\rstep{\rulename{fail-elim}}{v;e}{|fail|}$ as $e \equiv X[|fail|]$; join at $|fail|$.
	\end{description}

\item[Case \rulename{fail-elim}]: \ie $\rgc : |X^[fail]| \movesto |fail|$.
	Then $\rstep{\rr}{|X^[fail]|}{|X'^[fail]|}$ hence join at $|fail|$.

\item[Case \rulename{exi-elim}]: \ie  $\rgc : |def (ys,x,zs) e| \movesto |def (ys,zs) e|$;
	%
	(We can generalize \rulename{exi-elim} to first use a sequence of \rulename{exi-swap} to bring the $|x|$ binder to the end
	before applying \rulename{exi-elim} as this does not change the order of the \emph{remaining} binders.)
	%
	%
	Split cases on position of $\rdx{}$
	%
	\begin{description}
	\item[Case $\rdx{} \subset |e|$]: \ie $\rstep{\rr}{e}{e'}$; join at $|def (ys,zs) e'|$.
	\item[Case $\rdx{} \subset |def (ys,x,zs) e|$]: \ie via \rulename{exi-swap}; join at $|def (ys,zs) e|$.
	\end{description}

\item[Case \rulename{eqn-elim}]: \ie $\rgc : |def x (X^[x = v;e])| \movesto |X^[e]|$ where $x \not \in \freevars{|X^[v;e]|}$.
	%
	(We can generalize \rulename{exi-elim} to first use a sequence of \rulename{exi-swap} to bring the $|x|$ binder to the end
	before applying \rulename{eqn-elim} as this does not change the order of the \emph{remaining} binders.)
	%
	Split cases on position of $\rdx{}$
	%
	\begin{description}
	\item[Case $\rdx{} \subset |v|$]: \ie $\rstep{\rr}{v}{v'}$; join at $|X^[e]|$.
	\item[Case $\rdx{} \subset |e|$]: \ie $\rstep{\rr}{e}{e'}$ (where $\freevars{e'} = \freevars{e}$); join at $|X^[e']|$.
	\item[Case $\rdx{} \subset |X|$]: \ie $\rstep{\rr}{|X^[x = v; e]|}{|X'^[x=v;e]|}$ (where $\freevars{X'} = \freevars{X}$); join at $|X'^[e]|$.
	\end{description}
\end{description}
\end{proof}

\subsubsection{Speculation}

\begin{lemma}[Under-$\rspc$] \label{lem:under-s}
	If $\rstep{\rspc}{\rdx{\rspc}}{\rdx{\rspc}'}$ and
	   $\rdx{\rspc} \equiv E[\rdx{}]$ where $E \not \equiv |hole|$ and
	   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
	then there exists $\rdx{\rspc}''$ such that
	   $\rstepo{\rr}{\rdx{\rspc}'}{\rdx{\rspc}''}$ and
	   $\rstep{\rspc}{E[\rdx{}']}{\rdx{\rspc}''}$.
\end{lemma}

\begin{proof}
Split cases on the rule used in  $\rstep{\rspc}{\rdx{\rspc}}{\rdx{\rspc}'}$.

\begin{description}
\item[Case] \rulename{one-fail} (symmetric \rulename{all-fail})
	Impossible as $\rdx{} \not \subset \rdx{\rspc}$.

\item[Case \rulename{one-value}]:
	Here $\tx{\rspc} \equiv |one v| \movesto |v|$.
	Hence $\rdx{} \subset |v|$ \ie $\rr : |v| \movesto |v'|$, so join at |v'|.
\item[Case \rulename{all-value}]:
	Here $\tx{\rspc} \equiv |all v| \movesto |tup (v)|$.
	Hence $\rdx{} \subset |v|$ \ie $\rr : |v| \movesto |v'|$, so join at |(v')|.

\item[Case \rulename{one-choice}]:
	Here $\tx{\rspc} \equiv |one (v `choice` e)| \movesto |v|$.
	If $\rdx{} \subset |v|$, \ie $\rr : |v| \movesto |v'|$ then join at $|v'|$.
	If $\rdx{} \subset |e|$, \ie $\rr : |e| \movesto |e'|$ then join at $|v|$.

\item[Case \rulename{all-choice}]:
	Here $\tx{\rspc} \equiv |all (v_1 `choice` dots `choice` v_n)| \movesto |tup (v_1,dots,v_n)|$.
	%
	If $\rdx{} \subset |v_i|$ ie $\rr : |v_i| \movesto |v_i'|$
	then join at $|tup (v_1,dots,v_i',dots, v_n)|$.

\item[Case \rulename{choose-l}]: (symmetric \rulename{choose-r})
	Here $\tx{\rspc} \equiv |fail choice e| \movesto e$.
	Here, $\rdx{} \subset e$, \ie $\rr : e \movesto e'$ so join at $|e'|$.

\item[Case \rulename{choose-assoc}]: \ie $\tx{\rspc} \equiv (e_1 |choice| e_2) |choice| e_3 \movesto e_1 |choice| (e_2 |choice| e_3)$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
	\item[Case] $\rdx{} \subset e_1$, \ie $\rr : e_1 \movesto e_1'$ so join at $e_1' |choice| (e_2 |choice| e_3)$.
	\item[Case] $\rdx{} \subset e_2$, \ie $\rr : e_2 \movesto e_2'$ so join at $e_1 |choice| (e_2' |choice| e_3)$.
	\item[Case] $\rdx{} \subset e_3$, \ie $\rr : e_3 \movesto e_3'$ so join at $e_1 |choice| (e_2 |choice| e_3')$.
	\item[Case] $\rdx{} \equiv  |e_1 `choice` fail|$, \ie $\rr : |e_1 choice fail| \movesto e_1$ so join at $e_1 |choice| e_3$.
	\item[Case] $\rdx{} \equiv  |fail `choice` e_2|$, \ie $\rr : |fail choice e_2| \movesto e_2$ so join at $e_2 |choice| e_3$.
	\end{description}
\end{description}
\end{proof}


\subsection{Lemmas for Substitution and Unification} \label{sec:unify-lemmas}

\begin{lemma}[Substitution] \label{lem:subst}
	Let $\rr' \equiv \rr - \runi$.
	If $\rstep{\rr'}{\rdx{}}{\rdx{}'}$ then $\rstep{\rr'}{\subst{\rdx{}}{x}{v}}{\subst{\rdx{}'}{x}{v}}$.
\end{lemma}

\begin{proof} By induction on the structure of $\rdx{}$, splitting cases on the reduction rule used
	and using the fact that $|e|, |v|, |X|, |CX|, |SX|$ are all closed under value substitution.
\end{proof}

\begin{lemma}[Subst-Swap] \label{lem:subst-swap-c}
If $\rstep{\rulename{subst}}{e}{e_1}$ and $\rstep{\rulename{swap}}{e}{e_2}$
then exists $e'$ such that $\rsteps{\runi}{e_1, e_2}{e'}$.
\end{lemma}

\begin{proof}
Let $\rstep{\rulename{subst}}{\rdx{1}}{\rdx{1}'}$
and $\rstep{\rulename{swap}}{\rdx{2}}{\rdx{2}'}$
be the respective reducts. Via \cref{lem:disjoint}
it suffices to consider two cases:
\begin{description}
\item[Case \rulename{swap} under \rulename{subst}]: \ie $\rdx{2} \subset \rdx{1}$
Let $\rdx{1} \equiv |X^[x==v]|$; split cases on $\rdx{2}$ position.
	\begin{description}

	\item[Case $\rdx{2} \equiv |x==v|$]: via rule \rulename{var-swap}:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x=y]} && {X\{y/x\}[x=y]} \\
	&& {X\{y/x\}[y=x]} \\
	{X[y=x]} && {X\{x/y\}[y=x]}
	\arrow["\runi", from=1-1, to=1-3]
	\arrow["{\rr'}", dotted, from=1-3, to=2-3]
	\arrow["{\rr'}"', from=1-1, to=3-1]
	\arrow["\runi", dotted, from=3-1, to=3-3]
	\arrow["\runi", dotted, from=2-3, to=3-3]
\end{tikzcd}\]


	\item[Case $\rdx{2} \subset v$]: \ie $\rstep{\rulename{swap}}{v}{v'}$.
	% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = v]} && {X\{v/x\}[x = v]} \\
	{X[x=v']} && {X\{v'/x\}[x=v']}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{swap}}"', from=1-1, to=2-1]
	\arrow["{\rulename{subst}}"', dotted, from=2-1, to=2-3]
	\arrow["{\rulename{swap}\ (\text{repeat at each}\ v)}", dotted, two heads, from=1-3, to=2-3]
\end{tikzcd}\]
	\item[Case $\rdx{2} \subset X$]: \ie $X \equiv X'[\ldots \rdx{2} \ldots]$.
 		Let $u' \equiv \subst{u}{x}{v}$, split cases on \rulename{swap} RHS.
		\begin{description}
		\item[Case same variable]: $\rdx{2} \equiv |u == x|$ where $u$ is HNF or variable.
		% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X'[\ldots u = x \ldots][x = v]} && {X'\{v/x\}[\ldots u' = v \ldots][x = v]} \\
	& {} & \bullet \\
	{X'[\ldots x = u \ldots][x = v]} && {X'\{v/x\}[\ldots v = u' \ldots][x=v]}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{*-swap}}"', from=1-1, to=3-1]
	\arrow["{\rulename{subst}}"', dotted, from=3-1, to=3-3]
	\arrow[dotted, two heads, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=3-3, to=2-3]
	\arrow["{\cref{lem:eq-join-flip}}"{description, pos=0.7}, draw=none, from=2-2, to=2-3]
\end{tikzcd}\]
		\item[Case different variable]: $\rdx{2} \equiv |u == y|$ where $u$ is HNF or variable.
		\end{description}
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X'[\ldots u = y \ldots][x = v]} && {X'\{v/x\}[\ldots u' = y \ldots][x = v]} \\
	\\
	{X'[\ldots y = u \ldots][x = v]} && {X'\{v/x\}[\ldots y = u' \ldots][x=v]}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{swap}}"', from=1-1, to=3-1]
	\arrow["{\rulename{subst}}"', dotted, from=3-1, to=3-3]
	\arrow["{\rulename{swap}}", dotted, from=1-3, to=3-3]
\end{tikzcd}\]
	\end{description}
\item[Case \rulename{subst} under \rulename{swap}]: \ie $\rdx{1} \subset \rdx{2}$
   Let $\rdx{2} \equiv |hnf == x|$, so $\rdx{1} \subset |hnf|$, \ie $\rstep{\rulename{subst}}{|hnf|}{|hnf'|}$,
   so join at $|x = hnf'|$.
   % https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\mathit{hnf} = x} && {\mathit{hnf}' = x} \\
	{x = \mathit{hnf}} && {x = \mathit{hnf}'}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{swap}}"', from=1-1, to=2-1]
	\arrow["{\rulename{swap}}", dotted, from=1-3, to=2-3]
	\arrow["{\rulename{subst}}"', dotted, from=2-1, to=2-3]
\end{tikzcd}\]
\end{description}
\end{proof}

\begin{definition}[Levels]
Let $eu_1 \equiv |x_1 == v_1|$ and $eu_2 \equiv |x_2 == v_2|$ be two equations in a term $e$.
%
We say $eu_2$ \emph{is under} $eu_1$ if $eu_2 \subset X$ and $|X^[eu_1]| \subset e$.
\end{definition}

\begin{lemma}[Subst-Subst] \label{lem:subst-subst-c}
If $\rstep{\rulename{subst}}{e}{e_1}$ and $\rstep{\rulename{subst}}{e}{e_2}$
then $\join{\runi}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
Suppose that the reduct $\rstep{}{e}{e_i}$ is using the equation $eu_i \equiv |x_i == v_i|$. Split cases on
\begin{description}
\item[Case] $eu_1$ is under $eu_2$ and $eu_2$ is under $eu_1$:
	\cref{lem:subst-same} completes the proof.

\item[Case] $eu_1$ is under $eu_2$ and $eu_2$ is not under $eu_1$:
	\cref{lem:subst-diff} completes the proof.

\item[Case] $eu_1$ is not under $eu_2$ and $eu_2$ is under $eu_1$:
	\cref{lem:subst-diff} completes the proof.

\item[Case] $eu_1$ is not under $eu_2$ and $eu_2$ is not under $eu_1$:
	The substitutions are disjoint, so \cref{lem:disjoint} completes the proof.
\end{description}
\end{proof}


\begin{lemma}[Subst-Same] \label{lem:subst-same}
If $\rstep{\rulename{subst}}{e}{e_1}$ using $eu_1$ and
$\rstep{\rulename{subst}}{e}{e_2}$ using $eu_2$ such that
$eu_1$ is under $eu_2$ and $eu_2$ is under $eu_1$,
then $\join{\runi}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
As $eu_1$ is under $eu_2$ and $eu_2$ is under $eu_1$, we have $e \equiv |X^[x = v_1; y = v_2]|$,
\ie wlog the equations $eu_1$ and $eu_2$ are adjacent. Let us split cases on whether $x \equiv y$
\begin{description}
\item[Case $x \equiv y$]: We join $e_1$ and $e_2$ using \cref{lem:eq-join-flip}
via the context $X' \equiv |subst X x z|^[x = z]$ where $z$ is a fresh variable.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = u; x = v]} && {X\{u/x\}[x=u; u=v]} \\
	{X\{v/x\}[v = u; x = v]} && \bullet
	\arrow["{eu_2}"', from=1-1, to=2-1]
	\arrow["{eu_1}", from=1-1, to=1-3]
	\arrow[dotted, from=1-3, to=2-3]
	\arrow[dotted, from=2-1, to=2-3]
	\arrow["{\cref{lem:eq-join-flip}}"{description, pos=0.8}, draw=none, from=1-1, to=2-3]
\end{tikzcd}\]

\item[Case $x \not \equiv y$]: Let us split cases on whether $x, y$ appear in $\freevars{u}, \freevars{v}$ respectively.
	\begin{description}
	\item[Case $x \not \in \freevars{v}, y \not \in \freevars{u}$]:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = u; y = v]} && {X\{u/x\}[x=u; y=v]} \\
	{X\{v/x\}[x = u; y = v]} && {X\{v/x\}[x = u; y = v]}
	\arrow["{eu_2}"', from=1-1, to=2-1]
	\arrow["{eu_1}", from=1-1, to=1-3]
	\arrow["{eu_2}", dotted, from=1-3, to=2-3]
	\arrow["{eu_1}", dotted, from=2-1, to=2-3]
\end{tikzcd}\]

	\item[Case $x \not \in \freevars{v}, y \in \freevars{u}$]:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X[x = u; y = v]} && {X\{u/x\}[x=u; y=v]} \\
	{X\{v/y\}[x = u\{v/y\}; y = v]} && {X\{u\{v/y\}/x,v/y\}[x = u\{v/y\}; y = v]}
	\arrow["{eu_2}"', from=1-1, to=2-1]
	\arrow["{eu_1}", from=1-1, to=1-3]
	\arrow["{eu_2}", dotted, from=1-3, to=2-3]
	\arrow["{eu_1}", dotted, from=2-1, to=2-3]
\end{tikzcd}\]
	\item[Case $x \in \freevars{v}, y \not \in \freevars{u}$]: Symmetric to previous case.

	\item[Case $x \in \freevars{v}, y \in \freevars{u}$]: Join at |fail| if \rulename{u-occurs}, else
	impossible due to \norecursion.
	\end{description}
\end{description}
\end{proof}

\begin{lemma}[Subst-Diff] \label{lem:subst-diff}
If $\rstep{\rulename{subst}}{e}{e_1}$ using $eu_1$ and
$\rstep{\rulename{subst}}{e}{e_2}$ using $eu_2$ such that
$eu_1$ is not under $eu_2$ and $eu_2$ is under $eu_1$,
then $\join{\runi}{e_1}{e_2}$.
\end{lemma}

\begin{proof}
% As $eu_1$ is \emph{not under} $eu_2$ and $eu_2$ is under $eu_1$,
Here, we have $e \equiv X_1[ ... X_2[x_2 = v_2] ... ][x_1 = v_1]$
where the substitution with $|x_2=v_2|$ does not affect $X_1, x_1, v_1$.
%
Split cases on whether $x_1 \equiv x_2$.

\begin{description}
\item[Case $x_1 \equiv x_2 \equiv x$]: By \norecursion we have $x \not \in \freevars{v_1}, x \not \in \freevars{v_2}$.
Hence, we can join $e_1$ and $e_2$ using \cref{lem:eq-join} on the sub-terms
$\subst{X_2}{x}{v_1}[v_1=v_2]$ and $\subst{X_2}{x}{v_2}[v_1=v_2]$.
%
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x = v_2] \ldots][x = v_1]} & {} & {X_1[\ldots X_2\{v_2/x\}[x = v_2] \ldots][x = v_1]} \\
	{X_1\{v_1/x\}[\ldots X_2\{v_1/x\}[v_1 = v_2] \ldots][x = v_1]} & \bullet & {X_1\{v_1/x\}[\ldots X_2\{v_2/x\}[v_1 = v_2] \ldots][x = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}", from=1-1, to=1-3]
	\arrow["{eu_1}", dotted, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=2-1, to=2-2]
	\arrow[dotted, two heads, from=2-3, to=2-2]
	\arrow["{\cref{lem:eq-join}}"{description, pos=0.9}, draw=none, from=1-2, to=2-2]
\end{tikzcd}\]

\item[Case $x_1 \not \equiv x_2$]:
Let
	$|v_1'| \equiv \subst{v_1}{x_2}{v_2}$ and
	$|v_2'| \equiv \subst{v_2}{x_1}{v_1}$.
Split cases on whether $x_i \in \freevars{v_{3-i}}$.
\begin{description}
	\item[Case $x_2 \not \in \freevars{v_1}$]
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1[\ldots X_2\{v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	{X_1\{v_1/x_1\}[\ldots X_2\{v_1/x\}[x_2 = v_2'] \ldots][x_1 = v_1]} & {X_1\{v_1/x\}[\ldots X_2\{v_2'/x_2, v_1/x_1\}[x_2 = v_2'] \ldots][x_1 = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}"', dotted, from=2-1, to=2-2]
	\arrow["{eu_2}", from=1-1, to=1-2]
	\arrow["{eu_1}", dotted, from=1-2, to=2-2]
\end{tikzcd}\]

	\item[Case $x_2 \in \freevars{v_1}, x_1 \not \in \freevars{v_2}$]
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1[\ldots X_2\{v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	{X_1\{v_1/x_1\}[\ldots X_2\{v_1/x_1\}[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1\{v_1/x_1\}[\ldots X_2\{v_1/x_1, v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	& {X_1\{v_1/x_1\}[\ldots X_2\{v_1'/x_1, v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}", from=1-1, to=1-2]
	\arrow["{eu_1}", dotted, from=1-2, to=2-2]
	\arrow["{eu_2}"', dotted, from=2-1, to=3-2]
	\arrow["{eu_2}", dotted, from=2-2, to=3-2]
\end{tikzcd}\]
	\item[Case $x_2 \in \freevars{v_1}, x_1 \in \freevars{v_2}$] In this case, we get the below diagram
	where, since $x_2 \in \freevars{v_2'}$, the term $x_2 = v_2'$ either steps to |fail| (and so we can
	join at |fail|) or the term violates the \norecursion assumption.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_1[\ldots X_2[x_2 = v_2] \ldots][x_1 = v_1]} & {X_1[\ldots X_2\{v_2/x_2\}[x_2 = v_2] \ldots][x_1 = v_1]} \\
	{X_1\{v_1/x_1\}[\ldots X_2\{v_1/x_1\}[x_2 = v_2'] \ldots][x_1 = v_1]} & {X_1\{v_1/x_1\}[\ldots X_2\{v_1/x_1, v_2'/x_2\}[x_2 = v_2'] \ldots][x_1 = v_1]}
	\arrow["{eu_1}"', from=1-1, to=2-1]
	\arrow["{eu_2}", from=1-1, to=1-2]
	\arrow["{eu_1}", dotted, from=1-2, to=2-2]
\end{tikzcd}\]
\end{description}
\end{description}
\end{proof}

\mypara{Unification Lemmas} The next two \emph{unification} lemmas state
that our rewrite rules encode classical unification algorithms.

\begin{lemma}[Unify] \label{lem:eq-join}
If $\overline{z} \cap (\freevars{\overline{u}} \cup \freevars{\overline{v}}) = \emptyset$ then
$\join{\runi}{ \subst{X}{\overline{z}}{\overline{u}}[\overline{u = v}]}{ \subst{X}{\overline{z}}{\overline{v}}[\overline{u = v}]  }$
\end{lemma}

\begin{proof}
Let $X_{\overline{u}} \equiv \subst{X}{\overline{z}}{\overline{u}}$
and $X_{\overline{v}} \equiv \subst{X}{\overline{z}}{\overline{v}}$.
%
The proof follows by induction on the triple $(\sz{\text{free}}, \sz{\text{size}}, \sz{n})$ where
\begin{align*}
	\sz{\text{free}} & \doteq\ \sz{\freevars{\overline{u}}} + \sz{\freevars{\overline{v}}} \\
	\sz{\text{size}} & \doteq\ \Sigma_{i=1}^{n} \mathit{size}(u_i) + \mathit{size}(v_i) \\
	\sz{n}   	     & \doteq\ \mbox{the cardinality of}\ \overline{u}, \overline{v} \\
\end{align*}

Split cases on the \emph{first} equation $u_1 = v_1$.
\begin{description}
\item[Case $\hnf_1 = \hnf_2$] with \emph{incompatible} values:
	Here,

	$$\rstep{\rulename{u-fail}}
		{X_{\overline{u}}[\mathit{hnf}_1 = \mathit{hnf}_2; \overline{u'=v'}]}
		{X_{\overline{u}}[\mathtt{fail}]}
	$$
and
	$$\rstep{\rulename{u-fail}}
		{X_{\overline{v}}[\mathit{hnf}_1 = \mathit{hnf}_2; \overline{u'=v'}]}
		{X_{\overline{v}}[\mathtt{fail}]}
	$$
after which we can join at |fail| via \rulename{fail-elim}.
% RJ: commenting out diagram due to odd latex error (!)
%	join at |fail| via \rulename{u-fail} and \rulename{fail-elim}.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
% \[\begin{tikzcd}
% 	{X_{\overline{u}}[\mathit{hnf}_1 = \mathit{hnf}_2; \overline{u'=v'}]}; && {X_{\overline{u}}[\mathtt{fail}]} \\
% 	&& {\mathtt{fail}} \\
% 	{X_{\overline{v}}[\mathit{hnf}_1 = \mathit{hnf}_2; \overline{u'=v'}]} && {X_{\overline{v}}[\mathtt{fail}]}
% 	\arrow["{\rulename{u-fail}}", from=1-1, to=1-3]
% 	\arrow["{\rulename{u-fail}}"', dotted, from=3-1, to=3-3]
% 	\arrow[dotted, two heads, from=1-3, to=2-3]
% 	\arrow[dotted, two heads, from=3-3, to=2-3]
% \end{tikzcd}\]
\item[Case $|tup (u_1,dots,u_k) == tup(v_1,dots,v_k)|$] with tuples of the same arity $k$:
	use \rulename{u-tup} to get equations per component and join using the induction hypothesis,
	which is well-founded as the $\sz{\text{size}}$ is strictly smaller:
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_{\overline{u}}[\langle u_1,...,u_k\rangle = \langle v_1,...,v_k\rangle; \overline{u'=v'}]} && {X_{\overline{u}}[u_1=v_1,...,u_k=v_k; \overline{u'=v'}]} \\
	& {} & \bullet \\
	{X_{\overline{v}}[\langle u_1,...,u_k\rangle = \langle v_1,...,v_k\rangle; \overline{u'=v'}]} && {X_{\overline{v}}[u_1=v_1,...,u_k=v_k; \overline{u'=v'}]}
	\arrow["{\rulename{u-tup}}", from=1-1, to=1-3]
	\arrow["{\rulename{u-tup}}"', dotted, from=3-1, to=3-3]
	\arrow[dotted, two heads, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=3-3, to=2-3]
	\arrow["IH"{description, pos=0.8}, draw=none, from=2-2, to=2-3]
\end{tikzcd}\]
\item[Case $|x = y|$] use \rulename{subst} to replace all occurrences of $x$ with $y$, and then apply the
IH on the \emph{remaining} $n-1$ equations $\overline{u' = v'}$. Note that the induction is well-founded as
in this case $\sz{\text{free}}$ and $\sz{\text{size}}$ are unchanged but the number of equations decreases
by one.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_{\overline{u}}[x=y; \overline{u'=v'}]} && {X_{\overline{u}}\{y/x\}[x=y; \overline{u'\{y/x\}=v'\{y/x\}}]} \\
	& {} & \bullet \\
	{X_{\overline{v}}[x=y; \overline{u'=v'}]} && {X_{\overline{v}}\{y/x\}[x=y; \overline{u'\{y/x\}=v'\{y/x\}}]}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{subst}}"', dotted, from=3-1, to=3-3]
	\arrow[dotted, two heads, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=3-3, to=2-3]
	\arrow["IH"{description, pos=0.8}, draw=none, from=2-2, to=2-3]
\end{tikzcd}\]
\item[Case $|x = h|$] where $h$ is an HNF value and $x \not \in \freevars{h}$:
use \rulename{subst} to replace all occurrences of $x$ with $h$, and then apply the
IH on the remaining $n-1$ equations $\overline{u' = v'}$. Note that the induction is
well-founded in this case as $\sz{\text{free}}$ decreases since $x$ is removed from
the free variables of $\overline{u'}$ and $\overline{v'}$ and $X_{\overline{u}}$ and
$X_{\overline{v}}$ even though the $\sz{\text{size}}$ may increase due to the substitution.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{X_{\overline{u}}[x=h; \overline{u'=v'}]} && {X_{\overline{u}}\{h/x\}[x=h; \overline{u'\{h/x\}=v'\{h/x\}}]} \\
	& {} & \bullet \\
	{X_{\overline{v}}[x=h; \overline{u'=v'}]} && {X_{\overline{v}}\{h/x\}[x=h; \overline{u'\{h/x\}=v'\{h/x\}}]}
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["{\rulename{subst}}"', dotted, from=3-1, to=3-3]
	\arrow[dotted, two heads, from=1-3, to=2-3]
	\arrow[dotted, two heads, from=3-3, to=2-3]
	\arrow["IH"{description, pos=0.8}, draw=none, from=2-2, to=2-3]
\end{tikzcd}\]
\item[Case $|x = v|$] where $x \in \freevars{v}$: either join at |fail|
via \rulename{u-occurs} or violates the \norecursion assumption.
\end{description}
\end{proof}

\begin{lemma}[Unify-Flip] \label{lem:eq-join-flip}
If $\overline{z} \cap (\freevars{\overline{u}} \cup \freevars{\overline{v}}) = \emptyset$ then
$\join{\runi}{ \subst{X}{\overline{z}}{\overline{u}}[\overline{u = v}]}{ \subst{X}{\overline{z}}{\overline{v}}[\overline{v = u}]  }$
\end{lemma}

\begin{proof}
Same as \cref{lem:eq-join} except using \rulename{hnf-swap} and \rulename{var-swap}
to make the equations the same on both sides.
\end{proof}


\subsection{Unification is Confluent} % --------------------------------------------------------------------------

\newcommand{\runib}[1]{\ensuremath{\runi_{#1}}}
\newcommand{\runik}{\ensuremath{\runib{k}}}
\newcommand{\lamsub}[3]{\ensuremath{(\lambda #2. #3)[#1]}}
\newcommand{\unex}[1]{\ensuremath{\llparenthesis #1 \rrparenthesis}}

\begin{lemma}[$\runi$-Confluent] \label{lem:u-c}
$\runi$ is confluent.
\end{lemma}

\begin{proof}
We prove that $\runi$ is confluent via the following strategy inspired by the \emph{labeled reductions} \cite{Levy76}.
%
Let $\runik$ which is a subset of $\runi$ that only applies reductions to
terms that are \emph{under less than} $k$ $\lambda$s.
%
\begin{enumerate}
\item First, we show that $\runik$ is \emph{locally confluent} for all $k$ (\cref{lem:uk-lc}).
\item Second, we show that $\runik$ is \emph{terminating} for all $k$ (\cref{lem:uk-term}).
\item Third, consequently, by \cref{lem:local} we obtain that $\runik$ is confluent for all $k$.
\item Finally, we show that $\runi$ is confluent by using the largest $k$ in two traces, to join two
arbitrary sequences of $\runi$ reductions \cref{lem:uk-join}.
\end{enumerate}
\end{proof}


