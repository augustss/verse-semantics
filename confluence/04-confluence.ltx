\section{Confluence of \calcname: Proof} \label{sec:confluence}

\begin{definition}[Reductions] \label{def:reductions}
Let $\rr$ be the reduction relation defined as $\runi \cup \rcon \cup \rapp \cup \rgc$,
each of which is defined as the reduction relation induced by the following
rules in \cref{fig:rules}
%
\begin{itemize}
\item $\runi$ (Unification)
	\rulename{u-lit},
	\rulename{u-tup},
	\rulename{u-fail},
	\rulename{u-occurs},
	\rulename{subst},
	\rulename{hnf-swap},
	\rulename{var-swap},
	 %%%
	\rulename{choose},
	\rulename{seq-assoc},
	\rulename{eqn-float},
	\rulename{seq-swap};

\item $\rcon$ (Normalization)
	\rulename{exi-swap};
	\rulename{exi-float};
	\rulename{subst} (restricted to $|x == y|$),
	\rulename{var-swap};

\item $\rapp$ (Application)
	\rulename{app-add},
	\rulename{app-gt},
	\rulename{app-gt-fail},
	\rulename{app-beta},
	\rulename{app-tup},
	\rulename{app-tup-0};

\item $\rgc$ (Garbage Collection)
	\rulename{fail-elim},
	\rulename{val-elim},
	\rulename{exi-elim};
	\rulename{eqn-elim};

\item $\rspc$ (Speculation)
	\rulename{one-*},
	\rulename{all-*},
	\rulename{choose-*}.
\end{itemize}
%
\end{definition}

