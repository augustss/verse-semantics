\begin{lemma} \label{lem:ss-hops-exi}
\rss\ hops after \rulename{exi-swap}.
\end{lemma}
\begin{proof}
By splitting cases on the $\rss$
reduction that precedes the \rulename{exi-swap}.
\begin{description}
\item[Case \rulename{subst-var}] Trivial as as there is no overlap, so
any sequence of \rulename{subst-var} followed by \rulename{exi-swap}
is equivalent to first doing the \rulename{exi-swap} and then the \rulename{subst-var}.
\item[Case \rulename{var-swap}] Let the $\rdx{\rulename{swap}} \equiv |X^[x == y]|$.
%
	If the \rulename{exi-swap} preserves the order of $x$ and $y$ then the result follows
	trivially (as the reductions are non-overlapping.)
%
	If the \rulename{exi-swap} toggles the order then the result follows via the diagram
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\exists x, y. \ldots X[x=y]} && {\exists x, y. \ldots X[y=x]} \\
	{\exists y, x. \ldots X[x=y]} && {\exists y, x. \ldots X[y=x]}
	\arrow["{\rulename{exi-swap}}"', dotted, from=1-1, to=2-1]
	\arrow["{\rulename{var-swap}}"', dotted, tail reversed, no head, from=2-1, to=2-3]
	\arrow["{\rulename{exi-swap}}", from=1-3, to=2-3]
	\arrow["{\rulename{var-swap}}", from=1-1, to=1-3]
\end{tikzcd}\]
\end{description}
\end{proof}

\begin{lemma} \label{lem:exi-swap-con}
	\rulename{exi-swap} is confluent.
\end{lemma}

\begin{proof}
	Trivial, via the diamond property.
\end{proof}

\begin{lemma} \label{lem:ss-con}
	$\rss = \rulename{subst-var} + \rulename{swap}$ is confluent.
