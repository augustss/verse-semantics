The lemmas on the diagonal (resp. non-diagonal) entries establish confluence (resp. commutativity)
for the respective relation (resp. pairs of relations).}
\label{fig:confluence-summary}
\end{figure}

\begin{theorem}[Confluence] \label{thm:confluence}
The reduction relation $\rr$ is confluent.
\end{theorem}

\begin{proof}
First, we partition $\rr$ into the relations $\runi$, $\rapp$, $\rdis$, $\rfail$ and $\rspc$.
%
Next, we show that each of these relations is confluent and pairwise
commutative.
%
Finally, we use \cref{lem:comm-n} to prove their union $\rr$ is confluent.
\end{proof}

\section{Lemmas for Reductions-Under} \label{sec:under-lemmas}

\begin{lemma}[Disjoint] \label{lem:disjoint}
Let $e \equiv \ldots \rdx{1} \ldots \rdx{2} \ldots$
be an expression with two \emph{disjoint} reducts
$\rdx{1}$ and $\rdx{2}$.
%
If $\rstep{}{e}{\ldots \rdx{1}' \ldots \rdx{2} \ldots \equiv e_1}$ and
   $\rstep{}{e}{\ldots \rdx{1} \ldots \rdx{2}' \ldots \equiv e_2}$
then there exists $e'$ such that
		$\rstep{}{e_1}{e'}$ and
		$\rstep{}{e_2}{e'}$.
\end{lemma}

\begin{proof}
Trivial.
\end{proof}

In the rest of the proof, the above \cref{lem:disjoint} lemma
allows us to focus our attention on the cases where one reduct
\emph{occurs under} the other and vice versa.


\begin{lemma}[Under-$\rapp$] \label{lem:under-a}
If $\rstep{\rapp}{\rdx{\rapp}}{\rdx{\rapp}'}$ and
   $\rdx{\rapp} \equiv E[\rdx{}]$ and
   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rapp}''$ such that
   $\rstep{}{\rdx{\rapp}'}{\rdx{\rapp}''}$ and
   $\rstep{\rapp}{E[\rdx{}']}{\rdx{\rapp}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\rapp} \equiv E[\rdx{}]} & {E[\rdx{}']} \\
	{\rdx{\rapp}'} & {\rdx{\rapp}''}
	\arrow["\rapp"', from=1-1, to=2-1]
	\arrow["\rr", from=1-1, to=1-2]
	\arrow["\rapp", dotted, from=1-2, to=2-2]
	\arrow["\rr"', dotted, from=2-1, to=2-2]
\end{tikzcd}\]
\end{lemma}

\begin{proof} Split cases on the rule used in $\rapp$.
\begin{description}

\item[Case:] \rulename{app-beta} \ie $\tx{\rapp} \equiv (|lam x e|) |v| \movesto |def x (x == v; e)|$.
		If $\rdx{} \subset |e|$, \ie $\rr : e \movesto e'$, then join at $\rdx{\rapp}'' \equiv |def x (x == v; e')|$.
		If $\rdx{} \subset |v|$, \ie $\rr : |v| \movesto |v|'$, then join at $\rdx{\rapp}'' \equiv |def x (x == v'; e)|$.

\item[Case:] \rulename{app-tup} \ie $\tx{\rapp} \equiv |arr (v_0 dots v_n)| |v| \movesto |def x (x == v; (x == 0; v_0 `choice` dots `choice` x == n; v_n))|$.
		If $\rdx{} \subset |v_i|$, \ie $\rr: |v_i| \movesto |v_i|'$,
		then join at $|def x (x == v; (x == 0; v_0 `choice` dots x = i; v_i' dots `choice` x == n; v_n))|$.
		If $\rdx{} \subset |v|$, \ie $\rr: |v| \movesto |v|'$,
		then join at $|def x (x == v'; (x == 0; v_0 `choice` dots `choice` x == n; v_n))|$.

\item[Case:] \rulename{app-tup0} \ie $\tx{\rapp} \equiv |arr ()| |v| \movesto |fail|$.
		Here, $\rdx{} \subset v$, \ie $\rr: |v| \movesto |v|'$, then join at $\rdx{\rapp}'' \equiv |fail|$.

\item[Case:] \rulename{app-add}, \rulename{app-gt-*} In any of the primitive application rules, $\rdx{} \not\subset \rdx{\rapp}$.
\end{description}
\end{proof}

\begin{lemma}[Under-$\runi$] \label{lem:under-u}
%
Let $\rr' \equiv \rr - \rulename{subst}$.
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rstep{}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\rapp}{E[\rdx{}']}{\rdx{\runi}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} & {E[\rdx{}']} \\
	{\rdx{\runi}'} & {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rr'}", from=1-1, to=1-2]
	\arrow["\runi", dotted, from=1-2, to=2-2]
	\arrow["{\rr'}"', dotted, from=2-1, to=2-2]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case:] \rulename{subst} Here, $\rdx{\runi} \equiv X[x=v]
\item[Case:] \rulename{swap}
\item[Case:] \rulename{var-swap}
\item[Case:] \rulename{u-lit}
\item[Case:] \rulename{u-tup}
\item[Case:] \rulename{u-fail}
\item[Case:] \rulename{u-occurs}
\end{description}
\end{proof}

