	then exists
	   $\rsteps{\rulename{exi-float}}{e_1}{e_1'}$,
	   $\rsteps{\rulename{exi-float}}{e_2}{e_2'}$,
	such that
	   $\join{\rulename{exi-swap}}{e_1'}{e_2'}$.
\end{lemma}

\begin{proof}
On each side add the (missing) \rulename{exi-float} steps on the other side,
and then use (multiple) \rulename{exi-swap} to join.
\end{proof}

