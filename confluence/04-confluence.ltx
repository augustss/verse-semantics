\begin{lemma} \label{lem:f-exi-swap-join}
	If $\rsteps{\rulename{exi-float}}{e}{e_1}$ and
	   $\rsteps{\rulename{exi-float}}{e}{e_2}$
	then exists
	   $\rsteps{\rulename{exi-float}}{e_1}{e_1'}$,
	   $\rsteps{\rulename{exi-float}}{e_2}{e_2'}$,
	such that
	   $\join{\rulename{exi-swap}}{e_1'}{e_2'}$.
\end{lemma}

\begin{proof}
On each side add the (missing) \rulename{exi-float} steps on the other side,
and then use (multiple) \rulename{exi-swap} to join.
\end{proof}

\begin{lemma} \label{lem:f-rr-com}
\rulename{exi-float} strongly commutes with \rr - \rulename{exi-float}.
\end{lemma}

\begin{proof}
Split cases on each possible case of \rconm, the diamond is completed trivially as the rules are non-overlapping.
\end{proof}

\begin{lemma} \label{lem:m-pp-float}
\rconm strongly postpones after \rulename{exi-float},
so $\rcon^{*} \equiv \rulename{exi-float}^{*} \cdot \rconm^{*}$.
\end{lemma}

\begin{proof}
Split cases on each possible case of \rconm; the diamond is completed trivially as the rules are non-overlapping.
\end{proof}

