\subsection{Distillation: Normalization and Garbage Collection} % --------------------------------------------------------------------------


\begin{lemma}[$\rdis$-Confluent]%\label{lem:d-c}
    $\rdis$ is confluent.
\end{lemma}

\begin{proof}
We will show that $\rdis$ is locally confluent
via \cref{lem:d-local} and terminating \cref{lem:d-term},
and hence confluent by Newman's \cref{lem:local}.
\end{proof}

\begin{lemma} \label{lem:d-term}
    $\rdis$ is Noetherian.
\end{lemma}

\begin{proof}
Each step of $\rdis$ brings the term closer to a canonical \emph{normal form}
defined by the following grammar,
%
$$\begin{array}{rcl}
e_1 & := & |def x e_1| \vb e_2 \\
e_2 & := & |x == s ; e_2| \vb e_3 \\
e_3 & := & |x == h ; e_3| \vb e_4 \\
e_4 & := & |v| \vb \mathit{nv} \vb |v| = \mathit{nv} \\
\mathit{nv} & := & |v_1 v_2| \vb |e_1 `choice` e_1| \vb |one e_1| \vb |all e_1| \\
\end{array}$$
%
where each expression is either $|fail|$ or has
existentials at the top, then $|x == s|$ bindings,
then $|x == h|$ bindings, and no $|v|$ to the left of a semicolon.
%
Once a term is in this normalized form, no further $\rdis$ steps are possible.
%
\end{proof}

\begin{lemma}[$\rdis$-LC]\label{lem:d-local}
$\rdis$ is locally confluent.
\end{lemma}

\begin{proof}
Suppose we have two $\rdis$-steps:
via the redux $\rdx{1} \movesto \rdx{1}'$ and
via the redux $\rdx{2} \movesto \rdx{2}'$.
%
Let us split cases on the relative positions of $\rdx{1}$ and $\rdx{2}$.
%
The case where $\rdx{1}$ is disjoint from $\rdx{2}$ is trivial.
%
Suppose that $\rdx{1} \subset \rdx{2}$ (the case where $\rdx{2} \subset \rdx{1}$ is symmetric).
%
Split cases on the $\rdis$ rule used in $\rdx{2}$.
%
\begin{description}
\item[Case:] \rulename{norm-val} \ie $\tx{2} \equiv |v; e| \movesto |e|$.
		If $\rdx{1} \subset |v|$, \ie $\rdis_{1}: |v| \movesto |v'|$, then join at $|e|$.
		If $\rdx{1} \subset |e|$, \ie $\rdis_{1}: |e| \movesto |e'|$, then join at $|e'|$.

\item[Case:] \rulename{norm-seq-assoc} \ie $\tx{2} \equiv (e_1; e_2); e_3 \movesto e_1; (e_2 ; e_3)$.
		If $\rdx{1} \subset e_1$, \ie $\rdis_{1}: e_1 \movesto e_1'$, then join at $(e_1'; (e_2; e_3)$.
		If $\rdx{1} \subset e_2$, \ie $\rdis_{1}: e_2 \movesto e_2'$, then join at $(e_1; (e_2'; e_3)$.
		If $\rdx{1} \subset e_3$, \ie $\rdis_{1}: e_3 \movesto e_3'$, then join at $(e_1; (e_2; e_3'))$.
		If $e_1 \equiv |def x e_1'|$ and $\rdx{1} \subset e_1; e_2$ via \rulename{norm-seq-defr}
			then join at $|def x (e_1'; (e_2; e_3))|$.
		If $e_2 \equiv |def x e_2'|$ and $\rdx{1} \subset e_1; e_2$ via \rulename{norm-seq-defl}
			then join at $|def x (e_1; (e_2'; e_3))|$.
		If $\rdx{1} \subset e_1; e_2$ via \rulename{norm-seq-defr} where $e_1 \equiv |def x e_1'|$,
			then join at $|def x (e_1'; (e_2; e_3))|$.
		If $\rdx{1} \subset e_1; e_2$ via \rulename{norm-seq-defl} where $e_2 \equiv |def x e_2'|$
			then join at $|def x (e_1; (e_2'; e_3))|$.
		If $\rdx{1} \subset e_1; e_2$ via \rulename{norm-seq-swap-*} where $e_2 \equiv |x == v; e_2'|$
			then join at $|def x (x==v; (e_1; (e_2'; e_3)))|$.
		If $\rdx{1} \subset e_1; e_2$ via \rulename{norm-eq} where $e_2 \equiv |x == v'|$
			then join at $(e_1; (x = |v|; (x; e_3)))$.

\item[Case:] \rulename{norm-seq-swap} \ie $\tx{2} \equiv |e_1; x == v; e_2| \movesto |x == v; e_1; e_2|$.
	If $\rdx{1} \subset |e_1|$, \ie $\rdis_{1}: e_1 \movesto e_1'$, then join at $x = |v|; e_1'; e_2$.
	If $\rdx{1} \subset |e_2|$, \ie $\rdis_{1}: e_2 \movesto e_2'$, then join at $x = |v|; e_1; e_2'$.
	If $e_1 \equiv |def y e_1'|$ and $\rdx{1} \subset |e_1; (x == v; e_2)|$ via \rulename{norm-seq-defr}
		then join at $|def y (x == |v|; e_1'; e_2)|$.
	If $e_2 \equiv |def y e_2'|$ and $\rdx{1} \subset |e_1; (x == v; e_2)|$ via \rulename{norm-seq-defl}
		then join at $|def y (x == |v|; e_1; e_2')|$.

\item[Case:] \rulename{norm-swap-eq} \ie $\rdx{2} \equiv \hnf = x \movesto x = \hnf \equiv \rdx{2}'$.
	Here $\rdx{1} \subset \hnf$, \ie $\rdis_{1}: \hnf \movesto \hnf'$, hence join at $x = \hnf'$.

\item[Case:] \rulename{norm-seq-defr} \ie $\rdx{2} \equiv |def x e_1; e_2| \movesto |def x (e_1; e_2)| \equiv \rdx{2}'$.
	If $\rdx{1} \subset e_1$, \ie $\rdis_{1} : e_1 \movesto e_1'$, then join at $|def x e_1'; e_2|$.
	If $\rdx{1} \subset e_2$, \ie $\rdis_{1} : e_2 \movesto e_2'$, then join at $|def x e_1; e_2'|$.
    If $\rdx{1} \subset |def x e_1; e_2|$ via \rulename{norm-seq-defl} where $e_2 \equiv |def y e_2'|$
		then join at $|def x (def y (e_1; e_2'))|$ (using structural equivalance \rulename{swap-d}).
    If $\rdx{1} \subset |def x e_1|$ via \rulename{elim-def} where $\rgc : |def x e_1| \movesto e_1'$
		then by \cref{lem:wf-shape} $\rsteps{\rcon}{|e_1|}{|def xs (cs; e_1')|}$ where $x, |xs|$ not in $\freevars{e_1'}$.
		Hence, $\rsteps{\rcon}{|def x (e_1; e_2)}{def x (def xs (cs; e_1'; e_2))}$ after which we do another \rulename{elim-def}
		and join at $e_1'; e_2$.

\item[Case:] \rulename{norm-seq-defl} \ie $\tx{2} \equiv |e_1; def x e_2| \movesto |def x (e_1; e_2)|$.
	Symmetric to the previous case.

\item[Case:] \rulename{norm-defr} \ie $\rdx{2} \equiv |v| = |(def y e)| \movesto |def y (v == e)| \equiv \rdx{2}'$.
	If $\rdx{1} \subset v$, \ie $\rdis_{1} : v \movesto v'$, then join at $|def y (v' == e)|$.
	If $\rdx{1} \subset e$, \ie $\rdis_{1} : e \movesto e'$, then join at $|def y (v == e')|$.
	%
    If $\rdx{1} \subset |def y e|$ via \rulename{elim-def} where $\rgc : |def y e| \movesto e'$
		then by \cref{lem:wf-shape} $\rsteps{\rcon}{|e|}{|def xs (cs; e')|}$ where $x, |xs|$ not in $\freevars{e'}$.
		Hence, $\rsteps{\rcon}{|def y (v = e)}{def y (def xs (cs; v = e'))}$ after which we do another \rulename{elim-def}
		to join at $v = e'$.

\item[Case:] \rulename{norm-seqr} \ie $\rdx{2} \equiv |v == e_1; e_2| \movesto |e_1; v == e2| \equiv \rdx{2}'$.
    If $\rdx{1} \subset v$,   \ie $\rdis_{1} : v \movesto v'$,     then join at $|e_1; v' == e2|$.
    If $\rdx{1} \subset e_1$, \ie $\rdis_{1} : e_1 \movesto e_1'$, then join at $|e_1'; v == e_2|$.
    If $\rdx{1} \subset e_2$, \ie $\rdis_{1} : e_2 \movesto e_2'$, then join at $|e_1; v == e_2'|$.

\item[Case:] \rulename{norm-unifyr} \ie $\rdx{\rcon} \equiv |v_1 == (v_2 == e)| \movesto |def x (x == v_1; x == v_2; x == e)|$.
	If $\rdx{1} \subset v_1$, \ie $\rdis_{1} : v_1 \movesto v_1'$, then join at $|def x (x == v_1'; x == v_2; x == e)|$.
	If $\rdx{1} \subset v_2$, \ie $\rdis_{1} : v_2 \movesto v_2'$, then join at $|def x (x == v_1; x == v_2'; x == e)|$.
	If $\rdx{1} \subset e$  , \ie $\rdis_{1} : e   \movesto e'$,   then join at $|def x (x == v_1; x == v_2; x == e')|$.

\item[Case:] \rulename{elim-def} via \cref{lem:under-g} and \cref{lem:g-c}.
\end{description}
\end{proof}

\begin{lemma}[$\rdis-\rfail$-Comm] \label{lem:d-f-c}
$\rdis$ and $\rfail$ commute.
\end{lemma}

\begin{proof}
Via \cref{lem:c-f-c} and \cref{lem:g-f-c} and \cref{lem:comm-union}.
\end{proof}


\begin{lemma}[$\rcon-\rfail$-Comm] \label{lem:c-f-c}
$\rcon$ and $\rfail$ commute.
\end{lemma}

\begin{proof}
We show that $\rcon$ $*$-commutes with $\rfail$, hence commutes via \cref{lem:star-comm}.
%
Let $\tx{\rcon}$ and $\tx{\rfail}$ denote the reducts for $\rcon$ and $\rfail$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rcon}$ occurs under $\rdx{\rfail}$ or vice versa.

\begin{description}
\item[Case $\rdx{\rcon} \subset \rdx{\rfail}$] via \cref{lem:under-f}.
\item[Case $\rdx{\rfail} \subset \rdx{\rcon}$] Split cases on the rule used in $\rcon$.
	\begin{description}

	\item[Case:] \rulename{norm-val} \ie $\tx{\rcon} \equiv |v; e| \movesto |e|$.
		If $\rdx{\rfail} \subset |v|$, \ie $\rfail: |v| \movesto |v'|$, then join at $|e|$.
		If $\rdx{\rfail} \subset |e|$, \ie $\rfail: |e| \movesto |e'|$, then join at $|e'|$.

	\item[Case:] \rulename{norm-seq-assoc} \ie $\tx{\rcon} \equiv (e_1; e_2); e_3 \movesto e_1; (e_2 ; e_3)$.
		If $\rdx{\rfail} \subset e_1$, \ie $\rfail: e_1 \movesto e_1'$, then join at $(e_1'; (e_2; e_3)$.
		If $\rdx{\rfail} \subset e_2$, \ie $\rfail: e_2 \movesto e_2'$, then join at $(e_1; (e_2'; e_3)$.
		If $\rdx{\rfail} \subset e_3$, \ie $\rfail: e_3 \movesto e_3'$, then join at $(e_1; (e_2; e_3'))$.
		If $e_1 \equiv |fail|$ and $\rdx{\rfail} \subset e_1; e_2$ via \rulename{fail-seq-l}
			then join at $|fail|$ via multiple $\rfail$ steps.
		If $e_2 \equiv |fail|$ and $\rdx{\rfail} \subset e_1; e_2$ via \rulename{fail-seq-r}
			then join at $|fail|$ via multiple $\rfail$ steps.

	\item[Case:] \rulename{norm-seq-swap} \ie $\tx{\rcon} \equiv |e_1; x == v; e_2| \movesto |x == v; e_1; e_2|$.
		If $\rdx{\rfail} \subset |e_1|$, \ie $\rfail : e_1 \movesto e_1'$, then join at $x = |v|; e_1'; e_2$.
		If $\rdx{\rfail} \subset |e_2|$, \ie $\rfail : e_2 \movesto e_2'$, then join at $x = |v|; e_1; e_2'$.
		If $e_1 \equiv |fail|$ and $\rdx{\rfail} \subset |e_1; x == v; e_2|$ via \rulename{fail-seq-l}
			then join at $|fail|$ via multiple $\rfail$ steps.
		If $e_2 \equiv |fail|$ and $\rdx{\rfail} \subset |e_1; x == v; e_2|$ via \rulename{fail-seq-r}
			then join at $|fail|$ via multiple $\rfail$ steps.

	\item[Case:] \rulename{norm-swap-eq} \ie $\tx{\rcon} \equiv \hnf = x \movesto x = \hnf$.
		Here $\rdx{\rfail} \subset \hnf$, \ie $\rfail: \hnf \movesto \hnf'$, hence join at $x = \hnf'$.

	\item[Case:] \rulename{norm-seq-def*}
		In this case $\tx{\rcon} \equiv C[e_1, e_2] \movesto C'[e_1, e_2]$.
		If $\rdx{\rfail} \subset e_1$, \ie $\rfail: e_1 \movesto e_1'$, then join at $C'[e_1', e_2]$.
		If $\rdx{\rfail} \subset e_2$, \ie $\rfail: e_2 \movesto e_2'$, then join at $C'[e_1, e_2']$.

	% FIXME \rulename{norm-defr}, \rulename{norm-seqr}, \rulename{norm-unifyr}
	\item[Case:] \rulename{norm-defr} \ie $\rdx{\rcon} \equiv |v| = |(def y e)| \movesto |def y (v == e)|$.
		If $\rdx{\rfail} \subset v$, \ie $\rfail: v \movesto v'$, then join at $|def y (v' == e)|$.
		If $\rdx{\rfail} \subset v$, \ie $\rfail: v \movesto e'$, then join at $|def y (v == e')|$.

	\item[Case:] \rulename{norm-seqr} \ie $\rdx{\rcon} \equiv |v == (e_1; e_2)| \movesto |e_1; v == e2|$.
		If $\rdx{\rfail} \subset v$,   \ie $\rfail: v \movesto v'$,     then join at $|e_1; v' == e2|$.
		If $\rdx{\rfail} \subset e_1$, \ie $\rfail: e_1 \movesto e_1'$, then join at $|e_1'; v == e_2|$.
		If $\rdx{\rfail} \subset e_2$, \ie $\rfail: e_2 \movesto e_2'$, then join at $|e_1; v == e_2'|$.

	\item[Case:] \rulename{norm-unifyr} \ie $\rdx{\rcon} \equiv |v_1 == (v_2 == e)| \movesto |def x (x == v_1; x == v_2; x == e)|$.
		If $\rdx{\rfail} \subset v_1$, \ie $\rfail: v_1 \movesto v_1'$, then join at $|def x (x == v_1'; x == v_2; x == e)|$.
		If $\rdx{\rfail} \subset v_2$, \ie $\rfail: v_2 \movesto v_2'$, then join at $|def x (x == v_1; x == v_2'; x == e)|$.
		If $\rdx{\rfail} \subset e$  , \ie $\rfail: e   \movesto e'$,   then join at $|def x (x == v_1; x == v_2; x == e')|$.
		If $\rdx{\rfail} \subset |v_2 == e|$ via \rulename{fail-eq}, \ie $e \equiv |fail|$ hence join at $|fail|$ via multiple $\rfail$ steps.
	\end{description}
\end{description}
\end{proof}

\begin{lemma}[$\rgc-\rfail$-Comm] \label{lem:g-f-c}
	$\rgc$ and $\rfail$ commute.
\end{lemma}

\begin{proof}
We show that $\rfail$ strongly commutes with $\rgc$.
%
Let $\tx{\rfail}$ and $\tx{\rgc}$ denote the reducts for $\rfail$ and $\rgc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rfail}$ occurs under $\rdx{\rgc}$ or vice versa.
%
\begin{description}
\item[Case $\rdx{\rgc} \subset \rdx{\rfail}$] via \cref{lem:under-f}.

\item[Case $\rdx{\rfail} \subset \rdx{\rgc}$]
	Suppose that $\tx{\rgc} \equiv \exists x_1,\ldots. x_1=v_1; \ldots; e \movesto e$,
	where no $x_i \in \freevars{e}$.
	If $\rdx{\rfail} \subset e$, \ie $\rfail: e \movesto e'$,
		then as $\freevars{e'} \subseteq \freevars{e}$ we can join at $e'$.
	If $\rdx{\rapp} \subset v_i$, \ie $\runi : v_i \movesto v_i'$,
		then we can join at $e$.
\end{description}
\end{proof}

\begin{lemma}[Under-$\rcon$] \label{lem:under-c}
%
Let $\rr' = \rr - \rfail - \rgc - \rcon$.
%
If $\rstep{\rcon}{\rdx{\rcon}}{\rdx{\rcon}'}$ and
   $\rdx{\rcon} \equiv E[\rdx{}]$ and
   $\rstep{\rr'}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rcon}''$ such that
   $\rstep{\rr'}{\rdx{\rcon}'}{\rdx{\rcon}''}$ and
   $\rstep{\rcon}{E[\rdx{}']}{\rdx{\rcon}''}$.
\end{lemma}

\begin{proof}
Split cases on the rule used in $\rstep{\rcon}{\rdx{\rcon}}{\rdx{\rcon}'}$.
\begin{description}
%
\item[Case:] \rulename{norm-val} \ie $\rdx{\rcon} \equiv |v; e| \movesto |e| \equiv \rdx{\rcon}'$.
%
If $\rdx{} \subset |v|$, \ie $\rr': |v| \movesto |v'|$, then $\rdx{\rcon}'' \equiv |e|$.
If $\rdx{} \subset |e|$, \ie $\rr': |e| \movesto |e'|$, then $\rdx{\rcon}'' \equiv |e'|$.

\item[Case:] \rulename{norm-seq-assoc} \ie $\rdx{\rcon} \equiv (e_1; e_2); e_3 \movesto e_1; (e_2 ; e_3) \equiv \rdx{\rcon}'$.
If $\rdx{} \subset e_1$, \ie $\rr': e_1 \movesto e_1'$, then $\rdx{\rcon}'' \equiv (e_1'; (e_2; e_3)$.
If $\rdx{} \subset e_2$, \ie $\rr': e_2 \movesto e_2'$, then $\rdx{\rcon}'' \equiv (e_1; (e_2'; e_3)$.
If $\rdx{} \subset e_3$, \ie $\rr': e_3 \movesto e_3'$, then $\rdx{\rcon}'' \equiv (e_1; (e_2; e_3'))$.
If $\rdx{} \subset e_1;e_2$ \ie via \rulename{deref-s} $\rr' : e_1;e_2 \movesto e_1;e_2'$, then $\rdx{\rcon}'' \equiv e_1;(e_2';e_3)$.

\item[Case:] \rulename{norm-seq-swap-*} \ie $\rdx{\rcon} \equiv |e_1; x == v; e_2| \movesto |x == v; e_1; e_2| \equiv \rdx{\rcon}'$.
If $\rdx{} \subset |e_1|$, \ie $\rr' : e_1 \movesto e_1'$, then $\rdx{\rcon}'' \equiv x = |v|; e_1'; e_2$.
If $\rdx{} \subset |e_2|$, \ie $\rr' : e_2 \movesto e_2'$, then $\rdx{\rcon}'' \equiv x = |v|; e_1; e_2'$.
If $\rdx{} \subset |x==v;e_2|$ \ie via \rulename{deref-s} $\rr' : |x==v;e_2| \movesto |x==v;e_2'|$, then $\rdx{\rcon}'' \equiv |x==v; (e_1; e_2')|$.

\item[Case:] \rulename{norm-swap-eq} \ie $\tx{\rcon} \equiv \hnf = x \movesto x = \hnf$.
Here $\rdx{} \subset \hnf$, \ie $\rr': \hnf \movesto \hnf'$, hence $\rdx{\rcon}'' \equiv x = \hnf'$.

\item[Case:] \rulename{norm-seq-def*}, \ie $\rdx{\rcon} \equiv C[e_1, e_2] \movesto C'[e_1, e_2] \equiv \rdx{\rcon}'$.
If $\rdx{} \subset e_1$, \ie $\rr': e_1 \movesto e_1'$, then $\rdx{\rcon}'' \equiv C'[e_1', e_2]$.
If $\rdx{} \subset e_2$, \ie $\rr': e_2 \movesto e_2'$, then $\rdx{\rcon}'' \equiv C'[e_1, e_2']$.

\item[Case:] \rulename{norm-defr} \ie $\rdx{\rcon} \equiv |v| = |(def y e)| \movesto |def y (v == e)|$.
If $\rdx{} \subset v$, \ie $\rr': v \movesto v'$, then $\rdx{\rcon}'' \equiv |def y (v' == e)|$.
If $\rdx{} \subset e$, \ie $\rr': e \movesto e'$, then $\rdx{\rcon}'' \equiv |def y (v == e')|$.

\item[Case:] \rulename{norm-seqr} \ie $\rdx{\rcon} \equiv |v == e_1; e_2| \movesto |e_1; v == e2|$.
If $\rdx{} \subset v$, \ie $\rr': v \movesto v'$, then $\rdx{\rcon}'' \equiv |e_1; v' == e2|$.
If $\rdx{} \subset e_1$, \ie $\rr': e_1 \movesto e_1'$, then $\rdx{\rcon}'' \equiv |e_1'; v == e_2|$.
If $\rdx{} \subset e_2$, \ie $\rr': e_2 \movesto e_2'$, then $\rdx{\rcon}'' \equiv |e_1; v == e_2'|$.

\item[Case:] \rulename{norm-unifyr} \ie $\rdx{\rcon} \equiv |v_1 == (v_2 == e)| \movesto |def x (x == v_1; x == v_2; x == e)|$.
If $\rdx{} \subset v_1$, \ie $\rr': v_1 \movesto v_1'$, then $\rdx{\rcon}'' \equiv |def x (x == v_1'; x == v_2; x == e)|$.
If $\rdx{} \subset v_2$, \ie $\rr': v_2 \movesto v_2'$, then $\rdx{\rcon}'' \equiv |def x (x == v_1; x == v_2'; x == e)|$.
If $\rdx{} \subset e$  , \ie $\rr': e   \movesto e'$,   then $\rdx{\rcon}'' \equiv |def x (x == v_1; x == v_2; x == e')|$.

\end{description}
\end{proof}

\begin{lemma}[$\rdis-\rspc$-Comm] \label{lem:d-s-c}
	$\rdis$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
Via \cref{lem:c-s-c} and \cref{lem:g-s-c} and \cref{lem:comm-union}.
\end{proof}


\begin{lemma}[$\rcon-\rspc$-Comm] \label{lem:c-s-c}
	$\rcon$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
We show that $\rcon$ and $\rspc$ strongly commute, and hence commute.
%
Let $\tx{\rcon}$ and $\tx{\rspc}$ denote the reducts for $\rcon$ and $\rspc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rcon}$ occurs under $\rdx{\rspc}$ or vice versa.
%
\begin{description}
%
\item[Case $\rdx{\rspc} \subset \rdx{\rcon}$] via \cref{lem:under-c}.
%
\item[Case $\rdx{\rcon} \subset \rdx{\rspc}$] via \cref{lem:under-s}.
%
\end{description}
\end{proof}

\begin{lemma}[$\rfail$-Confluent] \label{lem:f-c}
	$\rfail$ is confluent.
\end{lemma}

\begin{proof}
We show that $\rfail$ has the diamond property hence is confluent.
%
Suppose we have two $\rfail$-steps:
via the redux $\rdx{1} \movesto \rdx{1}'$ and
via the redux $\rdx{2} \movesto \rdx{2}'$.
%
Let us split cases on the relative positions of $\rdx{1}$ and $\rdx{2}$.
%
The case where $\rdx{1}$ is disjoint from $\rdx{2}$ is trivial.
%
Suppose that $\rdx{1} \subset \rdx{2}$ (the case where $\rdx{2} \subset \rdx{1}$ is symmetric).
%
Split cases on the $\rfail$ rule used in $\rdx{2}$.
%
\begin{description}
\item[Case] \rulename{fail-seq-l} \ie $\tx{2} \equiv |fail|; e \movesto |fail|$.
		  	Here $\rdx{1} \subset e$ so join at $|fail|$.
\item[Case] \rulename{fail-seq-l} \ie $\tx{2} \equiv e; |fail| \movesto |fail|$.
		  	Here $\rdx{1} \subset e$ so join at $|fail|$.
\item[Case] \rulename{fail-eq} \ie $\tx{2} \equiv x = |fail| \movesto |fail|$.
			Here $\rdx{1} \not \subset \rdx{\rfail}$.
\end{description}
\end{proof}


\begin{lemma}[$\rfail-\rspc$-Comm] \label{lem:f-s-c}
	$\rfail$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
We show that $\rspc$ strongly commutes with $\rfail$.
%
Let $\tx{\rspc}$ and $\tx{\rfail}$ denote the reducts for $\rspc$ and $\rfail$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rspc}$ occurs under $\rdx{\rfail}$ or vice versa.
%
\begin{description}
\item[Case $\rdx{\rspc} \subset \rfail$] via \cref{lem:under-f}
\item[Case $\rdx{\rfail} \subset \rspc$] via \cref{lem:under-s}.
\end{description}
\end{proof}

\begin{lemma}[Under-$\rfail$] \label{lem:under-f}
If $\rstep{\rfail}{\rdx{\rfail}}{\rdx{\rfail}'}$ and
   $\rdx{\rfail} \equiv E[\rdx{}]$ and
   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rfail}''$ such that
   $\rstepo{\rr}{\rdx{\rfail}'}{\rdx{\rfail}''}$ and
   $\rstep{\rfail}{E[\rdx{}']}{\rdx{\rfail}''}$.
\end{lemma}

\begin{proof}
Split cases on the rule used in $\rdx{\rfail}$.
\begin{description}
\item[Case] \rulename{fail-seq-l} \ie $\tx{\rfail} \equiv |fail|; e \movesto |fail|$.
	Here $\rdx{} \subset e$ so $\rdx{\rfail}'' \equiv |fail|$.
\item[Case] \rulename{fail-seq-l} \ie $\tx{\rfail} \equiv e; |fail| \movesto |fail|$.
	Here $\rdx{} \subset e$ so $\rdx{\rfail}'' \equiv |fail|$.
\item[Case] \rulename{fail-eq} \ie $\tx{\rfail} \equiv x = |fail| \movesto |fail|$.
	Here $\rdx{} \not \subset \rdx{\rfail}$.
\end{description}
\end{proof}

\subsection{Garbage Collection} % --------------------------------------------------------------------------

\begin{lemma}[$\rgc$-Confluent] \label{lem:g-c}
	$\rgc$ has the diamond property, hence is confluent.
\end{lemma}

\begin{proof}
By \cref{lem:diamond} after showing that $\rgc$ satisfies the diamond property.
Suppose we have two $\rgc$-steps:
via the redux $\rdx{1} \movesto \rdx{1}'$ and
via the redux $\rdx{2} \movesto \rdx{2}'$.
%
Let us split cases on the relative positions of $\rdx{1}$ and $\rdx{2}$.
%
The case where $\rdx{1}$ is disjoint from $\rdx{2}$ is trivial.
%
Suppose that $\rdx{1} \subset \rdx{2}$ (the case where $\rdx{2} \subset \rdx{1}$ is symmetric).
%
Suppose that $\tx{2} \equiv \exists x_1,\ldots. x_1=v_1; \ldots; e \movesto e$,
where no $x_i \in \freevars{e}$.
\begin{description}
\item[Case $\rdx{1} \subset e$], \ie $\rgc_1: e \movesto e'$,
	then as $\freevars{e'} \subseteq \freevars{e}$ we can join at $e'$.
\item[Case $\rdx{1} \subset v_i$], \ie $\runi : v_i \movesto v_i'$,
	then we can join at $e$.
\item[Case $\rdx{1}$ and $\rdx{2}$ overlap], \ie the reducts are of the form
	$$\rgc_1 \equiv   \exists \overline{w},\overline{z},\overline{x},\overline{y}. x_1=\ldots; y_1=\ldots; z_1=\ldots; e
			 \movesto \exists \overline{w},\overline{z}. z_1=\ldots; e$$
	$$\rgc_2 \equiv   \exists \overline{w},\overline{y},\overline{x},\overline{z}. x_1=\ldots; z_1=\ldots; y_1=\ldots; e
			 \movesto \exists \overline{w},\overline{y}. y_1=\ldots; e$$
That is $\overline{x}$ denotes the common eliminated variables, $\overline{y}$ and $\overline{z}$ denote distinct
variables eliminated in the first and second redexes, and $\overline{w}$ denotes the variables not eliminated in
either step. Note that as each of the above is a valid \rgc step, the variables $\overline{y}$ and $\overline{z}$
do not appear free in $e$, and each binder is defined uniquely in the constraints $y_1=\ldots$ and $z_1=\ldots$.
Hence, we can perform a second GC step from each of the terms above and join them as:
	$$\rgc_1' \equiv   \exists \overline{w},\overline{z}. z_1=\ldots; e \movesto \exists \overline{y}. e$$
	$$\rgc_2' \equiv   \exists \overline{w},\overline{y}. y_1=\ldots; e \movesto \exists \overline{y}. e$$
\end{description}
\end{proof}

\begin{lemma}[$\rgc-\rspc$-Comm] \label{lem:g-s-c}
	$\rgc$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
We show that $\rgc$ and $\rspc$ strongly commute.
%
Let $\tx{\rgc}$ and $\tx{\rspc}$ denote the reducts for $\rgc$ and $\rgc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rgc}$ occurs under $\rdx{\rspc}$ or vice versa.
%
\begin{description}
\item[Case $\rdx{\rgc} \subset \rdx{\rspc}$:] via \cref{lem:under-s}.
\item[Case $\rdx{\rspc} \subset \rdx{\rgc}$:] via \cref{lem:under-g}.
\end{description}
%
\end{proof}

\begin{lemma}[Under-$\rgc$] \label{lem:under-g}
If $\rstep{\rgc}{\rdx{\rgc}}{\rdx{\rgc}'}$ and
   $\rdx{\rgc} \equiv E[\rdx{}]$ where $E \not \equiv |hole|$ and
   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rgc}''$ such that
   $\rstepo{\rr}{\rdx{\rgc}'}{\rdx{\rgc}''}$ and
   $\rstep{\rgc}{E[\rdx{}']}{\rdx{\rspc}''}$.
\end{lemma}

\begin{proof}
Suppose that $\rgc : \rdx{\rgc} \movesto \rdx{\rgc}'$ is a $\rgc$
redex via \rulename{elim-def}.
%
Then $\wff{\emptyset}{\rdx{\rgc}}{|xs|}{c_1 \dots c_n}{\rdx{\rgc}'}$
where $|xs| \not \in \freevars{\rdx{\rgc}'}$.
%
If $\rr : E[\rdx{}] \movesto E[\rdx{}']$ then by \cref{lem:wf-step}
we have $\wff{\emptyset}{E[\rdx{}'}{|xs|}{c_1' \dots c_n'}{e_2'}$
where either
%
(a)~$\rdx{\rgc}' \equiv e_2'$ or
%
(b)~$\rstep{}{\rdx{\rgc}'}{e_2'}$.
%
and hence, picking $\rdx{\rgc}''$ to be $e_2'$ completes the proof.
\end{proof}

\begin{lemma}[WF-Shape] \label{lem:wf-shape}
If $\wff{\Gamma}{e}{|xs|}{|cs|}{e'}$
then $\rsteps{\rcon}{e}{|def xs (cs; e')|}$.
\end{lemma}

\begin{proof}
By induction on the derivation of $\wff{\Gamma}{e}{|xs|}{|cs|}{e'}$.
\end{proof}

\begin{lemma}[WF-Step] \label{lem:wf-step}
If $\wff{\emptyset}{e_1}{|xs|}{c_1 \dots c_n}{e_2}$
   and $\rstep{}{e_1}{e_1'}$
then $\wff{\emptyset}{e_1'}{|xs|}{c_1' \dots c_n'}{e_2'}$ where either
%
(a) there exists $i$ such that  $\rstep{}{c_i}{c_i'}$ and $\forall j \neq i.\ c_j \equiv c_j'$ and $e_2 \equiv e_2'$,
or
(b) $\forall j.\ c_j \equiv c_j'$ and $\rstep{}{e_2}{e_2'}$.
%
\end{lemma}

\begin{proof}
By induction on the derivation of $\wff{\emptyset}{e_1}{|xs|}{|cs|}{e_2}$,
splitting cases on the rule used for $\rstep{\rr}{e_1}{e_1'}$.
\end{proof}


\subsection{Speculation} % --------------------------------------------------------------------------

\begin{lemma}[$\rspc$-Conf] \label{lem:s-c}
	$\rspc$ is confluent.
\end{lemma}

\begin{proof}
\cref{lem:under-s} shows that $\rspc$
has the diamond property (as $\rspc \subset \rr$),
and hence $\rspc$ is confluent via \cref{lem:diamond}.
\end{proof}

\begin{lemma}[Under-$\rspc$] \label{lem:under-s}
If $\rstep{\rspc}{\rdx{\rspc}}{\rdx{\rspc}'}$ and
   $\rdx{\rspc} \equiv E[\rdx{}]$ where $E \not \equiv |hole|$ and
   $\rstep{\rr}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\rspc}''$ such that
   $\rstepo{\rr}{\rdx{\rspc}'}{\rdx{\rspc}''}$ and
   $\rstep{\rspc}{E[\rdx{}']}{\rdx{\rspc}''}$.
\end{lemma}

\begin{proof}
Split cases on the rule used in  $\rstep{\rspc}{\rdx{\rspc}}{\rdx{\rspc}'}$.

\begin{description}

	\item[Case] \rulename{choose-assoc} \ie $\tx{\rspc} \equiv SX[(e_1 |choice| e_2) |choice| e_3] \movesto SX[e_1 |choice| (e_2 |choice| e_3)]$.
	Let us split cases on where $\rdx{}$ occurs.
		\begin{description}
		\item[Case] $\rdx{} \subset e_1$, \ie $\rr : e_1 \movesto e_1'$ so  $\rdx{\rspc}'' \equiv SX[e_1' |choice| (e_2 |choice| e_3)]$.
		\item[Case] $\rdx{} \subset e_2$, \ie $\rr : e_2 \movesto e_2'$ so  $\rdx{\rspc}'' \equiv SX[e_1 |choice| (e_2' |choice| e_3)]$.
		\item[Case] $\rdx{} \subset e_3$, \ie $\rr : e_3 \movesto e_3'$ so  $\rdx{\rspc}'' \equiv SX[e_1 |choice| (e_2 |choice| e_3')]$.
		\item[Case] $\rdx{} \equiv  |e_1 `choice` fail|$, \ie $\rr : |e_1 choice fail| \movesto e_1$ so  $\rdx{\rspc}'' \equiv SX[e_1 |choice| e_3)]$.
		\item[Case] $\rdx{} \equiv  |fail `choice` e_2|$, \ie $\rr : |fail choice e_2| \movesto e_2$ so  $\rdx{\rspc}'' \equiv SX[e_2 |choice| e_3)]$.
		\end{description}

	\item[Case] \rulename{choose-l} (symmetric \rulename{choose-r}) \ie $\tx{\rspc} \equiv SX[|fail choice e|] \movesto SX[e]$.
	Here, $\rdx{} \subset e$, \ie $\rr : e \movesto e'$ so $\rdx{\rspc}'' \equiv SX[e']$.

	\item[Case] \rulename{one-choice} (symmetric \rulename{one-value}, \rulename{all-value})
	Here $\tx{\rspc} \equiv |one (e_1 `choice` e_2)| \movesto e_1$ where $\wff{\emptyset}{e_1}{|xs|}{|cs|}{|v|}$.
	If $\rdx{} \subset e_1$, \ie $\rr : e_1 \movesto e_1'$ then by \cref{lem:wf-step}, $\rdx{\rspc}'' \equiv e_1'$.
	If $\rdx{} \subset e_2$, then join at $e_1$.

	\item[Case] \rulename{all-choice}
 	Here $\tx{\rspc} \equiv |all (e_1 `choice` dots `choice` e_n)| \movesto e'$
	where each $\wff{\emptyset}{e_i}{\overline{x_i}}{\overline{c_i}}{\overline{|v_i|}}$ and $e'$
	is the concatenation of binders, constraints and values of each $e_i$.
	If $\rdx{} \subset e_i$ ie $\rr : e_i \movesto e_i'$ then by \cref{lem:wf-step}
	$\wff{\emptyset}{e_i'}{\overline{x_i}}{\overline{c'_i}}{|v_i|'}$
	so $\rdx{\rspc}''$ is obtained by suitably concatenating the above binders, constraints and value
	with those of the other $e_j$.

	\item[Case] \rulename{one-fail} (symmetric \rulename{all-fail})
	Trivially $\rdx{} \not \subset \rdx{\rspc}$.
\end{description}
\end{proof}
