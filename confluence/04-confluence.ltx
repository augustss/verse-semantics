\subsection{Application} % --------------------------------------------------------------------------

\begin{lemma} \label{lem:a-c}
    $\rapp$ is confluent.
\end{lemma}

\begin{proof}
We show that $\rapp$ satisfies the diamond property and hence,
is confluent by \cref{lem:diamond}. Suppose that
%
$\rstep{\rapp}{e}{e_1}$ via the redux $\txr{\rapp}{1}$, and
%
$\rstep{\rapp}{e}{e_2}$ via the redux $\txr{\rapp}{2}$.
%
\simon{In $\tx{1}$ what is the subscript ``1'' on the arrow?  I expect to see a reduction relation there. Here it should be $\rapp$.  I'm baffled.} \ranjit{ACK:fixed, thanks!}
%
If $\rdx{1}$ and $\rdx{2}$ are disjoint in $e$, the terms $e_1$ and $e_2$
can be trivially joined in a single step.
%
If $\rdx{1} \occunder \rdx{2}$ (or $\rdx{2} \occunder \rdx{1}$) then \cref{lem:under-a} completes the proof.
\end{proof}




