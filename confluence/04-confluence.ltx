\subsection{Choice} % --------------------------------------------------------------------------

\begin{lemma} \label{lem:s-c}
	$\rspc$ is confluent.
\end{lemma}

\begin{proof}
\cref{lem:under-s} shows that $\rspc$
has the diamond property (as $\rspc \occunder \rr$),
and hence $\rspc$ is confluent via \cref{lem:diamond}.
\end{proof}
