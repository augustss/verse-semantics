\end{tikzcd}\]
\end{proof}

\begin{lemma} \label{lem:f-m-join}
	If $\rsteps{\rulename{norm-exi}}{e}{e_1}$ and
	   $\rsteps{\rulename{norm-exi}}{e}{e_2}$
	then exists
	   $\rsteps{\rulename{norm-exi}}{e_1}{e_1'}$,
	   $\rsteps{\rulename{norm-exi}}{e_2}{e_2'}$,
	   $\join{\rconm}{e_1'}{e_2'}$.
\end{lemma}

\begin{proof}
On each side add the (missing) \rulename{norm-exi} steps on the other side,
and then use (multiple) \rulename{exi-swap} (\rconm) to join.
\end{proof}

\begin{lemma} \label{lem:f-m-com}
\rulename{norm-exi} strongly commutes with \rconm.
\end{lemma}

\begin{proof}
Split cases on each possible case of \rconm, the diamond is completed trivially as the rules are non-overlapping.
\end{proof}

\begin{lemma} \label{lem:m-pp-float}
\rconm strongly postpones after \rulename{norm-exi},
so $\rcon^{*} \equiv \rulename{norm-exi}^{*} \cdot \rconm^{*}$.
\end{lemma}

\begin{proof}
Split cases on each possible case of \rconm; the diamond is completed trivially as the rules are non-overlapping.
\end{proof}

