\[\begin{tikzcd}
	e && {e'} \\
	\bullet && {e''}
	\arrow["{\rulename{exi-swap}}"', dotted, two heads, from=1-1, to=2-1]
	\arrow["\runi"', dotted, two heads, from=2-1, to=2-3]
	\arrow["\runi", dotted, two heads, from=1-3, to=2-3]
	\arrow["{\runi'}", two heads, from=1-1, to=1-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
(Similar to \cref{lem:hops-many-exi}),
By using \cref{lem:hops-many} with the facts that
%
\runi{} is confluent (\cref{lem:u-c}) and
%
$\runi$ \emph{hops after} $\rulename{exi-swap}$ (\cref{lem:u-hops-exi}).
\end{proof}

\begin{lemma} \label{lem:u-ue-com}
Let $\runi' = \runi + \rulename{exi-swap}$.
\runi' commutes with \runi.
\end{lemma}

\begin{proof}
%
The proof follows by observing that
$\runi$ \emph{\halfcommutes} with \rulename{exi-swap} \cref{lem:u-half-com-exi},
recalling that $\runi$ is confluent \cref{lem:u-c}, after which \cref{lem:half-com}
yields the conclusion $\runi$ commutes with $\runi + \rulename{exi-swap} \equiv \runi'$.
\end{proof}

\begin{lemma} \label{lem:u-half-com-exi}
	$\runi$ \halfcommutes with \rulename{exi-swap}.
\end{lemma}

\begin{proof}
Same as \cref{lem:ss-half-com-exi}; the rules in \runi \emph{other than those}
in the subset $\rss$ trivially \halfcommutes as they do not overlap with \rulename{exi-swap}.
\end{proof}


\subsection{$\runi \cup \rcon$ Commute With $\rapp \cup \rgc \cup \rspc$} % ------------------------------------------------------------------------

\begin{lemma}[$\runi$-$\rapp$-Comm]\label{lem:u-a-c}
    $\runi$ and $\rapp$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ $*$-commutes with $\rapp$ and hence commutes via \cref{lem:star-comm}.
Let $\tx{\runi}$ and $\tx{\rapp}$ denote the reducts for $\runi$ and $\rapp$ respectively.

\begin{description}
\item[Case: $\rdx{\runi}$ and $\rdx{\rapp}$ disjoint] via \cref{lem:disjoint}.
\item[Case: $\rdx{\runi} \occunder \rdx{\rapp}$] via \cref{lem:under-a}.
\item[Case: $\rdx{\rapp} \occunder \rdx{\runi}$] via \cref{lem:under-u}.
\end{description}
\end{proof}

% ------------------------------------------------------------------------------------------------------------------------

\begin{lemma}[$\runi-\rgc$-Comm] \label{lem:u-g-c}
	$\runi$ and $\rgc$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ $*$-commutes commutes wth $\rgc$, and hence by \cref{lem:star-comm}, $\runi$ commutes wth $\rgc$.
%
Let $\tx{\runi}$ and $\tx{\rgc}$ denote the reducts for $\runi$ and $\rgc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rgc}$ or vice versa.
%
\begin{description}
	\item[Case] $\rdx{\runi} \occunder \rdx{\rgc}$: via \cref{lem:under-g}.
	\item[Case] $\rdx{\rgc} \occunder \rdx{\runi}$: via \cref{lem:under-u}.
\end{description}
%
\end{proof}

% ------------------------------------------------------------------------------------------------------------------------

\begin{lemma}[$\runi-\rspc$-Comm] \label{lem:u-s-c}
	$\runi$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
We show that $\runi$ $*$-commutes with $\rspc$, and hence by \cref{lem:star-comm}, $\runi$ commutes wth $\rspc$.
%
Let $\tx{\runi}$ and $\tx{\rspc}$ denote the reducts for $\runi$ and $\rspc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined.
%
Let us split cases on whether $\rdx{\runi}$ occurs under $\rdx{\rspc}$ or vice versa.
%
\begin{description}
\item[Case] $\rdx{\runi} \occunder \rdx{\rspc}$ via \cref{lem:under-s}.
\item[Case] $\rdx{\rspc} \occunder \rdx{\runi}$ via \cref{lem:under-u}.
\end{description}
\end{proof}

