	\arrow["\rss"', dotted, two heads, from=2-1, to=2-3]
	\arrow["\rss", dotted, two heads, from=1-3, to=2-3]
	\arrow["\rconm", two heads, from=1-1, to=1-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
By using \cref{lem:hops-many} with the facts that
%
\rss{} is confluent (\cref{lem:ss-con}) and
%
$\rss$ \emph{hops after} $\rulename{exi-swap}$ (\cref{lem:ss-hops-exi}).
\end{proof}

\begin{lemma} \label{lem:ss-hops-exi} \label{lem:u-hops-exi}
\rss (resp. \runi) hops after \rulename{exi-swap}.
\end{lemma}
\begin{proof}
By splitting cases on the \rss (resp. \runi) reduction that precedes the \rulename{exi-swap}.
\begin{description}
\item[Case \rulename{var-swap}] Let the $\rdx{\rulename{swap}} \equiv |X^[x == y]|$.
%
	If the \rulename{exi-swap} preserves the order of $x$ and $y$ then the result follows
	trivially (as the reductions are non-overlapping.)
%
	If the \rulename{exi-swap} toggles the order then the result follows via the diagram
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\exists x, y. \ldots X[x=y]} && {\exists x, y. \ldots X[y=x]} \\
	{\exists y, x. \ldots X[x=y]} && {\exists y, x. \ldots X[y=x]}
	\arrow["{\rulename{exi-swap}}"', dotted, from=1-1, to=2-1]
	\arrow["{\rulename{var-swap}}"', dotted, tail reversed, no head, from=2-1, to=2-3]
	\arrow["{\rulename{exi-swap}}", from=1-3, to=2-3]
	\arrow["{\rulename{var-swap}}", from=1-1, to=1-3]
\end{tikzcd}\]

\item[Case \emph{non}-\rulename{var-swap}]
An $\runi$ reduction \emph{other than} \rulename{var-swap}
is variable-order independent, so the sequence of \runi-step
followed by \rulename{exi-swap} is equivalent to first doing
the \rulename{exi-swap} and then the \runi step.
\end{description}
\end{proof}

\begin{lemma} \label{lem:exi-swap-con}
	\rulename{exi-swap} is confluent.
\end{lemma}

\begin{proof}
	Trivial, via the diamond property.
\end{proof}

\begin{lemma} \label{lem:ss-con}
	$\rss = \rulename{subst-var} + \rulename{swap}$ is confluent.
\end{lemma}

\begin{proof}
Note that $\rss$ is a subset of $\runi$; the proof follows similar to the
proof of \cref{lem:u-c} (ignoring the bits about \rulename{u-tup} and
\rulename{u-lit} and \rulename{u-fail} and substituting HNF values.)
% \ranjit{TODO:tedious copy-paste}
\end{proof}

\begin{lemma} \label{lem:ss-m-com}
	\rss commutes with \rconm.
\end{lemma}

\begin{proof}
Recall that $\rconm \equiv \rss + \rulename{exi-swap}$.
%
The proof follows by observing that $\rss$ \emph{\halfcommutes} with \rulename{exi-swap} \cref{lem:ss-half-com-exi},
recalling that $\rss$ is confluent \cref{lem:ss-con}, after which \cref{lem:half-com} yields
the conclusion $\rss$ commutes with $\rss + \rulename{exi-swap} \equiv \rconm$.
\end{proof}


\begin{lemma} \label{lem:ss-half-com-exi}
	$\rss$ \halfcommutes with \rulename{exi-swap}.
\end{lemma}

\begin{proof}
Recall that $\rss \equiv \rulename{subst-var} + \rulename{var-swap}$.
Split cases and show each reduction \halfcommutes with \rulename{exi-swap}.
%
\begin{description}
\item[Case \rulename{subst-var}] As \rulename{subst-var} does not overlap with
  rulename{exi-swap}, it \halfcommutes trivially via the diamond property.

\item[Case \rulename{var-swap} (under \rulename{exi-swap})] The non-trivial cases are where the \emph{same}
  variables $x$, $y$ are being swapped by both rules (otherwise, the reductions
  \halfcommutes trivially via the diamond property).
  For the variables to be the same, the \rulename{var-swap}
  \emph{must} occur under the \rulename{exi-swap} (as otherwise the same variables
  are not in scope.) Hence, the proof is completed by the following diagram.
  % https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\exists x, y. \ldots X[x=y]} && {\exists y, x. \ldots X[x=y]} \\
	{\exists x, y. \ldots X[y=x]} && {\exists y, x. \ldots X[y=x]}
	\arrow["{\rulename{var-swap}}"', from=1-1, to=2-1]
	\arrow["{\rulename{exi-swap}}"', dotted, from=2-1, to=2-3]
	\arrow["{\rulename{var-swap}}", dotted, tail reversed, no head, from=1-3, to=2-3]
	\arrow["{\rulename{exi-swap}}", from=1-1, to=1-3]
\end{tikzcd}\]
\end{description}
\end{proof}

\subsection{Unification + Normalization is Confluent} % ------------------------------------------------------------------------

Recall that
\begin{align*}
\rcon & \doteq\ \rulename{exi-float} + \rulename{exi-swap} + \rss \\
\intertext{and define}
\runi' & \doteq \ \runi + \rulename{exi-swap} \\
\end{align*}

\begin{lemma}\label{lem:u-c-c}
	$\runi \cup \rcon$ is confluent.
\end{lemma}

\begin{proof}
%
We prove $\runi \cup \rcon$ is confluent by a generalization of the proof of \cref{lem:n-c}
where we use the full $\runi$ relation (instead of the subset $\rss$).
%
First we show that \runi' -- \ie $\runi \cup \rcon$ without-\rulename{exi-float} -- is confluent \cref{lem:ue-conf}.
%
Second we show that \runi' \emph{strongly postpones} after \rulename{exi-float} \cref{lem:u-pp-float}.
%
Consequently, each $\rsteps{\runi \cup \rcon}{}{}$ can be rewritten as the composition of
$\rsteps{\rulename{exi-float}}{}{}$ followed by $\rsteps{\runi'}{}{}$ after which
the following diagram completes the proof.

% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	&& \bullet \\
	\bullet &&&& \bullet \\
	& \bullet && \bullet \\
	\bullet && \bullet && \bullet \\
	\bullet &&&& \bullet \\
	& \bullet && \bullet \\
	&& \bullet
	\arrow["{\rulename{exi-float}}"{description}, two heads, from=1-3, to=2-1]
	\arrow["{\rulename{exi-float}}"{description}, two heads, from=1-3, to=2-5]
	\arrow["{\rulename{exi-float}}"{description}, dotted, two heads, from=2-1, to=3-2]
	\arrow["{\rulename{exi-float}}"{description}, dotted, two heads, from=2-5, to=3-4]
	\arrow["{\runi'}"{description}, dotted, two heads, from=3-2, to=4-3]
	\arrow["{\runi'}"{description}, dotted, two heads, from=3-4, to=4-3]
	\arrow["{\runi'}"{description}, two heads, from=2-1, to=4-1]
	\arrow["{\runi'}"{description}, two heads, from=2-5, to=4-5]
	\arrow["{\rulename{exi-float}}"{description}, dotted, two heads, from=4-1, to=5-1]
	\arrow["{\runi'}"', dotted, two heads, from=5-1, to=6-2]
	\arrow["{\runi'}"{description}, dotted, two heads, from=4-3, to=6-2]
	\arrow["{\runi'}"{description}, dotted, two heads, from=4-3, to=6-4]
	\arrow["{\rulename{exi-float}}"{description}, dotted, two heads, from=4-5, to=5-5]
	\arrow["{\runi'}", dotted, two heads, from=5-5, to=6-4]
	\arrow["{\runi'}"{description}, dotted, two heads, from=6-2, to=7-3]
	\arrow["{\runi'}"{description}, dotted, two heads, from=6-4, to=7-3]
	\arrow["{\cref{lem:f-exi-swap-join}}"{description, pos=0.7}, draw=none, from=1-3, to=4-3]
	\arrow["{\cref{lem:f-rr-com}}"{description, pos=0.8}, draw=none, from=2-1, to=6-2]
	\arrow["{\cref{lem:f-rr-com}}"{description, pos=0.8}, draw=none, from=2-5, to=6-4]
	\arrow["{\cref{lem:ue-conf}}"{description, pos=0.8}, draw=none, from=4-3, to=7-3]
\end{tikzcd}\]
\end{proof}

\begin{lemma} \label{lem:u-pp-float}
Let $\runi' \doteq \runi + \rulename{exi-swap}$.
%
\runi' strongly postpones after \rulename{exi-float},
so $\runi'^{*} \equiv \rulename{exi-float}^{*} \cdot \runi'^{*}$.
\end{lemma}

\begin{proof}
Same as \cref{lem:m-pp-float}.
\end{proof}

\begin{lemma} \label{lem:ue-conf}
Let $\runi' \doteq \runi + \rulename{exi-swap}$. $\runi'$ is confluent.
\end{lemma}

\begin{proof}
	Via the following diagram, where:
	(1)~is \cref{lem:hops-many-exi-u};
	(2)~is \cref{lem:u-ue-com};
	(3)~is \cref{lem:u-c};
	(4)~is \cref{lem:exi-swap-con}.
