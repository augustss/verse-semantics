%% LABELS: \end{definition}

\begin{definition}[$k$-Unification]
%
A $k$-labeled term is a term where each subterm
occurring under at most $k$ $\lambda$'s is marked
by a special label $\ell$.
%
Let $\runik$ be defined as the set of all $\runi$
reductions where:
%
(1)~the $\runi$-redex is a $\ell$-labeled or occurs under $\leq k$ $\lambda$s, and
%
(2)~the \rulename{subst} preserves labels.
%
\end{definition}

% LABELS: Next, we show that $\runik$ is locally confluent for all $k$.
% LABELS: Note that plain substitutions \emph{do not} satisfy this property.
% LABELS: %
% LABELS: For example, consider the following two $\runib{1}$ reductions,
% LABELS: %
% LABELS: $$\begin{array}{rcll}
% LABELS: 	x = (|lam a (1=1; 1)|); |lam z x|
% LABELS: 		& \movesto & x = (|lam a 1|); |lam z x| \movesto x = (|lam a 1|); (|lam z (lam a 1)|) & \ldots (e_1) \\
% LABELS: 		& \movesto & x = (|lam a (1=1;1)|); (|lam z (lam a (1=1;1))|)			  & \ldots (e_2)
% LABELS: \end{array}$$
% LABELS: %
% LABELS: We cannot directly join $e_2$ and $e_1$ as that would require a $\runib{2}$ step since the $|1=1;1|$
% LABELS: term in $e_2$ occurs under \emph{two} $\lambda$s.


% LABELS: \mypara{Explicit Substitutions}
% LABELS: %
% LABELS: To ensure local confluence of $\runik$ we use the method of
% LABELS: \emph{explicit substitutions} \cite{abadi-explicit}.
% LABELS: %
% LABELS: \cref{fig:explicit-subst} shows the definition of explicit
% LABELS: substitutions $\sigma$ which is a sequence $[x_1 \mapsto v_1, \ldots, x_n \mapsto v_n]$.
% LABELS: %
% LABELS: In $\runik$ any substitutions under lambda at level $\geq k$
% LABELS: is made \emph{explicit}. That is
% LABELS: %
% LABELS: $$\subst{\lambda y.e}{x}{|v|}  \ \doteq \ \begin{cases}
% LABELS: 	\lambda y. (\subst{e}{x}{|v|})  & \mbox{if level} < k \\
% LABELS:     \lamsub{[x \mapsto |v|]}{y}{e}  & \mbox{otherwise}
% LABELS: \end{cases}$$
% LABELS: %
% LABELS: Furthermore, we can define substitutions on explicit substitutions as
% LABELS: %%
% LABELS: \begin{align*}
% LABELS: \subst{[x_1 \mapsto |v_1|,\ldots,x_n \mapsto |v_n|]}{x}{|v|} & \doteq\  [x \mapsto |v|, x_1 \mapsto \subst{|v_1|}{x}{|v|},\ldots,x_n \mapsto \subst{|v_n|}{x}{|v|}] \\
