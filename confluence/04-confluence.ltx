\begin{lemma} \label{lem:uk-term}
\runib{k} is Noetherian.
\end{lemma}

\begin{proof}
%\ranjit{TODO:crispen}
By induction on $k$.
\begin{description}
	\item[Base case ($k \equiv 0$)] via \cref{lem:uk-term-0}.
	\item[Inductive case]
		Assume the induction hypothesis that $\runib{k}$
		is Noetherian and prove $\runib{k+1}$ is Noetherian.
		Consider any $c \equiv \overline{u = v}; ee$.
		We will prove  that it is only possible to take
		finitely many $\runib{k+1}$ steps from $c$.
		%
		Suppose there is an infinite trace starting from $c$.
		%
		By \cref{lem:uk-term-0} there is some finite prefix
		of the trace $\rsteps{\runib{k+1}}{e}{e'}$ after which
		there are no more $\runib{0}$ steps.
		%
		Note that $e'$ is finite and of the form $\ldots d_1 \ldots d_n \ldots$
		comprising disjoint terms $d_1 \ldots d_n$.
		%
		Every $\runib{k+1}$ reduction from $e'$ is a $\runib{k}$ reduction
		from some $d_i$.
		%
		By the induction hypothesis, each of these reduction sequences is finite,
		and hence the complete reduction sequence must be finite.
\end{description}
\end{proof}


\begin{lemma} \label{lem:uk-term-0}
\runib{0} is Noetherian.
\end{lemma}

\begin{proof}
We prove that for any term $c \equiv \overline{u = v}; ee$ that it is only possible to take
finitely many $\runib{0}$ steps from $c$. Let $\text{All}$ be the set $\freevars{u,v,ee}$.
%
The proof follows by lexicographic induction on the tuple
%
\begin{align*}
	\sz{\text{choose}} & \doteq\ \mbox{number of locations to apply \rulename{choose}} \\
	\sz{\text{semi}}   & \doteq\ \mbox{number of locations to apply \rulename{seq-assoc}, \rulename{eqn-float}} \\
	\sz{\text{free}}   & \doteq\ \mbox{number of variables in}\ \text{All} - \text{Used} \\ % TODO: "per" X-block ... ordered by X-block nesting
	\mbox{where}\ \sz{\text{Used}}   & \doteq\ \mbox{variables that have been used as LHS of \rulename{subst}} \\ % TODO: "per" X-block ... ordered by X-block nesting
	\sz{\text{size}}   & \doteq\ \Sigma_{i=1}^{n} \mathit{size}(u_i) + \mathit{size}(v_i) \\
	\sz{\text{swap}}   & \doteq\ \mbox{number of locations to apply \rulename{var-swap}} \\
\end{align*}
%
where \emph{locations} refers to places at ``level $0$'' (\ie not under a $\lambda$)
where the rule can be applied.
%
Each application of
%
\begin{itemize}
\item \rulename{choose} strictly reduces $\sz{\text{choose}}$;
\item \rulename{seq-assoc*} strictly reduces $\sz{\text{semi}}$ (leaving $\sz{\text{choose}}$ unchanged);
\item \rulename{subst} strictly reduces $\sz{\text{free}}$ (leaving $\sz{\text{semi}}$, $\sz{\text{choose}}$ unchanged);
\item \rulename{u-*} strictly reduces $\sz{\text{size}}$ (leaving $\sz{\text{free}}$, $\sz{\text{semi}}$, $\sz{\text{choose}}$ unchanged);
\item \rulename{swap-var} strictly reduces $\sz{\text{swap}}$ (leaving $\sz{\text{size}}$, $\sz{\text{free}}$, $\sz{\text{semi}}$, $\sz{\text{choose}}$ unchanged).
\end{itemize}
%
Thus, any sequence of $\runib{0}$ steps is well-founded and guaranteed to terminate.
%
\end{proof}


\begin{lemma} \label{lem:u-lc}
\runi{} is locally confluent.
\end{lemma}

\begin{proof}
Let $\tx{1}$ and $\tx{2}$ denote the two $\runi$ reducts.
%
If the reducts are disjoint, then the terms can be joined trivially in a single step via \cref{lem:disjoint}.
%
By symmetry it suffices to consider the case where $\rdx{1}$ occurs under $\rdx{2}$.
%
Let us split cases on the rule used for $\rdx{1}$.
%
\begin{description}
\item[Case $\rdx{1}$ via $\runi - \rulename{subst} - \rulename{var-swap}$] join using \cref{lem:under-u}.
\item[Case $\rdx{1}$ via \rulename{var-swap}] join using \cref{lem:swap-under}.
\item[Case $\rdx{1}$ via \rulename{subst}] join using \cref{lem:subst-under}.
\end{description}
\end{proof}

\begin{lemma}[\rulename{var-swap} under] \label{lem:swap-under}
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rulename{swap}}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rulename{swap}}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\rr}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} && {E[\rdx{}']} \\
	{\rdx{\runi}'} && {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rulename{swap}}", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=1-3, to=2-3]
	\arrow["{\rulename{swap}}"', dotted, two heads, from=2-1, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case \rulename{u-lit} or \rulename{var-swap}]:
	impossible as no \rulename{subst} redex under $|k_1 == k_2|$ or $|x == y|$.
\item[Case \rulename{u-tup}]:
	Here, $\rdx{\runi} \equiv |tup (u_1,dots,u_n) == tup (v_1,dots,v_n)|$ and wlog
	the \rulename{subst} redex is $\rstep{u_1}{u_1'}$ so join at $|u_1' == v_1; dots; u_n == v_n|$.
\item[Case \rulename{u-fail}]:
	Here, $\rdx{\runi} \equiv \rstep{}{\hnf_i}{\hnf_i'}$ so join at $|fail|$
\item[Case \rulename{u-occurs}]:
	Here, $\rdx{\runi} \equiv |x == V^[x]|$ and the \rulename{subst} redex is under $|V^[x]|$, \ie
	$\rstep{\rulename{subst}}{V^[x]}{V^[x]'}$ as the free variables are preserved by \rulename{subst}
	hence we can join at $|fail|$.
\item[Case \rulename{hnf-swap}]:
	Here, $\rdx{\runi} \equiv \hnf = x$ and the \rulename{subst} redex is under $\hnf$ \ie $\rstep{\rulename{subst}}{\hnf}{\hnf'}$,
	hence join at $x = \hnf'$.
\item[Case \rulename{subst}]: via \cref{lem:subst-swap-c}.
\item[Case \rulename{choose}]: via \cref{lem:under-choose}.
\end{description}
\end{proof}

\begin{lemma}[\rulename{subst}-under] \label{lem:subst-under}
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rulename{subst}}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rulename{subst}}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\runi}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} && {E[\rdx{}']} \\
	{\rdx{\runi}'} && {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=1-3, to=2-3]
	\arrow["{\rulename{subst}}"', dotted, two heads, from=2-1, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case \rulename{u-lit} or \rulename{var-swap}]:
	impossible as no \rulename{subst} redex under $|k_1 == k_2|$ or $|x == y|$.
\item[Case \rulename{u-tup}]:
	Here, $\rdx{\runi} \equiv |tup (u_1,dots,u_n) == tup (v_1,dots,v_n)|$ and wlog
	the \rulename{subst} redex is $\rstep{u_1}{u_1'}$ so join at $|u_1' == v_1; dots; u_n == v_n|$.
\item[Case \rulename{u-fail}]:
	Here, $\rdx{\runi} \equiv \rstep{}{\hnf_i}{\hnf_i'}$ so join at $|fail|$
\item[Case \rulename{u-occurs}]:
	Here, $\rdx{\runi} \equiv |x == V^[x]|$ and the \rulename{subst} redex is under $|V^[x]|$, \ie
	$\rstep{\rulename{subst}}{V^[x]}{V^[x]'}$ as the free variables are preserved by \rulename{subst}
	hence we can join at $|fail|$.
\item[Case \rulename{hnf-swap}]:
	Here, $\rdx{\runi} \equiv \hnf = x$ and the \rulename{subst} redex is under $\hnf$ \ie $\rstep{\rulename{subst}}{\hnf}{\hnf'}$,
	hence join at $x = \hnf'$.
\item[Case \rulename{subst}]: via \cref{lem:subst-subst-c}.
\item[Case \rulename{choose}]: via \cref{lem:under-choose}.

\item[Case \rulename{seq-assoc}]: $\rdx{\runi} \equiv \rstep{}{(eu; e_1); e_2}{eu;(e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
		\item[Case] $\rdx{} \subset eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1; e_2)$.
		\item[Case] $\rdx{} \subset e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1'; e_2)$.
		\item[Case] $\rdx{} \subset e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1; e_2')$.
		\item[Case] $\rdx{} \subset (eu; e_1)$ \ie $\rulename{subst} : (eu; e_1) \movesto (eu'; e_1')$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1'; e_2)$.
		\item[Case] $\rdx{} \subset ((eu; e_1); e_2)$ \ie $\rulename{subst} : (eu; e_1);e_2 \movesto (eu'; e_1'); e_2'$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1'; e_2')$.
	\end{description}

\item[Case \rulename{eqn-float}]: $\rdx{\runi} \equiv \rstep{}{v = (eu; e_1); e_2}{eu;(v = e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
		\item[Case] $\rdx{} \subset v$ \ie $\rstep{\rr'}{v}{v'}$
			Join at $\rdx{\runi}'' \equiv eu; (v' = e_1; e_2)$.
		\item[Case] $\rdx{} \subset eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1; e_2)$.
		\item[Case] $\rdx{} \subset e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \subset e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1; e_2')$.
		\item[Case] $\rdx{} \subset (eu; e_1)$ \ie $\rulename{subst} : v = (eu; e_1); e_2 \movesto v = (eu'; e_1'); e_2$.
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \subset v = (eu; e_1); e_2$ \ie $\rulename{subst} : (v = eu; e_1);e_2 \movesto (v' = eu'; e_1'); e_2'$
			Join at $\rdx{\runi}'' \equiv eu'; (v' = e_1'; e_2')$.
	\end{description}
\end{description}
\end{proof}


\subsection{Normalization is Confluent} % ------------------------------------------------------------------------

Recall that $\rcon \ \equiv\ \rulename{exi-swap} + \rulename{exi-float} + \rulename{var-swap} + \rulename{subst-var}$
where
$$\rulename{subst-var} \quad  |X^[x==y;e]|  \movesto  |(subst X x y)^[x==y; subst e x y]|$$
It will be convenient to \emph{factor out} \rulename{exi-float} so let
%
\begin{align*}
\rss   &  \doteq\ \rulename{subst-var} + \rulename{var-swap} \\
\rconm &  \doteq\ \rss + \rulename{exi-swap} \\
\rcon  &  \doteq\ \rconm + \rulename{exi-float} \\
\end{align*}

\begin{lemma}[$\rcon$-Confluent]\label{lem:n-c}
    $\rcon$ is confluent.
\end{lemma}

\begin{proof}
The above result follows in two steps.
%
First we show that \rconm -- \ie normalization-without-\rulename{exi-float} -- is confluent in \cref{lem:m-conf}.
%
Second we show that \rconm \emph{strongly postpones} after \rulename{exi-float} \cref{lem:m-pp-float}.
%
Consequently, each $\rsteps{\rcon}{}{}$ can be rewritten as the composition of
$\rsteps{\rulename{exi-float}}{}{}$ followed by $\rsteps{\rconm}{}{}$ after which
the following diagram completes the proof.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	&& \bullet \\
	\bullet &&&& \bullet \\
	& \bullet && \bullet \\
	\bullet && \bullet && \bullet \\
	\bullet &&&& \bullet \\
	& \bullet && \bullet \\
	&& \bullet
	\arrow["{\rulename{exi-float}}"{description}, two heads, from=1-3, to=2-1]
