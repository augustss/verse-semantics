\begin{lemma} \label{lem:uk-term}
\runib{k} is Noetherian.
\end{lemma}

\begin{proof}
%\ranjit{TODO:crispen}
By induction on $k$.
\begin{description}
	\item[Base case ($k \equiv 0$)] via \cref{lem:uk-term-0}.
	\item[Inductive case]
		Assume the induction hypothesis that $\runib{k}$
		is Noetherian and prove $\runib{k+1}$ is Noetherian.
		%
		Let $\sigma$ be a $\runib{k+1}$ reduction sequence $e \movesto \ldots$.
		%
		We will prove that $\sigma$ is finite.
		%
		By the IH there is some \emph{finite prefix}
		of the trace $\rsteps{\runib{k+1}}{e}{e'}$ after which
		there are no more $\runi$ steps at level $\leq k$. % $\runib{k}$ steps.
		%
		Note that $e'$ is finite and of the form $\ldots (|lam x_1 e_1|) \ldots (|lam x_n e_n|) \ldots$
		comprising $n$ disjoint $\lambda$ terms.
		%
		Every $\runib{k+1}$ reduction from $e'$ is a $\runib{k}$ reduction
		from some $|e_i|$, that occur ``in parallel'' \ie without influencing
		each other, and which can be sequenced to get a $\runib{k+1}$ reduction
		sequence.
		%
		Again, by the induction hypothesis, each of these reduction
		sequences (for each $e_i$) is finite, and hence their sequencing
		is finite, hence $\sigma$ must be finite.
\end{description}
\end{proof}

\mypara{Labeled Blocks}
%
We prove the base case of \cref{lem:uk-term} by stratifying expressions
into \emph{labeled blocks}, \emph{tails}, \emph{rhs} and \emph{expressions} as
shown in \cref{fig:labeled-blocks}.
%
A \emph{tail} is a term that is ``inert'' for the purposes of \runib{0} reduction: namely a
value, application, existential, one, all or choice.
%
An \emph{rhs} is either a block or a tail (which includes a value).
%
A \emph{labeled block} is a sequence of equations $|v=r|$ of a value and an RHS $|r|$ followed by a tail $|t|$.
%
We assume each block carries a unique ``ghost'' label $\ell$ (that will be used to prove termination).
%
In any block $b$, for any two labels $\ell_1$ and $\ell_2$ we write $\ell_1 \prec_b \ell_2$ if
the block labelled by $\ell_2$ occurs \emph{inside} (under) the block labelled by $\ell_1$ in $b$.
%
We will use $b_{\ell}$ to denote the (unique) sub-block of $b$ labeled by $\ell$.
%
% \mypara{Block Labels and Rewriting}
%
For rewrites like \rulename{choose}, \rulename{seq-assoc}, \rulename{seq-swap}
and \rulename{eqn-float}, we assume that the rewritten term is given a fresh
set of distinct block labels.
%
For rewrites with \rulename{u-tup}, we assume fresh labels are given to the
new (inner) blocks created by tuple matching equations.
%
All other $\runi$ rewrites preserve blocks or delete them,
so we assume that the same labels carry over to the rewritten terms.

\begin{lemma} \label{lem:seq-swap-pp}
	\rulename{seq-swap} strongly postpones after $\runi$.
\end{lemma}

\begin{proof}
Split cases on each reduction of \runi; the diamond is completed
as the rules are non-overlapping.
\end{proof}

\begin{definition}[Elimination]
%
We say a reduction \emph{eliminates} a variable $x$ from a block $b$ if the reduction is
%
(1)~a \rulename{subst} reduction spanning $b$ or an enclosing block
%
(2)~using an equation $|x = v|$ where
%
(3) $|v|$ is either an HNF or a variable $y$ such that $x \prec y$.
%
A reduction sequence \emph{eliminates} a variable $x$ from a block $b$
if there is some reduction in the sequence that eliminates $x$ from
$b$, and the sequence contains no subsequent \rulename{subst} reductions
spanning any block strictly enclosing $b$.
\end{definition}

\begin{definition}[Early Substitution Redex]
An \emph{early} substitution redex is a redex of the form $|X^[y = x]|$ where $|x| \prec |y|$.
\end{definition}

\begin{lemma} \label{lem:uk-term-0-block}
\runib{0} is Noetherian for all \emph{blocks} $|b|$.
\end{lemma}

\begin{proof}
%
We prove that for any term $|b|$ that it is only possible to take
finitely many $\runib{0}$ steps from $|b|$.
%
Let $\sigma \doteq b \movesto b_1 \movesto b_2 \movesto \ldots$ be
a $\runib{0}$ reduction sequence starting at $b$.
%
Write $\sigma_i$ for the prefix $b \movesto \dots \movesto b_i$.
%
We will show that $\sigma$ must be finite.
%
Let $\runib{0}' \doteq \runib{0} - \rulename{seq-swap}$.
%
As \rulename{seq-swap} strongly postpones after $\runi$ \cref{lem:seq-swap-pp},
any infinite $\sigma$ can be translated to a either:
%
(a) A sequence with a \emph{finite} prefix of $\runib{0}'$ reductions
    followed by infinitely many \rulename{seq-swap}, or
%
(b) An infinite sequence of $\runib{0}'$ reductions.
%
Next, we show neither case is possible.

\textbf{Case (a)} This case is ruled out by the ordering restriction on \rulename{seq-swap} which
    ensures that after the finite prefix of $\runib{0}'$ reductions, we can only keep
    swapping equations till they reach a canonical linear order after which no further
    swaps are possible.

\textbf{Case (b)} Next, we (ignore \rulename{seq-swap} to) show there is no infinite
    sequence of $\runib{0}'$ reductions. To do so, suppose that $\sigma$ is such a reduction
	sequence.
	%
	For each prefix $(\sigma_i, e_i)$ we define the following lexicographic termination metric
\begin{align*}
	\sz{(\sigma_i, b_i)} & \doteq\  (\sz{\mathsf{choose}(b_i)}, \sz{\mathsf{semi}(b_i)}, \mathsf{block}(\sigma_i, b_i))
\intertext{where}
	%
	\mathsf{choose}(b_i) 		  & \doteq\ \mbox{\rulename{choose} redexes in}\ b_i \\
	\mathsf{semi}(b_i)   		  & \doteq\ \mbox{\rulename{seq-assoc} or \rulename{eqn-float} redexes in}\ b_i \\
	\mathsf{block}(\sigma_i, e_i) & \doteq\ [\ldots \ell \mapsto (\sz{\mathsf{cand}(\sigma_i, b_i, \ell)},
																      \mathsf{size}(b_i,\ell),
																  \sz{\mathsf{early}(b_i, \ell)},
																  \sz{\mathsf{swap}(b_i, \ell)}) \ldots \mid \ell \in b_i ] \\
								  & \quad \quad \mbox{where labels are ordered by}\ \prec_{b_i} \\
\intertext{and where, for a finite reduction (prefix) $\sigma'$ block $b$ and label $\ell$}
	\mathsf{cand}(\sigma', b, \ell) & \doteq\ \freevars{b_{\ell}} - \mathit{elim}(\sigma', b, \ell) \\
	\mathsf{elim}(\sigma', b, \ell) & \doteq\ \{ x \mid \sigma' \mbox{ eliminates } x \mbox{ from }  b_{\ell} \} \\
	\mathsf{size}(b, \ell) 		    & \doteq\ \mbox{size of the block}\ b_{\ell} \\
    \mathsf{early}(b, \ell)		    & \doteq\ \mbox{early substitution redexes in}\ b_{\ell} \\
	\mathsf{swap}(b, \ell)   	    & \doteq\ \mbox{\rulename{var-swap} redexes in}\ b_{\ell}
\end{align*}
%
The unification reductions preserve the following invariant: once a variable $x$ has been eliminated from a block,
it appears at most once in the block as an LHS of an equation $|x = v|$, and that equation can \emph{never} again be used
to perform a substitution in that block \emph{unless} new occurrences of $x$ are injected into the block by a substitution
performed in an \emph{enclosing} block, in which case, the $\mathsf{block}$ metric for the outer block will be strictly smaller.
%
% Intuitively, $\mathsf{cand}(\ell)$ is the number of ``substitution candidates'' for the block $\ell$,
% \ie the number of variables that could possibly be used as the LHS of a \rulename{subst} spanning the block $\ell$.
% Such a variable must appear at least twice in the block: as a ``source'' \ie the LHS of an equation, and as a ``target''
% occurrence elsewhere in the block.
%
Specifically, each application of
%
\begin{itemize}
\item \rulename{choose} strictly reduces $\sz{\mathsf{choose}}$;
\item \rulename{seq-assoc} or \rulename{eqn-float} strictly reduces $\sz{\mathsf{semi}}$ (leaving $\sz{\mathsf{choose}}$ unchanged);
\item \rulename{subst} strictly reduces $\sz{\mathsf{block}}$ (leaving $\sz{\text{semi}}$, $\sz{\mathsf{choose}}$ unchanged), as either
      it \emph{eliminates} a variable from the block $\ell$ that the substitution spans \emph{or} it is an \emph{early} substitution
	  that preserves the block size, but reduces the number of early substitution redexes for $\ell$;
\item \rulename{u-tup} strictly reduces $\sz{\mathsf{block}}$ (leaving $\sz{\text{semi}}$, $\sz{\mathsf{choose}}$ unchanged), as it
	  preserves $\mathsf{elim}$ and hence $\mathsf{cand}$, but reduces the $\mathsf{size}$ of $\ell$;
\item \rulename{u-lit}, \rulename{u-fail}, \rulename{u-occurs} strictly reduces $\sz{\text{block}}$ (leaving $\sz{\text{semi}}$, $\sz{\text{choose}}$ unchanged),
	  as they strictly reduce $\mathsf{size}$ while preserving or reducing $\mathsf{cand}$;
\item \rulename{var-swap} strictly reduces the $\mathsf{swap}$ component of $\mathsf{block}$,
	  leaving the other components and $\mathsf{semi}$, $\mathsf{choose}$ unchanged.
\end{itemize}
%
Thus, as $\sz{(\sigma_i, b_i)}$ is a strictly decreasing well-founded metric, the sequence $(\sigma_1, b_1), \ldots,$ is finite, and so
any sequence of $\runib{0}$' steps is guaranteed to terminate.
%
\end{proof}

\begin{lemma} \label{lem:uk-term-0}
\runib{0} is Noetherian for all \emph{tails} $t$, \emph{rhs} $r$ and \emph{expressions} $e$.
\end{lemma}

\begin{proof}
By induction on the structure of $|t|$, $|r|$ and $|e|$, using \cref{lem:uk-term-0-block} for the base case.
\end{proof}

\begin{lemma} \label{lem:u-lc}
\runi{} is locally confluent.
\end{lemma}

\begin{proof}
Let $\tx{1}$ and $\tx{2}$ denote the two $\runi$ reducts.
%
If the reducts are disjoint, then the terms can be joined trivially in a single step via \cref{lem:disjoint}.
%
By symmetry it suffices to consider the case where $\rdx{1}$ occurs under $\rdx{2}$.
%
Let us split cases on the rule used for $\rdx{1}$.
%
\begin{description}
\item[Case $\rdx{1}$ via $\runi - \rulename{subst} - \rulename{var-swap}$] join using \cref{lem:under-u}.
\item[Case $\rdx{1}$ via \rulename{var-swap}] join using \cref{lem:swap-under}.
\item[Case $\rdx{1}$ via \rulename{subst}] join using \cref{lem:subst-under}.
\end{description}
\end{proof}


\begin{lemma}[\rulename{var-swap} under] \label{lem:swap-under}
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rulename{swap}}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rulename{swap}}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\rr}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} && {E[\rdx{}']} \\
	{\rdx{\runi}'} && {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rulename{var-swap}}", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=1-3, to=2-3]
	\arrow["{\rulename{var-swap}}"', dotted, two heads, from=2-1, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case \rulename{u-lit} or \rulename{var-swap}]:
	impossible as no \rulename{var-swap} redex under $|k_1 == k_2|$ or $|x == y|$.
\item[Case \rulename{u-tup}]:
	Here, $\rdx{\runi} \equiv |tup (u_1,dots,u_n) == tup (v_1,dots,v_n)|$ and wlog
	the \rulename{var-swap} redex is $\rstep{u_1}{u_1'}$ so join at $|u_1' == v_1; dots; u_n == v_n|$.
\item[Case \rulename{u-fail}]:
	Here, $\rdx{\runi} \equiv \rstep{}{\hnf_i}{\hnf_i'}$ so join at $|fail|$
\item[Case \rulename{u-occurs}]:
	Here, $\rdx{\runi} \equiv |x == V^[x]|$ and the \rulename{var-swap} redex is under $|V^[x]|$, \ie
	$\rstep{\rulename{subst}}{V^[x]}{V^[x]'}$ as the free variables are preserved by \rulename{var-swap}
	hence we can join at $|fail|$.
\item[Case \rulename{hnf-swap}]:
	Here, $\rdx{\runi} \equiv \hnf = x$ and the \rulename{var-swap} redex is under $\hnf$ \ie $\rstep{\rulename{subst}}{\hnf}{\hnf'}$,
	hence join at $x = \hnf'$.
\item[Case \rulename{subst}]: via \cref{lem:subst-swap-c}.
\item[Case \rulename{choose}]: via \cref{lem:under-choose}.
\item[Case \rulename{seq-assoc}]:
    Here, $\rdx{\runi} \equiv \rstep{}{(eu; e_1); e_2}{eu;(e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
		\item[Case] $\rdx{} \occunder eu$ \ie $\rstep{\rulename{var-swap}}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1; e_2)$.
		\item[Case] $\rdx{} \occunder e_1$ \ie $\rstep{\rulename{var-swap}}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder e_2$ \ie $\rstep{\rulename{var-swap}}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1; e_2')$.
	\end{description}

\item[Case \rulename{eqn-float}]:
	$\rdx{\runi} \equiv \rstep{}{v = (eu; e_1); e_2}{eu;(v = e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
		\item[Case] $\rdx{} \occunder v$ \ie $\rstep{\rulename{var-swap}}{v}{v'}$
			Join at $\rdx{\runi}'' \equiv eu; (v' = e_1; e_2)$.
		\item[Case] $\rdx{} \occunder eu$ \ie $\rstep{\rulename{var-swap}}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1; e_2)$.
		\item[Case] $\rdx{} \occunder e_1$ \ie $\rstep{\rulename{var-swap}}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder e_2$ \ie $\rstep{\rulename{var-swap}}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1; e_2')$.
	\end{description}
\end{description}
\end{proof}

\begin{lemma}[\rulename{subst}-under] \label{lem:subst-under}
%
If $\rstep{\runi}{\rdx{\runi}}{\rdx{\runi}'}$ and
   $\rdx{\runi} \equiv E[\rdx{}]$ and
   $\rstep{\rulename{subst}}{\rdx{}}{\rdx{}'}$
then there exists $\rdx{\runi}''$ such that
   $\rsteps{\rulename{subst}}{\rdx{\runi}'}{\rdx{\runi}''}$ and
   $\rstep{\runi}{E[\rdx{}']}{\rdx{\runi}''}$.
% https://q.uiver.app/?&macro_url=https%3A%2F%2Fgist.githubusercontent.com%2Franjitjhala%2F463b2ed2e80d26d1ec1ef240b077b5ba%2Fraw%2Fce6f925cb4d1f0f91e4bc751f00e60bdb33e381f%2Ffresh_macros.tex
\[\begin{tikzcd}
	{\rdx{\runi} \equiv E[\rdx{}]} && {E[\rdx{}']} \\
	{\rdx{\runi}'} && {\rdx{\runi}''}
	\arrow["\runi"', from=1-1, to=2-1]
	\arrow["{\rulename{subst}}", from=1-1, to=1-3]
	\arrow["\runi", dotted, from=1-3, to=2-3]
	\arrow["{\rulename{subst}}"', dotted, two heads, from=2-1, to=2-3]
\end{tikzcd}\]
\end{lemma}

\begin{proof}
Split cases on the rule used in $\runi$.
\begin{description}
\item[Case \rulename{u-lit} or \rulename{var-swap}]:
	impossible as no \rulename{subst} redex under $|k_1 == k_2|$ or $|x == y|$.
\item[Case \rulename{u-tup}]:
	Here, $\rdx{\runi} \equiv |tup (u_1,dots,u_n) == tup (v_1,dots,v_n)|$ and wlog
	the \rulename{subst} redex is $\rstep{u_1}{u_1'}$ so join at $|u_1' == v_1; dots; u_n == v_n|$.
\item[Case \rulename{u-fail}]:
	Here, $\rdx{\runi} \equiv \rstep{}{\hnf_i}{\hnf_i'}$ so join at $|fail|$
\item[Case \rulename{u-occurs}]:
	Here, $\rdx{\runi} \equiv |x == V^[x]|$ and the \rulename{subst} redex is under $|V^[x]|$, \ie
	$\rstep{\rulename{subst}}{V^[x]}{V^[x]'}$ as the free variables are preserved by \rulename{subst}
	hence we can join at $|fail|$.
\item[Case \rulename{hnf-swap}]:
	Here, $\rdx{\runi} \equiv \hnf = x$ and the \rulename{subst} redex is under $\hnf$ \ie $\rstep{\rulename{subst}}{\hnf}{\hnf'}$,
	hence join at $x = \hnf'$.
\item[Case \rulename{subst}]: via \cref{lem:subst-subst-c}.
\item[Case \rulename{choose}]: via \cref{lem:under-choose}.

\item[Case \rulename{seq-assoc}]: $\rdx{\runi} \equiv \rstep{}{(eu; e_1); e_2}{eu;(e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
		\item[Case] $\rdx{} \occunder eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1; e_2)$.
		\item[Case] $\rdx{} \occunder e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (e_1; e_2')$.
		\item[Case] $\rdx{} \occunder (eu; e_1)$ \ie $\rulename{subst} : (eu; e_1) \movesto (eu'; e_1')$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder ((eu; e_1); e_2)$ \ie $\rulename{subst} : (eu; e_1);e_2 \movesto (eu'; e_1'); e_2'$
			Join at $\rdx{\runi}'' \equiv eu'; (e_1'; e_2')$.
	\end{description}

\item[Case \rulename{eqn-float}]: $\rdx{\runi} \equiv \rstep{}{v = (eu; e_1); e_2}{eu;(v = e_1; e_2)} \equiv \rdx{\runi}'$.
	Split cases on where $\rdx{}$ occurs.
	\begin{description}
		\item[Case] $\rdx{} \occunder v$ \ie $\rstep{\rr'}{v}{v'}$
			Join at $\rdx{\runi}'' \equiv eu; (v' = e_1; e_2)$.
		\item[Case] $\rdx{} \occunder eu$ \ie $\rstep{\rr'}{eu}{eu'}$
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1; e_2)$.
		\item[Case] $\rdx{} \occunder e_1$ \ie $\rstep{\rr'}{e_1}{e_1'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder e_2$ \ie $\rstep{\rr'}{e_2}{e_2'}$
			Join at $\rdx{\runi}'' \equiv eu; (v = e_1; e_2')$.
		\item[Case] $\rdx{} \occunder (eu; e_1)$ \ie $\rulename{subst} : v = (eu; e_1); e_2 \movesto v = (eu'; e_1'); e_2$.
			Join at $\rdx{\runi}'' \equiv eu'; (v = e_1'; e_2)$.
		\item[Case] $\rdx{} \occunder v = (eu; e_1); e_2$ \ie $\rulename{subst} : (v = eu; e_1);e_2 \movesto (v' = eu'; e_1'); e_2'$
			Join at $\rdx{\runi}'' \equiv eu'; (v' = e_1'; e_2')$.
	\end{description}
\end{description}
\end{proof}


\subsection{Normalization is Confluent} % ------------------------------------------------------------------------

Recall that $\rcon \ \equiv\ \rulename{exi-swap} + \rulename{exi-float} + \rulename{var-swap} + \rulename{subst-var}$
where
$$\rulename{subst-var} \quad  |X^[x==y;e]|  \movesto  |(subst X x y)^[x==y; subst e x y]|$$
It will be convenient to \emph{factor out} \rulename{exi-float} so let
%
\begin{align*}
\rss   &  \doteq\ \rulename{subst-var} + \rulename{var-swap} \\
\rconm &  \doteq\ \rss + \rulename{exi-swap} \\
\rcon  &  \doteq\ \rconm + \rulename{exi-float} \\
\end{align*}

