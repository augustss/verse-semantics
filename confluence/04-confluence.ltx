\begin{lemma}[$\rapp-\rcon$-Comm] \label{lem:a-c-c}
	$\rapp$ and $\rcon$ commute.
\end{lemma}

\begin{proof}
We show that $\rapp$ $*$-commutes with $\rcon$, hence commutes via \cref{lem:star-comm}.
%
Let $\tx{\rapp}$ and $\tx{\rcon}$ denote the reducts for $\rapp$ and $\rcon$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rapp}$ occurs under $\rdx{\rcon}$ or vice versa.

\begin{description}
\item[Case $\rdx{\rapp} \subset \rdx{\rcon}$] Split cases on the rule used in $\rcon$. Crucially,
the $\rapp$ rules apply at application sites which are disjoint from any of the $\rcon$ sites, hence
the proof is similar to but simpler than the case of $\rdx{\runi} \subset \rdx{\rcon}$ in \cref{lem:u-c-c}
as each $\rapp$-reduct must be strictly under \emph{one} of the components of the $\rcon$-reduct.
	\begin{description}
		\item[Case:] \rulename{norm-val} \ie $\tx{\rcon} \equiv |v; e| \movesto |e|$.
		If $\rdx{\rapp} \subset |v|$, \ie $\rapp : |v| \movesto |v'|$, then join at $|e|$.
		If $\rdx{\rapp} \subset |e|$, \ie $\rapp : |e| \movesto |e'|$, then join at $|e'|$.
	\item[Case:] \rulename{norm-seq-assoc} \ie $\tx{\rcon} \equiv (e_1; e_2); e_3 \movesto e_1; (e_2 ; e_3)$.
		If $\rdx{\rapp} \subset e_1$, \ie $\rapp : e_1 \movesto e_1'$, then join at $(e_1'; (e_2; e_3)$.
		If $\rdx{\rapp} \subset e_2$, \ie $\rapp : e_2 \movesto e_2'$, then join at $(e_1; (e_2'; e_3)$.
		If $\rdx{\rapp} \subset e_3$, \ie $\rapp : e_3 \movesto e_3'$, then join at $(e_1; (e_2; e_3'))$.
	\item[Case:] \rulename{norm-seq-swap} \ie $\tx{\rcon} \equiv |e_1; x == v; e_2| \movesto |x == v; e_1; e_2|$.
		If $\rdx{\rapp} \subset |e_1|$, \ie $\runi : e_1 \movesto e_1'$, then join at $x = |v|; e_1'; e_2$.
		If $\rdx{\rapp} \subset |e_2|$, \ie $\runi : e_2 \movesto e_2'$, then join at $x = |v|; e_1; e_2'$.
	\item[Case:] \rulename{norm-swap-eq} \ie $\tx{\rcon} \equiv \hnf = x \movesto x = \hnf$.
		Here $\rdx{\rapp} \subset \hnf$, \ie $\rapp: \hnf \movesto \hnf'$, hence join at $x = \hnf'$.
	\item[Case:] \rulename{norm-seq-def}, \rulename{norm-defr}, \rulename{norm-seqr}, \rulename{norm-unifyr}]
		In this case $\tx{\rcon} \equiv C[e_1, e_2] \movesto C'[e_1, e_2]$.
		If $\rdx{\rapp} \subset e_1$, \ie $\rapp : e_1 \movesto e_1'$, then join at $C'[e_1', e_2]$.
		If $\rdx{\rapp} \subset e_2$, \ie $\rapp : e_2 \movesto e_2'$, then join at $C'[e_1, e_2']$.
	\end{description}
\item[Case $\rdx{\rcon} \subset \rdx{\rapp}$] via \cref{lem:under-a}.
\end{description}
\end{proof}


\begin{lemma}[$\rapp-\rfail$-Comm] \label{lem:a-f-c}
