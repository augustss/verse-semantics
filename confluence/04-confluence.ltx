\newcommand{\rdis}{\ensuremath{\rcon \cup \rgc}}

\section{Confluence of \calcname} \label{sec:confluence}

\begin{definition}[Reductions] \label{def:reductions}
Let $\rr$ be the reduction relation defined as $\runi \cup \rapp \cup \rcon \cup \rgc \cup \rfail$,
each of which is defined as the reduction relation induced by the respective rules in \cref{fig:rewrite-rules}
%
\begin{itemize}
\item $\runi$ : Unification,
\item $\rapp$ : $\beta$-Application,
\item $\rcon$ : Conjunction,
\item $\rgc$ : Garbage Collection,
\item $\rfail$ : Fail Propagation.
\item $\rspc$ : Speculation.
\end{itemize}
%
\end{definition}

\begin{figure}
\begin{tabular}{rrrrrrrr}
\toprule
					& 	  	& \runi 		 & \rapp 		   & \rdis 		 	 & \rfail 		   & \rspc \\
\midrule
