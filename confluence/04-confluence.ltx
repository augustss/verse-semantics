\subsection{Application} % --------------------------------------------------------------------------

\begin{lemma} \label{lem:a-c}
    $\rapp$ is confluent.
\end{lemma}

\begin{proof}
We show that $\rapp$ satisfies the diamond property and hence,
is confluent by \cref{lem:diamond}. Suppose that
%
$\rstep{\rapp}{e}{e_1}$ via the redux $\tx{1}$
%
$\rstep{\rapp}{e}{e_2}$ via the redux $\tx{2}$.
%
If $\rdx{1}$ and $\rdx{2}$ are disjoint, the terms $e_1$ and $e_2$
can be trivially joined in a single step.
%
If $\rdx{1} \subset \rdx{2}$ (or $\rdx{2} \subset \rdx{1}$) then \cref{lem:under-a} completes the proof.
\end{proof}




\begin{lemma} \label{lem:a-g-c}
	$\rapp$ and $\rgc$ commute.
\end{lemma}

\begin{proof}
We show that $\rapp$ strongly commutes with $\rgc$, hence commutes via \cref{lem:strong-commute}.
%
Let $\tx{\rapp}$ and $\tx{\rgc}$ denote the reducts for $\rapp$ and $\rgc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rapp}$ occurs under $\rdx{\rcon}$ or vice versa.
%
\begin{description}
\item[Case $\rdx{\rapp} \subset \rdx{\rgc}$] via \cref{lem:under-g}.
\item[Case $\rdx{\rgc} \subset \rdx{\rapp}$] via \cref{lem:under-a}.
\end{description}
\end{proof}

\begin{lemma} \label{lem:a-s-c}
	$\rapp$ and $\rspc$ commute.
\end{lemma}

\begin{proof}
We show that $\rapp$ strongly commutes with $\rspc$, hence commutes via \cref{lem:strong-commute}.
%
Let $\tx{\rapp}$ and $\tx{\rspc}$ denote the reducts for $\rapp$ and $\rspc$ respectively.
%
If the reducts are disjoint then terms can be trivially joined in a single step.
%
Let us split cases on whether $\rdx{\rapp}$ occurs under $\rdx{\rspc}$ or vice versa.
%
\begin{description}
\item[Case $\rdx{\rspc} \subset \rdx{\rapp}$] via \cref{lem:under-a}.
\item[Case $\rdx{\rapp} \subset \rdx{\rspc}$] via \cref{lem:under-s}.
\end{description}
%
\end{proof}

