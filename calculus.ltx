    \text{\Hexp{}s} & |he|  & ::=  & |def h in e| \vb |none| \vb |he_1 hchoice he_2| \\
    \text{Expressions} & e,r,s  & ::=  & x \vb k \vb |(e_1, dots, e_n)| \vb |x => he| \vb |op^(e)| \\
