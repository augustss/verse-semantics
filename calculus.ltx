    &&\vb & |do he| \\
    \text{Primops} & op  & ::= & cop \vb |apply | \\
    \text{Choice-free primops} & cop  & ::= & |gr| \vb |add| \vb |semi| \vb |unify| \\
    \text{Head values} & \hnf & ::= & k \vb (v_1, \ldots, v_n) \vb |x => he|  \\
    \text{Values} & v & ::= & x  \vb \hnf \\
    \text{Choice-free exprs} & ce  & ::=  & x \vb k \vb |(ce_1, dots, ce_n)| \vb |x => he| \vb cop(ce) \\
    \text{Heaps} & h & ::= & |emp| \vb |h_1 , h_2| \vb |x| \vb |x:=v| \\
