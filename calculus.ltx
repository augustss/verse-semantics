\section{Source Verse}

\begin{figure}
$$
\begin{array}{rcll}
  |e,t| & ::= & \textit{Expressions} \\
      &     & |x|               & \text{variable reference} \\
      & \vb & |k|               & \text{constant} \\
      & \vb & |e_1, dots, e_n|  & \text{array} \\
      & \vb & |()|              & \text{empty array} \\
      & \vb & |e_1 ; e_2|       & \text{sequencing} \\
      & \vb & |e_1^[e_2]|       & \text{function application} \\
      & \vb & |x := e|          & \text{definition} \\
      & \vb & |: t|             & \text{range} \\
      & \vb & |e_1 `choice` e_2| & \text{choice} \\
      & \vb & |e_1 = e_2|       & \text{unification} \\
      & \vb & |if(e) then b_1 else b_2| & \text{conditional expression} \\
      & \vb & |for(e) in b|     & \text{finite loop} \\
      & \vb & |function e effsR b|    & \text{anonymous function} \\
      & \vb & |typedef^{e}|      & \text{type definition} \\
  %%%%%
  \\
      &     & \textit{Expressions removed by desugaring} \\
      & \vb & |e_1 eqgt e_2|    & \text{lambda expression} \\
      & \vb & |lhs := e|          & \text{definition} \\
      & \vb & |e_1^(e_2)|       & \text{non-failing function application} \\
      & \vb & |op_b e|          & \text{prefix operator} \\
      & \vb & |e op_a|          & \text{postfix operator} \\
      & \vb & |e_1 op_i e_2|    & \text{infix operator} \\
      & \vb & |l : e|           & \text{of type} \\
      & \vb & |e_1 where e_2|   & \text{reverse sequencing} \\
      & \vb & |if(e) then b|    & \text{conditional expression} \\
      & \vb & |if(e) else b|    & \text{conditional expression} \\
      & \vb & |if{e}|           & \text{conditional expression} \\
      & \vb & |for{e}|          & \text{finite loop} \\
      & \vb & |let(e) in b|     & \text{local binding} \\
      & \vb & |do b|            & \text{scope delimiter} \\
      & \vb & |case(e) of b|    & \text{case expression} \\
      & \vb & |case{e_1; dots e_n}| & \text{case expression} \\
\end{array}
$$
