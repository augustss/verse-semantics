    \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
    \text{Programs} & p  & ::=  & e \\
    \text{Expressions} & e,r,s  & ::=  & |v| \vb |e_1 == e_2| \vb |e_1 ; e_2| \vb |applyx v_1 v_2|
     \vb |e_1 choice e_2| \vb |fail| \\
     && \vb & |def h e| \\
     && \vb & |one e| \vb |all e| \vb |succeeds e| \vb |decides e| \\
    \text{Values} & v & ::= & x  \vb \hnf \\
    \text{Head values} & \hnf & ::= & k \vb op \vb |array (v_1, dots, v_n)| \vb |x => e| \vb |range| \\
    \text{Primops} & op  & ::= & |gt| \vb |add| \vb |isInt| \\
    \text{Choice-free exprs} & ce  & ::=  & |v| \vb |ce_1 == ce_2| \vb |ce_1 ; ce_2| \\
     && \vb & |one e| \vb |all e| \vb |succeeds e| \vb |decides e| \\
    \text{Heaps} & h & ::= & |emp| \vb |h_1 , h_2| \vb |x| \\
%    \text{Heap values} & hv & ::= & \epsilon \vb hv_1 , hv_2 \vb x:=v \\
    \\
    \text{Execution contexts} & X & ::= & \hole \vb |X == e| \vb |e == X| \vb |X ; e| \vb |e; X| \\
    \text{Choice contexts} & CX & ::= & \hole \vb |CX == e| \vb |ce == CX| \vb |CX ; e| \vb |ce; CX| \\
     &&\vb & |def h CX| \\
    \text{Scope contexts} & SX & ::= & |hole choice e| \vb |e choice hole | \\
     &&\vb & |one hole| \vb |all hole| \vb |succeeds hole| \vb |decides hole| \\
    \text{Heap context} & H & ::= & \hole \vb H,h \vb h,H\\
    \text{Value context} & V & ::= & \hole \vb |array (dots,V,dots)|\\
    \end{array} \\
    \\
    \textbf{Shorthand} \\
    \begin{array}{rcl}
      |()| & \text{means} & |array ()|\\
      |v_1, dots, v_n| & \text{means} & |array (v_1,dots, v_n)| \quad n \geq 2 \\
      v_1 \oplus v_2 & \text{means} & |applyx add ( v_1, v_2 )| \\
      v_1 > v_2 & \text{means} & |applyx gt ( v_1, v_2 )| \\
     \end{array} \\
  \\
  \text{We say $S_1 \disjoint S_2$ to mean that set $S_1$ is disjoint from $S_2$.}
  \end{array}
  $$
\caption{The Verse calculus: syntax} \label{fig:verse-syntax}
\end{figurebox}

