 \text{Choice contexts} & CX & ::= & \hole \vb |CX == e| \vb |ce == CX| \vb |CX ; e| \vb |ce; CX| \\
    &&\vb & |op^(CX)| \vb |def h in CX| \\
    \text{Left choice context} & L & ::= & \hole \vb |L choice e| \\
