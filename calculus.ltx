\begin{example} $$
  \begin{array}{rcl}
    \multicolumn{3}{l}{|def (x, y) (y == add^(x, 1); x == 3; y)|} \\
    \rulename{bind} & \movesto & |def y (y == add^(3, 1); 3; y)| \\
    \rulename{p-add} & \movesto & |def y (y == 4; 3; y)| \\
    \rulename{bind} & \movesto & |def emp (4; 3; 4)| \\
    \rulename{seq} & \movesto & |def emp 4| \\
