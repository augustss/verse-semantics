\section{Verse}

\begin{figurebox}
  $$
  \begin{array}{l}
    \textbf{Syntax} \\
    \begin{array}{lrcl}
    \text{Constants} & k \\
    \text{Variables} & x,y,z \\
    \text{Primops} & op  & ::= & |add| \mid |semi| \mid |unify| \mid |apply | \\
    \text{Atoms} & a  & ::=  & k \mid x \\
    \text{Expressions} & e  & ::=  & a \mid (e_1, \ldots, e_n) \mid |x => e|
                                       \mid |he choice he| \\
      \text{Values} & v & ::= & a \mid (v_1, \ldots, v_n) \mid |x => e|  \\
    \text{\Hexp{}s} & |he|  & ::=  & |def h in e| \\
    \text{Heaps} & h & ::= & \epsilon \mid h_1 , h_2 \mid x \mid x=v \\
      \text{Evaluation contexts} & E & ::= & \hole \mid E\; e \mid E \oplus e \mid k \oplus E
           \mid |let x=E in E[x]|
    \end{array} \\
    \\
    \textbf{Shorthand} \\
    \begin{array}{rcl}
      e_1 ; e_e & \text{means} & semi( e_1, e_2 ) \\
      e_1 \sim e_2 & \text{means} & unify( e_1, e_2 ) \\
      e_1 \oplus e_2 & \text{means} & add( e_1, e_2 ) \\
      e_1(e_2) & \text{means} & apply( e_1, e_2 ) \\
     \end{array} \\
    \\
    \textbf{Axioms}  \\
    \begin{array}{lrcl}
    \rulename{beta} & (\lambda x.e_1)\; e_2 & \movesto & |let x = e_2 in e_1| \\
    \rulename{let-v} & |let x = v in e| & \movesto & e[x:=v] \\
    \rulename{let-c} & |(let x = e_x in e_1) e_2| & \movesto & |let x = e_x in (e_1 e_2)| \\
    \rulename{let-a} & |let x = (let y = e_y in e_x) in e| & \movesto
                       & |let y = e_y in let x = e_x in e| \\
    \rulename{delta} &  k_1 \oplus k_2 & \movesto & k_1 + k_2 \\
    \end{array}
   \end{array}
   $$
\caption{The Verse calculus} \label{fig:verse}
\end{figurebox}

