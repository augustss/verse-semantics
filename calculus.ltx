     \vb |e_1 choice e_2| \vb |fail| \\
     && \vb & |def h e| \\
     && \vb & |one e| \vb |all e| \vb |succeeds e| \vb |range e| \\
    \text{Values} & v & ::= & x  \vb \hnf \\
    \text{Head values} & \hnf & ::= & k \vb op \vb |array (v_1, dots, v_n)| \\
    && \vb & |x => e| \vb |rec f e| \vb ty \\
    \text{Primops} & op  & ::= & cop \\
    \text{Choice-free primops} & cop  & ::= & |gt| \vb |add| \\
    \text{Types} & ty & ::= & |int| \vb |string| \vb |typex v| \\
    \text{Choice-free exprs} & ce  & ::=  & |v| \vb |applyx cop ce| \vb |ce_1 == ce_2| \vb |ce_1 ; ce_2| \\
    \text{Heaps} & h & ::= & |emp| \vb |h_1 , h_2| \vb |x| \\
%    \text{Heap values} & hv & ::= & \epsilon \vb hv_1 , hv_2 \vb x:=v \\
 \\
 \text{Execution contexts} & X & ::= & \hole \vb |X == e| \vb |e == X| \vb |X ; e| \vb |e; X| \\
    && \vb & |applyx X e| \vb |applyx e X| \vb |def h X | \\
 \text{Choice contexts} & CX & ::= & \hole \vb |CX == e| \vb |ce == CX| \vb |CX ; e| \vb |ce; CX| \\
    &&\vb & |applyx CX e| \vb |applyx ce CX| \vb |def h CX| \\
    \text{Heap context} & H & ::= & \hole \vb H,h \vb h,H
    \end{array} \\
    \\
    \textbf{Shorthand} \\
    \begin{array}{rcl}
      |()| & \text{means} & |array ()|\\
      |v_1, dots, v_n| & \text{means} & |array (v_1,dots, v_n)| \quad n \geq 2 \\
      v_1 \oplus v_2 & \text{means} & |applyx add ( v_1, v_2 )| \\
      v_1 > v_2 & \text{means} & |applyx gt ( v_1, v_2 )| \\
     \end{array} \\
  \\
  \textbf{Bound variables $\boundvars{h}$ of a heap} \\
  \begin{array}{rcl}
    \boundvars{ |emp| } & = & \emptyset \\
    \boundvars{ |h_1 , h_2| } & = & \boundvars{h_1} \cup \boundvars{h_2} \\
    \boundvars{ |x| } & = & \{x\}
  \end{array}
   \\ \\
  \textbf{Bound variables $\boundvars{X}$ of a context} \\
  \begin{array}[t]{rcl}
    \boundvars{ \hole } & = & \emptyset \\
    \boundvars{ |def h X| } & = & \boundvars{h} \cup \boundvars{X} \\
    \boundvars{ |applyx X e| } & = & \boundvars{X} \\
    \boundvars{ |applyx e X| } & = & \boundvars{X}
  \end{array}\qquad
  \begin{array}[t]{rcl}
    \boundvars{ |X==e| } & = & \boundvars{X} \\
    \boundvars{ |e==X| } & = & \boundvars{X} \\
    \boundvars{ |X;e| } & = & \boundvars{X} \\
    \boundvars{ |e;X| } & = & \boundvars{X}
  \end{array}
  \\
  \text{We say $S_1 \disjoint S_2$ to mean that set $S_1$ is disjoint from $S_2$.}
  \end{array}
  $$
\caption{The Verse calculus: syntax} \label{fig:verse-syntax}
\end{figurebox}

