\section{Desugaring Source Verse}

\begin{figure}
$$
\begin{array}{rcll}
  |De| & \multicolumn{3}{l}{ \text{converts Source Verse to a subset of Source Verse.} } \\
  |De k| & = & |k| \\
  |De x| & = & |x| \\
  |De (e_1, dots, e_n)| & = & |De e_1 , dots, De e_n| \\
  |De (e_1 ; e_2)| & = & |De e_1 ; De e_2| \\
  |De (e_1^[e_2])| & = & |(De e_1)[De e_2]| \\
  |De (e_1^(e_2))| & = & |De (succeeds (e_1^[e_2]))| \\
  |De (!e)| & = & |De (if e then :false else false)| \\
  |De (:t)| & = & |: De t| \\
  |De (op_b e)| & = & |De (prefix op_b [e])| & \text{if |op_b| can fail}\\
  |De (op_b e)| & = & |De (prefix op_b (e))| \\
  |De (e op_a)| & = & |De (postfix op_a [e])| & \text{if |op_a| can fail}\\
  |De (e op_a)| & = & |De (postfix op_a (e))| \\
  |De (e_1 eqgt e_2)| & = & |De (function e_1 () {e_2})| \\
  |De (l := e)| & = & |Ld l (De e)| \\
  |De (l : t)| & = & |Ld l (De (:t))| \\
  |De (e_1 srcand e_2)| & = & |De (e_1; e_2)| \\
  |De (e_1 srcor e_2)| & = & |De (if(e_1) else e_2)| \\
  |De (e_1 = e_2)| & = & |De e_1 = De e_2| \\
  |De (e_1 where e_2)| & = & |De (x := e_1; e_2; x)| & \text{|x| fresh} \\
  |De (e_1 `choice` e_2)| & = & |De e_1 `choice` De e_2| \\
  |De (e_1 op_i e_2)| & = & |De (operator op_i [e_1, e_2])| & \text{if |op_i| can fail}\\
  |De (e_1 op_i e_2)| & = & |De (operator op_i (e_1, e_2))| \\
  |De (if{e})| & = & |De (if(e) else false)| \\
  |De (if(e_1) then e_2)| & = & |De (if(e_1) then e_2 else false)| \\
  |De (if(e_1) else e_2)| & = & |De (if (x := e_1) then x else e_2)| & \text{|x| fresh} \\
  |De (if(e_1) then e_2 else e_3)| & = & |if (De e_1) then De e_2 else De e_3| \\
  |De (for{e})| & = & |De (for (x := e) in { x })| & \text{|x| fresh} \\
  |De (let(e) in b)| & = & |De (e); De b| & \textit{see note} \\
  |De (do b)| & = & |De b| & \textit{see note}  \\
  |De (case{e_1; dots e_n})| & = & |De ((x:any) => case(x){e_1; dots e_n})| & \text{|x| fresh} \\
  |De (case(e){e_1; dots e_n}| & = & |De (x:=e; if(e_1[x]) else dots if(e_n[x]) else :false)| \\
  |De (function e effsR b)| & = & |De (function(e)(dots)((r^[b])))| & \\
  |De (function e () b)| & = & |function(x:any)()((Mt e x; do{De b}))| & \text{|x| fresh} \\
  |De (typedef^{e})| & = & |typedef^{De e}| \\
  |De ({e_1; dots e_n})| & = & |De (e_1; dots e_n)| \\
  \\
\end{array}
$$
{\em Note}: The desugaring assumes a scope correct Verse program.
This means that there can be not variable name clashes in |let| and |do|.
A more robust desugaring could $\alpha$-convert such clashes.
\caption{Desugaring of expressions} \label{fig:desugar-expr}
\end{figure}

\begin{figure}
$$
\begin{array}{rcll}
  |Ld| & \multicolumn{3}{l}{\text{converts a definition |l := e| to simple definitions with just |x := e|.}} \\
  |Ld x e| & = & |x := e| \\
  |Ld (l : t) e| & = & |Ld l (t^[e])| \\
  |Ld (fun^(e_1)) e_2| & = & |Fd (fun^(e_1)) e_2| \\
  |Ld (l ?) e| & = & |Ld l (e ?)| \\
  |Ld (e_1 hat ) e_2| & = & |De (assign^(e_1,e_2))| \\
  |Ld (l_0, dots, l_n) e| & = & |x := e; Ld l_0 (x^[0]); dots; Ld l_n (x^[n]); De (!x^[n+1]) | & \text{|x| fresh} \\
  |Ld (l_1 minusgt l_2) (:e)| & = & |Ld l_1 x; Ld l_2 (e^[x:any])| & \text{|x| fresh} \\
  \\
  |Fd| & \multicolumn{3}{l}{\text{converts function definitions to |functionKW|.}} \\
  |Fd (fun^(e)effsR) e_2| & = & |Fd fun (De (function e_1 effsR {e_2}))| \\
  |Fd x e| & = & |x := e| \\
  \\
  |Mt| & \multicolumn{3}{l}{\text{does a matching (variant of unification) that treats functions specially.}} \\
  |Mt k e| & = & |k = e| \\
  |Mt x e| & = & |x := e| \\
  |Mt (e_0, dots, e_n) e| & = & |x := De e; Mt e_0 (x^[0]); dots; Mt e_n (x^[n]); De (!x^[n+1]) | & \text{|x| fresh} \\
  |Mt (e_1 := e_2) e_3| & = & |De (e_1 := (e_2 = e_3))|  & \textit{Is this right?} \\
  |Mt (: t) e| & = & |De (:t := e)| \\
  |Mt (e_1; e_2) e_3| & = & |De e_1; Mt e_2 e_3| \\
  |Mt (e_1 where e_2) e_3| & = & |Mt e_1 (e_2; e_3)| \\
  |Mt (let (e_1) in e_2) e_3| & = & |De e_1; Mt e_2 e_3| \\
  |Mt (e_1^(e_2)effsR:t) e_3| & = & |Mt (e_1^(e_2)effsR:= :t) e_3| \\
  |Mt (e_1^(e_2)effsR:=e_3) e_4| & = & |Mt (e_1 : typedef{function(e_2)effsR{e_3}}) e_4| \\
  |Mt (e_1 : t) e_2| & = & |De (e_1:t := e_2)| & \textit{Is this right?}\\
  |Mt e_1 e_2| & = & |De (do{e_1}) = e_2| & \text{otherwise} \\
%% Maybe?  |Mt (l ?) e| & = & |Mt l (e ?)| & \text{otherwise} \\
%%  \\
%%  |Ty (:t)| & = & |De t| \\
%%  |Ty e| & = & |De (typedef{e})| \\
\end{array}
$$
\lennart{|Mt| can probably be simplified by using |De| on the first argument before calling it.}
