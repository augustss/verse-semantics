  \textbf{Bound variables $\boundvars{h}$, and value variables $\valvars{h}$, of a heap} \\
  \begin{array}{rcl}
    \boundvars{ |emp| } & = & \emptyset \\
    \boundvars{ |h_1 , h_2| } & = & \boundvars{h_1} \cup \boundvars{h_2} \\
    \boundvars{ |x:=v| } & = & \{x\} \\
    \boundvars{ |x| } & = & \{x\}
  \end{array}
  \qquad
  \begin{array}{rcl}
    \valvars{ |emp| } & = & \emptyset \\
    \valvars{ |h_1 , h_2| } & = & \valvars{h_1} \cup \valvars{h_2} \\
    \valvars{ |x:=v| } & = & \{x\} \\
    \valvars{ |x| } & = & \emptyset
  \end{array}
   \\ \\
  \textbf{Bound variables $\boundvars{X}$ of a context} \\
  \begin{array}[t]{rcl}
    \boundvars{ \hole } & = & \emptyset \\
    \boundvars{ |def h in X| } & = & \boundvars{h} \cup \boundvars{X} \\
    \boundvars{ |op^(X)| } & = & \boundvars{X} \\
  \end{array}\qquad
  \begin{array}[t]{rcl}
    \boundvars{ |X==e| } & = & \boundvars{X} \\
    \boundvars{ |e==X| } & = & \boundvars{X} \\
    \boundvars{ |X;e| } & = & \boundvars{X} \\
    \boundvars{ |e;X| } & = & \boundvars{X}
  \end{array}
  \\
  \text{We say $S_1 \disjoint S_2$ to mean that set $S_1$ is disjoint from $S_2$.}
  \end{array}
  $$
