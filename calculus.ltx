\section{Verse}

\begin{figurebox}
  $$
  \begin{array}{l}
    \textbf{Syntax} \\
    \begin{array}{lrcl}
    \text{Constants} & k \\
    \text{Variables} & x,y,z \\
    \text{Primops} & op  & ::= & cop \mid |apply | \\
    \text{Choice-free primops} & cop  & ::= & |add| \mid |semi| \mid |unify| \\
    \text{Expressions} & e  & ::=  & x \mid k \mid |(e_1, dots, e_n)| \mid |x => he| \mid |op^(e)| \\
    &&\mid & |he_1 choice he_2| \mid |fail| \\
    &&\mid & |if he then e_1 else e_2| \mid |for he in e|  \\
    \text{Head values} & \hnf & ::= & k \mid (v_1, \ldots, v_n) \mid |x => he|  \\
    \text{Values} & v & ::= & x  \mid \hnf \\
    \text{Choice-free expressions} & ce  & ::=  & x \mid k \mid |(ce_1, dots, ce_n)| \mid |x => he| \mid cop(ce) \\
    \text{\Hexp{}s} & |he|  & ::=  & |def h in e| \mid |none| \mid |he_1 hchoice he_2| \\
    \text{Heaps} & h & ::= & \epsilon \mid h_1 , h_2 \mid x \mid x=v \\
    \text{Heap values} & hv & ::= & \epsilon \mid hv_1 , hv_2 \mid x=v \\
    \text{Evaluation contexts} & E & ::= & \hole \mid (E,e) \mid (e,E) \mid op(E) \\
    \text{Choice contexts} & CE & ::= & \hole \mid (CE,e) \mid (ce,CE) \mid op(CE) \\
    \text{Left choice context} & LHE & ::= & \hole \mid |LHE hchoice he| \\
    \end{array} \\
    \\
    \textbf{Shorthand} \\
    \begin{array}{rcl}
      e_1 ; e_e & \text{means} & semi( e_1, e_2 ) \\
      e_1 \sim e_2 & \text{means} & |unify( e_1, e_2 )| \\
      e_1 \oplus e_2 & \text{means} & |add( e_1, e_2 )| \\
      e_1(e_2) & \text{means} & |apply( e_1, e_2 )| \\
     \end{array} \\
  \end{array}
  $$
\caption{The Verse calculus: syntax} \label{fig:verse-syntax}
\end{figurebox}

\begin{figurebox}
  $$
  \begin{array}{l}
    \textbf{Axioms for \hexp{}s}  \\
    \begin{array}{lrcl}
    \rulename{X1} & |none hchoice he| & \movesto & he \\
    \rulename{X2} & |he hchoice none| & \movesto & he \\[1mm]
    \rulename{C1} & |def H in CE^[fail]| & \movesto & |none| \\
    \rulename{C2} & |def H in CE^[he_1 choice he_2]| & \movesto
    & \begin{array}[t]{@@{}l}
        |(def H in CE^[do he_1]) hchoice| \\  |(def H in CE^[do he_2])|
        \end{array}\\[5mm]
    \rulename{B1} & |def H^[x] in E^[x=k]| & \movesto & |def H^[x=k] in E^[k]| \\
    \rulename{B2} & |def H^[x] in E^[x==(e_1,e_2)]| & \movesto
    & \begin{array}[t]{@@{}l}
          |def H^[x_1,x_2,x=(x_1,x_2)]| \\
          |in E^[(x_1==e_1,x_2==e_2)]]|
        \end{array} \\
    \multicolumn{4}{c}{\text{if}\;
           \boundvars{H[x]} \disjoint \freevars{e_1,e_2} \quad \text{and} \quad
           x_1,x_2 \disjoint \freevars{H[x],e_1,e_2} } \\[1mm]
    \rulename{S1} & |def H^[x=v] in e| & \movesto & |(def H^[emp] in e)|[x:=v]
    \end{array} \\
    \\
    \textbf{Axioms for expressions}  \\
    \begin{array}{lrcl}
    \rulename{L1} & |apply(x => def h in e_1, e_2)| & \movesto & |do (def (h,x) in (x=e_2; e_1))| \\
    \rulename{P1} & |add(k_1 ,k_2)| & \movesto & k_1+k_2 \\
    \rulename{P2} & |v ; e| & \movesto & |e| \\
    \rulename{P3} & |hnf == x| & \movesto & |x == hnf| \\[2mm]
    \rulename{K1} & |if none then e_1 else e_2| & \movesto & e_2 \\
    \rulename{K2} & |if LHE^[def h in v] then e_1 else e_2| & \movesto & |do (def h in e_1)| \\[2mm]
    \rulename{F1} & \begin{array}[t]{@@{}l}
      |for| \begin{array}[t]{l}
        |(def h_1 in v_1)| \\
        |hchoice dots hchoice| \\
        |(def h_n in v_n)|
        \end{array} \\
      |in e|
    \end{array} & \movesto & 
    \begin{array}[t]{@@{}l}
      |(do (def h_1 in e)| \\
      | , dots ,| \\
      | do (def h_n in e))|
      \end{array}
        \end{array} \\
    \\
    
   \end{array}
   $$
\caption{The Verse calculus: axioms} \label{fig:verse-axioms}
\end{figurebox}

