\lennart{Yes, there are several ways where some paths terminate, and others don't.  I don't know what to do about it.}

\begin{figurebox}
  $$
    \begin{array}{lrcl}
      \text{Evaluation context} &
         E & ::= & \hole \vb |E == e| \vb |e == E| \vb |E ; e| \vb |e; E| \\
      && \vb & |op^(E)| \vb |def h in E| \vb |E choice e| \vb |e choice E| \\
      && \vb & |if E then e else e| \vb |for E in e| \\
    \end{array}
  $$
\caption{The Verse calculus: evaluation} \label{fig:verse-eval}
\end{figurebox}

