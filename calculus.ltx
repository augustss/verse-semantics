\begin{figurebox}
  $$
  \begin{array}{l}
    \textbf{Syntax} \\
    \begin{array}{lrcl}
    \text{Integer constants} & k \\
    \text{Variables} & \multicolumn{3}{l}{x,y,z,f,g} \\
    \text{Programs} & p  & ::=  & e \\
