%  -------------------------- Syntax -----------------------
\newcommand{\figureSyntax}{
\begin{figure}[t]
  $$
  \begin{array}{lr@@{\;}c@@{\;}l@@{}}
      \text{Integers} & k \\
      \text{Variables} & \multicolumn{3}{l}{x,y,z,r,f,g} \\
      \text{Programs} & p  & ::=  & |one e| \quad \text{where} \; \freevars{e} = \{ \} \\
      \text{Expressions} & e & ::= & |v| \vb |v==e| \vb |e_1 ; e_2| \vb |e_1 choice e_2| \vb |fail| \vb |def x b| \vb |apply1N v_1 v_2| \vb |one b| \vb |all b| \\
      \text{Values} & |v| & ::= & x  \vb \hnf \\
      \text{Head values} & \hnf & ::= & k \vb op \vb |arr (v_1, xdots, v_n)| \vb |lam x e| \\
      \text{Primops} & op  & ::= & |gt| \vb |add|
  \end{array}
      $$
  \caption{Syntax}
\end{figure}
}

%  -------------------------- Contexts -----------------------
\newcommand{\figureContexts}{
\begin{figure}
    $$
      \begin{array}{lr@@{\;}c@@{\;}l}
      \text{Substitution contexts} & S & ::= & \hole \vb |v == S| \vb |e; S| \vb |S ; e| \\
      \text{Value contexts} & V & ::= & \hole \vb |tup (v_1, xdots, V, xdots, v_n)|\\
      \text{Scope contexts} & SX & ::= & |one SC| \vb |all SC| \\
                            & SC & ::= & |hole| \vb |SC choice e| \vb |e choice SC| \\

      \text{Choice contexts} & CX & ::= & \hole \vb |v == CX| \vb |CX ; e| \vb |ce; CX| \vb |def x CX| \\
      \text{Choice-free exprs} & ce  & ::=  & |v| \vb |v == ce| \vb |ce_1 ; ce_2|
                                      \vb |def x ce| \vb |apply1 op v| \vb |one e| \vb |all e|
\\
    \end{array}
     $$
    \caption{The syntax of contexts}
    \label{fig:contexts} \label{fig:choice-free-syntax}
\end{figure}
}

