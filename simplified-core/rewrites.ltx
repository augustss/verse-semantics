% ------------------ ICFP rewrite rules -------------------

\newcommand{\figureRewriteRules}{
  \begin{figure}
%% GS: Add @@{} to match other changes made below to get more horizontal space in Figure 3 
%%    $\begin{array}{l}

         %%          $\begin{array}{@@{}l@@{}}
    $\begin{array}{@@{}l}

    % \rulegroupname{Primitive operations}

%% GS: change \quad to \hskip0.5em to get a little more horizontal space to work with in this figure; also add @@{}
%% \begin{array}{@@{\quad} l  r @@{\;}c@@{\;} l l}
%%\begin{array}{@@{\hskip0.5em} l @@{}r @@{\;}c@@{\;} l@@{\hskip4em}l}

%% \begin{array}{@@{\hskip0.5em} l @@{\hspace{-.5em}} r @@{\;}c@@{\;} l l}
\begin{array}{@@{\hskip0.5em} l @@{\hspace{-.5em}} r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Application:}
\rulename{app-add}          & |applyN add (k_1 ,k_2)| & \movesto & |k_3| & \text{where $k_3 = k_1 + k_2$}\\
\rulename{app-gt}           & |applyN gt (k_1,k_2)|   & \movesto & |k_1| &  \text{if $k_1 > k_2$} \\
\rulename{app-gt-fail}      & |applyN gt (k_1,k_2)|   & \movesto & |fail| &  \text{if $k_1 \leq k_2$} \\
\rulename{app-beta}^{\alpha} & |apply1 (lam x e) v| & \movesto & |def x (x==v; e)|
                                                  & \text{if $x \not\in \freevars{|v|}$} \\
\rulename{app-tup}          & |apply1 (tup (v_0,xdots, v_n)) v| & \movesto &
                              |(v == 0^^^ v_0) choice xdots choice (v == n^^^ v_n)| \\
\rulename{app-tup-0}        & |apply1 emptytup v| & \movesto & |fail| \\
%%\end{array}
%%\\
\\[-0.6em]

%% GS: change \quad to \hskip0.5em to get a little more horizontal space to work with in this figure 
%% \begin{array}{@@{\quad} l @@{\hspace{-.5em}} r @@{\;}c@@{\;} l l}
%%\begin{array}{@@{\hskip0.5em} l @@{\hspace{-.5em}} r @@{\;}c@@{\;} l l}
    % The quad indents the lines
    % The \hspace{-..} removes redundant space between rule name column and LHS column
    % that arises because the longest rule name and the longer LHS are not on the same line
    % The \; reduces the spacing around the arrow
\rulegroupname{Unification:}
  \rulename{u-lit}   & |k_1 == k_2| & \movesto & |emptytup| & \text{if $k_1=k_2$} \\
%%  \rulename{u-tup} & \hspace{-1.8em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e| & \movesto & |v_1==v1';xdots;v_n==v_n'; e| \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_0,xdots,v_n) == tup (v0',xdots,v_n')| & \movesto & |v_0==v0';xdots;v_n==v_n'| \\
  \rulename{u-tup-0} & \hspace{-2.0em} |emptytup == emptytup| & \movesto & |emptytup| \\
  \rulename{u-fail} & |hnf_1 == hnf_2| & \movesto & |fail| & \text{if \rulename{u-lit}, \rulename{u-tup}, \rulename{u-tup-0} do not match} \\
  \rulename{u-occurs} & |x==V^[x]| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
  \rulename{subst} & |S^[x==v]| & \movesto & |(subst S x v)^[x==v]| \hspace*{-0.3em}
  & \text{if $|x| \in \freevars{|S|}$, $|x| \notin \freevars{|v|}$ or $|v|$ is a lambda}, \\
  &&&& \text{\hskip 0.7em and ($(|v| = |y| \implies |x| \prec |y|)$)} \\
  \rulename{hnf-swap} & |hnf==x|    & \movesto & |x==hnf| \\
  \rulename{var-swap} & |y==x|    & \movesto & |x==y| & \text{if |x| $\prec$ |y| } \\
%%  \rulename{var-swap-subst} & |X^[x==y; e]| & \movesto & |subst X y x^[y==x; subst e y x]| & \text{if |y| $\prec$ |x| } \\
%%  \rulename{val-swap-ord} & |eq_1; eq_2; e| & \movesto & |eq_2; eq_1; e| & \text{if |eq_2| $\prec$ |eq_1| } \\
  \rulename{seq-swap} & |e; x==v| & \movesto & |x==v; e; emptytup| &
                      \text{unless (|b| is |y==v'| and |y| $\preceq$ |x|)} \\

    \\[-0.6em]

\rulegroupname{Elimination:}
\rulename{val-elim} & |v ; e| & \movesto & |e| \\
\rulename{exi-elim} & |def x e| & \movesto & |e| & \text{if $|x| \notin \freevars{|e|}$}\\
\rulename{eqn-elim} & |def x (S^[x==v])| & \movesto & |S^[emptytup]| & \text{if $|x| \notin \freevars{|S^[v]|}$} \\
\rulename{fail-elim} & |S^[fail]| & \movesto & |fail| & \text{if $|S| \ne \hole$} \\

    \\[-0.6em]

\rulegroupname{Normalization:}
\rulename{exi-float}^{\alpha} & |S^[def x e]| & \movesto & |def x (S^[e])| & \text{if $|S| \ne \hole,\,  x \notin \freevars{|S|}$} \\
\rulename{seq-assoc} & |(e_1 ; e_2) ; e_3| & \movesto & |e_1 ; (e_2 ; e_3)| \\
\rulename{eqn-seq-push} & |v == (e_1 ; e_2)| & \movesto & |e_1 ; v == e_2| \\
\rulename{eqn-choice-push} & |v == (e_1 choice e_2)| & \movesto & |v == e_1 choice v == e_2| \\
\rulename{eqn-eqn-push} & |v_1 == (v_2 == e)| & \movesto & |v_1 == emptytup ; v_2 == e| \\
\rulename{eqn-result} & |v == e ; emptytup| & \movesto & |v == e| \\
\rulename{exi-swap} & |def x (def y e)| & \movesto & |def y (def x e)| \\
%\rulename{seq-swap} & |eq_1; eq_2; e| & \movesto & |eq_2; eq_1; e| &
%                      \hspace{-3em}\text{if ($eq_1 \in ceq$ or $eq_2 \in ceq$) and $eq_2 \prec eq_1$} \\
%\multicolumn{5}{l}{\text{\lennart{Plan: remove rule above, use rule below, move to unification group}}}\\

    \\[-0.6em]

\rulegroupname{Choice:}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice}  & |one (v choice e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)| \\
\rulename{choose-r} & |fail choice e| & \movesto & |e| \\
\rulename{choose-l} & |e choice fail| & \movesto & |e| \\
\rulename{choose-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
\rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & \text{if}~|CX| \ne \hole \\


\end{array} \\
\\[-0.3em]
\text{\textit{Note}: In the rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.}
\end{array}$
\caption{\textbf{The \vcname: Rewrite rules}} \label{fig:rules}
\Description{A table that exhibits the rewrite rules for the Verse Calculus, groupesd into five categories: Application, Unification, Normalization, Garbage Collection, and Choice}
\end{figure}
}

