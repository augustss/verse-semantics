library verse-densem
    import:           general-libs
    hs-source-dirs:   verse-densem
    default-extensions:  TypeOperators
    exposed-modules:
                      SExp
                      Dom
                      ENV
                      Oper
                      SemSeqENV
    build-depends:    verse-libs,
                      base,
                      containers,
                      text,
                      pretty,
                      QuickCheck,
                      scientific

-- Various Verse utilities on which other stuff depends
-- Should really have its own cabal project
library verse-libs
