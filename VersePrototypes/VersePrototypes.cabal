-- shared parser for various verse implementations and experiments
library verse-parser
    import:           general-libs
    hs-source-dirs:   parser
    exposed-modules:
                      Parser.Expr
                      Parser.Error
                      Parser.Parser
                      Parser.OpParser
    other-modules:

    build-depends: parser-combinators
                 , verse-libs

test-suite verse-parser-test
    import:           general-libs
    hs-source-dirs:   parser/test
    type: exitcode-stdio-1.0

    -- exposed-modules:
    main-is:          Main.hs

    default-language: GHC2021
    ghc-options:      -Wall -Wno-name-shadowing

    other-modules: Paths_VersePrototypes
    build-depends: base
                 , megaparsec
                 , containers
                 , text
                 , filepath
                 , directory
                 , verse-parser
