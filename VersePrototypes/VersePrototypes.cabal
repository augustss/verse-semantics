cabal-version:      3.0
name:               VersePrototypes
version:            0.1.0.0
synopsis:           Haskell prototypes and testing for Verse
description:        Programs for automated and interactive tests of Core Verse rewrite systems.
tested-with:        GHC==9.4
copyright:          Epic Games 2022
data-dir:           versetests
data-files:         *.versetest

extra-source-files: CHANGELOG.md
                    README.md

-- This common-block is macro-expanded everywhere you see 'import: general-libs'
common general-libs
    default-language: Haskell2010
    ghc-options:      -Wall -Wno-unrecognised-warning-flags -Wno-x-partial -O -ticky
    build-depends:    base,
                      directory,
                      containers,
                      random,
                      mtl >= 2.3,
                      pretty,
                      megaparsec,
                      haskeline,
                      scientific

executable verse-repl
    import:           general-libs

    -- In the repl/ subdirectory
    hs-source-dirs:   repl
    build-depends:    verse-libs,
                      verse-densem,
                      haskeline,
                      optparse-applicative,

    main-is:          Main.hs

executable confluence-check
    -- In the Confluence/ subdirectory
    import:           general-libs
    hs-source-dirs:   Confluence
                      .
    build-depends:    text,
                      QuickCheck,
                      verse-libs

    main-is:          Main.hs

    -- In an executable, exposed-modules doesn't matter
    other-modules:
                      Core.Expr
                      Core.Solver
                      Core.Rules
                      Core.Rule
                      Core.Blocked
                      Core.Bind
                      Core.Traced
                      Epic.Print
                      Epic.List
                      Epic.UnionFind
                      Epic.BellmanFord
                      FrontEnd.Error



-- executable trsverifier
--    import:           general-libs
--    hs-source-dirs:   Verifier
--    build-depends:    verse-libs,
--                      optparse-applicative,
--                      QuickCheck,
--                      githash
--
--    main-is:          TRSVerify.hs
--
--    default-language: Haskell2010

executable tester
     import:           general-libs
     hs-source-dirs:   tester
     build-depends:    verse-libs,
                       megaparsec,
                       optparse-applicative,
                       uniplate,

     main-is:          Main.hs

     default-language: Haskell2010

executable refimpltester
     import:           general-libs
     hs-source-dirs:   refimpltester
     build-depends:    verse-libs,
                       megaparsec,
                       optparse-applicative,
                       HUnit,
                       prettyprinter,
                       comonad,
                       semigroupoids,
                       text,
                       unordered-containers,
                       bytestring,
                       transformers,
                       hashable,
                       parsec,
                       filepath,
     hs-source-dirs:   ../VerseReferenceImpl/src

     main-is:          Main.hs

     default-language: GHC2021
     ghc-options:      -Wall -Wno-name-shadowing

     other-modules:
        Control.Monad.Extras
        Control.Monad.Ref
        Control.Monad.Supply
        Control.Monad.Verse
        Control.Monad.Wrong
        Data.Fix
        Data.IntMap.Lazy.Extras
        Data.IntMap.Strict.Extras
        Language.Verse
        Language.Verse.Access
        Language.Verse.Contract
        Language.Verse.Desugar
        Language.Verse.Desugar.Exp
        Language.Verse.Effect.Split
        Language.Verse.Error
        Language.Verse.Eval
        Language.Verse.Ident
        Language.Verse.Indent
        Language.Verse.Intrinsic
        Language.Verse.Label
        Language.Verse.Loc
        Language.Verse.Mode
        Language.Verse.Parse.Exp
        Language.Verse.Parse2
        Language.Verse.Path
        Language.Verse.Pos
        Language.Verse.Rewrite
        Language.Verse.Rewrite.Exp
        Language.Verse.SimpleName
        Language.Verse.Token
        Language.Verse.Val



