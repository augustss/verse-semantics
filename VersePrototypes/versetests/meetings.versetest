verify("M4Nov24-2", pass){ f(x:int):=x; g( h(:int):int ) := h[1]; g[f] }
  # Test that the call to g[f] checks that f truly satisfies the domain of g.

verify("M21Aug24-1", pass){ (F():int = G[]) ; (G():int = 1); F[] }


# Meeting 16 Aug 24
verify("M16Aug24-1", pass){ f(x:int):=nat[x] => f[-3]  }
  # This is an odd one!  If it had been
  #     (f(x:int)<succeeds>:int) => f[3]
  # i.e.   (f := fun(x:int){ :<succeeds>int }
  # it'd mean that f is a function that returns some int
  # In the actual test case it promises to succeed, returning nat[x]
verify("M16Aug24-2", pass, tim=skip_rej){ (a:int) => (f(:int):=nat[a]) => f[a]  }
  # M16Aug24-4: similar to M16Aug24-1

verify("M16Aug24-3", pass){ f(x:int):nat := nat[x] => f[-3]  }
verify("M16Aug24-4", pass){ f(x:int):type{nat[x]} => f[-3]  }

# Meeting 14 Aug 24
testeq("jan1", pass){ (f(x:int)<succeeds>:= x); y:int; f[y]=3} {3}
  # "jan1" pass relies on not having a check<succeeds> in the execution
  # desugaring of f; or on not having check{} insist on ground-ness

verify("jan2", pass, tim=skip_rej){ f(x:int)<succeeds>:int = x; g(y:int):= {if(f(y)=y) then 1 else 2} ; g[3] }
verify("jan3", pass, tim=skip_rej){ h(x:int,y:int)<decides>:int= x=y; if(h[2,2]=2) then 1 else 2 }
verify("jan4", pass){ h(x: int, y:int)<decides>:int= x=y; () => if(h[2,2]) then 1 else 2 }

verify("jan5a", fail,tim=D00){ f(c:char):=1; as:any
                       => as=array{_}
                       =>  x:=as[0]
                       => bs:=array{:int}
                       => bs=as => f[x] }
  # jan5a: x is an int, and f expects a char, so body of lambda fails

verify("jan5b", pass, broken){ f(c:int):=1; as:any
                               => as=array{_}
                               => x:=as[0]
                               => bs:=array{:int}
                               => bs=as => f[x] }
  # jan5b: x is an int, and f expects an int, so body of lambda succeeds

verify("jan6a", pass) { ty(x:int)<succeeds>:int := if(x=0) then x else 0; g(z:ty)<succeeds>:int := z }
verify("jan6b", pass) { ty(x:int)<succeeds>:int := x; g(z:ty)<succeeds>:int := z }
verify("jan6c", pass) { ty(x:int)<succeeds> := { if(x=0) then x else 0 };
                        g(z:ty)<succeeds>:int := z=0 }

# ---------------------------------
# Opacity and function arguments: 14 Aug 24
verify("FCS1", pass){ f(x:int)<decides>:int := x>3
                    ; g()<decides> := f['m'] }
   # FCS1: f is opaque; call f['m'] is allowed by verifier even though domain test fails

verify("FCS2", fail){ f(x:int)<decides>:int := x>3
                    ; g()<succeeds> := f[4] }
   # FCS2: f is opaque; can't prove f[4] succeeds, even though it does

verify("FCS3", fail){ f(x:int)<closed><succeeds>:int := x+3
                    ; g()<succeeds> := f['m'] }
   # FCS3: f is opaque, and domain test fails, so g rejects the call

verify("FCS4", pass){ f(x:int)<decides> := x>3
                    ; g()<succeeds> := f[4] }
   # f is transparent; call f[4] actually succeeds

verify("FCS5", pass){ f(x:int)<decides> := x>3
                    ; g()<decides> := f['m'] }
   # FCS5: f['m'] is allowed by verifier even though domain test fails
   #       same as FCS1, but this time transparent f

verify("FCS6", fail, tim=skip_acc) { f(x:int)<decides>:char := 7 }
   # FCS7: 7 is not a char.  Rejected despite <decides>
verify("FCS7", fail, tim=skip_acc) { f(x:int)<decides>:type{10} := 7 }
   # FCS8: 7 is not 10.  Rejected despite <decides>

verify("FCS8", pass)   { f(3=4)<succeeds>:int := 7 }
verify("FCS9", pass,tim=skip_rej)   { f(3=4)<succeeds>:int := 'm' }

# --------- Round parens --------------
verify("FCS10", fail){ f1(x:int)<decides>:int := x>3
                     ; g()<decides> := f1('m') }
   # FCS10: f1 is opaque; Round parens; can't prove f1('m') succeeds

verify("FCS11", fail){ f1(x:int)<decides>:int := x>3
                     ; g()<decides> := f1(2) }
   # FCS11: f1 is opaque; Round parens; arg type matches,
   # but since f1 is <decides> we can't prove f1(2) succeeds

verify("FCS12", fail){ f2(x:int)<decides> := x>3
                     ; g()<decides> := f2('m') }
   # FCS12; can't prove f1('m') succeeds

verify("FCS13", fail){ f2(x:int)<decides> := x>3
                           ; g()<decides> := f2(2) }
   # FCS13: Round parens; can't prove f1(2) succeeds

verify("FCS14", pass){ f2(x:int)<decides> := x>3
                           ; g()<decides> := f2(4) }
   # FCS14: Round parens; this time we can prove that f2(4) succeeds

# More function call semantics
verify("TimL300", pass) {a:int => g(f()(x:int):=3):=4 => g[f1()(x:int):=a] => 3}
verify("TimL300-1", pass) { (g(x:int):int) => g['m'] => 3 }
verify("TimL300-2", pass) { (g(x:int) :=3) => g['m'] => 3 }
  # TimL300-1,2: more exotic versions of FCS6

verify("TimL300-3", pass) { (g( f(x:int):char ):=4)  => g[ (x:int) =>'m'] => 3 }
verify("TimL300-4", pass) { (g( f(x:int):char ):=4)  => g[ h(x:int):='m'] => 3 }
verify("TimL300-5", pass) { (g( f(x:int):char ):int) => g[ h(x:int):='m'] => 3 }
verify("TimL300-6", pass)   { (g( f(x:int):='m' ):int) => g[ h(x:int):='m'] => 3 }
verify("TimL300-7", pass) { (g( f(x:int):="not-monkey" ):int) => g[ h(x:int):='m'] => 3 }
verify("TimL300-8", pass)   { f(x:int):int := 1; if (f['m'] >0) then{1} else{2} = 2 }
verify("TimL300-9", pass, broken)   { f( g(x:int):char ):int := 1
                                    ; if (f[(x:int)=>1] >0) then{1} else{2} = 2 }


# Meeting 9 August
testeq("M9Aug24-1", pass){ foo(x:any)<decides> := { x=99 }; p:any; foo[p]; p } { 99 }
  # M9Aug24-1 uses bidirectional programming
