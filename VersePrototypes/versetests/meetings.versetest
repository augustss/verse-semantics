  ; f()<succeeds>:int =
     { string[x] # or x = 2, etc.
     ; loop[] # will hit this loop, and say f is verified
     }
  ; x = 1; f[] }
  # M27Jan25-1: will crash at runtime, and so must be rejected

testeq("M27Jan25-2", fail, skip)
    { loop():false := loop[]; x:any; one{ char[x]; loop[] }; x=1 }
    {1}
  # M27Jan25-2: this should fail, because the one{} is stuck on
