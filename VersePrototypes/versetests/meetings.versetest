# M24Jan25-*: examples involving "gr 3" type
verify("M24Jan25-1", pass){ f():(function (x:int)<decides>{x>3}) := 7 }
verify("M24Jan25-2", fail){ f():(function (x:int)<decides>{x>3}) := 2 }
verify("M24Jan25-3", pass){ (f():(function (x:int)<decides>{x>3}) := 7)
                          ; (f[] > 3) }
verify("M24Jan25-4", fail){ (f():(function (x:int)<decides>{x>3}) := 7)
                          ; (f[] > 4) }

# M20Jan25-*: examples involving a higher order function type
verify("M20Jan25-1", pass){ f():type{(:string) => (:string)} := (x:any => x) }
verify("M20Jan25-1a", pass){ t := type{(:string) => (:string)}
                           ; f():t := (x:any => x) }
  # M20Jan25-1a: here we name t := type{stuff} and it still works
verify("M20Jan25-1b", fail){ t := {(:string) => (:string)}
                           ; f():type{t} := (x:any => x) }
  # M20Jan25-1b: here we don't expect to be able to name `t`

verify("M20Jan25-2", pass)
                          { (f():type{(:string) => (:string)} := (x:any => x))
                          ; string[ f[]["woo"] ] }
verify("M20Jan25-3", fail){ (f():type{(:string) => (:string)} := (x:any => x))
                          ; string[ f[][77] ] }
verify("M20Jan25-4", fail){ (f():type{(:string) => (:string)} := (x:any => x))
                          ; int[ f[]["woo"] ] }

verify("M20Jan25-5", pass){ f(x:int)(y:int)(z:int):int := x+y+z }
  # M20Jan25-5 is a 3-level curried function, just showing how that desugars

verify("M20Dec24-0", pass){ f(x:int)<decides> := { x=(1|2) } }
  # M20Dec24-0: f <decides>, not iterates, because x has one value in RHS

verify("M20Dec24-1", pass){ f(x:int)<decides> := { x=(1|2) }
                          ; all { y:int; f[y] } }
  # M20Dec24-1: function is transparent, so inline it and everything is good

verify("M20Dec24-2", fail){ f(x:int)<decides>:int := { x=(1|2) }
                          ; all { y:int; f[y] } }
  # M20Dec24-2: function is opaque, so the 'all' gets stuck

verify("M20Dec24-3", pass){ f(x := 1|2)<decides>:int := x
                          ; all {y:int; f[y] } }
  # M20Dec24-3: f is opaque but the iteration is in the domain

verify("M20Dec24-4", pass){ f(3)<succeeds>:int := 22; x:int; f[x] }



verify("M22Nov24-1", fail){ if( (x:=1) | (x:=2) ) then {x} else 0 }
  # M22Nov24-1: the 'x' in the then-branch is unbound

verify("M20Nov24-1", pass){ f(x:string):= { if (int[x]) then { x[1] } else 0 } }
 # M20Nov24-1: the int[x] is contradictory with x:string,
 # so we ingore the bad-ness of x[1]
verify("M20Nov24-2", pass){ f(x:comparable):= { if (int[x]) then { x+1 } else 0 } }

