# ------------ 8 Apr 2025 -------------
testeq("M8Apr25-1", pass){ succ(x:int):int := x+1
                         ; h->f:=function(:int){:int}
                         ; h=succ
                         ; f[3] } { 4 }

verify("M8Apr25-2", pass, broken){ succ(x:int):int := x+1; h->f:=function(:int){:int}; h=succ; f[3]=4 }

  # This rather strange test fails to verify at the moment

# -------------- More examples that involve choice in the domain ------------
verify("M28Mar25-1", fail) { f( g():=1|2 )<succeeds>:int := { g[]; 7} }
  # -1: a copy of M19Mar25-12.  Should fail because g[] inlines to (1|2)

verify("M28Mar25-2", pass) { f( g():=1|2 )<succeeds>:int := { 7 } }
  # -2: passes; now g is not called

verify("M28Mar25-3", pass) { f( g():int:=1|2 )<succeeds>:int := { g[]; 7} }
  # -3: passes; g is now opaque, so we don't see the choice at the call site

verify("M28Mar25-4", pass) { f( g():int:=1|2 )<succeeds>:int := { g[]; 7}
                           ; f[ () => 1 ] }
  # -4: Like -3, but we call f.  Yes: the argument returns 1 or 2
verify("M28Mar25-5", fail) { f( g():int:=1|2 )<succeeds>:int := { g[]; 7}
                           ; f[ () => 3 ] }
  # -5: Like -3, but we call f.  No: the argument function does not return 1 or 2
# -------------------------------------------------------------------------------------

verify("M26Mar25-5", pass) { h( g(:int):char )<closed> := { g[2] }
                           ; if (h[99]) then{ 1 }else{ 2 } = 2 }
  # -5: 99 is definitely not a function so we get into the else branch

verify("M26Mar25-6", pass) { h( g(:int):string )<closed>:string := { g[2] }
                           ; if (h[x:int => "monkey"]) then{ 1 }else{ 2 } = 1 }
  # -6: h's arg is a function of the right type, so we get into the then branch

verify("M26Mar25-7", fail) { h( g(:int):string )<closed>:string := { g[2] }
                           ; if (h[x:int => 3]) then{ 1 }else{ 2 } = 1 }
  # -7: h's arg is a function of the wrong type, so we /reject/

verify("M26Mar25-8", pass) { h( g(:int):string )<closed>:string := { g[2] }
                           ; Goofy(p:=h[x:int=>3]):=p }
  # -8: h's arg is a function of the wrong type, but it's in a domain, so accept

verify("M26Mar25-9", fail, broken) { f(x:int where g():int={"monkey"})<decides> := g() }
  # -9: Tim said that this should be rejected
  # In fact it succeeds, despite the call to g!  Becuase the client function
  # for `g` just returns `some(int)`.  It's the /definition/ that should
  # be rejected

verify("M26Mar25-10", fail) { f(x:int where g():int={"monkey"}) := { 3 }
                            ; f[3] }
 # -10: like -9, but does fail, because at the call of `f`,
 #      we cough up the task of verifying `g`

verify("M26Mar25-1", pass, broken)
           { t01( x:int where (0<=x; x<=1)) := x
           ; f( gg(:t01):=99 ) := { 3 }
           ; g(x:=(1|2)) := { 99 }
           ; f[ g ] }
  # -1: a rather tricky test, passing a domain-iterating function g
  #     to a function expecting the same values, but not domain-iterating

verify("M26Mar25-2", fail) { f()<decides> := { x:int := "monkey" } }
  # Rejected because "monkey" does not have type int
verify("M26Mar25-3", pass) { f()<decides> := {int["monkey"] } }
  # Passes because int["monkey"] simply fails and f is <decides>
verify("M26Mar25-4", pass) { f()<decides> := { x:int := int["monkey"] } }
  # Passes becuase int["monkey"] fails, and then has type int

verify("M20Mar25-1", pass) { f( (:int) | (:string) ):int := 3
                           ; f[2]; f["monkey"] }
  # -1: this one actually just scrapes past, even without
  #     pushing kappa inwards in WCHOICE, but only because int is
  #     visibly a partial identity function.
verify("M20Mar25-1a", pass) { succ(x:int) := x+1
                            ; f( (:succ) | (:string) ):int := 3
                            ; f[2]; f["monkey"] }
  # -1a: This requires WCHOICE to push kappa inwards

verify("M20Mar25-2", fail) { f( (:int) | (:string) ):int := 3
                           ; f['c'] }

# -------------- A collection of examples that involve choice in the domain ------------
verify("M19Mar25-1", pass)  { f( g:type{(:int) => :char} ):char := g[3] }
verify("M19Mar25-1a", pass) { f( g(:int):char            ):char := g[3] }
  # This should surely pass!  We apply g to 3, which gives a char.

verify("M19Mar25-2", pass) { (f( x:int    )<decides>  := x=(1|2)); all{ exists y { f[y] } } = (1,2) }
verify("M19Mar25-3", pass) { (f( x:=(1|2) )<succeeds> := x);       all{ exists y { f[y] } } = (1,2) }
  # -2 and -3 are transparent, so we can see the iteration order in both

verify("M19Mar25-4", fail) { (f( x:int )<decides>:int     := x=(1|2)); all{ exists y { f[y]; y } } = (1,2) }
verify("M19Mar25-5", pass) { (f( x:=(1|2) )<succeeds>:int := x);       all{ exists y { f[y]; y } } = (1,2) }
  # -4 iterates in the range and the caller can't see that
  # -5 iterates in the domain, and the caller /can/ see that

verify("M19Mar25-6", pass) { (f( g():type{1|2} )<succeeds>:int := g[]) }
verify("M19Mar25-7", pass) { (oneortwo(x:any)<decides> := x=1 | x=2)
                           ; (f( g():oneortwo )<succeeds>:int := g[]) }

verify("M19Mar25-8", pass) { (f( g(x:int):=4 )<succeeds>:int := g[7]=4)
                           ; h(x:int):=4
                           ; f[h] }
verify("M19Mar25-9", fail) { (f( g(x:int):=4 )<succeeds>:int := g[7]=4)
                           ; h(x:int):int:=4
                           ; f[h] }
# FIXME: #61
verify("M19Mar25-10", pass) { (f( z:int, g(x:int)<decides>:=x=4 )<succeeds>:int
                                 := if( y:=g[z] ) then{ y=z; y=4 } else{ 99 })
                            ; (h(x:int)<decides>:=x=4)
                            ; f[3,h] }
verify("M19Mar25-11", fail) { f( z:int, g(x:int)<succeeds>:=x=4 )<succeeds>:int
                                 := { g[z]; z=4 } }
  # g is like a transparent function; the effect annotation doesn't do much

verify("M19Mar25-12", fail) { f( g():=1|2 )<succeeds>:int := { g[]; 7} }
  # g behaves transparently, so f should because the domain has choices
# ----------------------------------------------------------------------------------

verify("M7Feb25-1", pass){ g1()<decides> := { (f(x:int):string := 27); fail }  }
  # M7Feb25-1: actually passes the verifier;
  # although f doesn't verify, it is never called
verify("M7Feb25-2", pass){ g2()<decides> := { exists y { (f(x:int):string := {y >2; 27})
                                                       ; fail } } }
  # M7Feb25-2 is similar

verify("M7Feb25-3", fail){ loop():type{fail} := { loop[] }
                         ; h3(x:int)<succeeds> :=
                             { if ( f()<succeeds>:type{x=3} := 3 )
                               then { fail }
                               else { fail }
                             ; loop[] } }
   # M7Feb25-3: If check<succeeds>{fail} is just stuck, then this program will verify.
   # But h3[2] fails!  as you can see in M7Feb25-4

testeq("M7Feb25-4", pass){ loop():type{fail} := { loop[] }
                         ; h3(x:int)<succeeds> :=
                             { if ( f()<succeeds>:type{x=3} := 3 )
                               then { fail }
                               else { fail }
                             ; loop[] }
                         ; h3[2] }
      { fail }
   # Actually it doesn't fail; rather it gets stuck on a runtime check<succeeds>
   # See MaxVerse9 Feb 12.
   # Now passing because we discard runtime check<fx>

verify("M7Feb25-5", fail, broken)
   { loop():type{fail} := { loop[] }
   ; h3(x:int)<succeeds> :=
        { if ( f()<succeeds>:type{x=3} := {y>4; 3} )
          then { fail }
          else { fail }
         ; loop[]; y:=5 } }
  # M7Feb25-5 fails when you call h3[2]; but it verifies,
  #   REGARDLESS of the choice of wrongFx
  # if ( verify(){ defn of f, stuck waiting for y }; \().blah ) then fail else fail
  # VERY BAD: verifies but gets stuck at runtime

verify("M7Feb25-6", fail, broken)
   { loop():type{fail} := { loop[] }
   ; h3(x:int)<succeeds> :=
        { if ( f()<succeeds>:type{x=3} := {y>4; 3} )
          then { f[] }
          else { fail }
         ; loop[]; y:=5 } }


