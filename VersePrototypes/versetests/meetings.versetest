# ------------ 2 May 2025 -------------
verify("M2May25-1", pass){ f6a( p(x:int)<decides>:=7 )<succeeds> := p[3] }
  # -1: accept: despite p <decides>, because p is transparent
verify("M2May25-1a", fail){ f6a( p(x:int)<decides>:int )<succeeds> := p[3] }
  # -1a: reject: p is opaque so <decides> wins
verify("M2May25-1b", fail){ f6a( p(x:int)<decides>:int := 7 )<succeeds> := p[3] }
  # -1b: reject just like -1a

verify("M2May25-2", fail, broken){ f6a( p(x:int)<decides>:=7 )<succeeds> := p[3]
                         ; all { f6a[ p(x:int)<closed><decides>:=fail ]} }
  # -2: reject because arg to f6a doesn't return 7

verify("M2May25-3", pass){ f6a( p(x:int)<decides>:=7 )<succeeds> := p[3]
                         ; all { f6a[ p(x:int)<closed><decides>:=7 ]} }
  # -3: accept because arg to f6a does return 7

verify("M2May25-4", pass){ f6a( p(x:int)<decides>:=7 )<succeeds> := p[3]
                         ; all { f6a[ p(x:int)<closed><succeeds>:=7 ]} }
  # -4: same as -3, but with a <succeeds> p


