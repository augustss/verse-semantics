verify("M9Aug24-3", pass,tim=skip_rej){ F1(X:any)<closed><decides> := X = 1|2 }

# Meeting 7 August
verify("M7Aug24-1", pass ) { G(f()<decides>:int):=3; G[ h():=3 ] }
verify("M7Aug24-2", fail,tim=skip_acc ) { G(f()<decides>:int):=3; G[ h():='m' ] }
   # h() := 'm' does not have the right return type
verify("M7Aug24-3", pass ) { G(f()<decides>:int):=3; G[ h()<decides>:=3=4 ] }

verify("M7Aug24-4", fail, tim=V10 ) { x:int := 'm' }
