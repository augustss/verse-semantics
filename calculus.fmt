%format lambda = "\lambda\!"
%format BigLambda = "\Lambda\!"
%format at = "\, @\!\!"
%format dot = "\! ."
%format alpha = "\alpha"
%format beta = "\beta"
%format gamma = "\gamma"
%format tau = "\tau"
%format sigma = "\sigma"
%format varsigma = "\varsigma"
%format upsilon = "\upsilon"
%format colonequals = "\colonequals"
%format dots = "\cdots"
%format dollar = "\$"
%format choice = "[ \! ]"
%format he = "he"
%format def = "\textbf{def}"

