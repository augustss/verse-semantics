%% ----------------------
%% Stuff for TimCore

%format timlam h fx i x s0 j y s1 = "\textbf{tlam}(" h "," fx ")\," i "," x "\{" s0 "\}" j "," y "\{" s1 "\}"
%format lam2 x r e = "\lambda" x "\shortrightarrow{}" r ".\," e
%format scope (vs) (stuff) (e) = "\textbf{scope}(" vs ";" stuff ").\," e

%% 'g' inferences
%format edge v w = v "\leftarrow" w
%format fails s v  = s "\{" v==fail "\}"
%format equals s v w  = s "\{" v==w "\}"
%format lengthis s y z = s "\{" length^[y]==z "\}"
%format dominates s v w = s "\{" v "\twoheadleftarrow" w "\}"

%format fvs e = "\mathsf{fvs}" e

%format effects (g) (e) = "\mathcal{FX}(" g "," e ")"

%format fx_1
%format fx_2
%format andeffects (fx1) (fx2) = fx1 "\ast" fx2

%% --------- Effects ------------
%format succeeds = "\textbf{succeeds}"
%format succeedsE (e) = "\textbf{succeeds}\{" e "\}"
%format decides = "\textbf{decides}"
%format decidesE (e) = "\textbf{decides}\{" e "\}"
%format iterates = "\textbf{iterates}"
%format iteratesE (e) = "\textbf{iterates}\{" e "\}"
%format resolves = "\textbf{resolves}"
%format fails = "\textbf{fails}"
%format abstracts = "\textbf{abstracts}"
%format contradicts = "\textbf{contradicts}"


%% ----------------------
%format ^ = " "
%format ^^ = "\hspace{0.1em}"

%format subst e x (v) = "\subst{" e "}{" x "}{" v "}"

%format (De (x)) = "\De{" ^ x "}"
%format (Me (i) (e)) = "\Me{" ^ i "}{" ^e "}"
%format (An (x)) = "\An{" ^ x "}"
%format (Cr (x)) = "\Cr{" ^ x "}"
%format (Bi (x)) = "\Bi{" ^ x "}"
%format (Vr (x)) = "\Vr{" ^ x "}"
%format (Vl (x)) = "\Vl{" ^ x "}"
%format (Th (x)) = "\Th{" ^ x "}"
%format (Pd (x)(y)) = "\Pd{" ^ x "}{" ^ y "}"
%format (Ld (x)(y)) = "\Ld{" ^ x "}{" ^ y "}"

%format match (e) (b) = e "\blacktriangleright" b
%format `match`       = "\blacktriangleright"

%% ----------- Applications --------------
%% %format applyx a b = a "@" b
%% %format applyx a b = a "\," b

%% Function application with no arguments
%format apply0 a = a "\langle\rangle"

%% Function application with 1 argument
%format apply1 a (b) = a "(" b ")"

%% Function application with 1 argument, without parenthesis
%format apply1N a b = a "\," b

%% Function application with many arguments
%format applyN a (b) = a "\langle" b "\rangle"

%% ----------- End of Applications --------------

%format space = "\hspace{0.3em}"
%format lam x (e) = "\lambda" x".\," e
%format lam2 x r e = "\lambda"x"\!\shortrightarrow{}\!"r".\," e
%format lamhdr x = "\lambda" x".\,"
%format mlam (e1) (e2) = "\mu\hspace{0.03em}" e1 ".\," e2
%format thunk (e) = "\lambda \langle\rangle.\," e
%format lambda = "\lambda\!"
%format BigLambda = "\Lambda\!"
%format tlam (x) (e1) (e2) = tlamKW "(" x ")\{" e1 "\}\{" e2 "\}"
%format tlamt (x) (e1) (e2) (e3) = tlamKW "(" x ")\{" e1 "\}\{" e2 "\}\{" e3 "\}"
%format tlamKW = "\textbf{tlam}"
%format oftype (e) (t) = oftypeKW "(" e ")\{" t "\}"
%format oftypeKW = "\textbf{ofType}"
%format at = "\, @\!\!"
%format dot = "\! ."
%format alpha = "\alpha"
%format beta = "\beta"
%format gamma = "\gamma"
%format tau = "\tau"
%format sigma = "\sigma"
%format varsigma = "\varsigma"
%format upsilon = "\upsilon"
%format colonequals = "\colonequals"
%format dollar = "\$"
%format fordo (a) b = "\textbf{for}(" a ")\,\textbf{do}\," b

%% Sequences e1; ...; en; v
%format se = "es"
%format xs = "\overline{x}"
%format cs = "\overline{c}"
%format rs = "\overline{r}"
%format vs = "\overline{v}"
%format es = "\overline{e}"
%format ys = "\overline{y}"
%format zs = "\overline{z}"
%format es_1
%format es_2
%format hnf = "\mathit{hnf}"
%format q_1
%format q_2
%format qc_1
%format qc_2

%% xs etc stole syntax used in examples.
%format xsl = " xs "
%format ysl = " ys "
%format zsl = " zs "

%% Old version: | for BNF, [] for choice
%format vbar = "\mathop{\mid}"
%%%format choice = "[ \! ]"
%%%format `choice` = "\mathop{[ \! ]}"
%format choice = "\rule[-0.1em]{0.15em}{0.75em}"
%% 1mm is about 0.3em with the current font
%format `choice` = "\hspace{0.19em}\mathop{\rule[-0.1em]{0.15em}{0.75em}}\hspace{0.2em}"

%% New version: tall | for BNF, fat | for choice
%%format vbar = "\mathop{\bigm|}"
%%format choice = "\boldsymbol{|}"
%%format `choice` = "\mathop{\boldsymbol{|}}"

%format hastype (x) (y) = x "\," hastypeKW "\," y
%format hastypeKW = "{\bf hastype}"

%format srcand = "\&\&"
%format srcor = "||"
%format hat = "\hat{\hspace{0.8em}}"

%format hchoice = "\|"
%format he = "he"
%format none = "\textbf{none}"
%format fail = "\textbf{fail}"
%format succeed = "\textbf{succeed}"
%format wront = "\wrong"
%format do = "\textbf{do}"
%format if = "\textbf{if}"
%format collect = "\textbf{collect}"
%format orElse = "\textbf{orElse}"

%% Arrays and tuples
%format array (x) = "\textbf{array}\{" x "\}"
%% %format arrKW = "\textbf{arr}"
%% %format arr (x) = arrKW "\{" x "\}"
%format arr (x) = "\langle" x "\rangle"
%format (tup (x)) = "\langle{}" x "\rangle"
%format emptytup = "\langle" "\rangle"

%format left (x)  = "L \triangleright" x
%format right (x)  = "R \triangleright" x

%format tuple = "\textbf{tup}"
%format typeKW (x) = "\textbf{type}"
%format typex (x) = "\textbf{type}\{" x "\}"
%format oneKW = "\textbf{one}"
%format one (x) = "\textbf{one}\{" x "\}"
%format one2 (r) (x) = "\textbf{one}("r")\{" x "\}"

%format assumeKW = "\textbf{assume}"
%format assertKW = "\textbf{assert}"
%format succeedKW = "\textbf{succeed}"
%format verifyKW = "\textbf{verify}"
%format decideKW = "\textbf{decide}"

%format assume (x) = "\textbf{assume}\{" x "\}"
%format assert (x) = "\textbf{assert}\{" x "\}"
%format succeed (x) = "\textbf{succeed}\{" x "\}"
%format verify (x) = "\textbf{verify}\{" x "\}"
%format decide (x) = "\textbf{decide}\{" x "\}"

%format allKW = "\textbf{all}"
%format all (x) = "\textbf{all}\{" x "\}"
%format all2 (r) (x) = "\textbf{all}("r")\{" x "\}"
%format splitKW = "\textbf{split}"
%%  OLD SYNTAX   %format split (x) (y) (z) = "\textbf{split}(" x ")\{" y "," z "\}"
%format split (x) (y) (z) = "\textbf{split}\{" x "\}\langle" y "," z "\rangle"
%% %format defKW = "\textbf{def}"
%format defKW = "\exists{}"
%format def (x) (y) = "\exists" x ".\," y
%format forall (x) (y) = "\forall" x ".\," y
%format dlet (x) (r) (b) = "\textbf{let}\;" x "=" r "\;\textbf{in}\,\{" b "\}"
%format llet (x) (r) (b) = "\textbf{let}\;" x "=" r "\;\textbf{in}\," b
%format defTwoLines (x) (y) = "\textbf{def}\;" x "\;\textbf{in}\\\{" y "\}"
%format storeKW = "\textbf{store}"
%format store (x) (y) = "\textbf{store}\;" x "\;\textbf{in}\,\{" y "\}"
%format storeTwoLines (x) (y) = "\textbf{store}\;" x "\;\textbf{in}\\\{" y "\}"
%format cell (k) (v) = k "\mapsto\!" v
%format rangeKW = "\textbf{range}"
%format range = "\textbf{range}"
%format square(x) = x "^2"
%format univ (x) (y) = "\forall" x ".\," y

%format in = "\textbf{in}"
%format then = "\textbf{then}"
%format else = "\textbf{else}"
%format for = "\textbf{for}"
%format block = "\textbf{block}"
%format orElse = "\textbf{orElse}"
%format collect = "\textbf{collect}"
%format apply = "\textbf{apply}"
%format arrow = "\textbf{arrow}"
% only used in comments, but still prettier this way:
%format true = "\textbf{true}"
%format false = "\textbf{false}"
%format truth = "\textbf{truth}"
%format fix = "\textbf{fix}"
%format unify = "\textbf{unify}"
%format add = "\textbf{add}"
%%%%format map = "\textbf{map}"
%format sub = "\textbf{sub}"
%format semi = "\textbf{seq}"
%format gt = "\textbf{gt}"
%format rec = "\textbf{rec}"
%format wrong = "\textbf{wrong}"
%format int = "\textbf{int}"
%format nat = "\textbf{nat}"
%format isInt = "\textbf{isInt}"
%format string = "\textbf{string}"
%format function (x)(rhs) = functionKW "(" x ")\{" rhs "\}"
%format functionKW = "\textbf{function}"
%format prefix op = "\textbf{prefix}\textquote " op "\textquote"
%format postfix op = "\textbf{postfix}\textquote " op "\textquote"
%format operator op = "\textbf{operator}\textquote " op "\textquote"
%format typedef = "\textbf{typedef}"
%format type = "\textbf{type}"
%format option = "\textbf{option}"
%format case = "\textbf{case}"
%format of = "\textbf{of}"
%format assign = "\textbf{assign}"
%format alloc = "\textbf{alloc}"
%format read = "\textbf{read}"
%format write = "\textbf{write}"
%format any = "\textbf{any}"
%format dots = "\!\ldots\!"
%format tdots = "\!\!\!\cdots\!\!\!"
%format emp = "\epsilon"
%format plus = "\oplus"
%format hole = "\hole"
%format lte = "\prec"

%% Effects checking, like succeeds{e}
%format check (r) (b) = "{\bf check}(" r ")\{" b "\}"

%format xdots = "\mydots"
%format ctrdots = "\cdots"
%format lowdots = "\ldots"
%format commadots = "\;\ldots"

%% Unification
%format == = "\hspace{-0.14em}=\hspace{-0.14em}"
%%%format == = "\!=\!"
%format :== = "\hspace{-0.14em}:=\hspace{-0.14em}"


