%% ----------- Metatheory --------------
%format cut (n) (x) = "\operatorname{cut}_{" n "}(" x ")"
%format cutr (n) = "\underset{" n "}\movesto"
%format cutrr (n) = "\underset{" n "}\movesfrom"
%format `cuten` = "\equiv_{n}"
%format cute (n) = "\equiv_{" n "}"
%format cute' (n) e1 e2 = e1 "\equiv_{" n "}" e2
%format ~ = "\mathrel{\sim}"
%format ~= = "\mathrel{\simeq}"
%format ->*  = "\movesto^{\ast}"
%format <-*  = "\movesfrom^{\ast}"
%format <->  = "\mathrel{\convertible}"
%format ===  = "\mathrel{\equiv}"
%format `ss`  = "\mathrel{\subseteq}"
%format :=  = "\mathrel{\coloneqq}"
%format `cup`  = "\mathop{\cup}"
%format stepA       = "\underset{A}\movesto"
%format stepAs      = "\underset{A}\movesto^{\ast}"
%format stepAr      = "\underset{A}\movesfrom"
%format stepArs     = "\underset{A}\movesfrom^{\ast}"
%format stepAe      = "\underset{A}\movesto^{=}"
%format stepB       = "\underset{B}\movesto"
%format stepBs      = "\underset{B}\movesto^{\ast}"
%format stepBr      = "\underset{B}\movesfrom"
%format stepBrs     = "\underset{B}\movesfrom^{\ast}"
%format stepB       = "\underset{B}\movesto"
%format stepAB      = "\underset{AB}\movesto"
%format stepABs     = "\underset{AB}\movesto^{\ast}"
%format stepABr     = "\underset{AB}\movesfrom"
%format stepABrs    = "\underset{AB}\movesfrom^{\ast}"
%format stepUs      = "\underset{U}\movesto^{\ast}"
%format stepUr      = "\underset{U}\movesfrom"
%format stepUrs     = "\underset{U}\movesfrom^{\ast}"
%format stepUn      = "\underset{U_n}\movesto"
%format stepUns     = "\underset{U_n}\movesto^{\ast}"
%format stepUnr     = "\underset{U_n}\movesfrom"
%format stepUnrs    = "\underset{U_n}\movesfrom^{\ast}"
%format stepUnm1    = "\underset{U_{n-1}}\movesto"
%format stepUnm1s   = "\underset{U_{n-1}}\movesto^{\ast}"
%format stepUnm1r   = "\underset{U_{n-1}}\movesfrom"
%format stepUnm1rs  = "\underset{U_{n-1}}\movesfrom^{\ast}"
%format stepUC      = "\underset{UC}\movesto"
%format stepUCs     = "\underset{UC}\movesto^{\ast}"
%format stepUCr     = "\underset{UC}\movesfrom"
%format stepUCrs    = "\underset{UC}\movesfrom^{\ast}"
%format stepUCn     = "\underset{UC_n}\movesto"
%format stepUCns    = "\underset{UC_n}\movesto^{\ast}"
%format stepUCnr    = "\underset{UC_n}\movesfrom"
%format stepUCnrs   = "\underset{UC_n}\movesfrom^{\ast}"
%format stepUCnm1   = "\underset{UC_{n-1}}\movesto"
%format stepUCnm1s  = "\underset{UC_{n-1}}\movesto^{\ast}"
%format stepUCnm1r  = "\underset{UC_{n-1}}\movesfrom"
%format stepUCnm1rs = "\underset{UC_{n-1}}\movesfrom^{\ast}"
%format stepE       = "\underset{E}\movesto"
%format stepEr      = "\underset{E}\movesfrom"
%format stepEp      = "\underset{E||}\movesto"
%format stepEpr     = "\underset{E||}\movesfrom"
%format stepX       = "\movestoX"
%format stepXs      = "\movestoX^{\ast}"
%format stepXr      = "\movesfromX"
%format stepXrs     = "\movesfromX^{\ast}"
%format mu x (e)    = "\mu" x".\," e
%format muKW        = "\mu{}"
%format Omega       = "\mathit{\Omega}"
%format ell         = "\ell"
%format ell_1       = "\ell_1"
%format ell_2       = "\ell_2"
%format phi         = "\varphi"
%format psi         = "\psi"
%format `elem`      = "\in"
%format ++          = "\bowtie"
%format term(v)     = "\termapp{" v "}"
