\subsection{Structural rules}

\begin{center}
\frame{$
\begin{array}{@@{\hskip0.5em} l r @@{\;\;}c@@{\;\;} l l@@{}}
\rulename{hp-alpha} & |blk (X,x) hp e| & \leftrightarrow
    & |blk (X,y) (subst hp x y) (subst e x y)|  & \text{if |y| $\not\in$ |freevars (hp,e)|}\\
\rulename{lam-alpha} & |lam x e| & \leftrightarrow & |lam y (subst e y x)| & \text{if $|y| \not\in |freevars e|$} \\
\\
\rulename{seq}   & |v; e|              & \movesto & |e| \\
\rulename{norm1} & |v == (e_1;e_2)|    & \movesto & |e_1; v == e_2| \\
\rulename{norm2} & |v == (e_1 == e_2)| & \movesto & |v == e_1; v == e_2| \\
\rulename{norm3} & |(e_1;e_2) == e_3|  & \movesto & |e_1; e_2 == e_3| \\
\rulename{norm4} & |(v == e_1) == e_2| & \movesto & |v == e_1; v == e_2| \\
\rulename{norm5} & |(e_1 ; e_2); e_3|  & \movesto & |e_1; (e_2 ; e_3)| \\
\end{array}
$} \\
\captionof{figure}{Structural and normalisation rules}
\end{center}

\subsection{Iteration and choice}

\begin{center}
\frame{$
\begin{array}{l r @@{\;\;}c@@{\;\;} l l}
\rulename{fail}     & |iter2 ic (B^[fail]) e| & \movesto & |e| \\
\rulename{choice}   & |iter2 ic (B^[b_1 `choice` b_2]) e|
  & \movesto &  |iter2 ic (B^[ block b_1 ]) (iter2 ic (B^[ block b_2 ]) e3)| \\
  & & \multicolumn{2}{l}{\text{if |choicefreeb B|}} \\
\\
\rulename{if}   & |iter2 ifKW (B^[delay e_1]) e_2|
   & \movesto &  |block (B^[e_1])| \\
\rulename{for}  & |iter2 ifKW (B^[v]) e|
    & \movesto & |block (blk x emptyheap (applyN cons2 ((arr x, B^[v]), e)))| \\


\end{array}
$} \\
\captionof{figure}{Iteration and choice}
\end{center}


\begin{figure}[h]
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Application}
\rulename{app-add}          & |applyN add (k_1 ,k_2)| & \movesto & |k_3| & \text{where $k_3 = k_1 + k_2$}\\
\rulename{app-gt}           & |applyN gt (k_1,k_2)|   & \movesto & |k_1| &  \text{if $k_1 > k_2$} \\
\rulename{app-gt-fail}      & |applyN gt (k_1,k_2)|   & \movesto & |fail| &  \text{if $k_1 \leq k_2$} \\
\rulename{app-isint}        & |apply1 isInt k|   & \movesto & |k| &  \text{if $k$ is an integer} \\
\rulename{app-isint-fail}      & |applyN isInt v|   & \movesto & |fail| &  \text{if $v$ is not an integer} \\
\rulename{app-lam}^{\alpha} & |apply1 (lam x e) v| & \movesto & |def x (x==v; e)|
                                                  & \text{if $x \not\in \freevars{|v|}$} \\
\rulename{app-tup0}        & |apply1 emptytup v| & \movesto & |fail| \\
\rulename{app-tup}          & |apply1 (tup (v_0,xdots, v_nm1)) v| & \movesto &
                            |(v == 0^^^ v_0) choice xdots choice (v == (n-1)^^^ v_nm1)| & n \geq 0
\end{array}
\\ \\[-0.8em]
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Unification}
  \rulename{u-lit}   & |k == k; e| & \movesto & |e| & \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e|
       & \movesto & |v_1==v1' `eqsemi` xdots `eqsemi` v_n==v_n' `eqsemi` e| & n \geq 0\\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & |fail| & \text{if \rulename{u-lit}, \rulename{u-tup}, \rulename{u-olam} do not match} \\
  \rulename{u-occurs} & |x==V^[x]; e| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
  \rulename{u-swap} & |hnf == x; e| & \movesto & |x == hnf; e| \\
\\[-0.8em]

\rulegroupname{Substitution}

\rulename{exi-subst} & |def x (C^[x==v; e])| & \movesto & |subst (C^[e]) x v|
  & \text{if |blockedc (singleton x) C|, |((singleton x) `cup` boundvars C) `disjoint` freevars v|}  \\
\rulename{rec} & |z = V^[lam x e_1]; e_2| & \movesto & \multicolumn{2}{l}{|z = V^[lam x (def z (z = V^[lam x e_1]; e_1))]; e_2|
  \hspace{4mm} \text{$|z| \in \freevars{|lam x e_1|}$}} \\
%\rulename{exi-subst-var} & |def x (C^[y==x; e])| & \movesto & |subst (C^[e]) x y|
%  & \text{if |validc x emptyset C|, $x \not= y$}  \\
% \rulename{exi-float}^{\alpha} & |C^[def x e]| & \movesto & |def x C^[e]| & \text{if $|noteq C hole|, x \notin \freevars{|C|}, \boundvars{|C|} = \emptyset$} \\
% \rulename{exi-choice}^{\alpha} & |def x (C^[e_1 choice e_2])| & \movesto & |C^[(def x e_1) choice (def x e_2)]| & \text{if $x \notin \freevars{|C|} \cup \boundvars{|C|}$} \\
\end{array}
\\ \\[-0.8em]

\begin{array}{@@{\hskip0.5em} l  r @@{\;}c@@{\;} l l@@{}}

\rulegroupname{Choice}
\rulename{fail} & |C^[fail]| & \movesto & |fail|
    & \text{if |noteq C hole, blockedc emptyset C, choicefreec C|}\\
    \\[-0.8em]

\rulegroupname{Iter}
\rulename{iter-fail}    & |iter2 ic fail e_0| & \movesto & |e_0| \\
\rulename{iter-value}   & |iter2 ic e e_0| & \movesto & |applyiter ic e e_0| \\
\rulename{iter-choice}  & |iter2 ic (C^[e_1 `choice` e_2]) e_0| & \movesto &
   |iter2 ic (C^[e_1]) (iter2 ic (C^[e_2]) e_0)| \\

\end{array} \\
\\[-0.8em]
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\rulegroupname{Open Lambdas}
  \rulename{u-olam}   & |olam z_1 v_1 == olam z_2 v_2; e| & \movesto & \multicolumn{2}{@@{}l}{|def z_3 (z_1 == olam z_3 v_2; z_2 == olam z_3 v_1); e|} \\
  \rulename{app-olam} & |apply1N (olam z v_1) v_2| & \movesto & |def x (x == apply1N z v_2; x == apply1N v_1 v_2; x| \\
  \rulename{exi-app} & |def z e| & \movesto &
  \multicolumn{2}{@@{}l}{|subst e z ((lam x (def y y)))| \hspace{5mm} \text{if |z| occurs in |e| only as |apply1N z v|}}
\end{array}
\\
\text{\textit{Note}: In rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.} \\
\end{array}$

\caption{\textbf{The \vcname: Rewrite rules for execution}} \label{fig:rules}
\Description{A table that exhibits the rewrite rules for the Verse Calculus, groupesd into five categories: Application, Unification, Normalization, Garbage Collection, and Choice}
\end{figure}
