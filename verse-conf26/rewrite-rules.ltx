\subsection{Auxiliary functions}

\begin{center}
\frame{$
\begin{array}{l}
\\
\begin{array}{ll}
  |subst e x v| & \text{Capture-avoiding substitution of |v| for |x| in |e|} \\
  \freevars{e} & \text{Free variables of $e$} \\
  \boundvars{S} & \text{Bound variables of a context $S$} \\
  \freevarsoutsidelambdas{v} & \text{Free variables outside lambdas in $v$}
\end{array}
\\ \\
\begin{array}{r @@{\;\;}c@@{\;\;} l}
|leftchoicefree(C)| & :: & |Bool| \\
|leftchoicefree(hole)| & = & |True| \\
|leftchoicefree(C == e)| & = & |leftchoicefree(C)| \\
|leftchoicefree(C ; e)| & = & |leftchoicefree(C)| \\
|leftchoicefree(e == C)| & = & |choicefree(e) && leftchoicefree(C)| \\
|leftchoicefree(e ; C)| & = & |choicefree(e) && leftchoicefree(C)| \\
|leftchoicefree(apply1N e C)| & = & |False| \\
\\
|choicefree(e)| & :: & |Bool| \\
|choicefree(v)| & = & |True| \\
|choicefree(e_1; e_2)| & = & |choicefree(e_1) && choicefree(e_2)| \\
|choicefree(e_1 == e_2)| & = & |choicefree(e_1) && choicefree(e_2)| \\
|choicefree(apply1N e_1 e_2)| & = & |choicefree(e_1) && choicefree(e_2)| \\
|choicefree(fail)| & = & |True| \\
|choicefree(b_1 `choice` b_2)| & = & |False| \\
|choicefree(block (blk X hp e))| & = & |choicefree(e)| \\
|choicefree(iter2 allKW b e)| & = & |True| \\
|choicefree(iter2 ifKW b e)| & = & |False| \\
|choicefree(iter2 forKW b e)| & = & |choicefree(e)|
\end{array}
\end{array}
$} \\
\captionof{figure}{Auxiliary functions}
\end{center}



