\subsection{Verification rules}


\begin{center}
\fbox{$
\begin{array}{@@{}l}
\begin{array}{@@{}l r @@{\;\;}c@@{\;\;} l l}
  \rulename{mfun} & |twiddle h w (functionX at fx bt)|
  & \movesto
 & \begin{array}[t]{@@{}l}
     |verifyKW|(u;)\{\exists |p,q,termbinders at|\{\}.\,
     \begin{array}[t]{@@{}l}
      |p == (twiddle u w_1 at);| \\
      |Wcirc bb (q == apply1N h p);| \\
      |check fx (twiddle q w_2 (block bt))|\}
     \end{array}
     \\
     \lambda u.\; \exists p,q,|termbinders at|\{\}.
      \begin{array}[t]{l}
      |p == (twiddle u w_3 at);| \\
      |Wcirc bb (q == apply1N h p);| \\
      |twiddle q w_4 (block bt)|
      \end{array} \\
   \end{array} \\
&& \text{where} \\
&& \multicolumn{3}{l}{\begin{array}[t]{rcll}
  |(bb,dr,vx)| & = & w\\
  w_1 & = & |(bbcirc,drdom,verifyflag)| \\
  w_2 & = & |(bb,drrng fx,verifyflag)| \\
  w_3 & = & |(bbblob,drdom,vx)| \\
  w_4 & = & |(bbblob,drrng fx,execflag)| \\
  |Wcirc bbcirc e| & = & |emptytup| \\
  |Wcirc bbblob  e| & = & |e| \\
\end{array}} \\
\end{array}
\\ \\

\begin{array}{@@{}l r @@{\;\;}c@@{\;\;} l l}
  \rulename{moftype} & |twiddle u w (oftype t_1 t_2)|
  & \movesto & |u == apply1N (Mcirc w t_1) (Mcirc w t_2)| & \text{if |w = (b, execflag, drdom)|} \\
  && \movesto & |oftypefx ((twiddle u w t_1)) fx (Mcirc w t_2)| & \text{if |w = (b, execflag, drrng fx)|} \\
  && \movesto & |blockKW| \{ \exists y,t \{\}.\; \begin{array}[t]{@@{}l}
                 |y == Mcirc w t_1; t == Mcirc w t_2;| \\
                 |check succeeds (apply1N t y); oftype y t))| \}
                 \end{array}
       & \text{if |w = (b, verifyflag, drdom)|} \\
  && \movesto & |blockKW| \{ \exists y,t \{\}.\; \begin{array}[t]{@@{}l}
                 |y == Mcirc w t_1; t == Mcirc w t_2;| \\
                 |check succeeds (apply1N t y)| \}
                 \end{array}
       & \text{if |w = (b, verifyflag, drrng _)|} \\
\\
  \rulename{oftype} & |oftypefx e_1 fx e_2| & \movesto & |apply1N e_2 e_1| & \text{Outside |verifyKW|} \\
\end{array} \\

\end{array}
$} \\
\captionof{figure}{Matching functions with verification}
\end{center}

\begin{center}
\fbox{$
\begin{array}{@@{}l}

\begin{array}{@@{}l r @@{\;\;}c@@{\;\;} l l}
  \text{Proof contexts}  & P & ::= & |blk X hp Q| \\
  & |Q| & ::= & |hole| \vb |e == Q| \vb |Q == e|
           \vb  |e ; Q| \vb |Q ; e| \vb  |applyN e Q| \vb |applyN Q e|
    \vb |iter2 ic Q e|
\end{array} \\
\\

\begin{array}{@@{}l r @@{\;\;}c@@{\;\;} l l}
 \rulename{solver} & |verify2 rs as b| & \movesto & |tup ()| \hspace{5mm} \text{if $|rs;as| \vDash \mathit{inconsistent}$} \\
 \rulename{v-val} & |verify2 rs as (B^[v])|      & \movesto & |tup ()| & \\
 \rulename{v-choice} & |verify2 rs as (P^[e_1 choice e_2])|      & \movesto & |verify2 rs as (P^[e_1]) ; verify2 rs as (P^[e_2])| & \\
 \rulename{v-fail} & |verify2 rs as (P^[fail])|    & \movesto & |tup ()| & \\[1mm]
 \rulename{split-val} & |verify2 rs as (P^[r==gv; e])| & \movesto &
    |verify2 rs (as, r==gv) (P^[ e ]);| \\
    &&& |verify2 rs (as, noteq r gv) (P^[ fail ])|\\[1mm]
  \rulename{split-op} & |verify2 (rs) as (P^[apply1N op gv])| & \movesto &
          |verify2 (rs,r) (as, r = apply1N op gv) (P^[ r ]);| \\
    &&& |verify2 rs (as, not (apply1N op gv)) (P^[ fail ])| \\
    &&& \text{if $r \not\in R$} \\[1mm]
 \rulename{split-tup} & |verify2 rs as (P^[r==tup (v_1, xdots, v_n); e])|
     & \movesto & |verifyKW|
           \begin{array}[t]{@@{}l}
             |(rs, r_1 xdots r_n; as, r==tup (r_1, xdots, r_n))| \\
             |{ P^[ r_1==v_1; xdots; r_n == v_n; e ] };|
           \end{array}\\
    &&& |verify2 rs (as, noteq r (tup (_, xdots,_))) (P^[ fail ])| \\
 \rulename{split-app} & |verify2 (rs) as (P^[apply1N f gv])| & \movesto &
          |verify2 (rs,r) (as, r = applyN AP (f,gv)) (P^[ r ]);| \\
    &&& \text{if $f \in R, r \not\in R$} \\
 \rulename{split-appf} & |verify2 (rs) as (P^[apply1N f (lam x e)])| & \movesto &
          |verify2 (rs,r) as (P^[ r ]);| \\
    &&& \text{if $f \in R, r \not\in R$} \\
  \rulename{v-some} & |verify2 rs as (P^[oftypefx e_1 fx e_2])| & \movesto
  & |verify2 (rs,r) as (def x (x = apply1N e_2 r; P^[x]))|; & \text{if |fx| can succeed} \\
  &&& |verify2 rs as (def x (x = apply1N e_2 r; P^[fail]))|; & \text{if |fx| can fail} \\
  &&& \text{if $|r| \notin |rs|$ and |freevars v `disjoint` boundvars P|} \\
\end{array}\\
\end{array}
