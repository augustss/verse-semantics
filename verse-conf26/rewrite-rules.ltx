% -----------------------------------------------------
%                 Rewrite rules
% -----------------------------------------------------

% ---------------------------------------------------
\section{Rewrite rules}

This section give the rewrite rules.  Some general observations.

\begin{itemize}
\item Many rules have a side condition like $x \not\in \freevars{e}$.  The idea is that
  we silently use the alpha-renaming rules (\Cref{fig:alpha-rules}) to
  make these side conditions hold.
\item All rules are careful to keep non-value sub-expressions in the same order.
  This only matters in the future when effects (including I/O) play a bigger role.
  Example: the normalisation rules in \Cref{fig:normalisation-rules}.
  
\end{itemize}

\subsection{Substitution and promotion}

\renewcommand{\arraystretch}{1.1}
\begin{center}
\fbox{$
\begin{array}{l r @@{\;\;}c@@{\;\;} ll}
\rulename{subst} & |blk X (hp,hbind x v) (S^[x])|
  & \movesto & |blk X (hp,hbind x v) (S^[v])| &  \text{if $x \not\in \boundvars{S}$} \\
 \rulename{gc} & |blk (X,Y) hp e| & \movesto & |blk X (hp `without` Y) e|
   & \text{if $Y \disjoint \freevars{\rng(|hp `without` Y|),e}$, $Y \not= \{\}$ } \\
\rulename{promote-l} & |blk (X,x) hp (C^[ x==v ])|
  & \movesto & \multicolumn{2}{@@{}l}{|blk (X,x) (subst hp x v, hbind x v) (C^[v])|} \\
  & & \multicolumn{3}{r}{\text{if $x \not\in \dom(hp)$,
        $\freevarsoutsidelambdas{v} \disjoint \dom(hp) \cup \{x\}$}} \\
\rulename{promote-r} & |blk (X,x) hp (C^[ v==x ])|
  & \movesto & \text{...just like \rulename{promotel}} \\
\end{array}
$} \\
\captionof{figure}{Structural and normalisation rules}
  \label{fig:alpha-rules} \label{fig:normalisation-rules}
\end{center}

\begin{itemize}
\item Given a heap binding |hbind x v|, rule \rulename{subst} substitutes |v| for
  a \emph{single} occurrence of |x|.  The context |S| (see \Cref{fig:vc-syntax})
  allows us to look deep in the term,
  including under choices and lambdas.
\item The \rulename{gc} rule allows us to garbage-collect a strongly-connected component of
  possibly-recursive bindings in the heap.
\item You might wonder if we could eliminate \rulename{promote-r} in
  favour of a \rulename{swap} rule that swaps |x=hnf| to |hnf=x|.  But
  we must also deal with |x=y| where |y| is bound locally and |x| is
  bound further out.  We could have a swap rule that swaps |v=x| but
  that could loop infinitely on |x=y| which seems unpleasant.
\end{itemize}

% ---------------------------------------------------
\subsection{Unification}

\begin{center}
\fbox{$
\begin{array}{l r @@{\;\;}c@@{\;\;} l l}
\rulename{eqk1} & |k == k| & \movesto & |k| \\
\rulename{eqk2} & |k_1 == k_2| & \movesto & |fail| & \text{if $k_1 \not= k_2$} \\
\rulename{eqtup1} & |arr(v_1, xdots, v_n) == arr(w_1,xdots,w_n)| & \movesto
   & |v_1==w_1; xdots v_n==w_n; arr(v_1,xdots,v_n)| \\
\rulename{eqtup2} & |arr(v_1, xdots, v_n) == arr(w_1,xdots,w_m)| & \movesto & |fail|
  & \text{if $n \not= m$ } \\
\rulename{eqfail} & |hnf_1 == hnf_2| & \movesto
  & \multicolumn{2}{@@{}l}{|fail| \hspace{4mm} \text{if |hnf_1| and |hnf_2| have different root shapes}} \\
\end{array}
$} \\
\captionof{figure}{Unification rules}
\end{center}

\begin{itemize}
\item There is no rule for |(lam x e_1) == (lam y e_2)| because the runtime can't test for equality of functions.
\item Instead that equality is \emph{stuck}.  A stuck expression is our version of ``goes wrong at runtime''.  It should never happen; the verifier should reject such a program before we run it.
\item So (slightly surprisingly) there no rule for |x==x| either, in case
  |x| is bound to a lambda.  That equality is stuck until |x| gets a value.
\end{itemize}

% ---------------------------------------------------
\subsection{Primitive operations}

We just give a small representative selection here.
\begin{center}
\fbox{$
\begin{array}{l r @@{\;\;}c@@{\;\;} l l}
\rulename{add} & |applyN add (ki_1,ki_2)| & \movesto & |ki_1+ki_2| \\
\rulename{gt1} & |applyN gt (ki_1,ki_2)| & \movesto & |ki_1| & \text{if $ki_1>ki_2$} \\
\rulename{gt2} & |applyN gt (ki_1,ki_2)| & \movesto & |fail| & \text{if $ki_1 \leq ki_2$} \\
\rulename{isInt1} & |applyN isInt ki| & \movesto & |ki| & \text{(|ki| is an integer)} \\
\rulename{isInt2} & |applyN isInt v| & \movesto & |fail| & \text{if |v| is not an integer} \\
\rulename{cons} & |applyN consKW (v_0, arr(v_1,xdots,v_n))| & \movesto & |arr(v_0,v_1,xdots,v_n)| \\
\rulename{dotdot} & |applyN dotdot (ki_1,ki_2)|
  & \movesto & |ki_1 `choice` (ki_1+1) `choice` xdots `choice` ki_2|
\end{array}
$}
\captionof{figure}{Primitive operation rules}
\end{center}
\begin{itemize}
\item An ill-typed application, such as |applyN add (3,lam x x)| where the argument(s) are not integers, is just stuck.  Similarly for other primitive operators.
\end{itemize}

% ---------------------------------------------------
\subsection{Beta reduction}

\begin{center}
\fbox{$
\begin{array}{l r @@{\;\;}c@@{\;\;} l l}
  \rulename{beta-l} & |apply1N (lam x b) e| & \movesto & |block (blk x () (x == e; block b))|
        \hspace{5mm} \text{if $x \not\in \freevars{e}$} \\
  \rulename{beta-t} & |apply1Np (arr (v_0,xdots,v_n)) e|
  & \movesto & |block (blk x () (x==e; ((blk () () (x==0;v_0)) `choice` xdots `choice` (blk () () (x==n; v_n)))))| \\
\end{array}
$} \\
\captionof{figure}{Primitive operation rules}
\end{center}

\begin{itemize}
\item Note that \rulename{beta-t} does narrowing.
\item In \rulename{beta-t} the binding |x==e| is there to avoid duplicating |e|.
\item The base case of \rulename{beta-t} for the empty tuple simply yields failure.
\end{itemize}

% ---------------------------------------------------
\subsection{Structural and normalisation rules}

\begin{center}
\fbox{$
\begin{array}{l r @@{\;\;}c@@{\;\;} l l}
\rulename{hp-alpha} & |blk (X,x) hp e| & \leftrightarrow
    & |blk (X,y) (subst hp x y) (subst e x y)|  & \text{if |y| $\not\in$ |freevars (hp,e)|}\\
\rulename{lam-alpha} & |lam x e| & \leftrightarrow & |lam y (subst e y x)| & \text{if $|y| \not\in |freevars e|$} \\
\\
\rulename{seq}   & |v; e|              & \movesto & |e| \\
\rulename{norm1} & |v == (e_1;e_2)|    & \movesto & |e_1; v == e_2| \\
\rulename{norm2} & |v == (e_1 == e_2)| & \movesto & |v == e_1; v == e_2| \\
\rulename{norm3} & |(e_1;e_2) == e_3|  & \movesto & |e_1; e_2 == e_3| \\
\rulename{norm4} & |(v == e_1) == e_2| & \movesto & |v == e_1; v == e_2| \\
\rulename{norm5} & |(e_1 ; e_2); e_3|  & \movesto & |e_1; (e_2 ; e_3)| \\
\\
\rulename{float} & |blk X hx (C^[block (blk Y hy e)])|
                 & \movesto & |blk (X,Y) (hx,hy) (C^[e])| \\
                 && \multicolumn{3}{l}{\text{if $X \disjoint Y$, $Y \not\in \freevars{C}$,
                   $\freevarsoutsidelambdas{\rng(hy)} \disjoint X$}}
\end{array}
$} \\
\captionof{figure}{Structural and normalisation rules}
\end{center}

\begin{itemize}
\item \rulename{norm4} is necessary to make progress with |(x == p+1) == 5|. We want to unify |x| with |5| which might in turn unlock unification for |p|.
\item \rulename{norm5} is not strictly necessary, but it helps to de-clutter; e.g. |(e_1;5);e_2| rewrites to |e_1;e_2|.
\end{itemize}

% ---------------------------------------------------
\subsection{Iteration and choice}

\begin{center}
\fbox{$
\begin{array}{l r @@{\;\;}c@@{\;\;} l l}
\rulename{fail}     & |iter2 ic (B^[C^[fail]]) e| & \movesto & |e| \\
\rulename{choice}   & |iter2 ic (B^[C^[b_1 `choice` b_2]]) e|
    & \movesto &  |iterKW(ic)| \begin{array}[t]{@@{}l}
  \{ |B^[ C^[block b_1 ]]| \} \\
  \{ |iter2 ic (B^[ C^[block b_2] ]) e3| \}
  \end{array} \\
  & & \multicolumn{2}{l}{\text{if |leftchoicefree C|}} \\
\\
\rulename{if}   & |iter2 ifKW (B^[delay e_1]) e_2|
   & \movesto &  |block (B^[e_1])| \\
\rulename{all}  & |iter2 allKW (B^[v]) e|
    & \movesto & |cons (B^[v]) e| \\
\rulename{for}  & |iter2 forKW (B^[v]) e|
    & \movesto & |block (blk x () (applyN cons2 (arr (x, B^[v]), e)))|
\end{array}
$} \\
\captionof{figure}{Iteration and choice}
\end{center}

