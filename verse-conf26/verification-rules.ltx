% ----------------------------------------
%             Verification rules
% ----------------------------------------

\begin{figure}[t]
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
  \multicolumn{5}{l}{\textit{Auxiliary functions}} \\
  & |skolval X v| & = & |X| \cap |freevars v| = \emptyset \\[2mm]


\multicolumn{5}{l}{\textit{Guard}} \\
\rulename{guard-elim} & |v guard e| & \movesto & |e| & \text{if $\skol{|v|}$}\\
\end{array} \\
\\[-2mm]

\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\multicolumn{5}{l}{\textit{Check}} \\
\rulename{check-fail}   & |check fx fail|  & \movesto & |fail|
   & \text{$|fx| \in \{|fails|,|decides|\}$}\\
  \rulename{check-suc}    & |check fx v|  & \movesto & |v| & \text{$\skol{|v|}, |fx| \in \{|succeeds|,|decides|\}$} \\
  \rulename{check-choice} & |check succeeds (v choice e)|  & \movesto & |v choice (check fails e)| & \text{$\skol{|v|}$} \\
\end{array} \\
\\[-0.6em]

\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
\multicolumn{5}{l}{\textit{Verify} \hspace{3mm} \text{All rules require |blockedc emptyset P|}} \\
\rulename{solver} & |verify2 rs as e| & \movesto & |tup ()| \hspace{5mm} \text{if $|rs;as| \vDash \mathit{inconsistent}$} \\
  \rulename{verify-val} & |verify2 rs as v|      & \movesto & |tup ()| & \\
  \rulename{verify-choice} & |verify2 rs as (e_1 choice e_2)|      & \movesto & |verify2 rs as e_1 ; verify2 rs as e_2| & \\
  \rulename{verify-fail} & |verify2 rs as fail|    & \movesto & |tup ()| & \\[1mm]
  \rulename{verify-drop} & |verify2 rs_1 as_1 (C^[verify2 rs_2 as_2 e])|
  & \movesto & |verify2 rs_1 as_1 (C^[emptytup])| & \\
  \rulename{skolemise}^{\alpha} & |verify2 rs as (P^[some v])| & \movesto
  & |verify2 (rs,r) as (def x (x = apply1N v r; P^[x]))| \\
  &&& \text{if $|r| \notin |rs|$ and |skolval (boundvars P) v|} \\
 \rulename{split-v} & |verify2 rs as (P^[r==gv; e])| & \movesto &
    |verify2 rs (as, r==gv) (P^[ e ]);| \\
    &&& |verify2 rs (as, noteq r gv) (P^[ fail ])|\\[1mm]
  \rulename{split-op} & |verify2 (rs) as (P^[apply1N op gv])| & \movesto &
          |verify2 (rs,r) (as, r = apply1N op gv) (P^[ r ]);| \\
    &&& |verify2 rs (as, not (apply1N op gv)) (P^[ fail ])| \\
    &&& \text{if $r \not\in R$} \\[1mm]
 \rulename{split-app} & |verify2 (rs) as (P^[apply1N f gv])| & \movesto &
          |verify2 (rs,r) (as, r = applyN AP (f,gv)) (P^[ r ]);| \\
    &&& \text{if $f \in R, r \not\in R$} \\
 \rulename{split-appf} & |verify2 (rs) as (P^[apply1N f (lam x e)])| & \movesto &
          |verify2 (rs,r) as (P^[ r ]);| \\
    &&& \text{if $f \in R, r \not\in R$} \\
 \rulename{split-tup} & |verify2 rs as (P^[r==tup (v_1, xdots, v_n); e])|
     & \movesto & |verifyKW|
           \begin{array}[t]{@@{}l}
             |(rs, r_1 xdots r_n; as, r==tup (r_1, xdots, r_n))| \\
             |{ P^[ r_1==v_1; xdots; r_n == v_n; e ] };|
           \end{array}\\
    &&& |verify2 rs (as, noteq r (tup (_, xdots,_))) (P^[ fail ])| \\
\end{array}\\

\end{array}$
\\[0.1in]
\caption{TRS Verifier Rewrite Rules}
\label{fig:spj-verifier-rewrite-rules}
\end{figure}

% ------------------------------------------------------------
%                Array rules
% ------------------------------------------------------------

\begin{figure}[t]
$\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l r @@{\;}c@@{\;} l l@@{}}
  \rulename{iter-choose}   & |iter2 ic (C^[choose v e]) e_0|
  & \movesto & \begin{array}[t]{@@{}l}
    |defintro k;  k == vsize v (C^[some(thunk e)]| \\
    |iter2 ic (choose k (C^[e])) e_0|
    \end{array} \\

\rulename{one-choose} & |iter2 oneKW (choose v e) e_0|
  & \movesto & |iter2 ifKW (v=0; thunk e_0) (some(thunk e))| \\

\rulename{if-choose} & |iter2 ifKW (choose v e) e_0|
  & \movesto & |iter2 ifKW (v=0; thunk e_0) (force (some(thunk e)))| \\

\rulename{all-choose} & |iter2 allKW (choose v e) e_0|
  & \movesto & |varr v e `plusplus` e_0| \\

\end{array}
\end{array}$
\\[0.1in]
\caption{Verifier Rules for Arrays}
\label{fig:verifier-rules-arrays}
\end{figure}

