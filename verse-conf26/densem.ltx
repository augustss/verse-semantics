\end{figure}


% -------------------------------------------------------------
%               The Verse Monad
% -------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\text{The Verse computation type $\Vm{\cdot}$ comes equipped with the following operations} \\
  \begin{array}{rcll}
    \vmempty & :: & \Vm{a} \\
    \vminject & :: & \powerset{a} \rightarrow \Vm{a} \\
    \vmcat    & :: & \Vm{a} \rightarrow \Vm{a} \rightarrow \Vm{a} & \text{Ordered choice} \\
    \vmseq    & :: & \Vm{a} \rightarrow \Vm{a} \rightarrow \Vm{a} & \text{Inner-set intersection}\\
    \vminnerunion  & :: & \Vm{a} \rightarrow \Vm{a} \rightarrow \Vm{a} & \text{Inner-set union} \\
    \vmunion  & :: & \Vm{a} \rightarrow \Vm{a} \rightarrow \Vm{a} & \text{Unordered choice}\\
    \vmunions & :: & \powerset{\Vm{a}} \rightarrow \Vm{a}  & \text{Infinite unordered choice} \\
    \vmmap    & :: & (a \rightarrow b) \rightarrow \Vm{a} \rightarrow \Vm{b} \\
%    \vmmapset    & :: & (\powerset{a} \rightarrow \powerset{b}) \rightarrow \Vm{a} \rightarrow \Vm{b} \\
%    \vmflatten & :: & \Vm{\powerset{a}} \rightarrow \Vm{a} \\
    \vmfold   & :: & \multicolumn{2}{l}{(\powerset{a} \rightarrow \Vm{b} \rightarrow \Vm{b}) \rightarrow \Vm{b}
                          \rightarrow \Vm{a} \rightarrow \Vm{b}} \hspace{5mm} \text{Fold over choices} \\
    \vmpi & : & \Vm{a} \rightarrow (a \rightarrow \Vm{b}) \rightarrow \Vm{\Vm{\fpr{a}{b}}} \\
    \vmcollapse & :: & \Vm{a} \rightarrow \powerset{a}  & \text{Remove empty choices} \\
  \end{array}
  \\ \\
  \textbf{Desirable laws} \\
  \begin{array}{rclcl}
%     \vmempty \vmbind k & = & \vmempty \\
     \vmempty \vmseq   s & = & \vmempty & = & s \vmseq \vmempty \\
     \vmempty \vmcat   s & = & s        & = & s \vmcat \vmempty \\
     \vmempty \vmunion s & = & s        & = & s \vmunion \vmempty \\
     \vmcollapse(\vminject(s)) & = & s \\
  \end{array}
\\ \\
%   \textbf{Monad comprehensions} \\
%  \text{The Verse monad enjoys the usual monad-comprehension notation:} \\
%  \begin{array}{rcl}
%    \vmcompL e \vmcompR & = & \vmreturn(e) \\
%    \vmcompL e_1 \vb e_2, \; Q \vmcompR
%       & = & |if| \; e_2 \; |then| \; \vmcompL e_1 \vb Q \vmcompR \; |else|\; \vmempty \\
%    \vmcompL e_1 \vb x \leftarrow e_2, \; Q \vmcompR & = & e_2 \vmbind \lambda x. \vmcompL e_1 \vb Q \vmcompR \\
%    \vmcompL e_1 \vb x \in e_2, \; Q \vmcompR & = & \vminject(e_2) \vmbind \lambda x. \vmcompL e_1 \vb Q \vmcompR \\
%  \end{array}
% \\ \\
  \textbf{Derived functions} \\
  \begin{array}{rcl}
%     \vmflatmap & :: & (a \rightarrow \powerset{b}) \rightarrow \Vm{a} \rightarrow \Vm{b} \\
%     \vmflatmap(f,s) & = & \vmflatten(\; \vmmap( f, s ) \; ) \\[1mm]
%    (\ENVhide) & :: & \Env \rightarrow \powerset{\Ident} \rightarrow \powerset{\Env} \\
%    \rho \ENVhide vs & = & \{ \rho' \in \Env \vb \forall x \not\in vs \Rightarrow \rho(x) = \rho'(x) \} \\[1mm]
    \vmmapset & :: & (\powerset{a} \rightarrow \powerset{b}) \rightarrow \Vm{a} \rightarrow \powerset{b} \\
    \vmmapset(f,s) & = & \vmfold( \; (\lambda x\, t. \, \vminject(f(x)) \vmcat t), \; \vmempty, \; s \;) \\[1mm]
    (\vmhide) & :: & \Vm{\Env} \rightarrow \powerset{\Ident} \rightarrow \Vm{\Env} \hspace{5mm}
        \text{Binds less tightly than $\vmseq$, $\vmunion$ etc} \\
    s \vmhide vs & = & \vmmapset( \; (\lambda \EV. \, \HIDE{\EV}{vs}),\; s \;) \\[1mm]
    \vmnot      & :: & \Vm{\Env} \rightarrow \Vm{\Env} \\
    \vmnot(s) & = & \vminject( \conCompl( \vmcollapse(s))) \\
\\
    \vmprune & :: & \Vm{a} \rightarrow \Vm{a} \\
    \vmprune(s) & = & \vmfold(op, \vmempty, s)  \\
    & \multicolumn{2}{l}{\text{where}} \\
    && \begin{array}[t]{@@{}l}
         op :: \powerset{a} \rightarrow \Vm{a} \rightarrow \Vm{a} \\
         op( \EV, rest ) = \left\{ \begin{array}{ll}
               rest  & \text{if $\EV = \{\}$} \\
               \vminject(\EV) \vmcat rest & \text{otherwise}
               \end{array} \right. \\
       \end{array} \\
    \\

    \vmone & :: & \Vm{\Env} \rightarrow \powerset{\Ident} \rightarrow \Vm{\Env} \\
    \vmone( s, vs ) & = & \vmfold( op, \vmempty, s ) \\
    & \multicolumn{2}{l}{\text{where}} \\
    && \begin{array}[t]{@@{}l}
         op :: \powerset{\Env} \rightarrow \Vm{\Env} \rightarrow \Vm{\Env} \\
         op( \EV, rest ) = \vminject(\EV) \vminnerunion (\vminject( \conCompl( \HIDE{\EV}{vs})) \vmseq rest )
       \end{array} \\
\\
    \vmconcat & :: & [\Vm{a}] \rightarrow \Vm{a} \\
    \vmconcat(\, [] \, ) & = & \vmempty \\
    \vmconcat(\, s:ss \, ) & = & s \vmcat \vmconcat(ss) \\
    \end{array}

\end{array}
$$
\caption{The Verse computation type}
\end{figure}

