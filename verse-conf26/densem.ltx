% ------------------------------------------------------------------------------------
%
%            The semantics itself
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}
  & \semess{E}{u}{v}{|t|} & : & \VmENV  \\

% Wildcards and atoms
  \rulename{swild}  &  \semess{E}{u}{v}{|
    _|} & = & \vminject \conBrack{u =v} \\
\rulename{svar}   &  \semess{E}{u}{v}{|x|} & = & \vminject \conBrack{u=v=x} \\
\rulename{sconst} &  \semess{E}{u}{v}{|k|} & = & \vminject \conBrack{u=v=k}\\
\rulename{sprim}  &  \semess{E}{u}{v}{|o|} & = & \vminject \conBrack{u=v=o} \\

% Capture input and output
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &
   \vminject\conBrack{x=v} \vmseq \semess{E}{u}{v}{t} \\
% \rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
%    \vminject\conBrack{x=u} \vmseq \semess{E}{u}{v}{t} \\

% Tuples
\multicolumn{2}{@@{}l}{\rulename{stup} \; \hfill \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}}
  & = & (\vminject \conBrack{ u=|arr (u_1, xdots, u_n)|, v=|arr (v_1, xdots, v_n)|} \\
  &&&   \; \vmseq \semess{E}{u_1}{v_1}{t_1}
         \vmseq \mydots
         \vmseq \semess{E}{u_n}{v_n}{t_n}) \\
&&&      \vmhide { \{u_1,\mydots u_n,v_1 \mydots v_n\} }
         \hfill u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v} \\

% Choice and failure
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & \vmempty \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
  & = & \semess{B}{u}{v}{t_1} \vmcat \semess{B}{u}{v}{t_2} \\
% \rulename{suchoice} &  \semess{E}{u}{v}{|t_1 `uchoice` t_2|}
%   & = & \semess{B}{u}{v}{t_1} \vmunion \semess{B}{u}{v}{t_2} \\

% Unification and matching
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|} & = &   \semess{E}{u}{v} {t_1} \vmseq \semess{E}{u}{v}{t_2} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|matches t_1 t_2|} & = &
   (\semess{E}{u}{w}{t_1} \vmseq \semess{E}{w}{v}{t_2}) \vmhide \{w\} \hfill w \not\in \freevars{t_1,t_2,u,v} \\

% Sequencing
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|} & = &  \semapp{C}{t_1} \vmseq \semess{E}{u}{v}{t_2} \\
\rulename{swhere} &  \semess{E}{u}{v}{|t_1 where t_2|} & = &  \semess{E}{u}{v}{t_1} \vmseq  \semapp{C}{t_2} \\
% Dot-dot
\rulename{sdotdot} &  \semess{E}{u}{v}{|t_1 ..  t_2|}
  & = & \vminject \conBrack{u=v} \vmseq \semess{E}{p_1}{q_1}{t_1} \vmseq \semess{E}{p_2}{q_2}{t_2} \vmseq \\
  & & & \vmunions \{\;  \vmconcat [ \vminject \conBrack{v=q_1+i, i \leq q_2 - q_1}  \vb i \leftarrow [0..n] ]  \vb n \in \N \; \} \\
  & & & \vmhide \{p_1,q_1,p_2,q_2\} \hfill  p_1,q_1,p_2,q_2 \not\in \freevars{t_1,t_2,u,v} \\[1mm]

% Application and type
\rulename{sapp} & \semess{E}{u}{v}{|apply1N t_1 t_2|}
& = &  \vminject \conBrack{u=v} \vmseq \semess{E}{f}{g}{t_1}
       \vmseq \semess{E}{p}{q}{t_2}
       \vmseq \semap{F}{|apply1N g q|}v  \\
    & & & \vmhide \{f,g,p,q\} \hfill f,g,p,q \not\in \freevars{t_1,t_2,u,v} \\[1mm]
\rulename{stype} &  \semess{E}{u}{v}{|:t|} & = & \semess{E}{p}{q}{t} \vmseq \semap{F}{|apply1N q u|}v
  \vmhide \{p,q\} \hfill p,q \not\in \freevars{t,u,v} \\[1mm]

\end{array}
  \\ \\
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%       B, C, and F
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\begin{array}{rcll}
 \semess{B}{u}{v}{|t|} & : & \VmENV \\
 \semess{B}{u}{v}{|t|} & = & \semess{E}{u}{v}{t} \vmhide \semapp{I}{|t|} \\[1mm]
 \semapp{C}{|t|} & : & \VmENV \\
 \semapp{C}{|t|} & = & \semess{E}{p}{q}{|t|} \vmhide \{p,q\} \hfill p,q \not\in \freevars{t}\\[1mm]
 \semap{F}{|apply1N f x|}r & : & \VmENV \\
 \semap{F}{|apply1N f x|}r  & = &
\vmunions \begin{array}[t]{@@{}l}
           \,\{ \; \vmmapset(\; \lambda prs. \conBrack{ f = \Fun(\ff), \fpr{x}{r} \in prs }, \ff \; )\\
           \vb \Fun(\ff : \Vm{\Val \times \Val} ) \in \Val \; \}
           \end{array}
\end{array} \\
\\

\end{array}
$$
\caption{Denotational semantics of Essential Verse, Part 1}
\label{fig:E-sls1}
\end{figure}

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}

% IF
\multicolumn{2}{@@{}l}{\rulename{sif} \; \hfill
  \semess{E}{u}{v}{|if3 t_0 t_1 t_2|} }
& = & \begin{array}[t]{@@{\;}l@@{\,}l}
        (S_0 \vmseq \semess{B}{u}{v}{t_1} \vmhide xs)
            \vmunion
          (\vmnot(S_0 \vmhide xs) \vmseq \semess{B}{u}{v}{t_2}) \\
        \textbf{where} \; \xs = \semap{I}{|t_0|}, \; S_0 = \vmone( \semap{C}{|t_0|}, xs )
      \end{array}
\\[5mm]

% FOR
\multicolumn{2}{@@{}l}{\rulename{sfor} \; \hfill \semess{E}{u}{v}{|fordo t_0 t_1|}}
  & = & \vmfold ( op, z, \semapp{C}{|t_0|} ) \\
&& \multicolumn{2}{@@{}l}{\textbf{where} \hfill
       p,q,u_1,u_2,v_1,v_2 \not\in \freevars{t_0,t_1,u,v}}\\
