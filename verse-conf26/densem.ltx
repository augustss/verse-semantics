% -------------------------------------------------------------
%               The Verse Monad
% -------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\text{The Verse monad $\Vm{\cdot}$ comes equpped with the following operations} \\
  \begin{array}{rcl}
    \vmreturn & :: & a \rightarrow \Vm{a} \\
    (\vmbind) & :: & \Vm{a} \rightarrow (a \rightarrow \Vm{b}) \rightarrow \Vm{b} \\
    \vminject & :: & \powerset{a} \rightarrow \Vm{a} \\
    \vmseq    & :: & \Vm{a} \rightarrow \Vm{a} \rightarrow \Vm{a} \\
    \vmcat    & :: & \Vm{a} \rightarrow \Vm{a} \rightarrow \Vm{a} \\
    \vminject & :: & \powerset{a} \rightarrow \Vm{a} \\
    \vmunion  & :: & \powerset{a} \rightarrow \Vm{a} \\
  \end{array}
  \\ \\
  \textbf{Monad comprehensions} \\
  \text{The Verse monad enjoys the usual monad-comprenension notation:} \\
  \begin{array}{rcl}
    \vmcompL e \vmcompR & = & \vmreturn(e) \\
    \vmcompL e_1 \vb x \leftarrow e_2, \; Q \vmcompR & = & e_2 \vmbind \lambda x. \vmcompL e_1 \vb Q \vmcompR \\
    \vmcompL e_1 \vb x \in e_2, \; Q \vmcompR & = & \vminject(e_2) \vmbind \lambda x. \vmcompL e_1 \vb Q \vmcompR \\
  \end{array}
\\ \\
  \textbf{Derived functions} \\
  \begin{array}{rcl}
  (\vmhide) & :: & \Vm{\Env} \rightarrow \powerset{\Ident} \rightarrow \Vm{\Env} \\
  s \vmhide vs & = & \vmcompL \rho \vb \rho' \leftarrow s, \rho \in \Env, x \not\in vs \Rightarrow \rho(x) = \rho'(x) \vmcompR \\
  \end{array}
\end{array}
$$
\caption{The Verse monad}
\end{figure}

% -------------------------------------------------------------
%               The ENV type and its operations
% -------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}

\textbf{Domains}\\
\begin{array}{rl@@{\;\;}c@@{\;\;}ll}
  v \in & \Value & = & \Int(\Z) + \Fun(\F) \\\
  & \F & = & \Vm{\semfcn}  & \text{Any invariants? e.g. disjoint domains} \\
  \rho \in & \Env & = & \Ident \rightarrow \Value  & \text{Total: gives a value to every identifier} \\
  \EV \in &\ENV & = & \powerset{ \Env } \\
  \{ \fpr{x_1}{y_1}, \mydots, \fpr{x_n}{y_n} \} \in & \semfcn & = & \powerset{ \Val \times \Val }
  & \text{Partial functions} \\
\end{array} \\
\\
\textbf{The constraint language}\\
\begin{array}{l@@{\;\;}rc@@{\;\;}ll}
  \text{Simple values}    & a & ::= & |v| \vb |x| \vb op[a_1,\mydots,a_n] \vb |arr (a_0, xdots, a_n)| \\
% \vb |truth a|\\
  \text{Constraints} &  \EV & ::= & \conBrack{relop[a_1,\mydots,a_n]} \\
   &  & \vb & \conBrack{ \fpr{x}{y} \in h } \vb \conBrack{ x \not\in \dom(h) }  & \text{where}\; h \in \semfcn \\
%   &  & \vb & \conBrack{ \conFun{a_{arg}}{a_{res}}{a_{fun}}{i}{n}}  \\
  &  & \vb & \conEmpty \vb \conUniv \\
  &  & \vb & \EV_1 \cup \EV_2 \vb \EV_1 \cap \EV_2 \\
  &  & \vb & \conCompl(\EV)  & \text{Complement} \\
  &  & \vb & \HIDE{\EV}{xs} & \text{Hiding} \\
  \text{Relational ops} &  relop & ::= & = \vb < \vb \leq \vb \geq \vb > \\
  \text{Value ops} & op & ::= & + \vb - \vb * \vb / \\
  & & \vb & \funcat \vb \tupcat  & \text{Function and tuple concatenation resp.} \\
  & & \vb & \fununion & \text{Function/tuple union} \\
\end{array}\\
\\[-1mm]
\textbf{Interpretation of simple values and constraints}\\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
  \sembrack{\EV} & : & \ENV \\
  \sembrack{\conEmpty} & = & \{\} \\
  \sembrack{\conUniv} & = & \Env   & \text{Set of all environments} \\
  \sembrack{\conCompl(\EV)} & = & \complE( \sembrack{\EV} )\\
  \sembrack{\HIDE{\EV}{xs}} & = & \{ \rho \in \Env \vb \exists \rho' \in \sembrack{\EV} .\, \forall x \not\in xs.\, \rho(x) =  \rho'(x) \} \\
  \sembrack{\EV_1 \cup \EV_2} & = & \sembrack{\EV_1} \cup \sembrack{\EV_2} \\
  \sembrack{\EV_1 \cap \EV_2} & = & \sembrack{\EV_1} \cap \sembrack{\EV_2} \\
  \sembrack{\conBrack{a_1=a_2}} & = & \{ \rho \in \Env \vb \semapp{A}{a_1}\rho = \semapp{A}{a_2}\rho \} \\
  \sembrack{\conBrack{a_1>a_2}} & = & \{ \rho \in \Env \vb \semapp{A}{a_1}\rho > \semapp{A}{a_2}\rho \}
      \hspace{4mm} \text{...and similarly other $relops$} \\
  \sembrack{ \conBrack{\fpr{x}{y} \in h} } & = & \{ \rho \in \Env \vb \fpr{\rho(x)}{\rho(y)} \in h \} \\
  \sembrack{ \conBrack{ x \not\in \dom(h) } } & = & \{ \rho \in \Env \vb \rho(x) \not\in \dom(h) \}
\end{array} \\
\\
\begin{array}{r@@{\;\;}c@@{\;\;}ll}
\semapp{A}{|a|} & : & \parfun{\Env}{\Val} \\
\semapp{A}{|x|}\rho & = & \rho(x) \\
\semapp{A}{|v|}\rho & = & v \\
%\semapp{A}{|o|}\rho & = & \semap{O}{o} \\
\semapp{A}{|a_1 + a_2|}\rho & = & \Int(r_1 + r_2)
  & \text{if $\Int(r_1)= \semapp{A}{a_1}\rho$ and
     $\Int(r_2) = \semapp{A}{a_2}\rho$ } \\

% \semapp{A}{|truth a|}\rho & = &  FUN [ \fpr{v}{v} ] \hspace{5mm} \text{where $v = \semapp{A}{a}\rho$} \\
\semapp{A}{|a_1| \fununion |a_2|}\rho & = & \Fun(r_1 \pomunion r_2)
    &\text{if $\Fun(r_1)= \semapp{A}{a_1}\rho$, $\Fun(r_2)= \semapp{A}{a_2}\rho$,
                      $\pomdom(r_1)\cap \pomdom(r_2) = \emptyset$} \\
\semapp{A}{|a_1| \funcat |a_2|}\rho & = & \Fun(r_1 \pomcat r_2)
    & \text{if $\Fun(r_1)= \semapp{A}{a_1}\rho$, $\Fun(r_2)= \semapp{A}{a_2}\rho$,
                      $\pomdom(r_1)\cap \pomdom(r_2) = \emptyset$} \\
\semapp{A}{|a_1| \tupcat |a_2|}\rho & = & \Fun(\pomtupcat(r_1,r_2))
    & \text{if $\Fun(r_1)= \semapp{A}{a_1}\rho$, $\Fun(r_2)= \semapp{A}{a_2}\rho$,
                      $\pomdom(r_1)\cap \pomdom(r_2) = \emptyset$} \\
\semapp{A}{|emptytup|}\rho & = & \Fun(\pomunit{ \pomempty } ) \\
\semapp{A}{|arr (a_0, xdots, a_n)|}\rho
  & = & \multicolumn{2}{@@{}l}{\Fun ( \; \pomunit{ \{ \fpr{0}{\semapp{A}{a_0}\rho} \}} \pomcat \ldots \pomcat
            \pomunit{ \{ \fpr{n}{\semapp{A}{a_n}\rho} \}} \; )} \\
% \semap{O}{|o|} & : & \Val \\
% \semap{O}{|<=|} & = & \mul\Fun[\,\{ \fpr{\tupE(x,y)}{x} \vb x \in \Z, y \in \Z, x \leq y \}\,] \\[1mm]
\end{array}\\
\\[-1mm]
\textbf{Semantic functions} \\

\begin{array}{lr@@{\;\;}c@@{\;\;}l}
\text{Binders of block} & \semap{I}{|t|} & : & \powerset{\Ident} \\
&  \semap{I}{|t|} & = & \text{the outer $\exists$-bound variables in |t|} \\[1mm]

% \text{Tuple values} &  \tupE & : & [\Val] \rightarrow \Val \\
% &  \tupE [v_0,\mydots,v_n] & = & \Fun \pomcompL \{ \fpr{i}{v_i} \} \vb i |<-| 0 \mycdots n \pomcompR
%   \hspace{1cm} \text{So $\tupE [] = \Fun(\pomempty)$}
\end{array} \\

\end{array}
$$
\caption{Semantic domains and associated functions}\label{fig:densem-notation}
\end{figure}


% ------------------------------------------------------------------------------------
%
%            The semantics itself
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}ll}
  & \semess{E}{u}{v}{|t|} & : & \VmENV  \\

% Wildcards and atoms
\rulename{swild}  &  \semess{E}{u}{v}{|_|} & = & \vminject \conBrack{u =v} \\
\rulename{svar}   &  \semess{E}{u}{v}{|x|} & = & \vminject \conBrack{u=v=x} \\
\rulename{sconst} &  \semess{E}{u}{v}{|k|} & = & \vminject \conBrack{u=v=k}\\
\rulename{sprim}  &  \semess{E}{u}{v}{|o|} & = & \vminject \conBrack{u=v=o} \\

% Capture input and output
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &
   \vminject\conBrack{x=v} \pomseq \semess{E}{u}{v}{t} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
   \vminject\conBrack{x=u} \pomseq \semess{E}{u}{v}{t} \\

% Tuples
\multicolumn{2}{@@{}l}{\rulename{stup} \; \hfill \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}}
  & = & (\vminject \conBrack{ u=|arr (u_1, xdots, u_n)|, v=|arr (v_1, xdots, v_n)|} \\
  &&&   \; \vmseq \semess{E}{u_1}{v_1}{t_1}
         \vmseq \mydots
         \vmseq \semess{E}{u_n}{v_n}{t_n}) \\
&&&      \vmhide { \{u_1,\mydots u_n,v_1 \mydots v_n\} }
         \hfill u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v} \\

% Choice and failure
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & \vminject( \emptyset ) \hspace{6mm} \text{Or do we need a $\VmKw$ empty elt?} \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
  & = & \semess{B}{u}{v}{t_1} \vmcat \semess{B}{u}{v}{t_2} \\
\rulename{suchoice} &  \semess{E}{u}{v}{|t_1 `uchoice` t_2|}
  & = & \semess{B}{u}{v}{t_1} \vmunion \semess{B}{u}{v}{t_2} \\

% Unification
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|} & = &   \semess{E}{u}{v} {t_1} \vmseq \semess{E}{u}{v}{t_2} \\

% Sequencing
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|} & = &  \semapp{C}{t_1} \vmseq \semess{E}{u}{v}{t_2} \\
% Dot-dot
\rulename{sdotdot} &  \semess{E}{u}{v}{|t_1 ..  t_2|}
  & = & \pomunit{\conBrack{u=v}} \pomseq \semess{E}{p_1}{q_1}{t_1} \pomseq \semess{E}{p_2}{q_2}{t_2} \pomseq \\
  & & & \pomunions \{\;  \pomcats [ \conBrack{v=q_1+i, i \leq q_2 - q_1}  \vb i \leftarrow [0..n] ]  \vb n \in \N \; \} \\
  & & & \pomHIDE \{p_1,q_1,p_2,q_2\} \hfill  p_1,q_1,p_2,q_2 \not\in \freevars{t_1,t_2,u,v} \\[1mm]

% Application and type
\rulename{sapp} & \semess{E}{u}{v}{|apply1N t_1 t_2|}
& = &  \pomunit{\conBrack{u=v}} \pomseq \semess{E}{f}{g}{t_1} \pomseq \semess{E}{p}{q}{t_2}
\pomseq \semap{F}{|apply1N g q|}v  \\
& & & \pomHIDE \{f,g,p,q\} \hfill f,g,p,q \not\in \freevars{t_1,t_2,u,v} \\[1mm]
\rulename{stype} &  \semess{E}{u}{v}{|:t|} & = & \semess{E}{p}{q}{t} \pomseq \semap{F}{|apply1N q u|}v
  \pomHIDE \{p,q\} \hfill p,q \not\in \freevars{t,u,v} \\[1mm]

% IF
\multicolumn{2}{@@{}l}{\rulename{sif} \; \hfill
  \semess{E}{u}{v}{|if3 t_0 t_1 t_2|} }
& = & \begin{array}[t]{@@{\;}l@@{\,}l}
        (S0 \pomseq \semess{B}{u}{v}{t_1} \pomHIDE xs)
            \pomunion
          (\pomNOT(S0 \pomHIDE xs) \pomseq \semess{B}{u}{v}{t_2}) \\
        \textbf{where} \; \xs = \semap{I}{|t_0|}, \; S0 = \pomONE( xs, \semap{C}{|t_0|} )
      \end{array}
\\[5mm]
\multicolumn{2}{@@{}l}{\rulename{sfor} \; \hfill \semess{E}{u}{v}{|fordo t_0 t_1|}}
& = &  \semFOR{\semapp{C}{t_0}}{\semap{I}{t_0}}{u}{v}{t_1} \\[2mm]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%       B, C, and F
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
& \semess{B}{u}{v}{|t|} & : & \VmENV \\
& \semess{B}{u}{v}{|t|} & = & \semess{E}{u}{v}{e} \pomHIDE \semapp{I}{|t|} \\[1mm]
& \semapp{C}{|t|} & : & \VmENV \\
& \semapp{C}{|t|} & = & \semess{E}{p}{q}{|t|} \pomHIDE \{p,q\} \hfill p,q \not\in \freevars{t}\\[1mm]
& \semap{F}{|apply1N f x|}r & : & \VmENV \\
& \semap{F}{|apply1N f x|}r  & = &
  \pomcompL  \conBrack{ f = \Fun(F) } \cap \conBrack{ \fpr{x}{r} \in h }\vb \Fun(F) \in \Val, \; h \leftarrow F \pomcompR
\end{array} \\
\\

%% --------------- ONE -------------------------------
\begin{array}{r@@{\;\;}c@@{\;\;}l}
  \pomONE & : & \powerset{\Ident} \rightarrow \VmENV \rightarrow \VmENV
       \hspace{5mm} \text{Result has no $(\pomcat)$}\\

%   \pomONE( xs, \pomempty )  & = & \pomempty \\
  \pomONE( xs, \pomunit{\EV} )  &  = & \pomunit{\EV} \\
  \pomONE( xs, S \pomunion T) & = & \pomONE(xs,S) \pomunion \pomONE(xs,T) \\
  \pomONE( xs, S \pomcat T )  & = & S1 \pomor ( \pomNOT(S1 \pomHIDE xs) \pomseq \pomONE(xs, T)) \\
                              & \multicolumn{2}{l}{\textbf{where}\; S1 = \pomONE(xs, S)} \\[1mm]

%% --------------- FOR -------------------------------
\semFOR{\_}{xs}{u}{v}{t_1} & : & \powerset{\Ident} \rightarrow \pomENV \rightarrow \pomENV \\
% \semFOR{\pomempty}{xs}{u}{v}{t_1} & = & \pomunit{\conBrack{u=v=|emptytup|}}
%                   \hfill \text{(NB: |for1 fail| returns empty tuple)} \\[1mm]
\semFOR{S \pomunion T}{xs}{u}{v}{t_1}
  & = & \semFOR{S}{xs}{u}{v}{t_1} \pomunion  \semFOR{T}{xs}{u}{v}{t_1} \\
\text{or}  & = & \semFOR{S}{xs}{u}{v}{t_1} \pomor  \semFOR{T}{xs}{u}{v}{t_1} \\
%                   & = & \pomunit{\conBrack{u=u_1 \fununion u_2, v=v_1 \fununion v_2}}
%                   \hfill u_1,v_1,u_2,v_2 \not\in \freevars{t_1,u,v,xs} \\
%    &&  \pomseq \semFOR{S}{xs}{u_1}{v_1}{t_1} \pomseq \semFOR{T}{xs}{u_2}{v_2}{t_1} \\
%    && \pomHIDE \{u_1,v_1,u_2,v_2\} \\[1mm]
\semFOR{S \pomcat T}{xs}{u}{v}{t_1}
                   & = & \pomunit{\conBrack{u=u_1 \tupcat u_2, v=v_1 \tupcat v_2}}
                   \hfill u_1,v_1,u_2,v_2 \not\in \freevars{t_1,u,v,xs} \\
    &&  \pomseq \semFOR{S}{xs}{u_1}{v_1}{t_1} \pomseq \semFOR{T}{xs}{u_2}{v_2}{t_1} \\
    && \pomHIDE \{u_1,v_1,u_2,v_2\} \\[1mm]
\semFOR{\pomunit{\EV}}{xs}{u}{v}{t_1}
       &  = &  (\pomunit{\EV} \pomseq \pomunit{\conBrack{u=|arr p|,v=|arr q|}}
                  \pomseq \semess{B}{p}{q}{t_1}) \pomHIDE \{p,q,xs\}   \\
 &&  \pomunion \; \pomNOT(\pomunit{\EV} \pomHIDE xs) \pomseq \pomunit{\conBrack{u=v=|emptytup|}}  \hspace{6mm}  p,q \not\in \freevars{t_1,u,v,xs} \\
\end{array}
\end{array}
$$
\caption{E-POM: denotational semantics of Essential Verse, using pomsets}
\label{fig:E-sls1}
\end{figure}


