% ------------------------------------------------------------------------------------
%
%           The SL monad
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
  \multicolumn{1}{c}{\fbox{\parbox{8cm}{
   \begin{center}
      ${\bf type} \; \SL{A} = \powersetnp{\seq{A}}$ \\
      \text{The set may be infinite, but the list is always finite}
   \end{center}
 }}} \\ \\

\textbf{SL is an applicative functor} \\[1mm]
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}l}
     \pureSL & : & \ENV \rightarrow \SL{\ENV}  \\
     \pureSL( \EV ) & = & \{ [ \EV ] \} \\[1mm]

\liftATwo & : & (A \rightarrow B \rightarrow C) \rightarrow \SL{A} \rightarrow \SL{B} \rightarrow\SL{C} \\
\liftATwo(OP,S_1,S_2) & = &
  \{ \; \concat(ss)
     \begin{array}[t]{@@{}l@@{\;}l}
     \vb & s_1 {:} \seq{A} \in S_1 \\
     , & \letvar t {:} \seq{\SL{C}} = [\; \mapSL(OP(\EV,\_), S_2) \vb \EV |<-| s_1 \; ] \\
     , & \letvar r {:} \SL{\seq{C}} = \pickE(t) \\
     , & ss {:} \seq{\seq{C}} \in r \; \}
     \end{array} \\
     \\[-2mm]

 (\seqSL) & : & \SL{\ENV} \rightarrow \SL{\ENV} \rightarrow \SL{\ENV} \\
 E_1 \seqSL E_2 & = & \liftATwo(\, \cap, \, E_1, \, E_2 \, ) \\[1mm]
 (\seqSLOne) & : & \ENV \rightarrow \SL{\ENV} \rightarrow \SL{\ENV} \\
 \EV_1 \seqSLOne E_2 & = & \pureSL(\EV_1) \seqSL E_2 \\
              & = & \mapSL(\;  \lambda \EV_2.\, \EV_1 \cap \EV_2, E_2 \;) \\[1mm]
  \mapSL & : & (A \rightarrow B) \rightarrow \SL{A} \rightarrow \SL{B} \\
  \mapSL(OP, E) & = & \{ \; [ OP( \EV) \vb \EV |<-| s ] \vb s \in E \; \} \\[1mm]
(\HIDESkw) & : &  \SL{\ENV} \rightarrow \powerset{\Ident} \rightarrow \SL{\ENV} \\
\HIDES{s}{xs} & = & \mapSL( \lambda \EV.\, \HIDE{\EV}{xs}, \; s) \\
\end{array}
\\
\\
\text{ \textbf{SL is also a monad (I think)} and bind is easier to think about than liftA2!} \\[1mm]
\begin{array}{@@{}r@@{\;\;}c@@{\;\;}l}
(\bindSL) & : & \SL{A} \rightarrow (A \rightarrow \SL{B}) \rightarrow \SL{B} \\
S \bindSL K & = & \{ \; \concat(ss)
\begin{array}[t]{@@{}l@@{\;}l}
   \vb & s{:}[A] \in S \\
   , & \letvar t {:} [\SL{C}] = [\, K(\EV) \vb \EV |<-| s\, ] \\
   , & \letvar r {:} \SL{[C]} = \pickE(t) \\
   , & ss{:}[[C]] \in r \; \}
\end{array} \\
& = & \{ \; \concat(ss) \vb s \in S, \; ss \in \pickE[\, K(\EV) \vb \EV |<-| s\, ] \; \} \hspace{3mm} \text{\emph{more compactly}}
  \\[1mm]
\liftATwo(OP,S_1, S_2) & = & \begin{array}[t]{@@{}l}
  S_1 \bindSL (\lambda \EV_1. \\
  S_2 \bindSL (\lambda \EV_2. \\
  \pureSL( OP(\EV_1,\EV_2) )\,))
  \end{array}
\end{array} \\
\\
\parbox{8cm}{NB: this naive version of $\liftATwo$ is wrong:
  $$\liftATwo(OP,S_1,S_2)
  = \{ [ OP(\EV_1,\EV_2) \vb \EV_1 |<-| s_1, \EV_2 |<-| s_2 ] \vb s_1 \in S_1, s_2 \in S_2 \}$$
...but there is no naive $\bindSL$.   True?}

\end{array}
$$
\caption{The $\SL{A}$ applicative functor}
\end{figure}

% ------------------------------------------------------------------------------------
%
%           Denotational semantics of Essential Verse in SLS style
%
% ------------------------------------------------------------------------------------

\begin{figure}
$$
\begin{array}{l}
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
    & \semess{E}{u}{v}{|t|} & : & \SL{\Env} \\

% Wildcards and atoms
\rulename{swild}  &  \semess{E}{u}{v}{|_|} & = & \pureSL \conBrack{u =v} \\
\rulename{svar}   &  \semess{E}{u}{v}{|x|} & = & \pureSL \conBrack{u=v=x} \\
\rulename{sconst} &  \semess{E}{u}{v}{|k|} & = & \pureSL \conBrack{u=v=k} \\
\rulename{sprim}  &  \semess{E}{u}{v}{|o|} & = & \pureSL \conBrack{u=v=o} \\

% Capture input and output
\rulename{sbind} &  \semess{E}{u}{v}{|x:=t|} & = &  \conBrack{x=v} \seqSLOne \semess{E}{u}{v}{t} \\
\rulename{ssquig} &  \semess{E}{u}{v}{|esssquig x t|} & = &
   \conBrack{x=u} \seqSLOne \semess{E}{u}{v}{t} \\

% Tuples
\multicolumn{2}{@@{}l}{\rulename{stup} \; \hfill \semess{E}{u}{v}{|array (t_1,xdots,t_n)|}}
& = & \begin{array}[t]{@@{}l}
         \conBrack{ u=|arr (u_1, xdots, u_n)|,
                    v=|arr (v_1, xdots, v_n)|}
         \seqSLOne \semess{E}{u_1}{v_1}{t_1}
         \seqSL \mydots
         \seqSL \semess{E}{u_n}{v_n}{t_n} \\
         \HIDESkw { \{u_1,\mydots u_n,v_1 \mydots v_n\} }
         \hspace{5mm} u_i,v_i\not\in \freevars{t_1 \mydots t_n, u,v}
      \end{array} \\

% Choice and failure
\rulename{sfail} &  \semess{E}{u}{v}{|fail|} & = & \{ [ ] \} \\
\rulename{schoice} &  \semess{E}{u}{v}{|t_1 `choice` t_2|}
  & = & \{ \; s_1 \append s_2 \vb s_1 \in \semess{B}{u}{v}{t_1}, s_2 \in \semess{B}{u}{v}{t_2} \; \} \\

% Unification
\rulename{sunify} &  \semess{E}{u}{v}{|t_1 == t_2|} & = &   \semess{E}{u}{v} {t_1} \seqSL \semess{E}{u}{v}{t_2} \\

% Sequencing
\rulename{sseq} &  \semess{E}{u}{v}{|t_1 ; t_2|} & = &  \semapp{C}{t_1} \seqSL \semess{E}{u}{v}{t_2} \\
% Dot-dot
\rulename{sdotdot} &  \semess{E}{u}{v}{|a_1 ..  a_2|}
& = & \conBrack{u=v} \seqSLOne
   \{  \; [\conBrack{v=a_1+i, i \leq a_2 - a_1}  \vb i \leftarrow [0..n] ]  \vb n \in \N \} \\

% Application and type
\rulename{sapp} & \semess{E}{u}{v}{|apply1N a_1 a_2|}
 & = &  \conBrack{u=v} \seqSLOne \semap{F}{|apply1N a_1 a_2|}v \\
\rulename{stype} &  \semess{E}{u}{v}{|:a|} & = & \semap{F}{|apply1N a u|}v  \\
\\

% IF
\multicolumn{2}{@@{}l}{\rulename{sif} \; \hfill
  \semess{E}{u}{v}{|if3 t_0 t_1 t_2|} }
& = &   \bigcup\limits_{s_0 \in \semap{C}{|t_0|}}\left\{
 \begin{array}{@@{\;}l@@{\,}l}
(\HIDES{\EV_1 \seqSLOne \semess{B}{u}{v}{t_2})}{xs} \\
\cup \\
(\HIDE{\conCompl(\EV_1)}{xs}) \seqSLOne \semess{B}{u}{v}{t_3} \\
 \textbf{where} \; \xs = \semap{I}{|t_0|}, \; \EV_1 = \firstE(xs,s_0)
 \end{array}
 \right\}
\\ \\
\multicolumn{2}{@@{}l}{\rulename{sfor} \; \hfill \semess{E}{u}{v}{|fordo t_1 t_2|}}
& = &   \bigcup\limits_{s_0 \in \semap{C}{|t_0|}} \left\{
 \begin{array}{@@{\;}l@@{\,}l}
   \conBrack{ u=(u_1 \oplus \mydots \oplus u_n), v=(v_1 \oplus \mydots \oplus v_n)}
   \seqSLOne D_1 \seqSL \mydots \seqSL D_n \\
\hspace{5mm} \HIDESkw \{u_1, \mydots, u_n, v_1, \mydots, v_n \} \\
\textbf{where} \\
\;  \begin{array}[t]{l}
  \{u_1, \mydots, u_n, v_1, \mydots, v_n \} \not\in \freevars{u,v,t_0,t_1} \\
  {} [\EV_1,\mydots,\EV_n] = s_0 \\
  S1 = \semess{B}{p}{q}{t_1} \\
  C_i = \begin{array}[t]{@@{}l}
      \HIDES{(\EV_i \seqSLOne \conBrack{u_i=|arr p|, v_i=|arr q|} \seqSLOne S1)}{\{p,q\}} \\
      \cup \\
      \conCompl( \EV_i ) \seqSLOne \pureSL \conBrack{u_i=|arr ()|, v_i=|arr ()|}
      \end{array} \\
  D_i = \HIDES{C_i}{xs} \\ 
  \xs = \semap{I}{|t_0|}
 \end{array}
 \end{array}
 \right\}
\end{array}
\\

\\
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%       B, C, and F
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\begin{array}{@@{}lr@@{\;\;}c@@{\;\;}l}
& \semess{B}{u}{v}{|t|} & : & \SL{ \ENV } \\
& \semess{B}{u}{v}{|t|} & = & \HIDES{\semess{E}{u}{v}{e}}{\semapp{I}{|t|}} \\[1mm]
& \semapp{C}{|t|} & : & \SL{ \ENV } \\
& \semapp{C}{|t|} & = & \HIDES{\semess{E}{p}{q}{|t|}}{\{p,q\}} \hspace{5mm} p,q \not\in \freevars{t}\\[1mm]
& \semap{F}{|apply1N a_1 a_2|}r & : & \SL{\ENV} \\
& \semap{F}{|apply1N a_1 a_2|}r  & = &
    \{ \ [ \; \conBrack{\conFun{a_2}{r}{a_1}{i}{n}} \vb i |<-| [0..n] \; ] \vb n \in \N
      \; \}
 \\[1.5ex]

& \firstE & : & \powerset{\Ident} \rightarrow [\ENV] \rightarrow \ENV \\
& \firstE(xs,\; []) & = & \{\} \\
& \firstE(xs,\; \EV : s)  & = & \EV \cup (\firstE(xs, s) \cap \conCompl(\HIDE{\EV}{xs})) \\
\end{array}
\end{array}
$$
