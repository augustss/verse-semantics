\begin{figure}
$$
  \begin{array}{l}
  \textbf{Set semantics}\\
  \begin{array}{rcll}
    \multicolumn{3}{l}{|type|\; \Vm{a} = \powerset{a}} \\[2mm]
    \vmempty & = & \{\} \\
    \vminject(\EV) & = & \EV \\
    s \vmcat t  & = & s \cup t \\
    \vmfold(k,z,s)   & = & k(s,z) \\
    \vmseq(s,t)   & =  & s \cap t \\
    \vminnerunion(s,t)  & = & s \cup t \\
    \vmunion(s,t)  & =  & s \cup t \\
    \vmunions(ss) & =  & \bigcup_{s \in ss}s \\
    \vmpi(s, F) & = & \{ g \in \parfun{a}{b} \vb \dom(g)=s, \forall (\fpr{x}{y}) \in g. \; y \in F(x) \} \\
    \vmcollapse(s) & = & s \\
  \end{array}
  \\ \\

  \text{The Verse sequence monad $\VmSeq{\cdot}$ comes equipped with the following operations} \\
  \begin{array}{rcll}
    \seqappend & :: & \VmSeq{a} \rightarrow \VmSeq{a} \rightarrow \VmSeq{a} \\
    \sequnit & :: & a \rightarrow \VmSeq{a} \\
    (\seqbind) & :: & \VmSeq{a} \rightarrow (a \rightarrow \VmSeq{b} \rightarrow \VmSeq{b} \\
    \seqfold & :: & (a \rightarrow b \rightarrow b) \rightarrow b \rightarrow \VmSeq{a} \rightarrow  b \\
    \seqzip & :: & (\powerset{a} \rightarrow a) \rightarrow \powerset{\VmSeq{a}} \rightarrow  \VmSeq{a}
      & \text{Dodgy-zip of infinite set}
  \end{array}
\\ \\

  \textbf{Sequence-of-set semantics}\\
  \begin{array}{rcll}
    \multicolumn{3}{l}{|type|\; \Vm{a} = \VmSeq{\powerset{a}}} \\[2mm]
    \vmempty & = & \sequnit( \{\} ) \\
    \vminject(\EV) & = & \sequnit(\EV) \\
    s \vmcat t  & = & \seqappend( s, t ) \\
    \vmseq(s,t)   & =  & s \seqbind \lambda \EV_1.\, t \seqbind \lambda \EV_2.\, \EV_1 \cap \EV_2\\
    \vminnerunion(s,t)  & = & s \seqbind \lambda \EV_1.\, t \seqbind \lambda \EV_2.\, \EV_1 \cup \EV_2\\

    \vmunion(s,t)  & = & \seqzip( \cup, \{ s, t \} )  &  \text{Dodgy union} \\
    \vmunions(ss) & =  & \seqzip( \cup, ss )  &  \text{Infinite dodgy union} \\
    \vmfold(k,z,s)   & = & \seqfold(k,z,s) \\
    \vmpi & = & ??? \\
    \vmcollapse( s ) & = & \seqfold( \cup, \{ \}, s )
  \end{array}
