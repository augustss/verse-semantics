# Test types
#  pass  evaluate the two expressions and expect them to be equal
#  fail  evaluate the two expressions,
#       they should be equal but currently the test fails

# Trivial tests
testeq("EV1",pass) {2}                                   {2}
testeq("EV2",pass) {x:=1; x}                             {1}

# Arithmetic
testeq("Arith1",pass) {3+4}                                 {7}
testeq("Arith2",pass) {3-4}                                 {0-1}
testeq("Arith3",pass) {3*4}                                 {12}
testeq("Arith4",pass) {32/4}                                {8}
testeq("Arith5",pass) {1/0}                                 {:false}
testeq("Arith6",pass) {-3}                                  {0-3}
testeq("Arith7",pass) {+3}                                  {0+3}

# Comparison
testeq("Cmp1",pass) {3<4}                                 {3}
testeq("Cmp2",pass) {3<3}                                 {:false}
testeq("Cmp3",pass) {3<2}                                 {:false}
testeq("Cmp4",pass) {3<=4}                                {3}
testeq("Cmp5",pass) {3<=3}                                {3}
testeq("Cmp6",pass) {3<=2}                                {:false}
testeq("Cmp7",pass) {3>4}                                 {:false}
testeq("Cmp8",pass) {3>3}                                 {:false}
testeq("Cmp9",pass) {3>2}                                 {3}
testeq("Cmp10",pass) {3>=4}                                {:false}
testeq("Cmp11",pass) {3>=3}                                {3}
testeq("Cmp12",pass) {3>=2}                                {3}
testeq("Cmp13",pass) {3<>4}                                {3}
testeq("Cmp14",pass) {3<>3}                                {:false}
testeq("Cmp15",pass) {3<>2}                                {3}
testeq("Cmp16",pass) {3=4}                                 {:false}
testeq("Cmp17",pass) {3=3}                                 {3}
testeq("Cmp18",pass) {3=2}                                 {:false}

# Failing unifications
# Values to consider: K, op, tuple, lambda
# K
testeq("Unif",pass) {1=2}                                 {:false}

# no prefix'op'
testeq("Unif1",pass) {1=prefix'-'}            {:false}
testeq("Unif2",pass) {1=(1,2)}                             {:false}

# ICFP rules gets stuck on any lambda comparison
testeq("Unif3",pass) {1=(x:any=>x)}                        {:false}

# op
testeq("Unif4",pass) {prefix'-'=1}                         {:false}
testeq("Unif5",pass) {prefix'-'=prefix'+'}     {:false}
testeq("Unif6",pass) {prefix'-'=(1,2,3)}                   {:false}
testeq("Unif7",pass) {prefix'-'=(x:any=>x)}                {:false}

# tuple
testeq("Unif8",pass) {(1,2)=1}                             {:false}
testeq("Unif9",pass) {(1,2)=prefix'-'}        {:false}
testeq("Unif10",pass) {(1,2)=(1,2,3)}                       {:false}
testeq("Unif11",pass) {(1,2)=(x:any=>x)}         {:false}

# lambda
testeq("Unif12",pass) {(x:any=>x)=1}             {:false}
testeq("Unif13",pass) {(x:any=>x)=prefix'-'}                {:false}
testeq("Unif14",pass) {(x:any=>x)=(1,2,3)}                  {:false}
testeq("Unif15",pass) {(x:any=>x)=(x:any=>1)}               {:false}

# Unification with equal values
testeq("Unif16",pass) {1=1}                                 {1}

# Not with POPL
#testeq("Unif17",pass)
#            {prefix'-'=prefix'-'}                 {prefix'-'}  # or maybe this shouldn't work?
testeq("Unif18",pass) {(1,2)=(1,2)}                         {(1,2)}
testeq("Unif19",pass) {(x:any=>x)=(x:any=>x)}               {:false}

# If BIND is implemented in parallel, it may forget to substitute in the substitutions
testeq("Unif20",pass) {x:any; y:any; x=y; y=1}  {1}
testeq("Unif21",pass) {x:any; y:any; x=1; y=x}  {1}
# Needs alpha conversion
testeq("Unif22",pass) {x:any; y:any; x=y; y=(x,x)}  {x:any; x=(x,x)} # check for occurs check
# Needs alpha conversion
testeq("Unif23",pass) {x:any; y:any; y=(x,x); x=y}  {x:any; x=(x,x)} # check for occurs check


# Arrays
testeq("Array1",pass){array{1;2;3}}                         {1,2,3}
testeq("Array2",pass){array{}}                              {()}
testeq("Array3",pass){Length(array{1;2;3})}                 {3}
testeq("Array4",pass){Length(array{})}                      {0}
testeq("Array5",pass){Length(array{_;_})}                   {2}

testeq("Array6",pass){x:=(1,2); y:=(1,3); one{x=y}}         {:false}
testeq("Array7",pass){x:any; y:any; x=(1,1); x=y; y=(2,2); y} {:false}
# This does not work left-to-right
testeq("Array8",pass){all{x:any; all{(x=1)|(x=0)}; x=0|1}}  {(0,1)}
testeq("Array9",pass) { a := (0,1); a[0] }                  {0}
testeq("Array10",pass){ all{1..4} }                         {array{1,2,3,4} }
testeq("Array11",pass){ for(1..4){7} }                      {array{7,7,7,7} }
testeq("Array12",pass){ for(i := 1..4){i+1} }               {array{2,3,4,5} }
testeq("Array13",pass){ a := array{7,8}; for(i:a){i+1} }    {array{8,9} }

# Array expression splicing
testeq("Array14",pass) {a:=(1,2); (0,..a,3)}                 {0,1,2,3}
testeq("Array15",pass) {a:=(1,2); (0,..a,3,..a)}             {0,1,2,3,1,2}

#
testeq("All1",pass) {all{:(1,2,3)}}                            {1,2,3}
testeq("All2",pass) {all{x:(1,2,3); x}}                        {1,2,3}
testeq("All3",pass) {all{x:= :(1,2,3); x}}                     {1,2,3}
testeq("All4",pass) {all{x:(1,2,3)}}                           {1,2,3}

# Functions
testeq("Fun1",pass){(x:int => x+1)[2]}                    {3}
testeq("Fun2",pass){(x:any => y:any => x+2*y)[2][3]}      {8}
testeq("Fun3",pass){(x:int => y:int => x+2*y)[2][3]}      {8}
testeq("Fun4",pass){function(x:int){x+1}[2]}              {3}
testeq("Fun5",pass){function(x:int)(y:int){x+2*y}[2][3]}  {8}
# Function argument matching

testeq("Fun6",pass) {one{ pair := (1, function(n:int){pair[0]})
                        ; pair[0]}}  {1}
   # Needs recursion

testeq("Fun7",pass) {one{ pair := (1, function(n:int){if (n = 0) {1} else  {n * pair[1](n-1)}})
                        ; pair[1](5) } }  {120}
   # Needs recursion
testeq("Fun8",pass) {f(x:int, y:int):=2*x+y; f(2,3)}  {7}

# P desugaring, i.e., p:=e
testeq("Pat1",pass) {x:=1}                                {1}
testeq("Pat2",pass) {x:=1; x}                             {1}
testeq("Pat3",pass) {f(x:int):=x+1; f[10]}                {(fn(x:int){x+1})[10]}
testeq("Pat4",pass) {f(x:int)(y:int):=x*10+y; f[2][3]}    {23}
testeq("Pat5",pass) {:int:=5}                             {5}       # LA is this even allowed
# fail/wrong? testeq("Pat",pass) {:int:=(1,2)}                         {:false}  # LA is this even allowed
testeq("Pat6",pass) {x:int:=1}                            {1}
# fail/wrong? testeq("Pat",pass) {x:int:='a'}                          {:false}
testeq("Pat7",pass) {succ(x:any):=x+1; (y:succ):=1}       {2}   # XXX or 1?
testeq("Pat8",pass) {succ(x:any):=x+1; y:succ:=1; y}      {2}
testeq("Pat9",pass) {succ(x:any):int:=x+1; succ[5]}       {6}
# XXX Not sure about these
#testeq("Pat10",pass) {x? := 5; x}                          {array{5}}
#testeq("Pat11",pass) {x? := 1/0; x}                        {array{}}
testeq("Pat12",pass) {(x,y,z) := (1,2,3); z,y,x}           {3,2,1}
testeq("Pat13",pass) {i->x := 2; (i, x)}                   {2,2}
testeq("Pat14",pass) {f(x:int where y:=2*x):=y; f[3]}      {6}
testeq("Pat15",pass) { x := ((:any) => 1)[x+1] }           {1}

# Array LHS splicing
testeq("Pat16",pass) {(a,b,c,d) := (0,1,2,3); (a, d)}      {(0, 3)}
testeq("Pat17",pass) {(a,..b)   := (0,1,2,3); (a, b)}      {(0, (1,2,3))}
testeq("Pat18",pass) {(..b,a)   := (0,1,2,3); (a, b)}      {(3, (0,1,2))}
testeq("Pat19",pass) {(a,..b,c) := (0,1,2,3); (a, b, c)}   {(0, (1,2), 3)}

# L desugaring, i.e., l:t
testeq("TB1",pass) {(x:int) = 5}                         {5}
testeq("TB2",pass) {ap0(f(x:int):int) := f[0]; succ(x:int):=x+1; ap0[succ]} {1}
testeq("TB3",pass) {ap0(f(x:int):=1) := f[0]; succ(x:int):=x+1; ap0[succ]} {1}
testeq("TB4",pass) {ap0(f(x:int):=2)<closed> := f[0]; succ(x:int):=x+1; ap0[succ]} {wrong}
  # ap0[succ] gets stuck because succ[0] does not return 2
testeq("TB5",pass) {ap(f():int) := f[]; five():=5; ap[five]} {5}

testeq("TB6",pass, skip) {(p^ : int) := 2}                      {p:=new[int][2]}
testeq("TB10",pass, skip) {p^[](:int):int}                      {0}
  # TB6,TB10: no pointers yet

testeq("TB7",pass, broken) {x? : int}                            { x : ?int }
testeq("TB8",pass, broken) {x[] : int}                           { x : []int }
  # TB7,8 are these legal?

testeq("TB9",pass) {all{i->x:(3,4,5); (i, x)}}           {(0,3),(1,4),(2,5)}


# For
#         Commented out until we implement 'for'; also re-add TRec3
testeq("For1",pass) {for(x:=1|2; y:=3|4) {x,y}}           {((1,3),(1,4),(2,3),(2,4))}
testeq("For2",pass) {for(x:(1,5,2,7,3); x > 2){x}}        {(5,7,3)}
testeq("For3",pass) {for(x:=1|2|3){x>0}}                  {(1,2,3)}
testeq("For4",pass) {for(x:=1|2|3){x>1}}                  {:false}
testeq("For5",pass) {for(x:=1|y; y:=2|3){(x,y)}}          {((1,2),(1,3),(2,2),(3,3))}
testeq("For6",pass) {
   upto(i:int, n:int) := { if (i > n) then :false else i | upto[i+1,n] };
   for(x:=upto[1,3]){x}}                           {(1,2,3)}
testeq("For7",pass)  {for{for(x:=1|2|3){4|x}}}             {((4,4,4),(4,4,3),(4,2,4),(4,2,3),(1,4,4),(1,4,3),(1,2,4),(1,2,3))}
testeq("For8",pass) {for(x:=1){x+1}}                      {array{2}}

# Skipping these since `f` is <iterates> and hence dodgy?
testeq("For9",pass, skip) {f():=1|2; for(f[]; x:=3|4){x}}       {(3,4,3,4)}
testeq("For10",pass, skip) {f():=1|2; for(x:=3|4; f[]){x}}       {(3,3,4,4)}
testeq("For11",pass, skip) {f():=1|2; for(f[]; x:=3|4; f[]){x}}  {(3,3,4,4,3,3,4,4)}

# Array access via choices
testeq("For12",pass) {for ((3,4,5)[x:int])  {x}}  {(0,1,2)}
testeq("For13",pass) {for (i->x:(3,4,5))  {(i,x)}}  {((0,3),(1,4),(2,5))}
testeq("For14",pass) {for (x:int, x=(2,0,2)[x+1])  {x}}  {array {0}}

# Joachim's tests
# Check that BIND removes _one_ unification only
testeq("JB1",pass) {x:any; x = (y:any => 1); x = (y:any => 2)}  {(y:any => 1) = (y:any => 2)}
testeq("JB2",pass) {x:any; x = (y:any => 1); x = (y:any => 1)}  {(y:any => 1) = (y:any => 1)}
testeq("JB3",pass) {x:any; y:any; x = y; x = y; x = 1}  {1}
testeq("JB4",pass) {x:any; y:any; x = y; x = y; x = (z:any => 1)}  {(z:any => 1) = (z:any => 1)}

# "Dom1": Unification in the domain
testeq("Dom1",pass) {f9( x := 3|4):int := x+1; all{ y:int; f9[y]; y }} {(3,4)}

# Recursion
testeq("TRec1",pass)
            {f(n:any) := if (n = 0) then 1 else f(n-1); f(1)}  {1}
testeq("TRec2",pass)
            {fac(n:any) := if (n = 0)  {1} else  {n * fac(n-1)}; fac(4)}  {24}

