# Non-retractions as types
testeq("Type1",pass) {succ(n:int) := n + 1; a:succ := 2; a}  {3}
testeq("Type2",pass) {succ(n:int) := n + 1;
            f(m:succ) := m;
            f(5)
            }
            {6}

# Evaluation in if
testeq("TIf1",pass) {if(y:int; y=1) 42 else 23} {42}
testeq("TIF2",pass) {if(y:int; y=1) y else 23}  {1}

# Random collection
testeq("EV10a",pass) {succ(x:int):=x+1; f(a:succ) := a; f[3]} {4}
testeq("EV10b",pass) {succ(x:int):=x+1; f(a := :succ) := a; f[3]} {4}
testeq("EV10c",pass) {succ(x:int):=x+1; f(a:=if (0) then :int else :succ):=a; f[3]} {3}
testeq("EV10d",pass) {succ(x:int):=x+1; f(a:=if (:false) then :int else :succ):=a; f[3]} {4}

testeq("EV10",pass) {succ(x:int):=x+1; f(c:int, a:=if(c=0)then :int else :succ):=a;
                    (f(0,0),f(1,0))} {0,1}
   # c:int, then depending on c, we either get a:int or a:succ

testeq("EV11",pass) {one{t:=type{0|1}; f(x:t)<closed>:=x+1; f[0]}}     {1}
testeq("EV12",pass) {one{t:=type{0|1}; f(x:t)<closed>:=x+1; f[2]}}     {:false}
testeq("EV13",pass) {t:=type{:int}; f(x:t)<closed>:=x+1; f[0]}    {1}
testeq("EV14",pass) {t:=type{:int}; f(x:t)<closed>:=x+1; f[()]}   {:false}
# These are very slow with alternative rules
testeq("EV15",pass) {t:=type{:int => :int}; f(x:t)<closed>:=x[0]; succ(x:int):=x+1; f[succ]}   {1}
testeq("EV16",pass) {t:=type{:int => :int}; f(x:t)<closed>:=x[0]; badsucc(x:int):=(); f[badsucc]}  {wrong}
  # EV16: this should go WRONG.. i.e. it gets stuck

# Try CBV fixpoint combinator.
# Too slow with some rules
testeq("EV17",pass) {
  Z(f:any) := ((x:any) => f[(v:any)=>x[x][v]])[(x:any) => f[(v:any)=>x[x][v]]];
  fac := Z[(fc:any) => (n:any) => if (n=0) then 1 else n*fc[n-1]];
  fac[3] }                                                                     {6}

testeq("EV18",pass) {0[0]}                                {wrong}
testeq("EV19",pass) {operator'/'(1,0)}                    {wrong}

testeq("EV20",pass) {f(x:int)<succeeds>:=x<10; f[3]}      {3}
testeq("EV21",pass) {f(x:int)<succeeds>:=x<10; f[11]}     {wrong}

testeq("EV22",pass) {swapBad  := (t:any => (x:any; y:any;           (y, x))); p:any; swapBad [p] = (2,3); p } {wrong}
testeq("EV23",pass, broken) { swapGood := (t:any => (x:any; y:any; t=(x, y); (y, x)))
                            ; p:any; swapGood[p] = (2,3); p }
                            {(3,2)}

# Confluence: Need local substitution, hence 'fail'
testeq("EV24",fail)  {x : int; if (              x = 1; x > 1)  {42} else {23}} {23}
testeq("EV24a",fail) {x : int; if (y:int; y = x; y = 1; y > 1)  {42} else {23}} {23}

