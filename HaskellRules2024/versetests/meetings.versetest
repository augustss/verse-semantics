# Email 28 July 24
# Email thread with Andy/Lennart.  The loop in G stops Y getting a value,
#  so this test fails with "out of fuel".
testeq( "M28Jul24-1", fail ) { F(X:int)<decides>:void = if (X = 2) then fail
                             ; Y := all{(F[1]; G[1]) | (G[2]; F[2])}
                             ; G(X:int):void = if (X = 2) then G(2)
                             ; Y } { array{1} }

