# Add new meetings at the top

# ---------------------------------
# Opacity and function arguments: 14 Aug 24
verify("FCS1", pass){ f(x:int)<decides>:int := x>3
                    ; g()<decides> := f["monkey"] }
   # FCS1: f is opaque; call f["monkey"] is allowed by verifier even though domain test fails

verify("FCS2", fail){ f(x:int)<decides>:int := x>3
                    ; g()<succeeds> := f[4] }
   # FCS2: f is opaque; can't prove f[4] succeeds, even though it does

verify("FCS3", fail){ f(x:int)<closed><succeeds>:int := x+3
                    ; g()<succeeds> := f["monkey"] }
   # FCS3: f is opaque, and domain test fails, so g rejects the call

verify("FCS4", pass){ f(x:int)<decides> := x>3
                    ; g()<succeeds> := f[4] }
   # f is transparent; call f[4] actually succeeds

verify("FCS5", pass){ f(x:int)<decides> := x>3
                    ; g()<decides> := f["monkey"] }
   # FCS5: f["monkey"] is allowed by verifier even though domain test fails
   #       same as FCS1, but this time transparent f

verify("FCS6", fail) { f(x:int)<decides>:string := 7 }
   # FCS7: 7 is not a string.  Rejected despite <decides>
verify("FCS7", fail) { f(x:int)<decides>:type{10} := 7 }
   # FCS8: 7 is not 10.  Rejected despite <decides>

verify("FCS8", pass)   { f(3=4)<succeeds>:int := 7 }
verify("FCS9", pass)   { f(3=4)<succeeds>:int := "monkey" }

# --------- Round parens --------------
verify("FCS10", fail){ f1(x:int)<decides>:int := x>3
                     ; g()<decides> := f1("monkey") }
   # FCS10: f1 is opaque; Round parens; can't prove f1("monkey") succeeds

verify("FCS11", fail){ f1(x:int)<decides>:int := x>3
                     ; g()<decides> := f1(2) }
   # FCS11: f1 is opaque; Round parens; arg type matches,
   # but since f1 is <decides> we can't prove f1(2) succeeds

verify("FCS12", fail){ f2(x:int)<decides> := x>3
                     ; g()<decides> := f2("monkey") }
   # FCS12; can't prove f1("monkey") succeeds

verify("FCS13", fail){ f2(x:int)<decides> := x>3
                           ; g()<decides> := f2(2) }
   # FCS13: Round parens; can't prove f1(2) succeeds

verify("FCS14", pass){ f2(x:int)<decides> := x>3
                           ; g()<decides> := f2(4) }
   # FCS14: Round parens; this time we can prove that f2(4) succeeds

# More function call semantics
verify("TimL300", pass, broken) {a:int => g(f()(x:int):=3):=4 => g[f1()(x:int):=a] => 3}
verify("TimL300-1", pass) { (g(x:int):int) => g["monkey"] => 3 }
verify("TimL300-2", pass) { (g(x:int) :=3) => g["monkey"] => 3 }
  # TimL300-1,2: more exotic versions of FCS6

verify("TimL300-3", pass) { (g( f(x:int):string ):=4)  => g[ (x:int) =>"monkey"] => 3 }
verify("TimL300-4", pass) { (g( f(x:int):string ):=4)  => g[ h(x:int):="monkey"] => 3 }
verify("TimL300-5", pass) { (g( f(x:int):string ):int) => g[ h(x:int):="monkey"] => 3 }
verify("TimL300-6", pass)   { (g( f(x:int):="monkey" ):int) => g[ h(x:int):="monkey"] => 3 }
verify("TimL300-7", pass, broken) { (g( f(x:int):="not-monkey" ):int) => g[ h(x:int):="monkey"] => 3 }
verify("TimL300-8", pass)   { f(x:int):int := 1; if (f["monkey"] >0) then{1} else{2} = 2 }
verify("TimL300-9", pass, broken)   { f( g(x:int):string ):int := 1; if (f[(x:int)=>1] >0) then{1} else{2} = 2 }


# Meeting 9 August
testeq( "M9Aug24-1", pass, broken){ foo(x:any)<decides> := { x=99 }; p:any; foo[p]; p } { 99 }
  # M9Aug24-1 uses bidirectional programming
verify( "M9Aug24-2", pass){ F1(X:int)<closed><decides> := X = 1|2 }
verify( "M9Aug24-3", pass){ F1(X:any)<closed><decides> := X = 1|2 }

# Meeting 7 August
verify( "M7Aug24-1", pass ) { G(f()<decides>:int):=3; G[ h():=3 ] }
verify( "M7Aug24-2", fail ) { G(f()<decides>:int):=3; G[ h():="monkey" ] }
   # h() := "monkey" does not have the right return type
verify( "M7Aug24-3", pass ) { G(f()<decides>:int):=3; G[ h()<decides>:=3=4 ] }

verify( "M7Aug24-4", fail ) { x:int := "monkey" }
   # Manifestly, "monkey" does not have type int
verify( "M7Aug24-5", pass ) { all{ x:int := (1 | 2) } }
verify( "M7Aug24-6", fail ) { all{ x:int := (1 | "monkey") } }


# Meeting 7 August
testeq( "M5Aug24-1", pass ) { G(X:int):void = if (X = 2) then G(2); G[7] } {()}
testeq( "M5Aug24-2", loop ) { G(X:int):void = if (X = 2) then G(2); G[2] } {7}
verify( "M5Aug24-3", fail ) { foo(f()<decides>:int)<succeeds> := {f[]} }
verify( "M5Aug24-4", pass, broken ) { foo(f()<computes>:int)<succeeds> := {f[] = f[]} }


