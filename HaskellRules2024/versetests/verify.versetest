# For now we just ignore 'computes' i.e. treat as 'succeeds'
verify("computes00", pass) { f(x:int)<computes>:int = 1 }
verify("computes01", fail,tim=V10) { f(x:int)<computes>:int = (x = 1) }

# Testing the tim style
test(D00){x:int => x=3}
test(S00){x:int => x=x}

# Comparable
verify("comparable00", fail,tim=U00){a:any => comparable[a]}
verify("comparable01", pass){a:int => comparable[a]}
verify("comparable02", pass){f(a:comparable):comparable => x:=f(2)}
verify("comparable03", pass){f(a:comparable):comparable => x:=f[2]}
verify("comp-tup", pass,tim=skip_unimpl){f(x:comparable)<decides>:comparable := {(p,q):=x; p } }

# RI accepts, Tim's verifier rejects:
verify("jan00", pass) { fi(x:int)<succeeds><closed>:int = {x};
                        ga(y:int) := { if (fi(y) = y) then 1 else 2 } }

# RI accepts, Tim's verifier rejects:
verify("jan01", pass,tim=skip_rej) { h(x:int, y:int)<decides><closed>:int = { x = y };
                        if (h[2, 2]) then 1 else 2 }

verify("blob", fail,tim=D00) { foo(f()<decides>:int) := {f[]} }

# Finite types (from Google doc "Verse: more tricky cases")
verify("Fin1", fail) { (y := if (y=2) then y+1 else 3); y }
verify("Fin2", pass) { (y:type{3} := if (y=2) then y+1 else 3); y=3 }
verify("Fin3", pass) { (y:type{3|4} := if (y=2) then y+1 else 3); y=3 }
verify("Fin2a", pass, broken ) { (y:type{3}   := if (y=2) then y+1 else 3); if (y=3) then 1 else fail  }
  # Fin2a should work because all clients of y should see some(\_.3)

verify("Fin3a", fail ) { (y:type{3|4} := if (y=2) then y+1 else 3); if (y=3) then 1 else fail }
  # Fin3a fails, I think, because clients of y see some(\_.3|4)

verify("Fin4", fail,tim=V10) { y:int = y }
verify("Fin5", fail,tim=skip_acc) { y:type{3} = y }
  # Tim actually accepts this, but only because type{3} is a singleton
verify("Fin6", fail,tim=V10) { y:type{3|4} = y }
verify("Fin7", pass,tim=skip_rej) { check<decides>{ y:type{3|4} = 3; y=3 } }
verify("Fin8a", pass,tim=skip_rej) { check<succeeds>{ y:type{3|4} = 3; y } }
  # Tim rejects this one
verify("Fin8b", pass,tim=skip_rej) { check<decides> { y:type{3|4} = 3; y } }
  # Tim rejects this one too
verify("Fin10", fail,tim=skip_acc) { G(f(:int):type{3}) := { y := f[y] } }
  # Tim accepts this, but only because type{3} is a singleton type
verify("Fin11", fail,tim=skip_acc) { G(f(:int):type{3|4}) := { y := f[y] } }
verify("Fin12", pass, broken) { G( f(:int)<closed> := 1 ) := { y := f[y] } }

# Examples from Google doc "Verse: tricky cases"
verify("Tricky:T1", pass){ f(i:any)<succeeds>:int = { if((x:int,y:int)=i) then{ x+y } else{ 0 }}
                         ; f[(2,3)] }
verify("Tricky:L1", pass){ f():int := 0; y:any; int[y]; y=f[] }
verify("Tricky:L2", fail){ f():int := 0; y:any; y="monkey"; int[y]; y=f[] }
verify("Tricky:L3", fail,tim=V10){ x:int; y:int = x; y=x; x }
verify("Tricky:L3a", fail,tim=V10){ foo(x:any)<succeeds> := {int[x]; y:int = x; y=x; x} }
verify("Tricky:G1", fail,tim=skip_acc){ foo(x:int):int := x; y := foo[y] }

verify("Tricky:PC2", pass, broken){ f(x := 1, y:= 2):int := 7; exists x y { f(x, y); x+y } }
  # PC2: bidirectional programming and narrowing

verify("Ampersand1", pass){ f ( x&y : int ) := { x + y }; f[2,3]=5 }
verify("Ampersand2", pass){ f ( x&y : int, q:int ) := { (q, x + y) }; f[2,3,7]=(7,5) }
verify("Ampersand3", pass){ (x&y : int) := 4; x+y = 8 }
  # Ampersand3: Both x and are bound to 4,
  #             just like in Ampersand4
verify("Ampersand4", pass){ ((f&g)(:int,:int):int) => f[3,4] }

verify("Ampersand5", pass, broken)
    { a&b&c:int =>
      (f&g)(:int,:int):int =>
      h(:int):int =>
      x:=f[a,c] =>
      y:=g[b,c] =>
      f=g =>
      h[x]=h[y] }
  # Ampersand5: This rather complicated test comes from Tim's tests
  # It's not really about "&"; rather, it involves unification of functions
  # Actually, it seems to make the verifier loop, oddly.
