verify("T7",fail,tim=P00) {f(x:int):=x; f()}
verify("T8",fail) {f(x:int):=x+1; f()}
verify("T9",pass) {f(x:int):int=x}
verify("T10",pass) {f(x:int):int=x+1; f(1)}
verify("T11",fail) {f(x:int):int=x+1; f()}
