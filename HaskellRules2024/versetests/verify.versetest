# Effects
verify("Eff1",pass) {f(x:int)<succeeds>:int := x}
verify("Eff2",pass) {f(x:int)<decides>:int := x}

# Currying
verify("Curry1",pass){ f(x:int)(y:int):int := x+y }

# Opacity
verify("Opacity1", fail) { f(x:int := 3) := x=3 }
      # Opacity1: the fn body only knows that x:int

verify("Opacity2", pass) {f(x:int := 3)<decides> := x=3 }
      # Opacity2: fn body only knows that x:int, but we have <decides>

verify("Opacity3", fail) { f(x:int)<decides>:type{x=99999} := 100000 }
      # verify("Opacity3", fail) { f(x:int)<decides>:type{x=3} := x+1 }

verify("Opacity4", pass) { three(x:int)<decides> := x = 3; main() := y<succeeds>:three := 3 }
      # Opacity4: 'main' should verify despite three's<decides>, because 'three' is transparent

# if-then-else (negations)
verify("If1",pass) { f(:any) := { 2 = if (1) then {2} else {99} } }
verify("If2", pass) { f(:any) := { 2 = if (10=20) then {300} else {2} } }
verify("If3", pass) { f(:any) := { if (x:=1) then {x} else {2} } }
verify("If4", pass) { f(:any) := { if(a:=1|2){a=1} } }

# Recursion
verify("Rec0a",pass) { f(n:int):int := f[n] }
verify("Rec0b",pass) { f(n:int):int := f[n-1] }
verify("Rec0c",pass) { f(n:int):int := if (n=0) then {0} else {f[n+1]} }
verify("Rec1",pass) { sum(n:int):int := if (n < 1) then { 0 } else { n + sum(n-1) } }
verify("Rec2",pass) { sum(n:any):int := if (0 < n) then { n + sum(n-1) } else { 0 } }
verify("Rec3",pass) { sum(n:int):int := if (0 < n) then { n + sum(n-1) } else { n } }

### Higher-order functions
verify("HO1",pass) { f(g(z:int):int) := {g(3)} }
verify("HO2",fail) { f(g(z:int):int) := {g(())} }
verify("HO3",pass) { f(g(z:int):int):int := {g(3)} }
verify("HO4",fail) { f(g(z:int):int):int := {g(())} }
verify("HO5",pass) { suc(x:int) := {99}; ex6(h(z:int):int) := {3}; ex6(suc) }
verify("HO6",pass) { ex6(hog(z:int):int):int := {hog(3)}  }
verify("HO7",pass) { suc(x:int) := {x + 1}; ex6(h(z:int):int):int := {h(3)}; ex6(suc) }
verify("HO8",fail) { suc(x:int) := {(x, 1)}
                   ; ex6(h(z:int):int):int := {h(3)}
                   ; ex6(suc) }
verify("HO9",pass) { suc(x:int):int := {x + 1}; ex6(h(z:int):int):int := {h(3)}; ex6(suc) }
verify("HO10",fail) { suc(x:int):int := {x + 1}; ex6(h(z:int):int):int := {h((3, 3))}; ex6(suc) }
verify("HO11",fail) { ex6(h(z:int):int):int := {h()}; ex6((:int) => 1)}

## Koen's hof examples
verify("HO12a",pass) { gg(x:int) := 1;  foo(f(g(:int):int):int) := { f(gg) } } # gg returns a float for any int
verify("HO12b",pass) { gg(x:int) := 1;  foo(f(g(:int):int):int):int := { f(gg) } } # gg returns a float for any int
verify("HO12",pass) { gg(x:int) := 1;  foo(f(g(:int):int):string):string:= { f(gg) } } # gg returns a float for any int
verify("HO13",fail) { gg(x:nat) := 1;  foo(f(g(:int):int):int):int := { f(gg) } } # should be rejected because f may apply gg to an negative number
verify("HO14",pass) { gg(x:any) := 1;  foo(f(g(:int):int):int):int := { f(gg) } } # should be accepted
verify("HO15",fail) { gg(x:int) := (); foo(f(g(:int):int):int):int := { f(gg) } } # because f expects g to return an int, and it doesn't
verify("HO16",pass) { bar1(x:int):type{_(:int):char} := { (y:int) => {'m' } } }
verify("HO17",fail) { bar2(x:int):type{_(:int):char} := { (y:int) => { 3  } } } # REJECT the function returns an int not a string
verify("HO18",fail) { bar3(x:int):type{_(:int):char} := { (y:nat) => { 'a'} } } # REJECT the function only works on naturals but is supposed to work on ints
verify("HO19",pass) { bar4(x:int):type{_(:int):char} := { (y:any) => { 'a'} } } # ACCEPT the function works on more than ints

# Tim tests
# Simplification of Tim's    `test(S00){f(x:int):=x, a:any => a=f => a[_]=3}`
verify("Tim1", pass) { f(x:int) := x; foo(:any) := {f[_]=3} }
verify("Tim2", fail) { f(x:int) := x; foo(:any) := {f[_]='3'} }

# decides
verify("Dec1",pass) { three(x:any)<decides> := { x = 3 } }
verify("Dec2",pass) { three(x:any)<decides> := { x = 3 } ; foo(x:three):three := {x} }
verify("Dec3",pass) { three(x:any)<decides> := { x = 3 } ; foo(x:three):three := {3} }
verify("Dec4",fail) { three(x:any)<decides> := { x = 3 } ; foo(x:three):three := {4} }
verify("Dec5",pass) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := z }
verify("Dec6",pass) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 666 }
verify("Dec7",pass) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 42 }
verify("Dec8",pass) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 708 - z }
verify("Dec9",fail) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 10 }
verify("Dec10",fail) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 10 - z }

verify("Dec8a",pass) { foo(x:int)<decides> := { x = 666 } ; phil(z:foo) := (708 - z = 42) }

verify("Dec11",pass) { f(x:int)<decides> := 2 ; bar(y:int)<succeeds> := f[y] }
  # Dec11: bar verifies despite foo's <decides>

# Subtyping (passes, but apparently, should be rejected!)
verify("ST1", pass) { wombat3(x:int) := x; f3( g(:nat):int ) := g[4];  f3[wombat3] }  # Need to #asktim
verify("ST2", pass) { check<succeeds>{ x := x; x = 2 } }                              # Need to #asktim

# Wildcards "_"
verify("FunPair2", pass) { (a := (_,_)) => a=(_,_) }
verify("FunPair3", pass) { f(a := (_,_)) := a=(_,_) }
   # Lambda takes a pair, a, as its argument, and then checks that the argument is a pair and returns it

