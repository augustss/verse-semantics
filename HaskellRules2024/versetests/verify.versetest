# Trivial tests
verify("Trivial-pass", pass){1}
verify("plus1", pass){main() := { 1 + 2 = 3} }
verify("plus2", fail){main() := { 1 + 2 = 4} }
verify("Trivial-fail", fail){check<succeeds>{0=1}}

# Guard tests from https://docs.google.com/document/d/17Ytcy9I_fDzW-a1FGYQkLh3oObFg47Ge6GdRy-FZjLM/edit
verify("Guard1", pass ) { f():int := 0; L1() := {y:int;  y = f[] } }
verify("Guard2", fail)  { f():int := 0; L2() := {y:any; y='m'; int[y]; y=f() } }
verify("Guard3",fail)  { f():int := 0; L2() := {y:int; y='m';         y=f() } }
verify("Guard4",fail)  { f(x:int) := int[x]; PC1() := {z := 'm' ; f[z] } }
verify("Guard5",pass)  { suc(a:int) := 10 ; g(x:int) := suc[x] }
verify("Guard6",pass)  { suc(a:int):int := 10 ; g(x:int):int := suc[x] }
verify("Guard7",pass)  { suc(a:int):int := {a+1} }
verify("Guard8",pass)  { suc(a:int):int := {a+1} ; g(x:int):int := suc[x] }
verify("Guard9",pass)  { f():int := 0; L1() := {y:int;  y = f[] } }
