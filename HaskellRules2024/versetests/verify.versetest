# ------------------------------------------------------------
# Proofs as programs
verify("PP1", pass) { foo(a:int, b:int, pf:type{a=b}) := { a = b } }

# PP3a/b: to verify H's defn, we need to know X=1, so we need to
#         call G() to the left of that defn
verify("PP3a", fail, broken)
                     { F( X:int, G():type{X = 1} )
                              := (H()<succeeds> := X = 1; H()
                                 ; G() )    # Call G last!
                        ; F(2, G1() := G1()) }
  # PP3a illustrates the case where Tim will verify but we do not.

# PP3b: Tim's verifier loops
# It dependes delicately on whether we try to verify the arg G1():=G1()
#    (which makes the verifier loop) or whether we skolemise an impossible thing
verify("PP3b", pass, tim=skip_loop)
   { F( X:int, G():type{X = 1} )
          := (G();    # Call G first!
              H()<succeeds> := X = 1; H())
   ; F(2, G1() := G1()) }

verify(":type2", pass) {x:int => f():type{x=0} => {f[],x=0}}
verify(":type5", pass) {a:int => b:any => f(:int):type{a=b} => {f[a],a=b}}


verify("TimEq", pass) {a:int => b:int => f(a):type{a=b} => {f[a],a=b}}

# "Effective assumptions"   These ones fail becaues we invoke the lemma too late
verify("PP2", fail,tim=D00) { (x : int) => g(z:int where x=100):type{x=100} => {x = 100; g[0]} }
# :type1:,:type6,:type4 Tim succeeds
verify(":type1", fail,tim=skip_acc) {x:int => f():type{x=0} => {x=0;f[]}}
verify(":type6", fail,tim=skip_acc) {a:int => b:int => f(a   ):type{a=b} => {a=b,f[a]}}
verify(":type4", fail,tim=skip_acc) {a:int => b:any => f(:int):type{a=b} => {a=b,f[a]}}

verify("blame0", pass) { f2( g() := 3 ) := g[] = 3 }

