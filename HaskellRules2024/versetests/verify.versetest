# Some simple tests
verify("ReflInt1",pass) {foo(z:int) := { z = z } }
verify("ReflInt2",pass) {f(x:int):={x=x;x}}
verify("T1",pass) {foo(z:any) := { x:int = 1; int[x] } }
verify("T3",pass) {f(x:int):=x+1}
verify("T4",fail) {f(x:int):=x+()}
verify("T5",pass) {f(x:int):=x; f(1)}
verify("T6",pass) {f(x:int):=x+1; f(1)}
verify("T7",fail) {f(x:int):=x; f()}
verify("T8",fail) {f(x:int):=x+1; f()}
verify("T9",pass) {f(x:int):int=x}
verify("T10",pass) {f(x:int):int=x+1; f(1)}
verify("T11",fail) {f(x:int):int=x+1; f()}
verify("T12",pass) {f(x:int):int = x; a := f(1); int[a] }
verify("T13",pass) {f(x:int):int=x+1; f(1)+1}
verify("T14",fail) {f(x:int):int=x+1; f(1)+()}
verify("T15",pass) {f(x:int,y:int)<decides> := (x > 0) }
verify("T16",pass) {f(x:int,y:int) := if (x > 0) then { 1 } else { 2 } }
verify("T17",fail) { g(x : int, y : int) := {a := x; b := a; b = y} }

### # Times out with ICFP rules
verify("T18",fail,ICFPverify=skip) { g(x : int, y : int, z: int) := {a := x; b := a; b = y} }
verify("T19",pass,ICFPverify=skip) { g(x : int, y : int, z: int where x = y) := {a := x; b := a; b = y} }
verify("T20",fail,ICFPverify=skip) { g(x : int, y : int, z: int where x = z) := {a := x; b := a; b = y} }
verify("T21",pass,ICFPverify=skip) { g(x : int, y : int, z: int, pf:type{x = y}) := {a := x; b := a; b = y} }
verify("T22",fail,ICFPverify=skip) { goob(x : int, y : int, z: int, pf:type{x = z}) := {a := x; b := a; b = y} }
verify("T23",fail,ICFPverify=skip) { f(x : int, y : int, g(z:int where x=y):type{x=y}) := {x = y; g[0]} }

# Ported tests from TRSVerify.hs
verify("T24",pass) { g() := (2 = 2; 2) }
verify("T25",pass) { ex01(x:any) := x }
