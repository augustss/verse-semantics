# Ported tests from TRSVerify.hs
verify("T24",pass) { g() := (2 = 2; 2) }
verify("T25",pass) { ex01(x:any) := x }
verify("T26",pass) { g(x:int) := x }
verify("T27",pass) { g(x:int):int := x }
# tim=skip: T28: Tim does not accept
verify("T28",pass,tim=skip_rej) { g(x:any):int := { if (int[x]) then 10 else 20 } }
verify("T29",fail,tim=P00) { g(x:any):int := { if (int(x)) then 10 else 20 } }
verify("T30",pass) { suc(a:int):int := {a + 1} ; g(x:int):int := { suc(x) } }
# tim=skip: T31: Tim does not accept
verify("T31",pass,tim=skip_rej) { foo(x:any):int := if (int[x]) then { x } else { 0 } }
verify("T32",pass) { foo(x:any):int := if (int[x]) then { x + 1 } else { 0 } }
# tim=skip: T36: Tim does not accept
verify("T36",pass,tim=skip_rej) { ex5(x:any):int := if (int[x]) then { 10 } else { 20 } }

# Testing 'if'
verify("T37",pass) { ex_if0(b:any) := if (b) then { 3 }  else { 4 } }
# tim=skip: T38: Tim does not accept
verify("T38",pass,tim=skip_rej) { ex_if1(x:any) := { b:any; if (b) then { 3 }  else { 4 } } }
  # T38: assumes (any = \x.x)
verify("T39",pass) { ex_if2(x:int) := if (0 <= x) then { 1 } else { 2 } }

# Stuck tests
verify("T40",fail,tim=A00) { ex_stuck1(x:any) := { y:any; y } }
verify("T41",fail,tim=A00) { ex_stuck2(x:any) := { y:any; z:any; y = (x, (x, y)); y } }
verify("T42",fail,tim=A00) { ex_stuck3(x:any) := { y:any; if (y = 3) then { y = 3 } else { y = 4 } } }
verify("T43",pass) { f(x:int) := {y:any; if (x > 1) then { y = 1 } else { y = 2 }; y} }
verify("T44",fail,tim=A00) { f(x:int) := {y:any; if (y > 1) then { y = 1 } else { y = 2 }; y} }

# Shows that Unfold-If is UNSOUND; instead use `Fork-If`
verify("T45",fail,tim=V10) { foo(n:any):int := if (int[n]) then { 0 } else { (1,2) } }
verify("T46",fail,tim=V10) { foo(n:any):int := if (int[n]) then { n } else { (1,2) } }
verify("T47",fail,tim=V10) { foo(n:any):int := if (0 < n) then { n } else { n } }

# flex/rigid tests
verify("T48",pass) { ex_rigid2flex(x:int) := {y := x; y} }
verify("T49",fail,tim=D00) { ex_flex2rigid1(x:int) := {x = 3} }
verify("T50",pass) { ex_flex2rigid2(x:int where x=3) := { x = 3} }

# Disallow any to unify with int?
# T51, T52: tim=skip: any is not allowed to compare with 666
verify("T51",pass,tim=skip_any) { foo(x:any)<decides> := { x = 666 } }
verify("T52",pass,tim=skip_any) { foo(x:any)<decides> := { x = 666; x }; bar(z:foo):foo := {z} }
verify("T53",pass) {f(x:int)<succeeds>:=x/2}
verify("T54",fail) {f(x:int)<succeeds>:=x/0}
# T55: Tim bug
verify("T55",fail,tim=skip_acc) {f(x:int)(y:int):int := (x,y)}
verify("T56",pass) {x:int,x=3}


# Effects
verify("Eff1",pass) {f(x:int)<succeeds>:int := x}
verify("Eff2",pass) {f(x:int)<decides>:int := x}

# Currying
verify("Curry1",pass){ f(x:int)(y:int):int := x+y }

# Opacity
verify("Opacity1", fail,tim=D00) { f(x:int := 3) := x=3 }
      # Opacity1: the fn body only knows that x:int

verify("Opacity2", pass) {f(x:int := 3)<decides> := x=3 }
      # Opacity2: fn body only knows that x:int, but we have <decides>

# Opacity3: see T55
verify("Opacity3", fail,tim=skip_acc) { f(x:int)<decides>:type{x=99999} := 100000 }
      # verify("Opacity3", fail) { f(x:int)<decides>:type{x=3} := x+1 }

# Opacity4: Tim doesn't implement LHS y<succeeda>:three
verify("Opacity4", pass,tim=skip_acc) { three(x:int)<decides> := x = 3; main() := y<succeeds>:three := 3 }
      # Opacity4: 'main' should verify despite three's<decides>, because 'three' is transparent

# if-then-else (negations)
verify("If1",pass) { f(:any) := { 2 = if (1) then {2} else {99} } }
verify("If2", pass) { f(:any) := { 2 = if (10=20) then {300} else {2} } }
verify("If3", pass) { f(:any) := { if (x:=1) then {x} else {2} } }
verify("If4", pass) { f(:any) := { if(a:=1|2){a=1} } }

# Recursion
# Rec0a: Tim bug?
verify("Rec0a",pass,tim=skip_loop) { f(n:int):int := f[n] }
verify("Rec0b",pass) { f(n:int):int := f[n-1] }
verify("Rec0c",pass) { f(n:int):int := if (n=0) then {0} else {f[n+1]} }
verify("Rec1",pass) { sum(n:int):int := if (n < 1) then { 0 } else { n + sum(n-1) } }
verify("Rec2",pass) { sum(n:any):int := if (0 < n) then { n + sum(n-1) } else { 0 } }
verify("Rec3",pass) { sum(n:int):int := if (0 < n) then { n + sum(n-1) } else { n } }

### Higher-order functions
verify("HO1",pass) { f(g(z:int):int) := {g(3)} }
verify("HO2",fail,tim=P00) { f(g(z:int):int) := {g(())} }
verify("HO3",pass) { f(g(z:int):int):int := {g(3)} }
verify("HO4",fail,tim=P00) { f(g(z:int):int):int := {g(())} }
verify("HO5",pass) { suc(x:int) := {99}; ex6(h(z:int):int) := {3}; ex6(suc) }
verify("HO6",pass) { ex6(hog(z:int):int):int := {hog(3)}  }
verify("HO7",pass) { suc(x:int) := {x + 1}; ex6(h(z:int):int):int := {h(3)}; ex6(suc) }
# HO8: Tim bug?
verify("HO8",fail,tim=skip_acc) { suc(x:int) := {(x, 1)}
                   ; ex6(h(z:int):int):int := {h(3)}
                   ; ex6(suc) }
verify("HO9",pass) { suc(x:int):int := {x + 1}; ex6(h(z:int):int):int := {h(3)}; ex6(suc) }
verify("HO10",fail) { suc(x:int):int := {x + 1}; ex6(h(z:int):int):int := {h((3, 3))}; ex6(suc) }
verify("HO11",fail,tim=P00) { ex6(h(z:int):int):int := {h()}; ex6((:int) => 1)}

## Koen's hof examples
verify("HO12a",pass) { gg(x:int) := 1;  foo(f(g(:int):int):int) := { f(gg) } } # gg returns a float for any int
verify("HO12b",pass) { gg(x:int) := 1;  foo(f(g(:int):int):int):int := { f(gg) } } # gg returns a float for any int
verify("HO12",pass) { gg(x:int) := 1;  foo(f(g(:int):int):char):char:= { f(gg) } } # gg returns a float for any int
verify("HO13",fail,tim=P00) { gg(x:nat) := 1;  foo(f(g(:int):int):int):int := { f(gg) } } # should be rejected because f may apply gg to an negative number
verify("HO14",pass) { gg(x:any) := 1;  foo(f(g(:int):int):int):int := { f(gg) } } # should be accepted
verify("HO15",fail,tim=P00) { gg(x:int) := (); foo(f(g(:int):int):int):int := { f(gg) } } # because f expects g to return an int, and it doesn't
verify("HO16",pass) { bar1(x:int):type{_(:int):char} := { (y:int) => {'m' } } }
verify("HO17",fail,tim=V10) { bar2(x:int):type{_(:int):char} := { (y:int) => { 3  } } } # REJECT the function returns an int not a string
verify("HO18",fail,tim=V10) { bar3(x:int):type{_(:int):char} := { (y:nat) => { 'a'} } } # REJECT the function only works on naturals but is supposed to work on ints
verify("HO19",pass) { bar4(x:int):type{_(:int):char} := { (y:any) => { 'a'} } } # ACCEPT the function works on more than ints
verify("HO20", fail, broken) { function( foo(x:int):type{int[x]} )<succeeds> { z := "monkey" ; foo[z] } }


verify("HO20-suc",fail,tim=U00)
                    { inc(x:int):int := {x};
                      g( h(:int):char ) := { 0 };
                      main()<succeeds> := { g[ inc ] }
                    }
verify("HO20-dec",fail,tim=U00)
                    { inc(x:int):int := {x};
                      g( h(:int):char ) := { 0 };
                      main()<decides> := { g[ inc ] }
                    }
verify("FO20-suc", fail) { f(x:int):int := {x}; main() := { f[ 'm' ] } }
verify("FO20-dec", pass) { f(x:int):int := {x}; main()<decides> := { f[ 'm' ] } }

verify("circular", fail,tim=D00) { a:any => f(x:int):type{int[x]} => f[a] } #works because we "get lucky"


# Tim tests
# Simplification of Tim's    `test(S00){f(x:int):=x, a:any => a=f => a[_]=3}`
verify("Tim1", pass) { f(x:int) := x; foo(:any) := {f[_]=3} }
verify("Tim2", fail) { f(x:int) := x; foo(:any) := {f[_]='3'} }

# decides
# Dec1-Dec4: cannot compare any
verify("Dec1",pass,tim=skip_any) { three(x:any)<decides> := { x = 3 } }
verify("Dec2",pass,tim=skip_any) { three(x:any)<decides> := { x = 3 } ; foo(x:three):three := {x} }
verify("Dec3",pass,tim=skip_any) { three(x:any)<decides> := { x = 3 } ; foo(x:three):three := {3} }
verify("Dec4",fail,tim=skip_any) { three(x:any)<decides> := { x = 3 } ; foo(x:three):three := {4} }
# Dec5-Dec10: Tim bug?
verify("Dec5",pass,tim=skip_rej) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := z }
verify("Dec6",pass,tim=skip_rej) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 666 }
verify("Dec7",pass,tim=skip_rej) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 42 }
verify("Dec8",pass) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 708 - z }
verify("Dec9",fail,tim=V10) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 10 }
verify("Dec10",fail) { foo(x:int)<decides> := { (x = 666) | (x = 42) } ; phil(z:foo):foo := 10 - z }

verify("Dec8a",pass) { foo(x:int)<decides> := { x = 666 } ; phil(z:foo) := (708 - z = 42) }

verify("Dec11",pass) { f(x:int)<decides> := 2 ; bar(y:int)<succeeds> := f[y] }
  # Dec11: bar verifies despite foo's <decides>

# Subtyping (passes, but apparently, should be rejected!)
verify("ST1", pass) { wombat3(x:int) := x; f3( g(:nat):int ) := g[4];  f3[wombat3] }  # Need to #asktim
verify("ST2", pass) { check<succeeds>{ x := x; x = 2 } }                              # Need to #asktim

