# For results running with Tim's verifier, see
# https://docs.google.com/spreadsheets/d/13htHZ708wVow5NXENgF50E4nEPjqhgJAb17ZzjXy4D4/edit?usp=sharing

# Trivial tests
verify("Triv-pass", pass){1}
verify("plus1", pass){main() := { 1 + 2 = 3} }
verify("plus2", fail){main() := { 1 + 2 = 4} }
verify("Triv-fail", fail){check<succeeds>{0=1}}

# Guard tests from https://docs.google.com/document/d/17Ytcy9I_fDzW-a1FGYQkLh3oObFg47Ge6GdRy-FZjLM/edit
verify("Guard1", pass ) { f():int := 0; L1() := {y:int;  y = f[] } }
verify("Guard2", fail)  { f():int := 0; L2() := {y:any; y='m'; int[y]; y=f() } }
verify("Guard3",fail)  { f():int := 0; L2() := {y:int; y='m';         y=f() } }
verify("Guard4",fail)  { f(x:int) := int[x]; PC1() := {z := 'm' ; f[z] } }
verify("Guard5",pass)  { suc(a:int) := 10 ; g(x:int) := suc[x] }
verify("Guard6",pass)  { suc(a:int):int := 10 ; g(x:int):int := suc[x] }
verify("Guard7",pass)  { suc(a:int):int := {a+1} }
verify("Guard8",pass)  { suc(a:int):int := {a+1} ; g(x:int):int := suc[x] }
verify("Guard9",pass)  { f():int := 0; L1() := {y:int;  y = f[] } }
# tim=skip: Guard10: Tim accepts this
verify("Guard10",fail,tim=skip_acc) { f(x:int):int := x; y := f[y] }
  # Guard10: y=f[y] must be stuck.  Shows the need for a guard
verify("Guard11",pass) { f(x:int):int := 3; y := f[y] }
  # Guard11: y=f[y] is not stuck because f is transparent
# tim=skip: Guard11: Tim crashes
testeq("Guard11a",pass,tim=skip_crash) { f(x:int):int := 3; y := f["monkey"] } {fail}
  # Guard11a: Should fail, not get stuck; f["monkey"] fails the domain test

verify("Guard12",fail,tim=A00) { (f(x:int):int) => y := f[y] }
  # Guard12: like Guard10
# tim=skip: Tim accepts
verify("Guard13",fail,tim=skip_acc) { (f(x:int):type{3}) => y := f[y] }
  # Guard13: even though f guarantees to return 3, it may block on x
  #          (or loop) before returning anything, so y:=f[y] should fail

testeq("Narrowing1",pass) { for{ f(x:=(1|2)) := x+1; z:= f[y:int]; y+z } } { array{3,5} }
verify("Narrowing2",fail) { for{ f(x:=(1|2)) := x+1; f(y:int) } }
  # Narrowing2: gets stuck because f(y) succeeds in more than one way.

# Some simple tests
verify("ReflInt1",pass) {foo(z:int) := { z = z } }
verify("ReflInt2",pass) {f(x:int):={x=x;x}}
