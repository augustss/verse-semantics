# ------------------------------------------------------------
# Proofs as programs
verify("PP1", pass) { foo(a:int, b:int, pf:type{a=b}) := { a = b } }

# PP3a/b: to verify H's defn, we need to know X=1, so we need to
#         call G() to the left of that defn
verify("PP3a", fail, broken)
                     { F( X:int, G():type{X = 1} )
                              := (H()<succeeds> := X = 1; H()
                                 ; G() )    # Call G last!
                        ; F(2, G1() := G1()) }
verify("PP3b", pass) { F( X:int, G():type{X = 1} )
                              := (G();    # Call G first!
                                  H()<succeeds> := X = 1; H())
                        ; F(2, G1() := G1()) }

verify(":type2", pass) {x:int => f():type{x=0} => {f[],x=0}}
verify(":type5", pass) {a:int => b:any => f(:int):type{a=b} => {f[a],a=b}}


verify("TimEq", pass) {a:int => b:int => f(a):type{a=b} => {f[a],a=b}}

# "Effective assupmtions"   These ones fail becaues we invoke the lemma too late
verify("PP2", fail) { (x : int) => g(z:int where x=100):type{x=100} => {x = 100; g[0]} }
verify(":type1", fail) {x:int => f():type{x=0} => {x=0;f[]}}
verify(":type6", fail) {a:int => b:int => f(a   ):type{a=b} => {a=b,f[a]}}
verify(":type4", fail) {a:int => b:any => f(:int):type{a=b} => {a=b,f[a]}}

verify("blame0", pass) { f2( g() := 3 ) := g[] = 3 }

