def sumProd, sumProdLoop, x#3, s, p
in {sumProd = (x#1 => (def xs
                       in {x#1 = xs = array(int)[def _ in _];
                           tuple(int, int)[sumProdLoop(0, xs, (0, 1))]}));
    sumProdLoop = (x#2 => (def i, xs, sp, sum, prod
                           in {x#2 = (i = int[def _ in _], xs = array(int)[def _ in _],
                                      sp = (sum = int[def _ in _], prod = int[def _ in _]));
                               tuple(int, int)[if (x = xs[i])
                                               then sumProdLoop(operator'+'(i, 1), xs,
                                                                (operator'+'(x, sum),
                                                                 operator'*'(x, prod)))
                                               else sp]}));
    x#3 = sumProd(1, 2, 3, 4, 5);
    s = x#3[0];
    p = x#3[1];
    print(operator'+'(s, p))}
