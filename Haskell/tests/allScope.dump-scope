{5;
 def x
 in {x = any[def _ in _];
     x};
 def x, y
 in {x = any[def _ in _];
     y = any[def _ in _];
     x = y};
 def x, f
 in {x = any[def _ in _];
     f = any[def _ in _];
     f[x]};
 def x, f
 in {x = any[def _ in _];
     f = any[def _ in _];
     f(x)};
 {x => x};
 def x
 in {x = any[def _ in _];
     x | (def y
          in {y = any[def _ in _];
              y})};
 def x, y
 in {x = any[def _ in _];
     x, x, 2, y = any[def _ in _], y};
 {if (def x in x = 1)
  then (def y
        in {y = 2;
            operator'+'(x, y)})
  else 3};
 {for (def x in x = 1 | 2) operator'+'(x, 1)}}
