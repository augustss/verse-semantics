\newcommand{\semfcn}{\Value \rightharpoonup \Value}
\newcommand{\fcn}{\mathbf{fcn}}
\newcommand{\get}[1]{\mathbf{sing}(#1)}

\newcommand{\dtuple}{\tuple{\Value}}
\newcommand{\fmapsto}{\!\mapsto\!}
\newcommand{\mkfcn}[1]{[#1]}

\begin{figure}
$
\begin{array}{l}
\textbf{Domains (sets)} \\
\begin{array}{rcll}
\Value & = & \mathbb{Z} + (\semfcn) \\
\Env & = & |Ident| \rightarrow \Value \\
W^{*} & = & \text{set of } W \\
Env^{*} & = & \text{set of } Env \\
\end{array}
\\ \\


  \begin{array}{rcll}
%\multicolumn{4}{l}{\text{\bf Valuation semantics of a closed program}} \\
  \semapp{P}{|e|}{} & : & \Value + |Wrong| \\
  \semapp{P}{|e|}{} & = & \left\{
  \begin{array}{ll}
    w,       & \text{if} \{w\} = \semapp{D}{|e|}{\rho_0} \\
    |Wrong|, & \text{otherwise}
  \end{array}
  \right.
\\ \\

%\multicolumn{4}{l}{\text{\bf Valuation semantics of an expression}} \\
  \semapp{E}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{E}{|x|}{\rho} & = & \msing{\rho(x)} \\
  \semapp{E}{|k|}{\rho} & = & \msing{k} \\
  \semapp{E}{|o|}{\rho} & = & \semapp{O}{|o|}{} \\
  \semapp{E}{|apply1N e_1 e_2|}{\rho} & = & %% \apply(\semapp{E}{|e_1|}{\rho}, \; \semapp{E}{|e_2|}{\rho}) \\
    \{ r \, || \, f \inb \semapp{E}{|e_1|}{\rho}, \; a \inb \semapp{E}{|e_2|}{\rho}, \; r \inb \apply(f, a) \} \\
  \semapp{E}{|e_1 = e_2|}{\rho}      & = & \semapp{E}{|e_1|}{\rho} \; \cap \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|e_1 ; e_2|}{\rho}      & = & %% \semapp{E}{|e_1|}{\rho} \; \msemi      \; \semapp{E}{|e_2|}{\rho} \\
    \{ y \, || \, x \inb \semapp{E}{|e_1|}{\rho}, \; y \inb \semapp{E}{|e_2|}{\rho} \} \\
  \semapp{E}{|x := e|}{\rho} & = & \msing{\rho(x)} \;\cap\; \semapp{E}{e}{\rho} \\
  \semapp{E}{|:e|}{\rho} & = & %% \ran(\semapp{E}{|e|}{\rho}) \\
    \{ r \, || \, f \inb \semapp{E}{|e|}{\rho}, \; a \inb \Value, \; r \inb \apply(f, a) \} \\
%FAIL  \semapp{E}{|fail|}{\rho} & = & \emptyset \\
  \semapp{E}{|vif e_1 e_2 e_3|}{\rho} & = &
  \left\{
  \begin{array}{ll}
    \semapp{D}{|e_3|}{\rho} & \text{if}\; \bar{\rho} = \emptyset \\
    \bigcup_{\rho' \dot{\in} \bar{\rho}} \semapp{D}{|e_2|}{\rho'} & \text{otherwise} \\
  \end{array}
  \right. \\
  & &  |where|\; \bar{\rho} = \semappp{C}{e_1}{\rho} \\
  \semapp{E}{|arr (e_0, xdots, e_n)|}{\rho} & = &
    \{ \mkfcn{0 \fmapsto x_0, \mydots, n \fmapsto x_n} \, || \, x_0 \inb \semapp{E}{|e_1|}{\rho}, \,\mydots,\, x_n \inb \semapp{E}{|e_n|}{\rho} \} \\
  \semapp{E}{|funk q e_1 e_2|}{\rho} & = & \{ f \;
    \begin{array}[t]{ll}
      || & f \inb \semfcn \\

      % Simon's version
      , & \forall x \in \Value.  \forall \rho' \in \semapp{X}{e_1}{\rho}. \\
        & \hspace{1em} (\semappp{M}{e_1}{x}{\rho'} \neq \emptyset) \\
        & \hspace{1em} \implies x \in \dom(f) \land f(x) \in \semapp{D}{e_2}{\rho'}  \\
      , & q=|closed| \implies \forall x \inb \dom(f). \\
      & \hspace{0.5em} \exists \rho' \in \semapp{X}{e}{\rho}.\, \semappp{M}{e_1}{x}{\rho'} \neq \emptyset \\

%%      \forall x \inb \Value. \\
%%      |let|\; \bar{\rho} = \semappp{B}{e_1}{x}{\rho}, \\
%%      |if|\; \bar{\rho} = \emptyset\; |then|\; (x \not\in \dom(f)) \lor (q == |open|) \\
%%      |else|\; x \in \dom(f) \land \forall \rho' \inb \bar{\rho}. f(x) \in \semapp{D}{e_2}{\rho'}

    \end{array} \\
    & & \} \\
    \\ 

    %\multicolumn{4}{l}{\text{\bf Valuation semantics of a scoped expression}} \\
  \semapp{X}{|e|} & : & \Env \rightarrow \Env^{*} \\
  \semapp{X}{e}{\rho} & = & \{ \extendrho{\rho}{x_1 \fmapsto w_1, \mydots, x_n \fmapsto w_n } \; || \;   w_1 \inb \Value, \mydots, w_n \inb \Value \} \\
  & & |where [x_1,xdots,x_n]| = \semapp{I}{|e|} \\[1mm]

  \semapp{C}{|e|} & : & \Env \rightarrow \Env^{*} \\
  \semappp{C}{|e|}{\rho} & = &
  \{ \rho' \; ||  \; \rho' \inb \semapp{X}{e}{\rho},  \emptyset \neq \semappp{E}{e}{\rho'} \} \\[1mm]

  \semapp{D}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{D}{|e|}{\rho} & = & \{ r \; || \; \rho' \inb \semapp{X}{e}{\rho}, r \inb \semapp{E}{|e|}{\rho'} \} \\

%\multicolumn{4}{l}{\text{\bf Alternative valuation semantics}} \\
%\semapp{E}{|e|}{\rho} & = & \semappp{M}{|e|}{\Value}{\rho}

  \end{array} \\ \\

\textbf{Alternative definition of } \semapp{E}{} \\
\begin{array}{rcll}
\semapp{E}{|e|}{\rho} & = & \bigcup_{u \inb \Value}\semapp{M}{|e|}{u}{\rho} \\
\end{array} \\

\end{array}
$
\caption{Expression semantics}
\label{fig:den-sem1}
\end{figure}

\begin{figure}
$
\begin{array}{l}

\text{\bf Match semantics} \\
\\
  \begin{array}{rcll}
%\multicolumn{4}{l}{\text{\bf Match semantics of a scoped expression}} \\
  \semapp{B}{|e|} & : & \Value \rightarrow \Env \rightarrow \Env^{*} \\
  \semappp{B}{|e|}{u}{\rho} & = &
  \{ \rho' \; || \; \rho' \inb \semapp{X}{e}{\rho}, \emptyset \neq \semappp{M}{e}{u}{\rho'} \} \\
\\

  \semapp{L}{|e|}{} & : & \Value \rightarrow \Env \rightarrow \mtype \\
  \semappp{L}{|e|}{u}{\rho} & = & \{ r \; || \; \rho' \inb \semapp{X}{e}{\rho}, r \inb \semapp{M}{|e|}{u}{\rho'} \} \\
\\
%\multicolumn{4}{l}{\text{\bf Match semantics of an expression}} \\
  \semapp{M}{|e|} & : & \Value \rightarrow \Env \rightarrow \mtype \\
  \semappp{M}{|x|}{u}{\rho} & = & \msing{\rho(x)} \cap \msing{u} \\
  \semappp{M}{|k|}{u}{\rho} & = & \msing{k} \cap \msing{u} \\
  \semappp{M}{|o|}{u}{\rho} & = & \semapp{O}{|o|}{} \cap \msing{u} \\
  \semappp{M}{|apply1N e_1 e_2|}{u}{\rho} & = &
    \{ r \, || \, f \inb \semapp{E}{|e_1|}{\rho}, \; a \inb \semapp{E}{|e_2|}{\rho}, \; r \inb \apply(f, a) \} \cap \msing{u} \\
  \semappp{M}{|e_1 = e_2|}{u}{\rho}      & = & \semappp{M}{|e_1|}{u}{\rho} \; \cap \; \semappp{M}{|e_2|}{u}{\rho} \\
  \semappp{M}{|e_1 ; e_2|}{u}{\rho}      & = &
    \{ y \, || \, x \inb \semapp{E}{|e_1|}{\rho}, \; y \inb \semappp{M}{|e_2|}{u}{\rho}) \} \\
  \semappp{M}{|x := e|}{u}{\rho} & = & \msing{\rho(x)} \;\cap\; \semappp{M}{e}{u}{\rho} \\
  \semappp{M}{|:e|}{u}{\rho} & = &
    \{ r \, || \, f \inb \semapp{E}{|e|}{\rho}, \; r \inb \apply(f, u) \} \\
%FAIL  \semappp{M}{|fail|}{u}{\rho} & = & \emptyset \\
  \semappp{M}{|vif e_1 e_2 e_3|}{u}{\rho} & = &
  \left\{
  \begin{array}{ll}
    \semapp{L}{|e_3|}{u}{\rho} & \text{if}\; \bar{\rho} = \emptyset \\
    \bigcup_{\rho' \dot{\in} \bar{\rho}} \semapp{L}{|e_2|}{u}{\rho'} & \text{otherwise} \\
  \end{array}
  \right. \\
  & &  |where|\; \bar{\rho} = \semappp{C}{e_1}{\rho} \\
  \semappp{M}{|arr (e_0, xdots e_n)|}{u}{\rho} & = &
  \{ \mkfcn{0 \fmapsto w_0,\mydots, n \fmapsto w_n} \, || \, u \in \semfcn, \, \dom(u) = \{0,\mydots,n\}, \\
  & & \hspace{0.5em} w_0 \inb \semappp{M}{|e_1|}{(u(0))}{\rho}, \,\mydots,\, w_n \inb \semappp{M}{e_n}{(u(n))}{\rho} \} \\
  \semappp{M}{|funk q e_1 e_2|}{g}{\rho} & = & \{ f \; ||
    \begin{array}[t]{l}
      f \inb \semfcn, \\
      g \in \semfcn, \\
      \forall x \inb \Value. \\
      |let|\; \bar{\rho} = \semappp{B}{e_1}{x}{\rho}, \\
      |if|\; \bar{\rho} = \emptyset\; |then|\; (x \not\in \dom(f)) \lor (q == |open|) \\
      |else|\; x \in \dom(f) \land \\
      \hspace{2em} \forall \rho' \inb \bar{\rho}. \\
      \hspace{3em} \forall x' \inb \semappp{M}{e_1}{x}{\rho'}.\, \\
      \hspace{4em} x' \in \dom(g) \land \\
      \hspace{4em} f(x) \in \semappp{L}{e_2}{(g(x'))}{\rho'}
    \end{array} \\
    & & \} \\

  \multicolumn{1}{l}{\text{\bf SPJ version}} \\
  \semappp{M}{|funk q e_1 e_2|}{g}{\rho} & = & \{ f \; ||
    \begin{array}[t]{l}
      f \inb \semfcn, \\
      g \in \semfcn,  \\
      \forall x \in \Value, \rho' \in \semapp{X}{e_1}{\rho}. \\
      \forall y \in \semapp{M}{e_1}{x}{\rho'}.  \\
      y \in \dom(g) \implies f(x) \in \semapp{L}{e_2}{g(y)}{\rho'} \}
    \end{array}
\\
    
  \end{array} \\ \\
  

\end{array}
$
\caption{Expression match semantics}
