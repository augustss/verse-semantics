\section{A denotational semantics}

\newcommand{\sconcat}{\bowtie}
\newcommand{\shead}{\mathit{head}}
\newcommand{\stuple}{\mathit{tuple}}
\newcommand{\scons}{:}

\newcommand{\semfcn}{\Value \rightharpoonup \Value}
\newcommand{\fcn}{\mathbf{fcn}}
\newcommand{\get}[1]{\mathbf{sing}(#1)}

\begin{figure}
$
\begin{array}{l}
\text{\bf Domains} \\
\begin{array}{rcll}
\Value & = & \mathbb{Z} + \tuple{\Value,\Value} + (\semfcn) \\
%% \tuple{\Value} & = & \text{a finite tuple of values $\Value$} \\
\Env & = & |Ident| \rightarrow \Value \\
T^{*} & = & \text{set of } T \\
\end{array}
\\ \\


  \begin{array}{rcll}
\multicolumn{4}{l}{\text{\bf Valuation semantics of a closed program}} \\
  \semapp{P}{|e|}{} & : & \Value + |Wrong| \\
  \semapp{P}{|e|}{} & = & \left\{
  \begin{array}{ll}
    w,       & \text{if} \{w\} = \semapp{S}{|e|}{\rho_0} \\
    |Wrong|, & \text{otherwise}
  \end{array}
  \right.
\\ \\

\multicolumn{4}{l}{\text{\bf Valuation semantics of a scoped expression}} \\
  \semapp{S}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{S}{|e|}{\rho} & = &
  \{ \semapp{E}{|e|}{(\extendrho{\rho}{x_1 \mapsto w_1, \mydots, x_n \mapsto w_n})}\, ||  \,
          w_1 \in \Value, \mydots, w_n \in \Value \} \\
  & & \text{where} |[x_1,xdots,x_n]| = \semapp{I}{|e|} \\
\\
\multicolumn{4}{l}{\text{\bf Valuation semantics of an expression}} \\
  \semapp{E}{|e|}{} & : & \Env \rightarrow \mtype \\
  \semapp{E}{|x|}{\rho} & = & \msing{\rho(x)} \\
  \semapp{E}{|k|}{\rho} & = & \msing{k} \\
  \semapp{E}{|o|}{\rho} & = & \semapp{O}{|o|}{} \\
  \semapp{E}{|apply1N e_1 e_2|}{\rho} & = & %% \apply(\semapp{E}{|e_1|}{\rho}, \; \semapp{E}{|e_2|}{\rho}) \\
    \{ r \, || \, f \in \semapp{E}{|e_1|}{\rho}, \; a \in \semapp{E}{|e_2|}{\rho}, \; r \in \apply(f, a) \} \\
  \semapp{E}{|e_1 = e_2|}{\rho}      & = & \semapp{E}{|e_1|}{\rho} \; \cap \; \semapp{E}{|e_2|}{\rho} \\
  \semapp{E}{|e_1 ; e_2|}{\rho}      & = & %% \semapp{E}{|e_1|}{\rho} \; \msemi      \; \semapp{E}{|e_2|}{\rho} \\
    \{ y \, || \, x \in \semapp{E}{|e_1|}{\rho}, \; y \in \semapp{E}{|e_2|}{\rho}) \} \\
  \semapp{E}{|x := e|}{\rho} & = & \msing{\rho(x)} \;\cap\; \semapp{E}{e}{\rho} \\
  \semapp{E}{|:e|}{\rho} & = & %% \ran(\semapp{E}{|e|}{\rho}) \\
    \{ r \, || \, f \in \semapp{E}{|e|}{\rho}, \; a \in \Value, \; r \in \apply(f, a) \} \\
  \semapp{E}{|fail|}{\rho} & = & \emptyset \\
  \semapp{E}{|arr (e_1, e_2)|}{\rho} & = &
    \{ \tuple{x,y} \, || \, x \in \semapp{E}{|e_1|}{\rho}, \; y \in \semapp{E}{|e_2|}{\rho}) \} \\
  \semapp{E}{|funk c e_1 e_2|}{\rho} & = & \{ f \; ||
    \begin{array}[t]{l}
      f \in \semfcn, 
      \forall x \in \Value. \\
      |let|\; \bar{\rho} = \semappp{B}{e_1}{\msing{x}}{\rho}, \\
      |if|\; \bar{\rho} = \emptyset\; |then|\; x \not\in \dom(f) \\
      |else|\; x \in \dom(f) \land \forall \rho' \in \bar{\rho}. f(x) \in \semapp{S}{e_2}{\rho'}
    \end{array} \\
    & & \} \\
  \semapp{E}{|funk o e_1 e_2|}{\rho} & = & \{ f \; ||
    \begin{array}[t]{l}
      f \in \semfcn, 
      \forall x \in \Value. \\
      |let|\; \bar{\rho} = \semappp{B}{e_1}{\msing{x}}{\rho}, \\
      |if|\; \bar{\rho} = \emptyset\; |then|\; \textbf{T} \\
      |else|\; x \in \dom(f) \land \forall \rho' \in \bar{\rho}. f(x) \in \semapp{S}{e_2}{\rho'}
    \end{array} \\
    & & \} \\

  \end{array} \\ \\
    
  \begin{array}{rcll}
  \semapp{O}{|op|}{} & : & (\semfcn)^{*} \\
  \semapp{O}{|gt|}{} & = & \{ \fcn \{ (\tuple{x,y},x) \, || \, x \in \mathbb{Z}, y \in \mathbb{Z}, x > y \} \} & \text{one function} \\
  \semapp{O}{|int|}{} & = & \{ \fcn \{ (x,x) \, || \, x \in \mathbb{Z} \} \} & \text{one function} \\
  \semapp{O}{|add|}{} & = & \{ f \, || \, f \in \semfcn, \; \forall x,y \in \mathbb{Z}.f(\tuple{x,y})=x+y \} & \text{many functions} \\
  \end{array} \\ \\
  
\end{array}
$
\caption{Expression semantics}
\label{fig:den-sem1}
\end{figure}

\begin{figure}
$
\begin{array}{l}

\text{\bf Match semantics} \\
\\
  \begin{array}{rcll}
%\multicolumn{4}{l}{\text{\bf Match semantics of a scoped expression}} \\
  \semapp{B}{|e|} & : & \mtype \rightarrow \Env \rightarrow \Env^{*} \\
  \semappp{B}{|e|}{u}{\rho} & = &
  \{ \rho' \; || 
  \begin{array}[t]{l}
  w_1 \in \Value, \mydots, w_n \in \Value, \\
  |let|\; \rho' = \extendrho{\rho}{x_1 \mapsto w_1, \mydots, x_n \mapsto w_n}, \\
  \emptyset \neq \semappp{M}{e}{u}{\rho'} \\
  \end{array} \\
  & &  \} \; \text{where} |[x_1,xdots,x_n]| = \semapp{I}{|e|} \\
\\
    
  \semapp{N}{|e|}{} & : & \mtype \rightarrow \Env \rightarrow \mtype \\
  \semappp{N}{|e|}{u}{\rho} & = &
  \{ \semapp{M}{|e|}{u}{(\extendrho{\rho}{x_1 \mapsto w_1, \mydots, x_n \mapsto w_n})}\, ||  \,
          w_1 \in \Value, \mydots, w_n \in \Value \} \\
  & & \text{where} |[x_1,xdots,x_n]| = \semapp{I}{|e|} \\
\\
%\multicolumn{4}{l}{\text{\bf Match semantics of an expression}} \\
  \semapp{M}{|e|} & : & \mtype \rightarrow \Env \rightarrow \mtype \\
  \semappp{M}{|x|}{u}{\rho} & = & \msing{\rho(x)} \cap u \\
  \semappp{M}{|k|}{u}{\rho} & = & \msing{k} \cap u \\
  \semappp{M}{|o|}{u}{\rho} & = & \semapp{O}{|o|}{} \cap u \\
  \semappp{M}{|apply1N e_1 e_2|}{u}{\rho} & = & %% \apply(\semappp{M}{|e_1|}{\rho}, \; \semappp{M}{|e_2|}{\rho}) \\
    \{ r \, || \, f \in \semapp{E}{|e_1|}{\rho}, \; a \in \semapp{E}{|e_2|}{\rho}, \; r \in \apply(f, a) \} \cap u \\
  \semappp{M}{|e_1 = e_2|}{u}{\rho}      & = & \semappp{M}{|e_1|}{u}{\rho} \; \cap \; \semappp{M}{|e_2|}{u}{\rho} \\
  \semappp{M}{|e_1 ; e_2|}{u}{\rho}      & = & %% \semappp{M}{|e_1|}{\rho} \; \msemi      \; \semappp{M}{|e_2|}{\rho} \\
    \{ y \, || \, x \in \semapp{E}{|e_1|}{\rho}, \; y \in \semappp{M}{|e_2|}{u}{\rho}) \} \\
  \semappp{M}{|x := e|}{u}{\rho} & = & \msing{\rho(x)} \;\cap\; \semappp{M}{e}{u}{\rho} \\
  \semappp{M}{|:e|}{u}{\rho} & = & %% \ran(\semappp{M}{|e|}{\rho}) \\
    \{ r \, || \, f \in \semapp{E}{|e|}{\rho}, \; a \in u, \; r \in \apply(f, a) \} \\
  \semappp{M}{|fail|}{u}{\rho} & = & \emptyset \\
  \semappp{M}{|arr (e_1, e_2)|}{u}{\rho} & = &
    \{ \tuple{x,y} \, || \, \tuple{u_1,u_2} \in u, \; x \in \semappp{M}{|e_1|}{u_1}{\rho}, \; y \in \semappp{M}{e_2}{u_2}{\rho}) \} \\
  %% \semappp{M}{|funk c e_1 e_2|}{u}{\rho} & = & TBD \\
  \semappp{M}{|funk c e_1 e_2|}{u}{\rho} & = & \{ f \; ||
    \begin{array}[t]{l}
      g \in u, g \in \semfcn, \\
      f \in \semfcn, \\
      \forall x \in \Value. \\
      |let|\; \bar{\rho} = \semappp{B}{e_1}{\msing{x}}{\rho}, \\
      |if|\; \bar{\rho} = \emptyset\; |then|\; x \not\in \dom(f) \\
      |else|\; x \in \dom(f) \land \forall \rho' \in \bar{\rho}. \\
      \hspace{2em} \forall x' \in \semappp{M}{e_1}{x}{\rho'},\, \\
      \hspace{2em} x' \in \dom(g) \land \\
      \hspace{2em} f(x) \in \semappp{N}{e_2}{\msing{g(x')}}{\rho'}
    \end{array} \\
    & & \} \\
  \semappp{M}{|funk o e_1 e_2|}{u}{\rho} & = & TBD \\
\\
    
  \end{array} \\ \\
  

\end{array}
$
\caption{Expression match semantics}
\label{fig:den-sem2}
\end{figure}

\begin{figure}
$
\begin{array}{l}
\text{\bf Utility functions} \\

\text{\bf Defined identifiers} \\
  \begin{array}{rcll}
  \semapp{I}{|e|}{} & : & |[Ident]| \\
  \semapp{I}{|apply1N e_1 e_2|}{} & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|e_1 = e_2|}{}       & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|e_1 ; e_2|}{}       & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|x := e|}{}          & = & |[x]| <> \semapp{I}{|e|}{} \\
  \semapp{I}{|:e|}{}              & = & \semapp{I}{|e|}{} \\
  \semapp{I}{|arr (e_1, e_2)|}{}  & = & \semapp{I}{|e_1|}{} |<>| \semapp{I}{|e_2|}{} \\
  \semapp{I}{|e|}                 & = & |[]| & \text{otherwise} \\
