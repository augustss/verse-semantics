\newcommand{\figureSyntaxPOPL}{
\begin{figure}[t]

$$
\begin{array}{l}
  \textbf{Abstract syntax} \\
    \begin{array}{lr@@{\;}c@@{\;}l}
    \textit{Integers}      & k \\
    \textit{Variables}     & \multicolumn{3}{l}{x,y,z,f,g} \\
    \textit{Primops}       & \op   & ::= & |gt| \vb |add| \\
    \textit{Scalar Values} & s     & ::= & k \vb x \\
    \textit{Heap Values}   & h     & ::= & \op \vb |arr (s_1, dots, s_n)| \vb |lam x e| \\
    \textit{Head Values}   & \hnf  & ::= & h \vb k \\
    \textit{Values}        & |v|   & ::= & s \vb h \\
    \textit{Expressions}   & e     & ::= & |fail| \vb |v| \vb |def x e| \vb |e_1 ; e_2| \vb |v == e|
                                             \vb |e_1 choice e_2| \vb |apply1N v_1 v_2| \vb |one e| \vb |all e| \\
    \textit{Programs}      & p     & ::= & |one e| \quad \text{where} \; \freevars{e} = \emptyset \\
    % \textit{Results}       & r     & ::= & |v| \vb |x == h ; r| \vb |def x r| \\
    % \textit{Results}       & r     & ::= & |def (x_1 ^^ dots ^^ x_n) (x_1 == h_1 ; dots ; x_n == h_n; v) | \\
    \textit{Bindings}       & c     & ::= & |x = v| \\
\end{array} \\
\\[-3mm]
\textbf{Concrete syntax:} \;\;
    \begin{array}[t]{l}
          \text{``|choice|'', ``;'', and ``|=|'' are right-associative.} \\
          \text{``|=|'' binds more tightly than ``;''.} \\
          \text{``$\lambda$'', ``|defKW|'' scope as far to the right as possible.} \\
          \hspace{2mm} \text{{\eg}, |(lam y (def x (x=1; x+y)))| means |(lam y ((def x (((x=1); (x+y))))))|.}
    \end{array} \\
\textbf{Desugaring} \\
    \begin{array}{rcll}
%%      |emptytup| & \text{means} & |arr ()|\\
%%      |tup (v_1, dots, v_n)| & \text{means} & |arr (v_1,dots, v_n)| \quad n \geq 2 \\
      v_1 + v_2 & \text{means} & |applyN add ( v_1, v_2 ) | & \\
      v_1 > v_2 & \text{means} & |applyN gt ( v_1, v_2 ) | & \\
      |apply1N e_1 e_2| & \text{means} & |def (f a) (f == e_1 ; a == e2; apply1N f a)|  & |f,a|\ \text{fresh} \\
      |tup (e_1, dots, e_n)| & \text{means} &
          |def (x_1 ^^ x_2 dots x_n) (x_1=e_1; dots; x_n=e_n; tup (x_1,dots, x_n)| & \text{|x_i| fresh} \\
      |e_1 == e_2|      & \text{means} & |def x (x == e_1 ; x == e_2)|       & |x|\ \text{fresh} \\
      |def (x_1 ^^ x_2 dots x_n) e| & \text{means} & |def x_1 (def x_2 (dots ^ def x_n e))| & \\

      |if e_1 then e_2 else e_3| & \text{means}
      & |def v (v == one( (e_1; thunk e_2) choice (thunk e_3)); apply0 v)| & \text{|v,x| fresh} \\
%       |for^(e_1) do e_2| & \text{means} & |def v (v == all (e_1; thunk e_2); applyN map (lam z (apply0 z), v))|
     \end{array} \\
  \\[-2mm]
  \text{$\freevars{e}$ means the free variable of $e$; in \versecalc{}, $\lambda$ and |defKW| are the only binders.}
  %\text{$S_1 \disjoint S_2$ means that set $S_1$ is disjoint from $S_2$.}
  \end{array}
$$
\caption{\textbf{The Verse Calculus: Syntax}}
\label{fig:syntax}
\end{figure}
