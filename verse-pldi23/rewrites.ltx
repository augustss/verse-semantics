\newcommand{\figureRewriteRules}{
\begin{figure}
$$\begin{array}{lr@@{\;}c@@{\;}l}
\textit{Expression context}     & E  & ::= & \hole \vb |tup (s_1, dots , hole , dots, s_n)| \vb |lam x E| \vb |def x E| 
                                              \vb |E == e| \vb |e == E| \\
                                &    & \vb & |E ; e| \vb |e ; E| \vb |apply1N E v| \vb |apply1N v E|
                                       \vb |E choice e| \vb |e choice E| \vb |all E| \vb |one E| \\
\textit{Application context}    & A  & ::= & |apply1N hole v| \vb |apply1N op hole| \vb |hole == hnf| \vb |v == A| \vb |def x A| \vb |A ; e| \vb |e ; A| \\
                                &    & \vb & |A choice e| \vb |e choice A| \vb |all A| \vb |one A| \\
\textit{Scope context}          & SX & ::= & |hole choice e| \vb |e choice hole| \vb |one hole| \vb |all hole| \\
\textit{Choice context}         & CX & ::= & \hole \vb |v == CX| \vb |CX; e| \vb |ce ; CX|  \vb |def x CX| \\
\textit{Choice-free expr}      & ce & ::= & |v| \vb |v == ce| \vb |ce_1 ; ce_2| \vb |one e| \vb |all e|
                                             %%% NOTE: the following is not in the POPL submission,
                                             %%% but needed to make progress in (1,2)[x:int]
                                             \vb |apply1 op v|
                                             \vb |def x ce| \\
\textit{Bound variables} & \multicolumn{3}{l}{
  \boundvars{E} =
  \begin{array}[t]{l}
      \text{The variables that are bound by |E| at the hole} \\
      \text{e.g. $\boundvars{|(def x (x=3)) `choice` (def y (hole = 4)))|} = \{y\}$}
  \end{array}
   }
\end{array}$$
\begin{longtable}[l]{@@{\quad} l @@{\hspace{-.5em}} r >{$}c<{$} l l}
\rulegroupname{Unification:~\runi}
\rulename{deref-s}  & |x == s ;  E^[x]| & \movesto & |x == s ; E^[s]| & $x \not \equiv s$; $x,s \not\in \boundvars{|E|}$ \\
\rulename{deref-h}  & |x == h ;  A^[x]| & \movesto & |x == h ; A^[h]| & $x,\freevars{h} \not\in \boundvars{A}$\\
\rulename{u-lit}    & |k == k |                                    & \movesto & k \\
\rulename{u-tup}    & |tup (v_1,dots,v_n) == tup (v1',dots,v_n')| & \movesto & {|v_1==v1';dots;v_n==v_n'|} \\
\rulename{u-fail-t} & |tup (v_1,dots,v_n) == tup (v1',dots,v_m')| & \movesto & |fail|& if $n \not = m$ \\
\rulename{u-fail-l}   & |k_1 == k_2  |     & \movesto & |fail| & if $k_1 \not = k_2$ \\
\rulename{u-fail-l-h} & |k == h | & \movesto & |fail| \\
\rulename{u-fail-t-f} & |tup (dots) == lam y e |   & \movesto & |fail| & \\
\rulename{u-fail-f} & |lam x_1 e_1 == lam x_2 e_2 |   & \movesto & |fail| &
\end{longtable}
\begin{longtable}[l]{@@{\quad} l @@{\hspace{-.5em}} r >{$}c<{$} l l}
\rulegroupname{Application:~\rapp}
\rulename{app-beta} & |apply1N (lam x e) v| & \movesto & |def x (x=v; e)|  & if $|x| \not \in \freevars{|v|}$ \\
\rulename{app-tup}  & |apply1N (tup (s_0 dots s_n)) v| & \movesto
	& |def x (x == v; (x = 0; s_0 choice dots choice x = n; s_n)| & if $|x| \not \in \freevars{|v|}$ \\
\rulename{app-add}  & |applyN add (k_1 ,k_2)| & \movesto & |k_1+k_2| \\
\rulename{app-gt}      & |applyN gt (k_1,k_2)|   & \movesto & |k_1| &  \text{if $k_1 > k_2$} \\
\rulename{app-gt-fail} & |applyN gt (k_1,k_2)|   & \movesto & |fail| &  \text{if $k_1 \leq k_2$}
\end{longtable}
\begin{longtable}[l]{@@{\quad} l @@{\hspace{-.5em}} r >{$}c<{$} l l}
\rulegroupname{Speculation:~\rspc}
\rulename{choose}     & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & if $|CX| \ne \hole$ \\
\rulename{choose-assoc} & |SX^[(e_1 choice e_2) choice e_3]| & \movesto & |SX^[e_1 choice (e_2 choice e_3)]| \\
\rulename{choose-r}   & |SX^[fail choice e]|       & \movesto & |SX^[e]| \\
\rulename{choose-l}   & |SX^[e choice fail]|       & \movesto & |SX^[e]| \\
\rulename{one-fail}   & |one fail|           & \movesto & |fail| \\
\rulename{one-choice} & |one (e_1 `choice` e_2)| & \movesto & |e_1| & if \wff{\emptyset}{|e_1|}{|xs|}{|cs|}{|v|} \\
\rulename{one-value}  & |one e|              & \movesto & |e| & if \wff{\emptyset}{|e|}{|xs|}{|cs|}{|v|} \\
\rulename{all-fail}   & |all fail|           & \movesto & |tup ()| \\
\rulename{all-choice} & |all (e_1 choice dots choice e_n)| & \movesto & |def xs cs ; tup (vs)|  & if \wff{\emptyset}{|es|}{|xs|}{|cs|}{\overline{|v|}} \\
\rulename{all-value}  & |all e|              & \movesto & |def xs cs ; tup v|     & if \wff{\emptyset}{e}{|xs|}{|cs|}{|v|}
\end{longtable}
\caption{\textbf{The Verse Calculus: Rewrite Rules}}\label{fig:rewrite-rules}
\end{figure}
}

\newcommand{\figureNormalizationRules}{
\begin{figure}
\begin{longtable}{@@{\quad} l r >{$}c<{$} l l}
\rulegroupname{Normalization:~\rcon}
\rulename{norm-val}       & |v ; e|               & \movesto & |e|                   & \\
\rulename{norm-seq-assoc} & |(e_1 ; e_2) ; e_3|   & \movesto & |e_1 ; (e_2 ; e_3)|    & \\
\rulename{norm-seq-swap1} & |e_1 ; x = v; e_2|    & \movesto & |x == v; e_1; e_2|     & if |e_1| is not of form |x' == v'|\\
\rulename{norm-seq-swap2} & |e_1 ; x = s; e_2|    & \movesto & |x == s; e_1; e_2|     & if |e_1| is not of form |x' == s'|\\
\rulename{norm-swap-eq}   & |hnf == x|            & \movesto & |x == hnf|            & \\
\rulename{norm-seq-defr}  & |(def x e_1); e_2|    & \movesto & |def x (e_1 ; e_2)|    & if $|x| \not \in \freevars{|e_2|}$\\
\rulename{norm-seq-defl}  & |e_1 ; (def x e_2)|   & \movesto & |def x (e_1 ; e_2)|    & if $|x| \not \in \freevars{|e_1|}$\\
\rulename{norm-defr}      & |e_1 == (def y e_2)|  & \movesto & |def y (e_1 == e_2)|   & if $|y| \not \in \freevars{|e_2|}$ \\
\rulename{norm-seqr}      & |v == (e_1 ; e_2)|    & \movesto & |e_1 ; v == e_2| \\
\rulename{norm-unifyr}    & |v == (e_1 == e_2)|   & \movesto & |v == e_1; v == e_2|   & \\[0.05in]

\rulegroupname{Fail Propagation:~\rfail}
\rulename{fail-seq-l}       & |fail ; e|            & \movesto & |fail| \\
\rulename{fail-seq-r}       & |e ; fail|            & \movesto & |fail| \\
\rulename{fail-eq}        & |v == fail|           & \movesto & |fail| \\[0.05in]

\rulegroupname{Garbage Collection:~$\rgc$}
\rulename{elim-def}     & |e_1| & \movesto & \multicolumn{2}{l}
  {|e_2| \quad \quad \text{if $\wff{\emptyset}{e_1}{|xs|}{|cs|}{|e_2|}$ and $|xs| \not\in \freevars{|e_2|}$}} \\
\rulegroupname{Structural rules}
        \rulename{swap-d} & |def x (def y e)| & \equiv & |def y (def x e)| &  \\
        \rulename{swap-c} & |x_1=v_1; x_2 = v_2; e| & \equiv & |x_2 = v_2; x_1=v_1; e|
\end{longtable}
\caption{\textbf{The Verse Calculus: Normalization Rules}}\label{fig:rules-normalize}
\end{figure}
