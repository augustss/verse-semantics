    % that arises because the longest rule name and the longer LHS are not on the same line
    % The \; reduces the spacing around the arrow
\rulegroupname{Unification:}
  \rulename{u-lit}   & |k_1 == k_2; e| & \movesto & |e| & \text{if $k_1=k_2$} \\
%%  \rulename{u-tup} & \hspace{-1.8em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e| & \movesto & |v_1==v1';xdots;v_n==v_n'; e| \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e| & \movesto & |v_1==v1';xdots;v_n==v_n'; e| \\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & |fail| & \text{if \rulename{u-lit}, \rulename{u-tup} do not match} \\
  \rulename{u-occurs} & |x==V^[x]; e| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
  \rulename{subst} & |X^[x==v;e]| & \movesto & |(subst X x v)^[x==v; subst e x v]| \hspace*{-0.3em}
  & \text{if $|x| \in \freevars{|X,e|}$, $|x| \notin \freevars{|v|}$}, \\
  &&&& \text{\hskip 0.7em and ($|v| = |y| \implies |x| \prec |y|$)} \\
  \rulename{hnf-swap} & |hnf==x; e|    & \movesto & |x==hnf; e| \\
  \rulename{var-swap} & |y==x; e|    & \movesto & |x==y; e| & \text{if |x| $\prec$ |y| } \\
%%  \rulename{var-swap-subst} & |X^[x==y; e]| & \movesto & |subst X y x^[y==x; subst e y x]| & \text{if |y| $\prec$ |x| } \\
%%  \rulename{val-swap-ord} & |eq_1; eq_2; e| & \movesto & |eq_2; eq_1; e| & \text{if |eq_2| $\prec$ |eq_1| } \\
  \rulename{seq-swap} & |v_1==e_1; x==v_2; e_2| & \movesto & |x==v_2; v_1==e_1; e_2| &
                      \text{unless (|v_1==y|, |e_1| is a value, and |y| $\preceq$ |x|)} \\

    \\[-0.6em]

\rulegroupname{Elimination:}
\rulename{exi-elim} & |def x e| & \movesto & |e| & \text{if $|x| \notin \freevars{|e|}$}\\
\rulename{eqn-elim} & |def x (X^[x==v;e])| & \movesto & |X^[e]| & \text{if $|x| \notin \freevars{|X^[v;e]|}$} \\
\rulename{fail-elim} & |X^[fail]| & \movesto & |fail| & \text{if $|X| \ne \hole$} \\

    \\[-0.6em]

\rulegroupname{Normalization:}
\rulename{exi-float}^{\alpha} & |X^[def x e]| & \movesto & |def x (X^[e])| & \text{if $|X| \ne \hole,\,  x \notin \freevars{|X|}$} \\
\rulename{eqn-float} & |v_2 == (v_1 == e_1 ; e_2); e_3| & \movesto & |v_1 == e_1 ; (v_2 == e_2; e_3)| \\
\rulename{exi-swap} & |def x (def y e)| & \movesto & |def y (def x e)| \\
%\rulename{seq-swap} & |eq_1; eq_2; e| & \movesto & |eq_2; eq_1; e| &
%                      \hspace{-3em}\text{if ($eq_1 \in ceq$ or $eq_2 \in ceq$) and $eq_2 \prec eq_1$} \\
%\multicolumn{5}{l}{\text{\lennart{Plan: remove rule above, use rule below, move to unification group}}}\\

    \\[-0.6em]

\rulegroupname{Choice:}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice} & |one (v `choice` e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-value}  & |all v| & \movesto & |tup v| \\
\rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)| \\
\rulename{choose-r} & |fail choice e| & \movesto & |e| \\
\rulename{choose-l} & |e choice fail| & \movesto & |e| \\
\rulename{choose-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
\rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & \text{if}~|CX| \ne \hole \\


\end{array} \\
\\[-0.3em]
\text{\textit{Note}: In the rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.}
\end{array}$
