\begin{figure}
  $$
    \begin{array}{lr@@{\;}c@@{\;}l}
    \text{Execution contexts} & X & ::= & \hole \vb |v == X| \vb |X ; e| \vb |e; X| \\
    \text{Value contexts} & V & ::= & \hole \vb |tup (v_1, dots ,V, dots, v_n)|\\
    \text{Scope contexts} & SX & ::= & |hole choice e| \vb |e choice hole |
    \vb |one hole| \vb |all hole| \\
\iffullverse
    && \vb & |succeeds hole| \vb |decides hole| \\
\fi
    \text{Choice contexts} & CX & ::= & \hole \vb |v == CX| \vb |CX ; e| \vb |ce; CX| \vb |def x CX| \\
    \text{Choice-free exprs} & ce  & ::=  & |v| \vb |v == ce| \vb |ce_1 ; ce_2|
    \vb |one e| \vb |all e|
    %%% NOTE: the following is not in the POPL submission,
