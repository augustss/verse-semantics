\begin{figure}
  $$
  \begin{array}{l}
    \textit{Structural rules} \\
    \begin{array}{lr@@{\;}c@@{\;}ll}
    \rulename{exist-swap} & |def (dots x y dots) e| & \movesto & |def (dots y x dots) e| \\
    \rulename{val-swap} & |e_1; x==v; e_2| & \movesto & |x==v; e_1; e_2| \\
    \rulename{var-swap} & |X^[x==y]| & \movesto & |subst X y x^[y==x]| \\
