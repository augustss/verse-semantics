\rulegroupname{Primitive operations}

\rulename{p-add} & |applyN add (k_1 ,k_2)| & \movesto & |k_1+k_2| \\
\rulename{p-gt} & |applyN gt (k_1,k_2)| & \movesto &
    $\begin{cases}
      |k_1| & \text{if $k_1 > k_2$} \\
      |fail| & \text{otherwise}
      \end{cases}$ \\

\iffullverse
    \rulename{p-isInt} & |apply1 isInt hnf| & \movesto &
    $\left\{\begin{array}{@@{}ll}
      |()| & \text{if |hnf| is an integer} \\
      |fail| & \text{otherwise}
      \end{array}\right.$
\fi

\rulegroupname{Application}

\rulename{app-beta} & |apply1 (lam x ({def xs (q; v_1)})) v_2| & \movesto & |{def (x xs) (x=v_2; q; v_1)}|
          & if $x \not\in \freevars{|v|} \cup \{\overline{x}\}$ \\
\rulename{app-tup-0} & |apply1 emptytup v| & \movesto & |fail| \\
\rulename{app-tup} & |apply1 (tup (v_0,dots v_n)) v| & \movesto & \largerhs{|{v = 0; v_0} choice dots choice {v = n; v_n}|} \\

\\[-2mm]
\rulegroupname{Block}

\rulename{merge} & |def xs Q^[v_1 == {def ys (q; v_2)}]; v_3| & \movesto & |def (xs ys) Q^[q; v_1 == v_2]; v_3| &
        if |xs # ys|\\

\\[-2mm]
\rulegroupname{Unification}

\rulename{ulit} & |Q^[k_1 == k_2]| & \movesto
    & \largerhs{$\begin{cases}
        |Q^[]| & \text{if $k_1=k_2$} \\
        |Q^[x==fail]| & \text{otherwise, |x| fresh}
      \end{cases}$} \\
\rulename{utup} & {|Q^[tup (v_1,dots,v_m) == tup (v1',dots,v_n')]|}
    % the \llap allows the LHS to reach into the first columns; ok due to the short rule name
    & \movesto & \largerhs{$\begin{cases}
        \multicolumn{2}{@@{}l}{|Q^[v_1==v1';dots;v_m=v_m']|} \\
            & \text{if $m=n$} \\
        |Q^[x==fail]| & \text{otherwise, |x| fresh}
      \end{cases}
    $}\\
\rulename{ux} & |v_1 == v_2 | & \movesto & |x == fail| & if not matched above, |x| fresh \\
%%\rulename{ux-occurs} & |x=V^[x]| & \movesto & |x == fail| & if $|V| \ne |hole|$, |x| fresh \\
\rulename{ux-occurs} & |x == v| & \movesto & {\text{???recursion???}} & \text{if $x \in \freevars{v}$}\\

\\[-2mm]
\rulegroupname{Variables}

\rulename{subst} & |Q^[x==v]| & \movesto & |(subst Q x v)^[x==v]|
    & if $|x| \in \freevars{|X|}$, $|x| \notin \freevars{v}$ \\

\rulename{def-eliml} & |def (V^[x]) (Q^[x==v_1]; v_2)| & \movesto & |def (V^[]) (Q^[]; v_2)|
    & if $|x| \notin \freevars{|Q|}\cup \freevars{|v|}$ \\

%\rulename{def-elimr} & |def (V^[x]) (Q^[v==x])| & \movesto & |def (V^[]) (Q^[])|
%    & if $|x| \notin \freevars{|Q|}\cup \freevars{|v|}$ \\

\rulename{def-elimv} & |def (V^[x]) (Q^[y=x]; v)| & \movesto & |def (V^[]) (subst (Q^[]; v) x y)|
    & if $|x| \neq |y|$ \\

\rulename{def-elim} & |def (V^[x]) (q; v)| & \movesto & |def (V^[]) (q; v)|
    & if $|x| \notin \freevars{|q|}$ \\

\rulename{swap} & |hnf==x|    & \movesto & |x==hnf| \\

\\[-2mm]
\rulegroupname{Fail propagation}

\rulename{fail} & |{def xs (Q^[v_1=fail]; v_2)}| & \movesto & |fail|  \\

