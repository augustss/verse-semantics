# Trivial
testceq(SEq) { 1 } { 1 }
testceq(SEq) { exists x . x=1 } { 1 }

testeq(SEq) { all{x:any; all{(x=1)|(x=0)}; x=0|1}}  {(0,1)}

# Versions
#  V0: POPL
#  V1: 2022-11-03, nested tuples allowed in syntax (never produced), A has (v = A), U-SCALAR removes x=x
#  V2: V1 + early alias elimination and B context under barrier

# Problem 1 from Ranjit in email chain "State of play"
# XXX What is the expected result?
testceq(SEq) { ID := (\a.a); exists x y . x = ID; one{ x = y; x(10) } }   { exists y . one{ y = (\a.a); 10 } }
# Test results:
#  V0: OK
#  V1: fails, not confluent
#  V2: OK

# Problem 2 from Ranjit's email
testceq(SEq) { ID := (\a.a); exists x y . x = ID; y = x; < y > }          { < \a.a > }
# Test results:
#  V0: OK
#  V1: OK
#  V2: OK

# Problem 3 from Ranjit's email
# XXX What is the expected result?
testceq(SEq) { exists a b c d x . x = <a, b>; x = <c, d>; x }              { exists c d . <c,d> }
# Test results:
#  V0: OK (2 results, joinable with structural rules)
#  V1: OK
#  V2: OK (2 results, joinable with structural rules)

# Variation on problem 3
# XXX What is the expected result?
testceq(SEq) { exists a b c d . one { exists x . x = <a,b>; x = <c, d>; x } }
             { exists a b c d . one { exists x . a=c; b=d;  x = <c, d>; x } }
# Test results:
