#  V2: OK

# Problem found by QC
testceq(SEq) { exists x . (exists y . x = y; x) | <> }                    { exists x . x | <> }
# Test results:
#  V0: Needs structural rules for progress
#  V1: fails, does not reduce
#  V2: OK
# The POPL rules can be augmented with
#  DEF-ELIMV ex x y1 ... yn . X[y = x]  -->  ex y1 ... yn . X[y]{x<-y} x/=y x/=yi

testceq(SEq) { exists f g a b c d . f(a); g(b); one { exists x . x = <a,b>; x = <c, d>; x } }
             { exists f g a b c d . f(a); g(b); one { exists x . a=c; b=d;  x = <c, d>; x } }

testceq(SEq) { exists f g a b c d x . f(a); g(b); x = <a, b>; x = <c, d>; x }
             { exists f g c d       . f(c); g(d); <c, d> }
