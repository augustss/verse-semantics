# Trivial tests
testeq(pass) {p := alloc$[0]; p}                       {alloc$[0]}
testeq(pass) {p := alloc$[99]; read$[p]}               {99}
testeq(pass) {p := alloc$[99]; write$[p,88]; read$[p]} {88}

# Sugared operators
testeq(pass) {p := new[int][99]; p^}                   {99}
testeq(pass) {p := new[int][99]; p .= 88; p^}          {88}
testeq(pass) {p := new[int][99]; p += 88; p^}          {187}
#testeq(pass) {p := new[int][99]; p -= 88; p^}          {11}
#testeq(pass) {p := new[int][99]; p *= 88; p^}          {8712}
#testeq(pass) {p := new[int][99]; p /= 88; p^}          {1}

# New syntax
testeq(pass) {var p:int=99; p}                         {99}
testeq(pass) {var p:int=99; set p = 88; p}             {88}


# store propagation on success
testeq(pass){var x:any=5; if (1=1)            then set x+=1 else set x+=2; x }    {6}
testeq(pass){var x:any=5; if (set x+=10; 1=1) then set x+=1 else set x+=2; x }    {16}
testeq(pass){var x:any=5; if (1=1; set x+=10) then set x+=1 else set x+=2; x }    {16}

# store propagation on failure
testeq(pass){var x:any=5; if (0=1)            then set x+=1 else set x+=2; x }    {7}
testeq(pass){var x:any=5; if (set x+=10; 0=1) then set x+=1 else set x+=2; x }    {7}
testeq(pass){var x:any=5; if (0=1; set x+=10) then set x+=1 else set x+=2; x }    {7}

# store propagation on success, choice 1
testeq(pass){var x:any=5; if (a:=1|2; a>0)            then set x+=1 else set x+=2; x }    {6}
testeq(pass){var x:any=5; if (set x+=10; a:=1|2; a>0) then set x+=1 else set x+=2; x }    {16}
testeq(pass){var x:any=5; if (a:=1|2; a>0; set x+=10) then set x+=1 else set x+=2; x }    {16}

# store propagation on success, choice 2
testeq(pass){var x:any=5; if (a:=1|2; a>1)            then set x+=1 else set x+=2; x }    {6}
testeq(pass){var x:any=5; if (set x+=10; a:=1|2; a>1) then set x+=1 else set x+=2; x }    {16}
testeq(pass){var x:any=5; if (a:=1|2; a>1; set x+=10) then set x+=1 else set x+=2; x }    {16}

# store propagation on failure, choice 3
testeq(pass){var x:any=5; if (a:=1|2; a>2)            then set x+=1 else set x+=2; x }    {7}
testeq(pass){var x:any=5; if (set x+=10; a:=1|2; a>2) then set x+=1 else set x+=2; x }    {7}
testeq(pass){var x:any=5; if (a:=1|2; a>2; set x+=10) then set x+=1 else set x+=2; x }    {7}

# store propagation on success, choice 1 + effects
testeq(pass){var x:any=5; if (a:=(set x+=100; 1) | (set x+=200; 2); a>0)            then set x+=1 else set x+=2; x }    {106}
testeq(pass){var x:any=5; if (set x+=10; a:=(set x+=100; 1) | (set x+=200; 2); a>0) then set x+=1 else set x+=2; x }    {116}
testeq(pass){var x:any=5; if (a:=(set x+=100; 1) | (set x+=200; 2); a>0; set x+=10) then set x+=1 else set x+=2; x }    {116}

# store propagation on success, choice 2 + effects
testeq(pass){var x:any=5; if (a:=(set x+=100; 1) | (set x+=200; 2); a>1)            then set x+=1 else set x+=2; x }    {206}
testeq(pass){var x:any=5; if (set x+=10; a:=(set x+=100; 1) | (set x+=200; 2); a>1) then set x+=1 else set x+=2; x }    {216}
testeq(pass){var x:any=5; if (a:=(set x+=100; 1) | (set x+=200; 2); a>1; set x+=10) then set x+=1 else set x+=2; x }    {216}

# store propagation on failure, choice + effects
testeq(pass){var x:any=5; if (a:=(set x+=100; 1) | (set x+=200; 2); a>2)            then set x+=1 else set x+=2; x }    {7}
testeq(pass){var x:any=5; if (set x+=10; a:=(set x+=100; 1) | (set x+=200; 2); a>2) then set x+=1 else set x+=2; x }    {7}
testeq(pass){var x:any=5; if (a:=(set x+=100; 1) | (set x+=200; 2); a>2; set x+=10) then set x+=1 else set x+=2; x }    {7}

# Various level of trickyness
testeq(pass) {
    p := new[int][0];
    (if(p+=1; p^ = 0) then 11 else 22), p^}
                                                       {(22, 0)}
testeq(pass) {
    p := new[int][0];
    (if(p+=1; p^ = 1) then 11 else 22), p^}
                                                       {(11, 1)}
testeq(pass) {
    p := new[int][0];
    q := new[int][0];
    r := new[int][0];
    a := for(p+=1; x:=1|2|3; q+=1; x<>2){r+=1; 9+x};
    (a, p^, q^, r^)}
                                                       {((10,12), 1, 2, 2)}

testeq(pass) {
    p := new[int][0];
    q := new[int][0];
    for(1|2|3) {
      p += 1;
      for(1|2|3|4) {
        q += p^;
      }
    };
    p^, q^
}                                                      {3,24}

#testout(pass) { print$[99]; print$[1] }                 {99,1}
#testout(pass) { for(x:=1|2|3){print$[x]}}               {1,2,3}

testeq(pass) {
    p := new[int][0];
    q := new[int][0];
    r := new[int][0];
    for(x:=1|2|3;
        for(y:=4|5|6; y<>5) { p += y; q += x };
        x<>2
       ) {
       r += 1
       };
    p^, q^, r^
    }
    {20,8,2}

