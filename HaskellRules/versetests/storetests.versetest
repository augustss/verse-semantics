testeq(pass) {
    p := new[int][0];
    q := new[int][0];
    (if(p=p)then 10 else 20), (if(p=q)then 30 else 40)
    }
    {10,40}

testeq(pass) { for(x:=1 ..4; x<>2; y:=5 ..(5+x); not ((x=4) and y > 7)) {x,y} }
    {((1, 5), (1, 6), 
      (3, 5), (3, 6), (3, 7), (3, 8),
      (4, 5), (4, 6), (4, 7))}

testeq(pass) { var p : any = 0; if(x:=0 ..(set p+=1), x>0){99}else{88}, p }    {99,1}
testeq(pass) { var p : any = 0; if(x:=2 ..(set p+=1), x>0){99}else{88}, p }    {88,0}

testeq(pass) {var q:int=0; for(x:=1|2|3; set q+=1; x<>2){0}; q}       {2}

testeq(pass) {p := new[int][0]; q := new[int][0]; a := for(p+=1; x:=1|2; q+=1){0}; (p^, q^)} {(1, 2)}

testeq(pass) {
    var p:any=0; var q:any=0; var r:any=0; var s:any=0; var t:any=0;
    for (set p+=1; x:=1 ..2; set q+=1; y:=1 ..3; set r+=1; z:=1 ..4; set s+=1;
         x<>y; z<4) {set t+=1};
    p,q,r,s,t
    }
    { 1,2,4,12,12 }

testeq(pass) { var a:int=0; for(x:=(set a=100; 10) | (set a=200; 20)) { (a, x) } } { (100,10), (200, 20) }
testeq(pass) { var a:int=0; for(x:=(set a+=100; 10) | (set a+=200; 20)) { (a, x) } } { (100,10), (300, 20) }

