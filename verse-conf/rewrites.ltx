\begin{figure}
  $$
  \begin{array}{l}
    \textit{Primitive operations} \\
    \begin{array}{lrcl}
    \rulename{p-add} & |applyN add (k_1 ,k_2)| & \movesto & k_1+k_2 \\
    \rulename{p-gt} & |applyN gt (k_1,k_2)| & \movesto &
    \left\{\begin{array}{@@{}ll}
      |k_1| & \text{if $k_1 > k_2$} \\
      |fail| & \text{otherwise}
      \end{array}\right. \\
%    \rulename{p-map} &
%      |applyN map (v, (v_1 choice dots choice v_n))|
%    & \movesto &
%    \begin{array}[t]{@@{}l}
%      |defTwoLines (x_1,dots x_n)
%       (x_1 == apply1 v v_1; dots x_n == apply1 v v_n; arr (x_1,dots,x_n))| \\
%    \end{array} \\
%    && \multicolumn{2}{l}{\text{if $\{x_1, \ldots, x_n\} \disjoint \freevars{v, v_1, \ldots, v_n}$}} \\[2mm]
\iffullverse
    \rulename{p-isInt} & |apply1 isInt hnf| & \movesto &
    \left\{\begin{array}{@@{}ll}
      |()| & \text{if |hnf| is an integer} \\
      |fail| & \text{otherwise}
      \end{array}\right. \\[2mm]
\fi
    \end{array} \\

    \textit{Application} \\
    \begin{array}{lrcl}
      \rulename{app-beta} & |apply1 (lam x e) v| & \movesto & |def x (x=v; e)|
          \quad \text{if $x \not\in \freevars{v}$} \\
    \rulename{app-arr} & |apply1 (tup (v_0,dots v_n)) v| & \movesto & |(v = 0; v_0) choice dots choice (v = n; v_n)| \\
    \end{array} \\
    \\[-2mm]

    \textit{Unification} \\
    \begin{array}{lrcl}
    \rulename{ulit} & |k_1 == k_2| & \movesto
    & \left\{\begin{array}{@@{}ll}
        |k_1| & \text{if $k_1=k_2$} \\
        |fail| & \text{otherwise}
      \end{array}\right. \\
    \rulename{ucon} & \begin{array}{@@{}l}
      |arr (v_1,dots,v_m)| \\
      | == arr (v1',dots,v_n')|
      \end{array} & \movesto
    & \left\{\begin{array}{@@{}ll}
    \multicolumn{2}{@@{}l}{|(v_1==v1';dots;v_m=v_m'; arr (v_1,dots,v_m))|} \\
    & \text{if $m=n$} \\
        |fail| & \text{otherwise}
      \end{array}\right.\\
    \rulename{ux1} & |k == arr (v_1,dots,v_n) | & \movesto & |fail| \\
    \rulename{ux2} & |arr (v_1,dots,v_n) == k | & \movesto & |fail| \\
    \rulename{ux3} & |(lam x e) == hnf| & \movesto & |fail|\\
    \rulename{ux4} & |hnf == (lam x e)| & \movesto & |fail|\\
    \rulename{ux5} & |op == hnf| & \movesto & |fail|\\
    \rulename{ux6} & |hnf == op| & \movesto & |fail|\\
    \rulename{ux-occurs} & |x=V^[x]| & \movesto & |fail| \quad \text{if }|V| \ne |hole|
     \end{array}\\

    \\[-2mm]

    \textit{Unification variables} \\
    \begin{array}{lrcll}
    \rulename{subst} & |X^[x==v]| & \movesto & |(subst X x v)^[x==v]|
        & \text{if $|x| \in \freevars{X}$, $|x| \notin \freevars{v}$} \\
    \rulename{subst-rec} & |x = V^[lam y e]| & \movesto & \multicolumn{2}{l}{|x = V[lam y (def x (x = V^[lam y e]; e))]|} \\
        &&&& \text{if $|x| \in \freevars{e}$, $x \ne y$} \\
    \rulename{def-eliml} & |def x (DX^[x==v])| & \movesto & |DX^[v]|
        & \text{if $|x| \notin \freevars{DX}$, $|x| \notin \freevars{v}$} \\
    \rulename{def-elimr} & |def x (DX^[v==x])| & \movesto & |DX^[v]|
        & \text{if $|x| \notin \freevars{DX}, |x| \notin \freevars{v}$} \\
    \rulename{swap} & |hnf==x|    & \movesto & |x==hnf| \\
    \rulename{def-float} & |X^[def x e]| & \movesto & |def x (X^[e])|
        & \text{if}~|X| \ne \hole,\,  x \notin \freevars{X}
    \end{array} \\

    \\[-2mm]

    \textit{Sequencing} \\
    \begin{array}{lrcl@@{\hspace{5mm}}l}
    \rulename{seq} & |v ; e| & \movesto & |e| \\
    \rulename{unify-seql} & |(e_1; e_2) == e_3| & \movesto & |e_1 ; (e_2 == e_3)| \\
    \rulename{unify-seqr} & |v == (e_1 ; e_2)| & \movesto & |e_1 ; (v == e_2)| \\
    \rulename{unify-unifyl} & |(e_1 == e_2) == e_3| & \movesto & |def x (x=e_1; x=e_2; x=e_3)| & x \; \text{fresh}\\
    \rulename{unify-unifyr} & |e_1 == (e_2 == e_3)| & \movesto & |def x (x=e_1; x=e_2; x=e_3)| & x \; \text{fresh}\\
    \end{array} \\
    \\[-2mm]
    \textit{Fail propagation} \\
    \begin{array}{lrcll}
    \rulename{fail-def} & |def x fail| & \movesto & |fail|  \\
    \rulename{fail}     & |X^[fail]| & \movesto & |fail| & \text{if}~|X| \ne \hole  \\
     \end{array}

   \end{array}
   $$
  \caption{The Verse calculus: rewrite rules (1)}
    \label{fig:general-axioms} \label{fig:rules1}
\end{figure}

\begin{figure}
  $$
    \begin{array}{lrcl}
    \text{Execution contexts} & X & ::= & \hole \vb |X == e| \vb |e == X| \vb |X ; e| \vb |e; X| \\
    \text{Value contexts} & V & ::= & \hole \vb |arr (v_1, dots ,V, dots, v_n)|\\
    \text{Scope contexts} & SX & ::= & |hole choice e| \vb |e choice hole |
    \vb |one hole| \vb |all hole| \\
\iffullverse
    && \vb & |succeeds hole| \vb |decides hole| \\
\fi
    \text{Definition contexts} & DX & ::= & X \vb |def x DX| \\
    \text{Choice contexts} & CX & ::= & \hole \vb |CX == e| \vb |ce == CX| \vb |CX ; e| \vb |ce; CX| \vb |def x CX| \\
    \text{Choice-free exprs} & ce  & ::=  & |v| \vb |ce_1 == ce_2| \vb |ce_1 ; ce_2|
    \vb |one e| \vb |all e|
  \end{array}
   $$
  \caption{The syntax of contexts}
    \label{fig:contexts}
\end{figure}

\begin{figure}
  $$
  \begin{array}{l}
    \textit{Choice} \\
    \begin{array}{lrcll}
    \rulename{fail-l} & |fail choice e| & \movesto & e \\
    \rulename{fail-r} & |e choice fail| & \movesto & e \\
    \rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & \text{if}~|CX| \ne \hole \\
    \rulename{assoc-choice} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| 
    \end{array} \\
    \\

    \textit{One and all} \\
    \begin{array}[t]{lrcl}
    \rulename{one-fail} & |one fail| & \movesto & |fail| \\
    \rulename{one-choice} & |one (v `choice` e)| & \movesto & |v| \\
    \rulename{one-value} & |one v| & \movesto & |v| \\
    \end{array} \hspace{5mm}
    \begin{array}[t]{lrcl}
    \rulename{all-fail} & |all fail| & \movesto & |arr ()| \\
    \rulename{all-choice} &
      |all (v_1 choice dots choice v_n)| & \movesto & |arr (v_1, dots, v_n)| \\
    \rulename{all-value} & |all v| & \movesto & |arr v| \\
    \end{array} \\
    \\[-2mm]

\iffullverse
    \textit{Effects} \\
    \begin{array}{lrcl}
    \rulename{succ-value} & |succeeds v| & \movesto & |v| \\
    \rulename{dec-fail} & |decides fail| & \movesto & |fail| \\
    \rulename{dec-value} & |decides v| & \movesto & |v| \\
    \end{array} \\
\fi
   \end{array}
   $$
  \caption{The Verse calculus: rewrite rules (2)}
    \label{fig:rules2}  \label{fig:choice}
\end{figure}

