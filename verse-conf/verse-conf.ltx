      |x := e; dots| & \equiv & |def x (x = e; dots)| \\
      |f^(x) := e; dots| & \equiv & |f := lam x e; dots| \\
      |f^(x,y) := e; dots| & \equiv & |f^(p) := def (x,y) (p=(x,y); e); dots| \\
