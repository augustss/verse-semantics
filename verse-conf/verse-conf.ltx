\section{Rewrite rules}

\begin{figure}
  $$
  \begin{array}{l}
    \textit{Choice} \\
    \begin{array}{lrcll}
    \rulename{fail-l} & |fail choice e| & \movesto & e \\
    \rulename{fail-r} & |e choice fail| & \movesto & e \\
    \rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| & \text{if}~|CX| \ne \hole \\
    \rulename{assoc-choice} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| 
    \end{array} \\
    \\

    \textit{Primitive operations} \\
    \begin{array}{lrcl}
    \rulename{p-add} & |applyx add (k_1 ,k_2)| & \movesto & k_1+k_2 \\
    \rulename{p-gt} & |applyx gt (k_1,k_2)| & \movesto &
    \left\{\begin{array}{@@{}ll}
      |k_1| & \text{if $k_1 > k_2$} \\
      |fail| & \text{otherwise}
      \end{array}\right. \\[2mm]
    \rulename{p-isInt} & |applyx isInt hnf| & \movesto &
    \left\{\begin{array}{@@{}ll}
      |()| & \text{if |hnf| is an integer} \\
      |fail| & \text{otherwise}
      \end{array}\right. \\[2mm]
    \end{array} \\

    \textit{Sequencing} \\
    \begin{array}{lrcl}
    \rulename{seq} & |v ; e| & \movesto & |e| \\
    \rulename{unify-seql} & |(e_1; e_2) == e_3| & \movesto & |e_1 ; (e_2 == e_3)| \\
    \rulename{unify-seqr} & |v == (e_1 ; e_2)| & \movesto & |e_1 ; (v == e_2)| \\
    \end{array} \\
    \\[-2mm]

    \textit{Application} \\
    \begin{array}{lrcl}
      \rulename{app-lam} & |applyx (lam x e) v| & \movesto & |def x (x=v; e)|
          \quad \text{if $x \not\in \freevars{v}$} \\
    \rulename{app-arr} & |applyx (arr (v_0,dots v_n)) v| & \movesto & |(v = 0; v_0) choice dots choice (v = n; v_n)| \\
    \end{array} \\
    \\[-2mm]

    \textit{One and all} \\
    \begin{array}{lrcl}
    \rulename{one-value} & |one v| & \movesto & |v| \\
    \rulename{one-choice} & |one (v `choice` e)| & \movesto & |v| \\
    \rulename{one-fail} & |one fail| & \movesto & |fail| \\
    \end{array} \\  \\[-1mm]
    \begin{array}{lrcl}
    \rulename{all-0} & |all fail| & \movesto & |()| \\
    \rulename{all-n} &
      |all (v_1 choice dots choice v_n)|
    & \movesto &
    \begin{array}[t]{@@{}l}
      |defTwoLines (x_1,dots x_n)
       (x_1 == applyx v_1 (); dots x_n == applyx v_n (); arr (x_1,dots,x_n))| \\
    \end{array} \\
    &&& \multicolumn{1}{l}{\text{if $\{x_1, \ldots, x_n\} \disjoint \freevars{v_1, \ldots, v_n}$}}
    \end{array} \\
    \\[-2mm]

    \textit{Effects} \\
    \begin{array}{lrcl}
    \rulename{succ-value} & |succeeds v| & \movesto & |v| \\
    \rulename{dec-fail} & |decides fail| & \movesto & |fail| \\
    \rulename{dec-value} & |decides v| & \movesto & |v| \\
    \end{array} \\
   \end{array}
   $$
  \caption{The Verse calculus: general axioms} \label{fig:general-axioms}
\end{figure}

\begin{figure}
  $$
  \begin{array}{l}
    \textit{Unification} \\
    \begin{array}{lrcl}
    \rulename{ucon} & |k_1 == k_2| & \movesto
    & \left\{\begin{array}{@@{}ll}
        |k_1| & \text{if $k_1=k_2$} \\
        |fail| & \text{otherwise}
      \end{array}\right. \\
    \rulename{uarr} & \begin{array}{@@{}l}
      |con K (v_1,dots,v_m)| \\
      | == con K (v1',dots,v_n')|
      \end{array} & \movesto
    & \left\{\begin{array}{@@{}ll}
        |v_1==v1';dots;v_m=v_m';|\\
        |con K (v_1,dots,v_m)| & \text{if $m=n$} \\
        |fail| & \text{otherwise}
      \end{array}\right.\\
    \rulename{ux1} & |k == con K (v_1,dots,v_n) | & \movesto & |fail| \\
    \rulename{ux2} & |con K (v_1,dots,v_n) == k | & \movesto & |fail| \\
     \end{array}\\

    \\[-2mm]

    \textit{Unification variables} \\
    \begin{array}{lrcll}
    \rulename{swap} & |hnf==x| & \movesto & |x==hnf| \\
    \rulename{subst} & |X^[x==v]| & \movesto
