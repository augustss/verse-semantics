    & \text{if $|x| \in \freevars{X}$, $|x| \notin \freevars{v}$} \\
    \rulename{subst-rec} & |x = V^[lam y e]| & \movesto & |x = V[lam y (def x (x = V^[y => e]; e))]|
    & \text{if $|x| \in \freevars{e}$, $x \ne y$}\\

    \rulename{def-elim} & |def x (X^[x==v])| & \movesto & |X^[v]|
    & \text{if $|x| \notin \freevars{X}$, $|x| \notin \freevars{v}$} \\
    \rulename{def-float} & |X^[def x e]| & \movesto & |def x (X^[e])|
    & \text{if}~|X| \ne \hole,\,  x \notin \freevars{X} \\
    \end{array} \\
    \\[-2mm]


    \textit{Fail propagation} \\
    \begin{array}{lrcl}
    \rulename{fail-seql} & |fail; e| & \movesto & |fail|  \\
    \rulename{fail-seqr} & |e; fail| & \movesto & |fail|  \\
    \rulename{fail-unifyl} & |fail = e| & \movesto & |fail|  \\
    \rulename{fail-unifyr} & |e = fail| & \movesto & |fail|  \\
    \rulename{fail-def} & |def x fail| & \movesto & |fail|  \\
     \end{array}

   \end{array}
   $$
