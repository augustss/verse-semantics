\subsubsection{Lemmas about Rules That Strongly Commute}


\begin{lemma}[\rulename{u-occurs-fail} strongly commutes with itself]\label{lem:u-occurs-fail-diamond}
  For all terms $t$,
  $t_1$, and $t_2$:\hfill\break\null\hskip2.5em if\quad
  $t_1 \xrnungosup{u-occurs-fail}{u} t \xrngosup{u-occurs-fail}{w} t_2$
  \unskip\quad then\quad
  $t_1 \xrngoeqsup{u-occurs-fail}{w} \tjoin \xrnungoeqsup{u-occurs-fail}{u} t_2$
  \hfill\break for some term $\tjoin$.
\end{lemma}
\begin{proof}
  Split cases on the position of $u$ relative to $w$ within $t$:
  \begin{description}
    \CASE{u=w} Let $\tjoin = t_1 = t_2$.
    \CASE{u \occdis w} Use \cref{lem:disjoint-sc}.
    \CASE{u \occstrictin w} Define $\tjoin$ by $t_1 \xrngosup{u-occurs-fail}{w} \tjoin$, then observe that\hfill\break
    $\tjoin = t_2$ because $\tjoin = \tsubst{\tsubst{t}{u}{t_1/u}}{w}{t_2/w} = \tsubst{t}{w}{t_2/w} \BY{\emph{dominance}} = t_2$. 
    \CASE{u \occstrictcontains w} Symmetrical with case $u \occstrictin w$.
  \end{description}
\end{proof}

\begin{lemma}[\rulename{u-occurs-fail} and \rulename{u-occurs-wrap} strongly commute]\label{lem:u-occurs-fail-sc-u-occurs-wrap}
  For all terms $t$, $t_1$, and $t_2$:\hfill\break\null\hskip2.5em if\quad
  $t_1 \xrnungosup{u-occurs-wrap}{u} t \xrngosup{u-occurs-fail}{w} t_2$
  \unskip\quad then\quad
  $t_1 \xrngosup{u-occurs-fail}{w'} \tjoin \xrnungoeqsup{u-occurs-wrap}{u} t_2$
  \hfill\break for some term $\tjoin$ and some occurrence $w'$.
\end{lemma}
\begin{proof}
  Split cases on the position of $u$ relative to $w$ within $t$:
  \begin{description}
    \CASE{u=w} Impossible.
    \CASE{u \occdis w} Let $w'=w$ and use \cref{lem:disjoint-sc}.
    \CASE{u \occstrictin w} Let $w' = w$; define $\tjoin$ by $t_1 \xrngosup{u-occurs-fail}{w'} \tjoin$, then observe that\hfill\break
    $\tjoin = t_2$ because $\tjoin = \tsubst{\tsubst{t}{u}{t_1/u}}{w}{t_2/w} = \tsubst{t}{w}{t_2/w} \SBY{\emph{dominance}} = t_2$. 
    \CASE{u \occstrictcontains w}     Let $\sigma_1 = \{ |x| \mapsto t/u(1,1), |hnf| \mapsto t/u(1,2), |e| \mapsto t/u(2) \}$.
    
    Then $ t_1 = \tsubst{t}{u}{\sigma_1(|x = (mu x hnf); e|)}$ and $t_2 = \tsubst{t}{w}{|fail|}$.
    
    Let $\sigma_1' = \{ |x| \mapsto t_2/u(1,1), |hnf| \mapsto t_2/u(1,2), |e| \mapsto t_2/u(2) \}$.

        \par$\begin{array}{@@{}l@@{\;}l@@{\;}l@@{}}
 \text{Let $\tjoin$} & = & \tsubst{t_1}{w'}{\tjoin/w'} \SBY{\emph{rewriting}} \\
    & = & \tsubst{\tsubst{t}{u}{\sigma_1(|x = (mu x hnf); e|)}}{w'}{\tjoin/w'} \SBY{value of $t_1$} \\
    & = & \tsubst{t}{u}{\tsubst{(\sigma_1(|x = (mu x hnf); e|))}{w'}{\tjoin/w'}} \SBY{\emph{associativity}} \\
     \end{array}$

    Now split cases on the position of $w$ within $t/u \tequiv |x=hnf; e|$~:
    \begin{description}
      \CASEIN{w \occin u(1,1)}{|x|} Impossible. 
      \CASEIN{w \occin u(1,2)}{|hnf|} Let $w'=u(1,2,2)(w/u(1,2))$.
        \par$\begin{array}{@@{}l@@{\;}l@@{\;}l@@{}}
 \text{Then $\tjoin$} & = & \tsubst{t}{u}{\tsubst{(\sigma_1(|x = (mu x hnf); e|))}{w'}{\tjoin/w'}} \BY{\emph{associativity}} \\
      & = & \tsubst{t}{u}{\tsubst{(\sigma_1(|x = (mu x hnf); e|))}{u(1,2,2)(w/u(1,2))}{\tjoin/u(1,2,2)(w/u(1,2))}} \BY{value of $w'$} \\
      & = & \tsubst{t}{u}{\tsubst{(\sigma_1(|x = (mu x hnf); e|))}{u(1,2,2)(w/u(1,2))}{\tjoin/u(1,2,2)(w/u(1,2))}} \BY{value of $w'$} \\
     \end{array}$


      \CASEIN{w \occin u(2)}{|e|} Let $w'=w$.
    \end{description}

    \par$\begin{array}{@@{}l@@{\;}l@@{\;}l@@{}}
    \tjoin' & = & \tsubst{t_2}{u}{\sigma(|x = (mu x hnf); e|)} \\
    & = & \tsubst{\tsubst{t}{w}{|fail|}}{u}{\sigma(|x = (mu x hnf); e|)} \\
    & = & \tsubst{\tsubst{t}{w}{|fail|}}{u}{\sigma(|x = (mu x hnf); e|)}
\end{array}$


  \end{description}
\end{proof}

