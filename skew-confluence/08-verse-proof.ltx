\begin{lemma}[\versecalc{} monotonic] \label{lem:vc-monotonic}
Every rewrite rule in \versecalc{} is monotonic with respect to $\leqomegavc$.
\end{lemma}

\begin{proof}
We consider each rewrite rule of \versecalc{} separately.
(Note that if $\omegavc$ applied to the left-hand side of a rule produces |Omega|, there is no need to consider the right-hand side, because $\forall M \suchthat |Omega| \leqomegavc M$.)

\begin{itemize}
\item \rulename{app-add} is monotonic in $\leqomegavc$
because $\omegavc(|applyN add (k_1 ,k_2)|) = |Omega|$.

\item \rulename{app-gt} is monotonic in $\leqomegavc$
because $\omegavc(|applyN gt (k_1,k_2)|) = |Omega|$.

\item \rulename{app-gt-fail} is monotonic in $\leqomegavc$
because $\omegavc(|applyN gt (k_1,k_2)|) = |Omega|$.

\item \rulename{app-beta} is monotonic in $\leqomegavc$
because $\omegavc(|apply1 (lam x e) v|) = |Omega|$.

\item \rulename{app-tup} is monotonic in $\leqomegavc$
because $\omegavc(|apply1 (tup (v_0,xdots, v_n)) v|) = |Omega|$.

\item \rulename{app-tup-0} is monotonic in $\leqomegavc$
because $\omegavc(|apply1 emptytup v|) = |Omega|$.

\item \rulename{u-lit} is monotonic in $\leqomegavc$
because $\omegavc(|k_1 == k_2; e|) = {?}\omegavc(e) \leqomega \omegavc(|e|)$.

\item \rulename{u-tup} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e|) = |x| \leqomega |x| = \omegavc(|v_1==v1';xdots;v_n==v_n'; e|)$. {\color{red} PROBLEM with exposed equations}

\item \rulename{u-fail} is monotonic in $\leqomegavc$
because $\omegavc(|hnf_1 == hnf_2; e|) = \omegavc(|?e|) \leqomega |fail| = \omegavc(|fail|)$.

\item \rulename{u-occurs-fail} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|x=hnf; e|) = {?}|subst e x Omega| \leqomega |fail| = \omegavc(|fail|)$.

\item \rulename{u-occurs-wrap} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|x=hnf; e|) = {?}|subst e x Omega| = \omegavc(|x=mu x hnf; e|)$.

\item \rulename{u-unwrap} is monotonic in $\leqomegavc$
because $\omegavc(|mu x hnf|) = |Omega|$.

\item \rulename{subst-ctx} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|X^[x==v;S^[e]]|) = |x| \leqomega |x| = \omegavc(|(substNP X x v)^[x==v; (substNP S x v)^[e]]|)$. {\color{red} TRICKY}

\item \rulename{subst-exp} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|X^[x==v;S^[e]]|) = |x| \leqomega |x| = \omegavc(|X^[x==v; S^[subst e x v]]|)$. {\color{red} TRICKY}

\item \rulename{hnf-swap} is monotonic in $\leqomegavc$
because $\omegavc(|hnf==x; e|) = \omegavc(?|subst e x Omega|) = \omegavc(|x==hnf; e|)$.

\item \rulename{var-swap} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|y==x; e|) = \omegavc({?}|subst2 e y Omega x Omega|) = \omegavc({?}|subst2 e x Omega y Omega|) = \omegavc(|x==y; e|)$.

\item \rulename{seq-swap} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|eq; x==v; e|) = |x| \leqomega |x| = \omegavc(|x==v; eq; e|)$.  {\color{red} TRICKY}

\item \rulename{val-elim} is monotonic in $\leqomegavc$
because $\omegavc(|v ; e|) = |Omega|$.

\item \rulename{exi-elim} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|def x e|) = \omegavc(?|subst e x Omega|) = \omegavc(|e|)$ (given that $x \not\in \freevars{e}$).

\item \rulename{eqn-elim} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|def x (X^[x==v;e])|) = |x| \leqomega |x| = \omegavc(|X^[e]|)$.   {\color{red} TRICKY}

\item \rulename{fail-elim} is monotonic in $\leqomegavc$
because $\omegavc(|X^[fail]|) = |fail| = \omegavc(|fail|)$.

\item \rulename{exi-float} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|X^[def x e]|) = \omegavc(|X^[subst e x Omega]|) \leqomega \omegavc(|subst (X^[e]) x Omega|) = \omegavc(|def x (X^[e])|)$.

\item \rulename{seq-assoc} is monotonic in $\leqomegavc$
because $\omegavc(|(eq ; e_1) ; e_2|) = |Omega|$.

\item \rulename{eqn-float} is monotonic in $\leqomegavc$
because $\omegavc(|v == (eq ; e_1); e_2|) = |Omega|$.

\item \rulename{exi-swap} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|def x (def y e)|) = \omegavc({?}|subst2 e y Omega x Omega|) = \omegavc({?}|subst2 e x Omega y Omega|) = \omegavc(|def y (def x e)|)$.

\item \rulename{one-fail} is monotonic in $\leqomegavc$
because $\omegavc(|one fail|) = |Omega|$.

\item \rulename{one-value} is monotonic in $\leqomegavc$
because $\omegavc(|one v|) = |Omega|$.

\item \rulename{one-choice} is monotonic in $\leqomegavc$
because $\omegavc(|one (v `choice` e)|) = |Omega|$.

\item \rulename{all-fail} is monotonic in $\leqomegavc$
because $\omegavc(|all fail|) = |Omega|$.

\item \rulename{all-value} is monotonic in $\leqomegavc$
because $\omegavc(|all v|) = |Omega|$.

\item \rulename{all-choice} is monotonic in $\leqomegavc$
because $\omegavc(|all (v_1 choice xdots choice v_n)|) = |Omega|$.

\item \rulename{choose-r} is monotonic in $\leqomegavc$
because $\omegavc(|fail choice e|) = \omegavc(|e|)$.

\item \rulename{choose-l} is monotonic in $\leqomegavc$
because $\omegavc(|e choice fail|) = \omegavc(|e|)$.

\item \rulename{choose-assoc} is monotonic in $\leqomegavc$
because $\omegavc(|(e_1 choice e_2) choice e_3|) = \omegavc(|e_1 choice (e_2 choice e_3)|)$.

\item \rulename{choose} is monotonic in $\leqomegavc$ \hfill\break
because $\omegavc(|SX^[CX^[e_1 choice e_2]]|) = |x| \leqomega |x| = \omegavc(|SX^[CX^[e_1] choice CX^[e_2]]|)$.   {\color{red} TRICKY}
\end{itemize}
\end{proof}



\subsection {Proof that \texorpdfstring{\versecalc{}}{VC} Is Skew Confluent}


Our goal is to show that for all rules \rulename{r} and \rulename{s} (possibly the same), for all terms $e$, $e_1$, and $e_2$, and for all sets of occurrences $U$ and occurrences $w$,
if   $e_1 \xrnungosup{r}{U} e \xrngosup{s}{w} e_2$
then
  $e_1 \leqomegavc \ejoin \xrnungosup{r}{u} e_2$
  for some term $\ejoin$.

Our overall strategy is to use an expanded rule set that includes a rule that is the inverse of \rulename{subst};
show that for all rules \rulename{r} and \rulename{s} (possibly the same), for all terms $e$, $e_1$, and $e_2$, and for all sets of occurrences $U$ and occurrences $w$,
if   $e_1 \xrnungosup{r}{u} e \xrngosup{s}{w} e_2$
then
  $e_1 \xrnbothdblsup{}{\preceq} \ejoin \xrnungosup{r}{u} e_2$
  for some term $\ejoin$.

  Our specific strategy is to use a tiling strategy based on tiles constructed so that
for all rules \rulename{r} and \rulename{s} (possibly the same), for all terms $e$, $e_1$, and $e_2$, and for all sets of occurrences $U$ and occurrences $w$,
if   $e_1 \xprnungosup{r}{U} e \xrngosup{s}{w} e_2$
then
  $e_1 \xprnbothdblsup{}{\preceq} \ejoin \xprnungosup{r}{U} e_2$
  for some term $\ejoin$.

  Fortunately, tiles of that form are easy to construct if \rulename{r} and \rulename{s} strongly commute, and
we already know that all rules in $\rapp \cup \rgc \cup \rspc$ have the diamond property and that all pairs of rules in $\rapp \cup \rgc \cup \rspc$ strongly commute.
We need only prove separately the ``difficult'' cases.


\subsubsection{Preliminary Lemmas}

\begin{lemma}\label{lem:disjoint-sc}
  For any two rules \rulename{r} and \rulename{s}, and for all terms $e$, $e_1$, and $e_2$:\hfill\break\null\hskip3.5em if\quad
  $e_1 \xrnungosup{r}{u} e \xrngosup{s}{w} e_2$
  \unskip\quad and\quad
  $u \occdis w$
  \unskip\quad then\quad
  $e_1 \xrngosup{s}{w} \ejoin \xrnungosup{r}{u} e_2$
  \hfill\break for some term $\ejoin$.
\end{lemma}
\begin{proof}
  PROBLEM
  From $e \xrngosup{r}{u} e_1 \xrngosup{s}{w} e'$ and $u \occdis w$ we have $e' = \tsubst{\tsubst{e}{u}{e_1/u}}{w}{e'/w}$,
  from $e \xrngosup{s}{w} e_2 \xrngosup{r}{u} e''$ and $u \occdis w$ we have $e'' = \tsubst{\tsubst{e}{w}{e_2/w}}{u}{e''/u}$,
    and we have $e' = e''$ by \emph{commutativity}; therefore let $\ejoin = e_1 = e_2$.
\end{proof}

\begin{lemma}\label{lem:set-disjoint-sc}
  For any two rules \rulename{r} and \rulename{s}, and for all terms $e$, $e_1$, and $e_2$:\hfill\break\null\hskip3.5em if\quad
  $e_1 \xprnungosup{r}{U} e \xrngosup{s}{w} e_2$
  \unskip\quad and\quad
  $u \occdis w$
  \unskip\quad then\quad
  $e_1 \xrngosup{s}{w} \ejoin \xprnungosup{r}{U} e_2$
  \hfill\break for some term $\ejoin$.
\end{lemma}
\begin{proof}
  PROBLEM
  From $e \xrngosup{r}{u} e_1 \xrngosup{s}{w} e'$ and $u \occdis w$ we have $e' = \tsubst{\tsubst{\tsubst{\tsubst{e}{u_1}{e_1/u_1}}{u_2}{e_1/u_2}\cdots}{u_n}{e_1/u_n}}{w}{e'/w}$
  from $e \xrngosup{s}{w} e_2 \xrngosup{r}{U} e''$ and $u \occdis w$ we have $e'' = \tsubst{\tsubst{e}{w}{e_2/w}}{u}{e_1/u}$,
    and we have $e' = e''$ by repeated application of \emph{commutativity}; therefore let $\ejoin = e_1 = e_2$.
\end{proof}

\begin{lemma}\label{lem:diamond-par-sc}
If $\xrngo{r}$ strongly commutes with itself, then $\xprngo{r}$ strongly commutes with $\xrngo{r}$.
\end{lemma}

\begin{lemma}\label{lem:sc-par-sc}
If $\xrngo{r}$ strongly commutes with $\xrngo{s}$, then $\xprngo{r}$ strongly commutes with $\xrngo{s}$.
\end{lemma}


