                                                  & \text{if $x \not\in \freevars{|v|}$} \\
\rulename{app-tup}          & |apply1 (tup (v_0,xdots, v_n)) v| & \movesto &
                              \multicolumn{2}{@@{}l}{|def x (x==v^^^ (x == 0^^^ v_0) choice xdots choice (x == n^^^ v_n))|
                              \hspace{0.7em}\text{fresh $|x| \not\in \freevars{|v, v_0, xdots,v_n|}$}} \hskip-0.7em \\
\rulename{app-tup-0}        & |apply1 emptytup v| & \movesto & |fail| \\
\\[-0.6em]
\rulegroupname{Unification:}
  \rulename{u-lit}   & |k_1 == k_2; e| & \movesto & |e| & \text{if $k_1=k_2$} \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e| & \movesto & |v_1==v1';xdots;v_n==v_n'; e| \\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & \multicolumn{2}{l}{|fail|
       \hspace{2cm} \begin{array}[t]{l} \text{if \rulename{u-lit}, \rulename{u-tup} do not match} \\
         \text{and neither |hnf_1| nor |hnf_2| is a lambda}
         \end{array}} \\
  \rulename{u-occurs} & |x==V^[x]; e| & \movesto & |fail| & \text{if $|V| \ne |hole|$} \\
  \rulename{u-wrap} & |x=hnf; e| & \movesto & |x=mu x hnf; e| &
                      \multicolumn{1}{@@{}l@@{}}{\begin{array}[t]{l} \text{if \rulename{u-occurs} does not match and} \\
         \text{~~$|x| \in \freevars{|hnf|}$}
         \end{array}} \\
  \rulename{u-unwrap} & |mu x hnf| & \movesto & |subst hnf x (mu x hnf)| \\
  \rulename{subst} & |x==v;e| & \movesto & |x==v; subst e x v| \hspace*{-0.3em} & \text{if $|x| \notin \freevars{|v|}$} \\
  \rulename{hnf-swap} & |hnf==x; e|    & \movesto & |x==hnf; e| \\
  \rulename{var-swap} & |y==x; e|    & \movesto & |x==y; e| \\
  \rulename{seq-swap} & |eq; x==v; e| & \movesto & |x==v; eq; e| \\

    \\[-0.6em]

\rulegroupname{Elimination:}
\rulename{val-elim} & |v ; e| & \movesto & |e| \\
\rulename{exi-elim} & |def x e| & \movesto & |e| & \text{if $|x| \notin \freevars{|e|}$}\\
  \rulename{eqn-elim} & |def x (x==v;e)| & \movesto & |e| & \text{if $|x| \notin \freevars{|v|,|e|}$} \\
\rulename{fail-elim-eq} & |x=fail; e| & \movesto & |fail| & \\
\rulename{fail-elim-l} & |fail; e| & \movesto & |fail| & \\
\rulename{fail-elim-r} & |eq; fail| & \movesto & |fail| & \\

    \\[-0.6em]

\rulegroupname{Normalization:}
\rulename{exi-float-eq}\rlap{${}^{\alpha}$} & |v=(def x e); e'| & \movesto & |def x (v=e;e')| & \text{if $x \notin \freevars{|v|,|e'|}$} \\
\rulename{exi-float-l}\rlap{${}^{\alpha}$} & |(def x e); e'| & \movesto & |def x (e;e')| & \text{if $x \notin \freevars{|e'|}$} \\
\rulename{exi-float-r}\rlap{${}^{\alpha}$} & |eq; (def x e)| & \movesto & |def x (eq; e)| & \text{if $x \notin \freevars{|eq|}$} \\
\rulename{seq-assoc} & |(eq ; e_1) ; e_2| & \movesto & |eq ; (e_1 ; e_2)| \\
\rulename{eqn-float} & |v == (eq ; e_1); e_2| & \movesto & |eq ; (v == e_1; e_2)| \\
\rulename{exi-swap} & |def x (def y e)| & \movesto & |def y (def x e)| \\

    \\[-0.6em]

\rulegroupname{Choice:}
\rulename{one-fail}   & |one fail| & \movesto & |fail| \\
\rulename{one-value}  & |one v| & \movesto & |v| \\
\rulename{one-choice} & |one (v `choice` e)| & \movesto & |v| \\
\rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{all-value}  & |all v| & \movesto & |tup v| \\
\rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)| \\
\rulename{choose-r} & |fail choice e| & \movesto & |e| \\
\rulename{choose-l} & |e choice fail| & \movesto & |e| \\
\rulename{choose-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & |e_1 choice (e_2 choice e_3)| \\
\rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & |SX^[CX^[e_1] choice CX^[e_2]]| &  \\


\end{array} \\
\\[-0.3em]
\text{\textit{Note}: In the rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.}
\end{array}$
