\subsection{Lambda-Letrec Calculus}

\guy{Ariola and Blom refer to this language variously as ``the lambda calculus with letrec'', ``the cyclic lambda calculus'', and ``$\lambda\circ$''; we will call it the ``lambda-letrec calculus'' and use ``$\lambda\circ$' in mathematical formulas
  as a subscript to marking certain functions as beign related specifically to the lambda-letrec calculus.}


  \begin{figure}
    $\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l @@{\hspace{1em}} r @@{\;}c@@{\;} l @@{}}
\rulegroupname{Beta reduction:}
  \text{$\beta\circ$}          & |apply1N (lam x M) N| & \movesto & |letrec M (x=N)| \\
\rulegroupname{Substitution (external or internal):}
  \text{es}          & |letrec (C^[x]) (x=M,D)| & \movesto & |letrec (C^[M]) (x=M,D)| \\
  \text{is}          & |letrec M (x=C^[y],y=N,D)| & \movesto & |letrec M (x=C^[N],y=N,D)| \\
\rulegroupname{Merge (external or internal):}
  \text{em}          & |letrec (letrec M D_1) D_2| & \movesto & |letrec M (D_1,D_2)| \\
  \text{im}          & |letrec M (x=(letrec N D_1), D_2)| & \movesto & |letrec M (x=N,D_1,D_2)| \\
\rulegroupname{Lift (of argument, function, or lambda):}
  \text{lifta}          & |apply1NN (letrec M D) N| & \movesto & |letrec (apply1NN M N) D| \\
  \text{liftf}          & |apply1NN M (letrec N D)| & \movesto & |letrec (apply1NN M N) D| \\
  \text{lift$\lambda$}          & |lam x (letrec M (D_1,D_2))| & \movesto & |letrec (lam x (letrec M D_1))D_2|     \qquad\qquad\text{conditions} \\
\rulegroupname{Garbage collection (of declaration or letrec):}
  \text{gcd}          & |letrec M (D_1,D_2)| & \movesto & |letrec M D_1|     \qquad\qquad\text{conditions} \\
  \text{gcl}          & |letrec M ()| & \movesto & |M| \\
\rulegroupname{Copy:}
  \text{cp}          & |M|^\sigma & \movesto & |M|     \qquad\qquad\text{conditions} \\
\end{array} \\

    \\[-1.1em]
       
       \text{\textit{Note}: In the rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.}
      \\ \guy{Need to be explicit about side conditions.}
\end{array}$
\caption{\textbf{Rewrite rules for the Lambda-Letrec Calculus}} \label{fig:ruleslambdale}
\Description{A table that exhibits the rewrite rules for the Lambda-Letrec Calculus}
\end{figure}



\subsection{Verse Calculus}



\newcommand\MC[2]{\multicolumn{#1}{@@{}l@@{}}{#2}}

\newcommand{\figureSkewProofRewriteRules}{
  \begin{figure}
    $\begin{array}{@@{}l}
\begin{array}{@@{\hskip0.5em} l @@{\hspace{-.5em}} r @@{\;}c@@{\;} l @@{\hskip4em} l r c l@@{}}
\rulegroupname{Application:}
\rulename{app-add}          & |applyN add (k_1 ,k_2)| & \movesto & \MC{2}{|k_3|} & \MC{3}{\text{where $k_3 = k_1 + k_2$}} \\
\rulename{app-gt}           & |applyN gt (k_1,k_2)|   & \movesto & \MC{2}{|k_1|} &  \MC{3}{\text{if $k_1 > k_2$}} \\
\rulename{app-gt-fail}      & |applyN gt (k_1,k_2)|   & \movesto & \MC{2}{|fail|} &  \MC{3}{\text{if $k_1 \leq k_2$}} \\
\rulename{app-beta}\rlap{${}^{\alpha}$} & |apply1 (lam x e) v| & \movesto & \MC{2}{|def x (x==v; e)|}
                                                  & \MC{3}{\text{if $x \not\in \freevars{|v|}$}} \\
\rulename{app-tup}          & |apply1 (tup (v_0,xdots, v_n)) v| & \movesto &
                              \MC{5}{|def x (x==v^^^ (x == 0^^^ v_0) choice xdots choice (x == n^^^ v_n))|
                              \hspace{0.7em}\text{fresh $|x| \not\in \freevars{|v, v_0, xdots,v_n|}$}} \hskip-0.7em \\
\rulename{app-tup-0}        & |apply1 emptytup v| & \movesto & \MC{2}{|fail|} \\

    \\[-1.0em]

\rulegroupname{Unification:}
  \rulename{u-lit}   & |k_1 == k_2; e| & \movesto & \MC{2}{|e|} & \MC{3}{\text{if $k_1=k_2$}} \\
  \rulename{u-tup} & \hspace{-2.0em} |tup (v_1,xdots,v_n) == tup (v1',xdots,v_n'); e| & \movesto & \MC{2}{|v_1==v1';xdots;v_n==v_n'; e|} \\
  \rulename{u-fail} & |hnf_1 == hnf_2; e| & \movesto & \MC{2}{|fail|} &
       \MC{3}{\begin{array}[t]{@@{}l@@{}} \text{if \rulename{u-lit}, \rulename{u-tup} do not match and} \\
         \text{\hskip0.6em  neither |hnf_1| nor |hnf_2| is a lambda}
         \end{array}} \\
  \rulename{u-occurs} & |x==V^[x]; e| & \movesto & \MC{2}{|fail|} & \MC{3}{\text{if $|V| \ne |hole|$}} \\
  \rulename{wrap} & |x=hnf; e| & \movesto & \MC{2}{|x=mu x hnf; e|} &
                      \MC{3}{\begin{array}[t]{@@{}l@@{}} \text{if \rulename{u-occurs} does not match and} \\
         \text{\hskip0.6em $|x| \in \freevars{|hnf|}$}
         \end{array}} \\
  \rulename{unwrap} & |mu x hnf| & \movesto & \MC{2}{|subst hnf x (mu x hnf)|} \\
  \rulename{subst} & |x==v;e| & \movesto & \MC{2}{|x==v; subst e x v|} \hspace*{-0.3em} & \MC{3}{\text{if $|x| \notin \freevars{|v|}$}} \\
  \rulename{hnf-swap} & |hnf==x; e|    & \movesto & \MC{2}{|x==hnf; e|} \\
  \rulename{seq-swap} & |eq; x==v; e| & \movesto & \rlap{|x==v; eq; e|}    & \hskip 2.5em\rlap{\rulename{var-swap}} & |y==x; e|    & \movesto & |x==y; e|\\

    \\[-1.0em]

\rulegroupname{Elimination:}
\rulename{val-elim} & |v ; e| & \movesto & \MC{2}{|e|} \\
\rulename{exi-elim} & |def x e| & \movesto & \MC{2}{|e|} & \MC{3}{\text{if $|x| \notin \freevars{|e|}$}} \\
\rulename{eqn-elim} & |def x (x==v;e)| & \movesto & \MC{2}{|e|} & \MC{3}{\text{if $|x| \notin \freevars{|v|,|e|}$}} \\
\rulename{fail-elim-eq} & |x=fail; e| & \movesto & \MC{2}{|fail|} & \\
\rulename{fail-elim-l} & |fail; e| & \movesto & \MC{2}{|fail|} & \\
\rulename{fail-elim-r} & |eq; fail| & \movesto &\MC{2}{|fail|} & \\

    \\[-1.0em]

\rulegroupname{Normalization:}
\rulename{exi-float-eq}\rlap{${}^{\alpha}$} & |v=(def x e_1); e_2| & \movesto & \MC{2}{|def x (v=e_1;e_2)|} & \MC{3}{\text{if $x \notin \freevars{|v|,|e_2|}$}} \\
\rulename{exi-float-l}\rlap{${}^{\alpha}$} & |(def x e_1); e_2| & \movesto & \MC{2}{|def x (e_1;e_2)|} & \MC{3}{\text{if $x \notin \freevars{|e_2|}$}} \\
\rulename{exi-float-r}\rlap{${}^{\alpha}$} & |eq; (def x e)| & \movesto & \MC{2}{|def x (eq; e)|} & \MC{3}{\text{if $x \notin \freevars{|eq|}$}} \\
\rulename{eqn-float} & |v == (eq ; e_1); e_2| & \movesto & \MC{2}{|eq ; (v == e_1; e_2)|} \\
\rulename{seq-assoc} & |(eq ; e_1) ; e_2| & \movesto & \MC{2}{|eq ; (e_1 ; e_2)|} \\
\rulename{exi-swap} & |def x (def y e)| & \movesto & \MC{2}{|def y (def x e)|} \\

    \\[-1.0em]

\rulegroupname{Choice:}
\rulename{one-fail}   & |one fail| & \movesto & |fail|                   & \rulename{all-fail}   & |all fail| & \movesto & |tup ()| \\
\rulename{one-value}  & |one v| & \movesto & |v|                       & \rulename{all-value}  & |all v| & \movesto & |tup v| \\
\rulename{one-choice} & |one (v `choice` e)| & \movesto & |v|    & \rulename{all-choice} & |all (v_1 choice xdots choice v_n)| & \movesto & |tup (v_1, xdots, v_n)| \\
\rulename{choose-r} & |fail choice e| & \movesto & |e|                & \rulename{choose-l} & |e choice fail| & \movesto & |e| \\
\rulename{choose-assoc} & |(e_1 choice e_2) choice e_3| & \movesto & \MC{2}{|e_1 choice (e_2 choice e_3)|} \\
\rulename{choose} & |SX^[CX^[e_1 choice e_2]]| & \movesto & \MC{2}{|SX^[CX^[e_1] choice CX^[e_2]]|} &  \\

\end{array} \\

    \\[-1.1em]
       
\text{\textit{Note}: In the rules marked with a superscript $\alpha$, use $\alpha$-conversion to satisfy the side condition.}
\end{array}$
\caption{\textbf{The \vcname: Rewrite rules to be used for the proof of skew confluence (July 14, 2023)}} \label{fig:rules}
\Description{A table that exhibits the rewrite rules for the Verse Calculus, grouped into five categories: Application, Unification, Normalization, Garbage Collection, and Choice}
\end{figure}
}


