%% Variations of the "\go" macro.
%%  "x" means the rule or rule set is tucked underneath. 
%%  "p" means the parallel-compatible closure (decorated by two strokes).
%%  "rn" means a rule name is given rather than a rule set name.
%%  "go" means a right arrow; "ungo" means a left arrow; "both" means a leftright arrow.
%%  "dbl" means a double-headed arrow (transitive reflexive closure); "eq" means reflexive closure ("p" versions do not have "eq" forms)
%%  "sup" means one superscript; "suptwo" means two superscripts

\makeatletter
\newcommand{\xleftrightarrow}[2][]{\ext@@arrow 3399\leftrightarrowfill@@{#1}{#2}}
\newcommand{\xLeftarrow}[2][]{\ext@@arrow 3095\Leftarrowfill@@{#1}{#2}}
\newcommand{\xRightarrow}[2][]{\ext@@arrow 0359\Rightarrowfill@@{#1}{#2}}
\newcommand{\xLeftrightarrow}[2][]{\ext@@arrow 3399\Leftrightarrowfill@@{#1}{#2}}

