%% arguments are {left pad}{right pad}{left end}{fill symbol}{centered symbol}{right symbol}{math style}
\newcommand\decoratedarrowfill@@[7]{{%
    \setbox\@@arrowbarbox\hbox{$#7\rightarrow$}%
    \newcommand\arrowbar{\hbox to \wd\@@arrowbarbox{\cleaders\hbox{$#7\mkern-2mu#4\mkern-2mu$}\hfill}}%
  $\m@@th\thickmuskip0mu\medmuskip\thickmuskip\thinmuskip\thickmuskip
   \relax#7#3\mkern-7mu%
   \cleaders\hbox{$#7\mkern-2mu#4\mkern-2mu$}\hfill 
   \if0#1\else\mkern#1mu\fi\hbox to 0pt{\hss#5\hss}\if0#2\else\mkern#2mu\fi
   \cleaders\hbox{$#7\mkern-2mu#4\mkern-2mu$}\hfill 
   \mkern-7mu#6$%
 }}

