# fn1: empty domain, empty range
testds("fn1", mon, pass) { function(0=1)<closed>{2=3} }                 {"[{{u=v=<>}}]"}
# fn2: empty domain, nonempty range
testds("fn2", mon, pass) { function(0=1)<closed>{2} }                   {"[{{u=v=<>}}]"}
# fn3: nonempty domain, empty range
testds("fn3", mon, pass) { function(0)<closed>{2=3} }                   {"[]"}
# fn3: nonempty domain, nonempty range
testds("fn4", mon, pass) { function(0)<closed>{0} }                     {"[{{u=v=<0>}}]"}

# fn5: ordered choice domain, no choice range
testds("fn5", mon, pass) { function(0|1)<closed>{2} }                   {"[{{u=v=<2,2>}}]"}
# fn6: no choice domain, ordered choice range
testds("fn5", mon, pass) { function(0)<closed>{2|3} }                   {"[{{u=v=<2>}},{{u=v=<3>}}]"}
# fn7: ordered choice domain, ordered choice range
testds("fn5", mon, pass) { function(0|1)<closed>{2|3} }                 {"[{{u=v=<2,2>}},{{u=v=<2,3>}},{{u=v=<3,2>}},{{u=v=<3,3>}}]"}

# fn5: unordered choice domain, no choice range
testds("fn5", mon, pass) { function(0|||1)<closed>{2} }                 {"[{{u=v=Fn[{(0,2),(1,2)}]}}]"}
# fn6: no choice domain, unordered choice range
testds("fn5", mon, pass) { function(0)<closed>{2|||3} }                 {"[{{u=v=<2>}}U{{u=v=<3>}}]"}
# fn7: unordered choice domain, unordered choice range
testds("fn5", mon, pass) { function(0|||1)<closed>{2|||3} }
  {"[{{u=v=Fn[{(0,2),(1,2)}]}}U{{u=v=Fn[{(0,2),(1,3)}]}}U{{u=v=Fn[{(0,3),(1,2)}]}}U{{u=v=Fn[{(0,3),(1,3)}]}}]"}

# fn8: ordered choice domain, unordered choice range
testds("fn8", mon, pass) { function(0|1)<closed>{2|||3} }
  {"[{{u=v=<2,2>}}U{{u=v=<2,3>}}U{{u=v=<3,2>}}U{{u=v=<3,3>}}]"}
# fn9: unordered choice domain, ordered choice range
testds("fn9", mon, pass) { function(0|||1)<closed>{2|3} }
  {"[{{u=v=Fn[{(0,2),(1,2)}]}},{{u=v=Fn[{(0,2),(1,3)}]}}U{{u=v=Fn[{(0,3),(1,2)}]}},{{u=v=Fn[{(0,3),(1,3)}]}}]"}

# fn10: free, constrained variable in the domain
testds("fn10", mon, pass) { function(0 where (a=1))<closed>{2} }
  {"[{{a=0,u=v=<>}}U{{a=1,u=v=<2>}}U{{a=2,u=v=<>}}U{{a=3,u=v=<>}}]"}
# fn11: free, constrained variable in the range
testds("fn11", mon, pass) { function(0)<closed>{2 where (a=1)} } {"[{{a=1,u=v=<2>}}]"}

